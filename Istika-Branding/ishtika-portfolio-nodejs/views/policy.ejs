<%- include('partials/header') %>

<style>
  /* Modern Background - Dark Theme */
  .policy-section-area {
    background: #262731 !important;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
  }

  .policy-section-area::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(239, 130, 6, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(239, 130, 6, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Main Content Card - Dark Theme */
  .policy-content {
    background: rgba(239, 130, 6, 0.1) !important;
    backdrop-filter: blur(20px);
    border-radius: 30px;
    padding: 60px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    position: relative;
    z-index: 1;
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
  }

  /* Modern Heading - Dark Theme */
  .policy-content h1 {
    font-size: 52px;
    font-weight: 700;
    color: #E67E22 !important;
    margin-bottom: 15px;
    display: inline-flex;
    align-items: center;
    gap: 15px;
  }

  .policy-shield-icon {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    box-shadow: 0 8px 20px rgba(239, 130, 6, 0.3);
  }

  .policy-intro {
    font-size: 18px;
    color: #ffffff !important;
    line-height: 1.8;
    margin-bottom: 40px;
    padding: 25px;
    background: rgba(239, 130, 6, 0.15) !important;
    border-left: 4px solid #E67E22;
    border-radius: 10px;
  }

  /* Section Cards - Dark Theme */
  .policy-section-card {
    background: rgba(239, 130, 6, 0.1) !important;
    border-radius: 20px;
    padding: 35px;
    margin-bottom: 25px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
  }

  .policy-section-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(239, 130, 6, 0.4);
    border-color: rgba(239, 130, 6, 0.6) !important;
    background: rgba(239, 130, 6, 0.15) !important;
  }

  .policy-section-card h3 {
    font-size: 26px;
    font-weight: 700;
    color: #E67E22 !important;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-icon {
    width: 45px;
    height: 45px;
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
    flex-shrink: 0;
  }

  .policy-section-card p {
    font-size: 16px;
    color: #ffffff !important;
    line-height: 1.8;
    margin-bottom: 15px;
  }

  /* Modern List Styling - Dark Theme */
  .policy-section-card ul {
    list-style: none;
    padding-left: 0;
    margin-top: 20px;
  }

  .policy-section-card ul li {
    font-size: 16px;
    color: #ffffff !important;
    line-height: 1.8;
    margin-bottom: 12px;
    padding-left: 35px;
    position: relative;
  }

  .policy-section-card ul li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    width: 24px;
    height: 24px;
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: bold;
  }

  /* Contact Section - Enhanced for Dark Theme */
  .policy-contact-box {
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%) !important;
    border-radius: 20px;
    padding: 40px;
    color: white;
    margin-top: 30px;
    box-shadow: 0 15px 40px rgba(239, 130, 6, 0.5) !important;
    border: 2px solid rgba(255, 255, 255, 0.1) !important;
  }

  .policy-contact-box h3 {
    color: white;
    font-size: 28px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .policy-contact-box p {
    color: white;
    font-size: 16px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .policy-contact-box a {
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .policy-contact-box a:hover {
    text-decoration: underline;
    opacity: 0.9;
  }

  .contact-icon {
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  /* Last Updated Badge - Dark Theme */
  .last-updated-badge {
    display: inline-block;
    background: rgba(239, 130, 6, 0.15) !important;
    color: #E67E22 !important;
    padding: 10px 20px;
    border-radius: 25px;
    font-size: 14px;
    font-weight: 600;
    margin-top: 30px;
    border: 2px solid rgba(239, 130, 6, 0.4) !important;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .policy-content {
      padding: 35px 25px;
    }

    .policy-content h1 {
      font-size: 36px;
    }

    .policy-section-card {
      padding: 25px;
    }

    .policy-contact-box {
      padding: 30px 25px;
    }
  }
</style>

<!--===== PRIVACY POLICY AREA STARTS =======-->
<div class="policy-section-area sp1" style="padding-top: 150px; padding-bottom: 80px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 m-auto">
                <div class="policy-content heading2" data-aos="fade-up" data-aos-duration="800">
                    <h1>
                      <span class="policy-shield-icon">
                        <i class="bi bi-shield-check"></i>
                      </span>
                      Privacy Policy
                    </h1>

                    <div class="policy-intro">
                      At Ishtika Homes, we are committed to protecting your privacy and ensuring the security of your personal information. This Privacy Policy outlines how we collect, use, and safeguard your data.
                    </div>

                    <!-- Information We Collect -->
                    <div class="policy-section-card" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
                      <h3>
                        <span class="section-icon">
                          <i class="bi bi-info-circle"></i>
                        </span>
                        Information We Collect
                      </h3>
                      <p>We may collect personal information such as your name, email address, phone number, and other details when you:</p>
                      <ul>
                        <li>Fill out a contact form on our website</li>
                        <li>Request property information</li>
                        <li>Subscribe to our newsletter</li>
                        <li>Schedule an appointment</li>
                      </ul>
                    </div>

                    <!-- How We Use Your Information -->
                    <div class="policy-section-card" data-aos="fade-up" data-aos-duration="800" data-aos-delay="200">
                      <h3>
                        <span class="section-icon">
                          <i class="bi bi-gear"></i>
                        </span>
                        How We Use Your Information
                      </h3>
                      <p>We use the information we collect to:</p>
                      <ul>
                        <li>Respond to your inquiries and requests</li>
                        <li>Provide you with information about our properties and services</li>
                        <li>Send you updates and marketing communications (with your consent)</li>
                        <li>Improve our website and services</li>
                      </ul>
                    </div>

                    <!-- Data Security -->
                    <div class="policy-section-card" data-aos="fade-up" data-aos-duration="800" data-aos-delay="300">
                      <h3>
                        <span class="section-icon">
                          <i class="bi bi-lock"></i>
                        </span>
                        Data Security
                      </h3>
                      <p>We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.</p>
                    </div>

                    <!-- Your Rights -->
                    <div class="policy-section-card" data-aos="fade-up" data-aos-duration="800" data-aos-delay="400">
                      <h3>
                        <span class="section-icon">
                          <i class="bi bi-person-check"></i>
                        </span>
                        Your Rights
                      </h3>
                      <p>You have the right to:</p>
                      <ul>
                        <li>Access your personal information</li>
                        <li>Request correction of inaccurate data</li>
                        <li>Request deletion of your data</li>
                        <li>Opt-out of marketing communications</li>
                      </ul>
                    </div>

                    <!-- Contact Us Box -->
                    <div class="policy-contact-box" data-aos="fade-up" data-aos-duration="800" data-aos-delay="500">
                      <h3>
                        <span class="contact-icon">
                          <i class="bi bi-envelope"></i>
                        </span>
                        Contact Us
                      </h3>
                      <p>If you have any questions about this Privacy Policy or how we handle your data, please contact us:</p>
                      <p>
                        <span class="contact-icon">
                          <i class="bi bi-envelope-fill"></i>
                        </span>
                        Email: <a href="mailto:<%= companyInfo.email %>"><%= companyInfo.email %></a>
                      </p>
                      <p>
                        <span class="contact-icon">
                          <i class="bi bi-telephone-fill"></i>
                        </span>
                        Phone: <a href="tel:<%= companyInfo.phone.bengaluru.replace(/\s+/g, '') %>"><%= companyInfo.phone.bengaluru %></a>
                      </p>
                    </div>

                    <div class="text-center">
                      <span class="last-updated-badge">
                        <i class="bi bi-calendar-check"></i> Last updated: November 2025
                      </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== PRIVACY POLICY AREA ENDS =======-->

<%- include('partials/footer') %>
