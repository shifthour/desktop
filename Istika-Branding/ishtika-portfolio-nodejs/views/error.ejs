<%- include('partials/header') %>

<!--===== ERROR AREA STARTS =======-->
<div class="error-section-area sp1 mt-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 m-auto text-center">
                <div class="error-content heading2">
                    <h1 style="font-size: 120px; color: var(--ztc-text-text-2);">500</h1>
                    <div class="space24"></div>
                    <h2>Server Error</h2>
                    <div class="space16"></div>
                    <p>Something went wrong on our end. Please try again later.</p>
                    <% if (error) { %>
                    <div class="space16"></div>
                    <p style="color: #999;"><%= error %></p>
                    <% } %>
                    <div class="space32"></div>
                    <div class="btn-area1">
                        <a href="/" class="header-btn1">Back to Home <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== ERROR AREA ENDS =======-->

<%- include('partials/footer') %>
