                <style>
                    /* Mobile view styling for founders section */
                    @media (max-width: 768px) {
                        .founders-content {
                            padding: 25px 20px !important;
                        }

                        .founders-intro h3 {
                            font-size: 22px !important;
                            line-height: 1.4 !important;
                        }

                        .founders-content p {
                            font-size: 16px !important;
                            word-wrap: break-word !important;
                            overflow-wrap: break-word !important;
                        }

                        /* Hide additional content on mobile by default */
                        .founders-more-content {
                            max-height: 0;
                            overflow: hidden;
                            transition: max-height 0.5s ease;
                        }

                        .founders-more-content.expanded {
                            max-height: 3000px;
                            transition: max-height 0.8s ease;
                        }

                        /* Show read more button only on mobile */
                        #founders-read-more-btn {
                            display: block !important;
                        }
                    }

                    /* Desktop view - always show full content */
                    @media (min-width: 769px) {
                        .founders-more-content {
                            max-height: none !important;
                        }

                        #founders-read-more-btn {
                            display: none !important;
                        }
                    }
                </style>

                <script>
                    function toggleFoundersContent() {
                        const moreContent = document.querySelector('.founders-more-content');
                        const readMoreText = document.getElementById('read-more-text');
                        const readMoreIcon = document.getElementById('read-more-icon');

                        if (moreContent.classList.contains('expanded')) {
                            moreContent.classList.remove('expanded');
                            readMoreText.textContent = 'Read More';
                            readMoreIcon.classList.remove('bi-chevron-up');
                            readMoreIcon.classList.add('bi-chevron-down');
                        } else {
                            moreContent.classList.add('expanded');
                            readMoreText.textContent = 'Read Less';
                            readMoreIcon.classList.remove('bi-chevron-down');
                            readMoreIcon.classList.add('bi-chevron-up');
                        }
                    }
