<%- include('partials/header') %>

<style>
    /* Hero Section Styles */
    .about-hero-section {
        position: relative;
        min-height: 80vh;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        overflow: hidden;
        padding: 0 0 40px;
        background-image: url('/assets/img/welcomepic.jpg');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
    }

    .about-hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.3) 100%);
        pointer-events: none;
    }

    .about-hero-section::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-content .hero-subtitle {
        font-size: 18px;
        color: #E67E22;
        font-weight: 600;
        margin-bottom: 15px;
        letter-spacing: 3px;
        text-transform: uppercase;
        animation: fadeInUp 0.8s ease-out;
    }

    .hero-content h1 {
        font-size: 52px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 0;
        line-height: 1.2;
        animation: fadeInUp 0.8s ease-out backwards;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    }

    .hero-content .hero-description {
        font-size: 19px;
        color: #ffffff;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.7;
        animation: fadeInUp 0.8s ease-out 0.2s backwards;
        text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.7);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @media (max-width: 768px) {
        .about-hero-section {
            min-height: 65vh;
            padding: 140px 0 40px;
        }

        .hero-content {
            margin-top: 100px;
        }

        .hero-content h1 {
            font-size: 34px;
        }

        .hero-content .hero-subtitle {
            font-size: 14px;
        }

        .hero-content .hero-description {
            font-size: 16px;
        }
    }

    .inner-others-area {
        margin-top: 0;
    }

    /* Vision & Mission Section */
    .vision-mission-section {
        position: relative;
        background-image: url('/assets/img/vision-mission-bg.jpg');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        min-height: 80vh;
        display: flex;
        align-items: center;
    }

    .vision-mission-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.75) 0%, rgba(239, 130, 6, 0.4) 50%, rgba(0, 0, 0, 0.75) 100%);
        pointer-events: none;
    }

    .vision-mission-section .container {
        position: relative;
        z-index: 2;
    }

    .vision-mission-section .section-header .subtitle {
        font-size: 18px;
        color: #ffd700;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8);
    }

    .vision-mission-section .section-header .subtitle img {
        width: 28px;
        height: 28px;
        filter: brightness(0) invert(1);
    }

    .vision-mission-section .section-header .main-title {
        font-size: 48px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 0;
        line-height: 1.3;
        text-shadow: 3px 3px 12px rgba(0, 0, 0, 0.9);
    }

    .vm-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 50px 40px;
        height: 100%;
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.4);
        transition: all 0.5s ease;
        border: 2px solid rgba(255, 255, 255, 0.2);
        position: relative;
        overflow: hidden;
    }

    .vm-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 5px;
        background: linear-gradient(90deg, #E67E22 0%, #ff9d42 100%);
        transform: scaleX(0);
        transition: transform 0.5s ease;
        box-shadow: 0 0 20px rgba(239, 130, 6, 0.8);
    }

    .vm-card:hover {
        transform: translateY(-15px) scale(1.02);
        box-shadow: 0 25px 80px rgba(239, 130, 6, 0.6);
        border-color: rgba(239, 130, 6, 0.6);
        background: rgba(255, 255, 255, 0.25);
    }

    .vm-card:hover::before {
        transform: scaleX(1);
    }

    .vm-icon {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 30px;
        transition: all 0.5s ease;
        box-shadow: 0 10px 30px rgba(239, 130, 6, 0.4);
    }

    .vm-icon i {
        font-size: 40px;
        color: #1a1a1a;
        font-weight: 700;
    }

    .vm-card:hover .vm-icon {
        transform: scale(1.15) rotate(10deg);
        box-shadow: 0 15px 40px rgba(239, 130, 6, 0.7);
    }

    .vm-card h3 {
        font-size: 32px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 25px;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    }

    .vm-card p {
        font-size: 18px;
        line-height: 1.9;
        color: rgba(255, 255, 255, 0.95);
        margin-bottom: 0;
        text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.6);
    }

    @media (max-width: 768px) {
        .vision-mission-section {
            min-height: auto;
            padding: 80px 0;
            background-attachment: scroll;
        }

        .vision-mission-section .section-header .main-title {
            font-size: 32px;
        }

        .vision-mission-section .section-header .subtitle {
            font-size: 14px;
        }

        .vm-card {
            padding: 40px 30px;
            margin-bottom: 30px;
        }

        .vm-icon {
            width: 75px;
            height: 75px;
        }

        .vm-icon i {
            font-size: 32px;
        }

        .vm-card h3 {
            font-size: 26px;
        }

        .vm-card p {
            font-size: 16px;
            line-height: 1.7;
        }
    }

    /* Leadership Team Section - Glassmorphism Style */
    .leadership-section {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a1a1a 100%);
        padding: 100px 0;
        position: relative;
        overflow: hidden;
    }

    .leadership-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
            radial-gradient(circle at 20% 50%, rgba(239, 130, 6, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(239, 130, 6, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .leadership-section .section-header {
        margin-bottom: 60px;
        text-align: center;
    }

    .leadership-section .section-header h5 {
        color: #E67E22;
        font-size: 18px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 15px;
    }

    .leadership-section .section-header h2 {
        color: #262731;
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .leadership-section .section-header p {
        color: #676767;
        font-size: 18px;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
    }

    .team-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid rgba(239, 130, 6, 0.1);
        margin-bottom: 30px;
    }

    .team-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 60px rgba(239, 130, 6, 0.25);
        border-color: rgba(239, 130, 6, 0.3);
    }

    .team-image-wrapper {
        position: relative;
        height: 320px;
        overflow: hidden;
        background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
    }

    .team-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .team-card:hover .team-image-wrapper img {
        transform: scale(1.1);
    }

    .team-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
        color: white;
        padding: 8px 16px;
        border-radius: 25px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 4px 15px rgba(239, 130, 6, 0.4);
    }

    .team-content {
        padding: 30px;
        position: relative;
    }

    .team-content h3 {
        color: #262731;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
        transition: color 0.3s ease;
    }

    .team-card:hover .team-content h3 {
        color: #E67E22;
    }

    .team-position {
        color: #E67E22;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 15px;
        display: block;
    }

    .team-description {
        color: #676767;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .team-experience {
        display: inline-block;
        background: rgba(239, 130, 6, 0.1);
        color: #E67E22;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .team-social {
        display: flex;
        gap: 12px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #eee;
    }

    .team-social a {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(239, 130, 6, 0.1);
        color: #E67E22;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        transition: all 0.3s ease;
    }

    .team-social a:hover {
        background: #E67E22;
        color: white;
        transform: translateY(-3px);
    }

    @media (max-width: 768px) {
        .leadership-section {
            padding: 60px 0;
        }

        .leadership-section .section-header h2 {
            font-size: 32px;
        }

        .team-image-wrapper {
            height: 280px;
        }

        .team-content {
            padding: 25px 20px;
        }

        .team-content h3 {
            font-size: 22px;
        }
    }

    /* About Ishtika Homes Section */
    .about-ishtika-section {
        position: relative;
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 0;
        background-image: url('/assets/img/brick-background.jpg');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .about-ishtika-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(239, 130, 6, 0.3) 0%, rgba(0, 0, 0, 0.3) 100%);
        pointer-events: none;
        display: none; /* REMOVE OVERLAY FOR ALL DEVICES TO TEST */
    }

    .about-ishtika-content {
        position: relative;
        z-index: 2;
        color: #ffffff;
    }

    .about-ishtika-content h2 {
        font-size: 42px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 30px;
        line-height: 1.3;
    }

    .about-ishtika-content p {
        font-size: 18px;
        line-height: 1.9;
        margin-bottom: 25px;
        color: rgba(255, 255, 255, 0.95);
    }

    .about-ishtika-content .highlight-years {
        font-size: 24px;
        font-weight: 700;
        color: #ffd700;
        background: rgba(255, 215, 0, 0.1);
        padding: 8px 16px;
        border-radius: 8px;
        display: inline-block;
        margin-top: 10px;
        border: 2px solid #ffd700;
    }

    /* Mobile Fix for Background Image - Use larger breakpoint for all mobile devices */
    @media (max-width: 1024px) {
        .about-ishtika-section {
            background: url('/assets/img/brick-background.jpg') no-repeat center center !important;
            background-size: cover !important;
            background-attachment: scroll !important;
            min-height: auto !important;
            padding: 60px 0 !important;
            /* Force hardware acceleration to prevent mobile blur */
            -webkit-transform: translateZ(0) !important;
            transform: translateZ(0) !important;
            -webkit-backface-visibility: hidden !important;
            backface-visibility: hidden !important;
            -webkit-perspective: 1000 !important;
            perspective: 1000 !important;
            /* Prevent image optimization/blur on mobile browsers */
            will-change: transform !important;
            image-rendering: -webkit-optimize-contrast !important;
            image-rendering: crisp-edges !important;
            -webkit-font-smoothing: antialiased !important;
            -moz-osx-font-smoothing: grayscale !important;
        }

        /* REMOVE overlay completely on mobile to show brick background */
        .about-ishtika-section::before {
            content: none !important;
            display: none !important;
            background: none !important;
        }

        /* Make text readable without overlay */
        .about-ishtika-content {
            background: rgba(0, 0, 0, 0.6) !important;
            padding: 30px 20px !important;
            border-radius: 15px !important;
        }

        .about-ishtika-content h2,
        .about-ishtika-content p {
            text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.9) !important;
        }

        .about-ishtika-content h2 {
            font-size: 28px !important;
            margin-bottom: 20px !important;
        }

        .about-ishtika-content p {
            font-size: 16px !important;
            line-height: 1.7 !important;
            margin-bottom: 20px !important;
        }

        .about-ishtika-content .highlight-years {
            font-size: 20px !important;
        }
    }
</style>

<!--===== HERO SECTION STARTS =======-->
<div class="about-hero-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="hero-content">
                    <h1><%= companyInfo.tagline %></h1>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== HERO SECTION ENDS =======-->

<!--===== ABOUT ISHTIKA HOMES SECTION STARTS =======-->
<div class="about-ishtika-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="about-ishtika-content">
                    <h2>About Ishtika Homes</h2>
                    <p>The name "Ishtika" is derived from Sanskrit, meaning "brick" – the fundamental building block that represents strength, stability, and the foundation of every great structure. This ancient word perfectly encapsulates our philosophy: to build not just houses, but homes that stand the test of time.</p>

                    <p>Founded over 12 years ago with a vision to transform Bangalore's residential landscape, Ishtika Homes has grown from a passionate dream into a trusted name in real estate development. Our journey began with a simple yet powerful belief – that every family deserves a home that combines modern amenities with traditional values, quality craftsmanship with affordability, and contemporary design with Vaastu compliance.</p>

                    <p>Over the years, we've delivered approximately 800,000 square feet of premium residential space, creating homes for hundreds of families across Bangalore. Each project is a testament to our unwavering commitment to quality, sustainability, and customer satisfaction. From completed landmarks like Advaitha and White Pearl to our ongoing developments like Anahata and Krishna, every Ishtika project tells a story of dedication, integrity, and excellence.</p>

                    <p>What started as a modest venture has evolved into a legacy of trust, with each brick we lay representing our promise to deliver not just superior construction, but a superior lifestyle. Today, Ishtika Homes stands proud as a developer that doesn't just build properties – we build communities, create value, and most importantly, fulfill dreams.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== ABOUT ISHTIKA HOMES SECTION ENDS =======-->

<!--===== OTHERS AREA STARTS =======-->
<div class="inner-others-area py-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="about-content-header heading2">
                    <div class="space20"></div>
                    <h2 style="color: #E67E22;">Vaastu Complaint Natural Sustainable Residences</h2>
                    <div class="space20"></div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="images image-anime reveal">
                    <img src="/assets/img/all-images/about-img15.png" alt="Vastu-compliant residential design">
                </div>
            </div>

            <div class="col-lg-9">
                <div class="other-area">
                    <div class="img1 image-anime reveal">
                        <img src="/assets/img/all-images/about-img16.png" alt="Premium sustainable residential construction">
                    </div>
                    <div class="space32"></div>
                    <div class="counter-box-area">
                        <div class="counter-box">
                            <h2 style="color: #E67E22;"><span class="counter"><%= companyInfo.stats.experience %></span>+</h2>
                            <p style="color: #E67E22;">Years Of Experience</p>
                        </div>

                        <div class="counter-box">
                            <h2 style="color: #E67E22;"><span class="counter"><%= companyInfo.stats.establishedProjects %></span>+</h2>
                            <p style="color: #E67E22;">Established Projects</p>
                        </div>

                        <div class="counter-box after">
                            <h2 style="color: #E67E22;"><span class="counter"><%= companyInfo.stats.ongoingProjects %></span>+</h2>
                            <p style="color: #E67E22;">Ongoing Projects</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== OTHERS AREA ENDS =======-->

<!--===== VISION & MISSION AREA STARTS =======-->
<div class="vision-mission-section sp1 py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 m-auto text-center mb-5">
                <div class="section-header">
                    <h5 class="subtitle" style="color: #E67E22; font-size: 24px;"><img src="/assets/img/icons/logo-icon1.svg" alt="Ishtika icon">Our Vision & Mission</h5>
                    <h2 class="main-title" style="color: #ffffff;">Building Tomorrow's Homes, Today</h2>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Vision Card -->
            <div class="col-lg-6">
                <div class="vm-card vision-card">
                    <div class="vm-icon">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <h3 style="color: #E67E22;">Our Vision</h3>
                    <p style="color: #ffffff;">To be one of Bangalore's most trusted real estate developers, recognized for creating Vastu-compliant, spacious homes that seamlessly blend traditional wisdom with contemporary luxury. We envision a future where every family enjoys premium living experiences at affordable prices, setting new benchmarks in quality, sustainability, and customer satisfaction.</p>
                </div>
            </div>

            <!-- Mission Card -->
            <div class="col-lg-6">
                <div class="vm-card mission-card">
                    <div class="vm-icon">
                        <i class="fa-solid fa-rocket"></i>
                    </div>
                    <h3 style="color: #E67E22;">Our Mission</h3>
                    <p style="color: #ffffff;">To deliver cost-effective, eco-friendly, and Vastu-aligned residential spaces with exceptional amenities and superior craftsmanship. We are committed to providing spacious, luxurious homes that respect traditional values while embracing modern technology, ensuring every project reflects our promise of quality, integrity, and excellence in real estate development.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== VISION & MISSION AREA ENDS =======-->

<!--===== OUR FOUNDERS SECTION STARTS =======-->
<div class="leadership-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 m-auto">
                <div class="section-header text-center">
                    <h5 data-aos="fade-up" style="color: #E67E22; font-size: 18px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; text-shadow: 0 0 20px rgba(239, 130, 6, 0.5);">The Visionaries</h5>
                    <h2 data-aos="fade-up" data-aos-delay="100" style="color: #E67E22; font-size: 42px; font-weight: 700; margin-bottom: 30px; text-shadow: 0 0 30px rgba(239, 130, 6, 0.6);">Our Founders</h2>
                </div>

                <div class="founders-content" data-aos="fade-up" data-aos-delay="200" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 25px; padding: 50px; box-shadow: 0 8px 32px 0 rgba(239, 130, 6, 0.3), inset 0 0 60px rgba(239, 130, 6, 0.05); border: 2px solid rgba(239, 130, 6, 0.3);">
                    <div class="founders-intro" style="margin-bottom: 30px;">
                        <h3 style="color: #E67E22; font-size: 28px; font-weight: 700; margin-bottom: 20px; text-align: center; text-shadow: 0 0 20px rgba(239, 130, 6, 0.5);">
                            <i class="bi bi-people-fill" style="margin-right: 10px;"></i>Mr. Chiranjeevi Reddy & Mr. Vijay Reddy
                        </h3>
                        <div style="width: 80px; height: 4px; background: linear-gradient(90deg, #E67E22 0%, #ff9d42 100%); margin: 0 auto 30px; border-radius: 2px; box-shadow: 0 0 15px rgba(239, 130, 6, 0.6);"></div>
                    </div>

                    <p style="color: #ffffff; font-size: 18px; line-height: 1.9; margin-bottom: 25px; text-align: justify; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);">
