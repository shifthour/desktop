<%- include('partials/header') %>

<style>
  /* Modern Background - Dark Theme */
  .contact-inner-section-area {
    background: #262731;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    padding-top: 150px !important;
    padding-bottom: 80px !important;
  }

  .contact-inner-section-area::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(239, 130, 6, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(239, 130, 6, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Modern Success/Error Alerts - Dark Theme */
  .modern-alert {
    background: rgba(239, 130, 6, 0.1) !important;
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 25px 30px;
    margin-bottom: 30px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 15px;
    border: none;
    animation: slideDown 0.5s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .modern-alert.success {
    border-left: 5px solid #28a745;
  }

  .modern-alert.error {
    border-left: 5px solid #dc3545;
  }

  .alert-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }

  .modern-alert.success .alert-icon {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
  }

  .modern-alert.error .alert-icon {
    background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);
    color: white;
  }

  .alert-content {
    flex: 1;
  }

  .alert-content strong {
    font-size: 18px;
    display: block;
    margin-bottom: 5px;
    color: #E67E22 !important;
  }

  .alert-content p {
    color: #ffffff !important;
  }

  .alert-close {
    background: none;
    border: none;
    font-size: 24px;
    color: rgba(255, 255, 255, 0.5) !important;
    cursor: pointer;
    padding: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .alert-close:hover {
    color: #ffffff !important;
    transform: rotate(90deg);
  }

  /* Modern Contact Header */
  .contact-inner-header h5 {
    font-size: 18px;
    color: #E67E22;
    font-weight: 600;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .contact-inner-header h2 {
    font-size: 42px;
    font-weight: 700;
    color: #E67E22;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .contact-inner-header > p {
    font-size: 16px;
    color: #ffffff;
    line-height: 1.8;
    margin-bottom: 30px;
  }

  /* Contact Info Cards - Dark Theme */
  .contact-info-cards {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .contact-info-card {
    background: rgba(239, 130, 6, 0.1) !important;
    backdrop-filter: blur(20px);
    border-radius: 15px;
    padding: 20px 25px;
    display: flex;
    align-items: center;
    gap: 15px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
    text-decoration: none;
  }

  .contact-info-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(239, 130, 6, 0.4);
    border-color: rgba(239, 130, 6, 0.6) !important;
    background: rgba(239, 130, 6, 0.15) !important;
  }

  .contact-card-icon {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 22px;
    flex-shrink: 0;
  }

  .contact-card-content {
    flex: 1;
  }

  .contact-card-label {
    font-size: 13px;
    color: #E67E22 !important;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 3px;
  }

  .contact-card-value {
    font-size: 16px;
    color: #ffffff !important;
    font-weight: 600;
  }

  .contact-info-card:hover .contact-card-value {
    color: #ff9d42 !important;
  }

  /* Modern Form Card - Dark Theme */
  .blog-contact-boxarea {
    background: rgba(239, 130, 6, 0.1) !important;
    backdrop-filter: blur(20px);
    border-radius: 25px;
    padding: 45px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
  }

  .blog-contact-boxarea h3 {
    font-size: 32px;
    font-weight: 700;
    color: #E67E22 !important;
    margin-bottom: 30px;
    text-align: center;
  }

  /* Modern Input Fields - Dark Theme */
  .input-area {
    margin-bottom: 20px;
    position: relative;
  }

  .input-area input,
  .input-area textarea {
    width: 100%;
    padding: 15px 20px;
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
    border-radius: 12px;
    font-size: 15px;
    transition: all 0.3s ease;
    background: rgba(255, 255, 255, 0.05) !important;
    color: #ffffff !important;
    font-family: inherit;
  }

  .input-area input:focus,
  .input-area textarea:focus {
    outline: none;
    border-color: #E67E22 !important;
    box-shadow: 0 0 0 4px rgba(239, 130, 6, 0.2);
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.08) !important;
  }

  .input-area textarea {
    min-height: 150px;
    resize: vertical;
  }

  .input-area input::placeholder,
  .input-area textarea::placeholder {
    color: rgba(255, 255, 255, 0.5) !important;
  }

  /* Modern Submit Button */
  .input-area button.header-btn1 {
    width: 100%;
    padding: 16px 30px;
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.4s ease;
    box-shadow: 0 8px 25px rgba(239, 130, 6, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .input-area button.header-btn1:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 35px rgba(239, 130, 6, 0.4);
  }

  .input-area button.header-btn1 img {
    transition: transform 0.3s ease;
  }

  .input-area button.header-btn1:hover img {
    transform: translateX(5px);
  }

  /* Mobile contact form optimization */
  @media (max-width: 768px) {
    .input-area input,
    .input-area textarea {
      font-size: 16px !important;
      padding: 14px 16px !important;
    }

    .input-area textarea {
      min-height: 120px !important;
    }

    .input-area button.header-btn1 {
      padding: 14px 24px !important;
      font-size: 15px !important;
    }

    .blog-contact-boxarea {
      padding: 30px 20px !important;
    }

    .blog-contact-boxarea h3 {
      font-size: 24px !important;
    }
  }

  @media (max-width: 480px) {
    .input-area {
      margin-bottom: 16px !important;
    }

    .input-area input,
    .input-area textarea {
      font-size: 16px !important;
      padding: 12px 14px !important;
    }

    .input-area textarea {
      min-height: 100px !important;
    }

    .input-area button.header-btn1 {
      padding: 12px 20px !important;
      font-size: 14px !important;
    }
  }

  /* Map Section - Dark Theme */
  .map-section {
    margin-top: 80px;
    padding: 0 15px;
  }

  .map-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .map-header h3 {
    font-size: 38px;
    font-weight: 700;
    color: #E67E22 !important;
    margin-bottom: 10px;
  }

  .map-header p {
    font-size: 16px;
    color: #ffffff !important;
  }

  .map-container {
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    max-width: 1400px;
    margin: 0 auto;
  }

  .map-container iframe {
    display: block;
  }

  /* Responsive Design */
  @media (max-width: 991px) {
    .contact-inner-header {
      margin-bottom: 40px;
    }

    .contact-inner-header h2 {
      font-size: 32px;
    }

    .blog-contact-boxarea {
      padding: 35px 25px;
    }
  }

  @media (max-width: 768px) {
    .contact-inner-section-area {
      padding-top: 120px !important;
    }

    .contact-inner-header h2 {
      font-size: 28px;
    }

    .blog-contact-boxarea h3 {
      font-size: 26px;
    }

    .map-header h3 {
      font-size: 28px;
    }
  }
</style>

<!--===== CONTACT AREA STARTS =======-->
<div class="contact-inner-section-area sp1">
    <div class="container">
        <% if (success) { %>
        <div class="modern-alert success" data-aos="fade-down" data-aos-duration="500">
            <div class="alert-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="alert-content">
                <strong>Success!</strong>
                <p style="margin: 0; color: #ffffff !important;">Your message has been sent successfully. We'll get back to you soon.</p>
            </div>
            <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="modern-alert error" data-aos="fade-down" data-aos-duration="500">
            <div class="alert-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="alert-content">
                <strong>Error!</strong>
                <p style="margin: 0; color: #ffffff !important;">There was an error sending your message. Please try again.</p>
            </div>
            <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <% } %>
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="contact-inner-header heading2" data-aos="fade-right" data-aos-duration="800">
                    <h5><img src="/assets/img/icons/logo-icon1.svg" alt="Ishtika icon">Contact Us</h5>
                    <h2>Get In Touch With Us: Your Trusted Home Builder</h2>
                    <p>We are here to help you find your dream home. Whether you are looking to buy a new property or invest in premium residential projects, our experienced team is ready to guide you every step of the way.</p>

                    <div class="contact-info-cards">
                        <!-- Location Card -->
                        <div class="contact-info-card" data-aos="fade-up" data-aos-duration="600" data-aos-delay="100">
                            <div class="contact-card-icon">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <div class="contact-card-content">
                                <div class="contact-card-label">Our Location</div>
                                <div class="contact-card-value"><%= companyInfo.address %></div>
                            </div>
                        </div>

                        <!-- Bengaluru Phone Card -->
                        <a href="tel:<%= companyInfo.phone.bengaluru.replace(/\s+/g, '') %>" class="contact-info-card" data-aos="fade-up" data-aos-duration="600" data-aos-delay="200">
                            <div class="contact-card-icon">
                                <i class="bi bi-telephone-fill"></i>
                            </div>
                            <div class="contact-card-content">
                                <div class="contact-card-label">Bengaluru Office</div>
                                <div class="contact-card-value"><%= companyInfo.phone.bengaluru %></div>
                            </div>
                        </a>

                        <!-- Bellary Phone Card -->
                        <a href="tel:<%= companyInfo.phone.bellary.replace(/\s+/g, '') %>" class="contact-info-card" data-aos="fade-up" data-aos-duration="600" data-aos-delay="300">
                            <div class="contact-card-icon">
                                <i class="bi bi-telephone-fill"></i>
                            </div>
                            <div class="contact-card-content">
                                <div class="contact-card-label">Bellary Office</div>
                                <div class="contact-card-value"><%= companyInfo.phone.bellary %></div>
                            </div>
                        </a>

                        <!-- Email Card -->
                        <a href="mailto:<%= companyInfo.email %>" class="contact-info-card" data-aos="fade-up" data-aos-duration="600" data-aos-delay="400">
                            <div class="contact-card-icon">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <div class="contact-card-content">
                                <div class="contact-card-label">Email Us</div>
                                <div class="contact-card-value"><%= companyInfo.email %></div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="blog-contact-boxarea" data-aos="fade-left" data-aos-duration="800">
                    <h3>Schedule an Appointment</h3>
                    <form class="row" method="post" action="/contact">
                        <div class="col-lg-6">
                            <div class="input-area">
                                <input type="text" name="name" placeholder="First Name *" required>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="input-area">
                                <input type="text" name="name2" placeholder="Last Name">
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="input-area">
                                <input type="email" name="email" placeholder="Email Address *" required>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="input-area">
                                <input type="tel" name="phone" placeholder="Phone Number *" required>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="input-area">
                                <input type="text" name="subject" placeholder="Subject">
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="input-area">
                                <textarea name="message" placeholder="Your Message *" required></textarea>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="input-area">
                                <button type="submit" class="header-btn1">Send Message <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!--===== CONTACT AREA ENDS =======-->

<!--===== MAP SECTION STARTS =======-->
<div class="map-section">
    <div class="container">
        <div class="map-header" data-aos="fade-up" data-aos-duration="800">
            <h3>Visit Our Office</h3>
            <p>Find us on the map and drop by for a visit</p>
        </div>
    </div>
    <div class="map-container" data-aos="fade-up" data-aos-duration="800">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d62230.26653246325!2d77.53671204529515!3d12.882518553968652!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae15006fac32ab%3A0x8017b52091e51ad3!2sIshtika%20Homes!5e0!3m2!1sen!2sin!4v1725620639014!5m2!1sen!2sin" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>
<!--===== MAP SECTION ENDS =======-->

<%- include('partials/footer') %>
