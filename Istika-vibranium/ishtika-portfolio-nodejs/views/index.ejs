<%- include('partials/header') %>

<style>
.main_tag{
    margin-top:-20px;
    font-size:30px !important;
    line-height: 25px !important;
}
.heading1 h1:first-of-type {
    font-size: 42px !important;
}
@media only screen and (max-width: 480px) {
    .heading1 h1 {
        line-height: 25px !important;
    }
    .heading1 h1:first-of-type {
        font-size: 22px !important;
    }
    .main_tag{
    margin-top:-10px;
    font-size:16px !important;
    line-height: 25px !important;
}

    /* Hero section mobile optimization */
    .tagline-hover {
        padding: 20px 15px !important;
        margin-top: 30px !important;
    }

    .tagline-hover h1 {
        font-size: 24px !important;
        line-height: 1.3 !important;
        margin-bottom: 40px !important;
        letter-spacing: 0 !important;
    }

    .tagline-hover p {
        font-size: 18px !important;
        line-height: 1.5 !important;
        margin-bottom: 25px !important;
    }

    .decorative-line {
        width: 50px !important;
        margin-bottom: 25px !important;
    }
}

/* Sound button */
.toggleSwitch {
  width: 50px;
  height: 50px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgb(39, 39, 39);
  border-radius: 50%;
  cursor: pointer;
  transition-duration: .3s;
  box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.13);
  overflow: hidden;
  top: -70px;
  left: 10px;
}

#checkboxInput {
  display: none;
}

.bell {
  width: 18px;
}

.bell path {
  fill: white;
}

.speaker {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition-duration: .3s;
}

.speaker svg {
  width: 18px;
}

.mute-speaker {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  z-index: 3;
  transition-duration: .3s;
}

.mute-speaker svg {
  width: 18px;
}

#checkboxInput:checked +.toggleSwitch .speaker {
  opacity: 0;
  transition-duration: .3s;
}

#checkboxInput:checked +.toggleSwitch .mute-speaker {
  opacity: 1;
  transition-duration: .3s;
}

#checkboxInput:active + .toggleSwitch {
  transform: scale(0.7);
}

#checkboxInput:hover + .toggleSwitch {
  background-color: rgb(61, 61, 61);
}

/* Counter area stats styling - Logo Brick Color */
.hero1-section-area .counter-area h2 {
  color: #E67E22 !important;
  font-weight: 600;
}

.hero1-section-area .counter-area p {
  color: #676767 !important;
  font-size: 16px;
}

/* Full-screen video with no gaps */
.hero1-section-area {
  padding: 0 !important;
  margin: 0 !important;
  margin-top: 0 !important;
  position: relative;
  top: 0;
}

.hero1-section-area .container-fluid {
  padding: 0 !important;
  margin: 0 !important;
  max-width: 100% !important;
}

.hero1-section-area .row {
  margin: 0 !important;
}

.hero1-section-area .col-12 {
  padding: 0 !important;
}

#myVideo {
  width: 100vw !important;
  height: 100vh !important;
  min-height: 100vh !important;
  object-fit: cover !important;
  border-radius: 0 !important;
  display: block;
  margin: 0;
  padding: 0;
}

/* Mobile video optimization */
@media (max-width: 768px) {
  #myVideo {
    height: 80vh !important;
    min-height: 80vh !important;
  }
}

/* Safari mobile specific fixes */
@supports (-webkit-touch-callout: none) {
  #myVideo {
    height: 100svh !important;
    min-height: 100svh !important;
  }

  @media (max-width: 768px) {
    #myVideo {
      height: 80svh !important;
      min-height: 80svh !important;
    }
  }
}

/* Add padding back to stats and tagline */
.hero1-section-area .col-12.mt-4,
.hero1-section-area .col-lg-12.mb-3 {
  padding-left: 15px !important;
  padding-right: 15px !important;
}

@media (min-width: 992px) {
  .hero1-section-area .col-12.mt-4,
  .hero1-section-area .col-lg-12.mb-3 {
    padding-left: 30px !important;
    padding-right: 30px !important;
  }
}

/* Mobile stats optimization */
@media (max-width: 991px) {
  .counter-area {
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }
}

@media (max-width: 480px) {
  .counter-area {
    padding: 12px 8px !important;
  }

  .counter-area h2 {
    font-size: 28px !important;
  }

  .counter-area p {
    font-size: 10px !important;
  }
}
</style>

<!--===== HERO AREA STARTS =======-->
<div class="hero1-section-area" style="background-color: #faf8f3;">
