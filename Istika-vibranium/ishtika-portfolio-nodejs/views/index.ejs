          autoplay
          muted
          loop
          playsinline
          style="display: block; margin-bottom: 0;">
          <source src="/anahata-project/project-video.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
        <input type="checkbox" id="checkboxInput">
        <label for="checkboxInput" class="toggleSwitch" onclick="audioToggle()">
            <div class="mute-speaker"><svg xmlns="http://www.w3.org/2000/svg" version="1.0" viewBox="0 0 75 75">
            <path d="M39.389,13.769 L22.235,28.606 L6,28.606 L6,47.699 L21.989,47.699 L39.389,62.75 L39.389,13.769z" style="stroke:#fff;stroke-width:5;stroke-linejoin:round;fill:#fff;"></path>
            <path d="M48,27.6a19.5,19.5 0 0 1 0,21.4M55.1,20.5a30,30 0 0 1 0,35.6M61.6,14a38.8,38.8 0 0 1 0,48.6" style="fill:none;stroke:#fff;stroke-width:5;stroke-linecap:round"></path>
            </svg></div>

            <div class="speaker"><svg version="1.0" viewBox="0 0 75 75" stroke="#fff" stroke-width="5">
            <path d="m39,14-17,15H6V48H22l17,15z" fill="#fff" stroke-linejoin="round"></path>
            <path d="m49,26 20,24m0-24-20,24" fill="#fff" stroke-linecap="round"></path>
            </svg></div>
        </label>
      </div>

      <!-- Stats & Tagline Section with Background Image -->
      <div class="col-12" style="position: relative; background-image: url('/assets/img/hero-tagline-bg.jpg'); background-size: cover; background-position: center; min-height: 700px; padding: 80px 20px; margin-top: -45px !important; padding-top: 80px !important;">

        <!-- Content Container -->
        <div style="position: relative; z-index: 2; max-width: 1200px; margin: 0 auto;">

          <!-- Stats Row -->
          <div class="row justify-content-center text-center mb-5">
            <div class="col-lg-3 col-md-6 col-6 mb-3" data-aos="fade-up" data-aos-duration="800">
              <div class="counter-area" style="background: rgba(50, 50, 50, 0.7); padding: 20px 15px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.2);">
                <h2 style="color: #E67E22 !important; font-size: 36px; font-weight: 700;"><span class="counter"><%= companyInfo.stats.experience %></span>+</h2>
                <p style="color: #ffffff !important; font-size: 12px; font-weight: 500; margin-top: 8px;">Years Of Experience</p>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 col-6 mb-3" data-aos="fade-up" data-aos-duration="1000">
              <div class="counter-area" style="background: rgba(50, 50, 50, 0.7); padding: 20px 15px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.2);">
                <h2 style="color: #E67E22 !important; font-size: 36px; font-weight: 700;"><span class="counter"><%= companyInfo.stats.establishedProjects %></span>+</h2>
                <p style="color: #ffffff !important; font-size: 12px; font-weight: 500; margin-top: 8px;">Established Projects</p>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 col-6 mb-3" data-aos="fade-up" data-aos-duration="1100">
              <div class="counter-area" style="background: rgba(50, 50, 50, 0.7); padding: 20px 15px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.2);">
                <h2 style="color: #E67E22 !important; font-size: 36px; font-weight: 700;"><span class="counter"><%= companyInfo.stats.ongoingProjects %></span>+</h2>
                <p style="color: #ffffff !important; font-size: 12px; font-weight: 500; margin-top: 8px;">Ongoing Projects</p>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 col-6 mb-3" data-aos="fade-up" data-aos-duration="1200">
              <div class="counter-area" style="background: rgba(50, 50, 50, 0.7); padding: 20px 15px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.2);">
                <h2 style="color: #E67E22 !important; font-size: 36px; font-weight: 700;"><span class="counter">2</span>K+</h2>
                <p style="color: #ffffff !important; font-size: 12px; font-weight: 500; margin-top: 8px;">Happy Residents</p>
              </div>
            </div>
          </div>

          <!-- Tagline -->
          <div class="text-center tagline-hover" style="max-width: 900px; margin: 60px auto 0; padding: 40px; transition: all 0.3s ease;" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="400">

            <!-- Decorative Top Line -->
            <div class="decorative-line" style="width: 80px; height: 3px; background: #E67E22; margin: 0 auto 40px; transition: width 0.3s ease;" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="200"></div>

            <!-- Main Headline -->
            <h1 class="text-anim" style="font-weight: 700; letter-spacing: -0.5px; margin-bottom: 40px; line-height: 1.4; color: #ffffff; text-shadow: 2px 2px 8px rgba(0,0,0,0.3); font-size: 42px; transition: all 0.3s ease;" data-aos="fade-down" data-aos-duration="1000" data-aos-delay="600">
              Vastu-Aligned, Everyday Luxury — Spacious homes that offer true value at Ishtika Homes
            </h1>

            <!-- Decorative Bottom Line -->
            <div class="decorative-line" style="width: 80px; height: 3px; background: #E67E22; margin: 0 auto; transition: width 0.3s ease;" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="1000"></div>

          </div>

          <style>
            .tagline-hover:hover {
              transform: translateY(-10px);
            }
            .tagline-hover:hover .decorative-line {
              width: 120px !important;
            }
            .tagline-hover:hover h1 {
              transform: scale(1.05);
            }
            .tagline-hover:hover p {
              color: #E67E22 !important;
              text-shadow: 2px 2px 10px rgba(239, 130, 6, 0.5) !important;
            }
          </style>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const video = document.getElementById('myVideo');
  const checkbox = document.getElementById('checkboxInput');

  // Start video playing muted as soon as possible
  video.muted = true;
  video.play().catch(() => {
    // If autoplay fails, it will still work with the autoplay attribute
  });

  checkbox.addEventListener('change', () => {
    video.muted = !checkbox.checked;
    if (video.paused) {
      video.play();
    }
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    },
    {
      threshold: 0.5,
    }
  );

  observer.observe(video);
</script>
