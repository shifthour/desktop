    .mobile-sidebar .social-links-mobile-menu ul li a i {
        font-size: 16px;
        color: #262731;
        transition: all 0.3s;
    }

    /* Overlay when menu is open */
    .mobile-sidebar::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s;
        z-index: -1;
    }

    .mobile-sidebar.mobile-menu-active::before {
