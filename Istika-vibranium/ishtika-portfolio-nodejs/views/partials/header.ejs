        width: 20px;
    }

    .header-area .menu-toggle .menu-lines span:nth-child(2) {
        width: 35px;
    }

    .header-area .menu-toggle .menu-lines span:nth-child(3) {
        width: 20px;
        margin-left: 15px;
    }

