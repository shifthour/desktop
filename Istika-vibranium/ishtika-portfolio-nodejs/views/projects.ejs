<%- include('partials/header') %>

<style>
  /* Modern Background Gradient */
  .projects-modern-bg {
    background: linear-gradient(135deg, #faf8f3 0%, #ffffff 100%);
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .projects-modern-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(239, 130, 6, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(239, 130, 6, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .projects-page-spacing {
    padding-top: 120px !important;
    padding-bottom: 80px;
  }

  /* Modern Project Header */
  .project-header-modern {
    position: relative;
    z-index: 1;
    margin-bottom: 60px;
  }

  .project-header-modern h2 {
    font-size: 48px;
    font-weight: 700;
    background: linear-gradient(135deg, #262731 0%, #E67E22 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 15px;
  }

  /* Enhanced Tab Buttons with Glassmorphism */
  .project-tabs {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 50px;
    position: relative;
    z-index: 1;
  }

  .project-tab-btn {
    padding: 15px 35px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(239, 130, 6, 0.2);
    color: #E67E22;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 50px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    position: relative;
    overflow: hidden;
  }

  .project-tab-btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(239, 130, 6, 0.1);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .project-tab-btn:hover::before {
    width: 300px;
    height: 300px;
  }

  .project-tab-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(239, 130, 6, 0.25);
    border-color: rgba(239, 130, 6, 0.4);
  }

  .project-tab-btn.active {
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    color: #ffffff;
    border-color: transparent;
    box-shadow: 0 8px 30px rgba(239, 130, 6, 0.4);
    transform: translateY(-3px);
  }

  .project-tab-btn .count-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.3);
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 13px;
    margin-left: 8px;
  }

  .project-tab-btn.active .count-badge {
    background: rgba(255, 255, 255, 0.25);
  }

  /* Project Content Container */
  .project-content {
    display: none;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .project-content.active {
    display: flex;
    flex-wrap: wrap;
    opacity: 1;
    animation: fadeIn 0.6s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Enhanced Project Cards - Dark Theme */
  .property-boxarea {
    background: #262731;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .property-boxarea:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(239, 130, 6, 0.3);
  }

  /* Image Container with Zoom Effect */
  .property-boxarea .img1 {
    position: relative;
    overflow: hidden;
    border-radius: 20px 20px 0 0;
    height: 250px;
  }

  .property-boxarea .img1::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .property-boxarea:hover .img1::after {
    opacity: 1;
  }

  .property-boxarea .img1 img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .property-boxarea:hover .img1 img {
    transform: scale(1.1);
  }

  /* Content Area */
  .property-boxarea .content-area {
    padding: 25px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .property-boxarea .content-area > a {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 12px;
    transition: color 0.3s;
    display: block;
  }

  .property-boxarea:hover .content-area > a {
    color: #E67E22;
  }

  /* Location Badge */
  .property-boxarea .content-area ul {
    list-style: none;
    padding: 0;
    margin: 0 0 15px 0;
  }

  .property-boxarea .content-area ul li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 14px;
    color: #ffffff;
  }

  .property-boxarea .content-area ul li img {
    width: 16px;
    height: 16px;
    filter: brightness(0) invert(1);
  }

  /* Description */
  .property-boxarea .content-area p {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
    color: #ffffff;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: 0.01em;
    margin-bottom: 20px;
    flex: 1;
  }

  /* Enhanced Button */
  .property-boxarea .header-btn1 {
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%);
    color: #ffffff;
    padding: 12px 25px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 15px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 4px 15px rgba(239, 130, 6, 0.3);
    position: relative;
    overflow: hidden;
  }

  .property-boxarea .header-btn1::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s;
  }

  .property-boxarea .header-btn1:hover::before {
    left: 100%;
  }

  .property-boxarea .header-btn1:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(239, 130, 6, 0.45);
  }

  .property-boxarea .header-btn1::after {
    content: '→';
    margin-left: 5px;
    transition: transform 0.3s;
  }

  .property-boxarea .header-btn1:hover::after {
    transform: translateX(5px);
  }

  /* Upcoming Section Enhancement */
  .upcoming-content-modern {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 30px;
    padding: 60px 40px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
    border: 2px solid rgba(239, 130, 6, 0.1);
  }

  .upcoming-content-modern h4 {
    font-size: 32px;
    font-weight: 700;
    color: #262731;
    margin-bottom: 20px;
  }

  .upcoming-content-modern p {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #676767;
    line-height: 1.7;
    letter-spacing: 0.01em;
    max-width: 600px;
    margin: 0 auto 30px;
  }

  /* Staggered Animation */
  .project-content.active .col-lg-4 {
    animation: slideUp 0.6s ease-out backwards;
  }

  .project-content.active .col-lg-4:nth-child(1) { animation-delay: 0.1s; }
  .project-content.active .col-lg-4:nth-child(2) { animation-delay: 0.2s; }
  .project-content.active .col-lg-4:nth-child(3) { animation-delay: 0.3s; }
  .project-content.active .col-lg-4:nth-child(4) { animation-delay: 0.4s; }
  .project-content.active .col-lg-4:nth-child(5) { animation-delay: 0.5s; }
  .project-content.active .col-lg-4:nth-child(6) { animation-delay: 0.6s; }
  .project-content.active .col-lg-4:nth-child(7) { animation-delay: 0.7s; }
  .project-content.active .col-lg-4:nth-child(8) { animation-delay: 0.8s; }
  .project-content.active .col-lg-4:nth-child(9) { animation-delay: 0.9s; }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .projects-page-spacing {
      padding-top: 100px !important;
    }

    .project-header-modern h2 {
      font-size: 32px;
    }

    .project-tabs {
      flex-direction: column;
      gap: 12px;
      padding: 0 20px;
    }

    .project-tab-btn {
      width: 100%;
      padding: 12px 20px;
      font-size: 14px;
    }

    .property-boxarea .img1 {
      height: 200px;
    }

    .upcoming-content-modern {
      padding: 40px 25px;
    }

    .upcoming-content-modern h4 {
      font-size: 24px;
    }
  }
</style>

<!--===== PROPERTY AREA STARTS =======-->
<div class="projects-modern-bg">
  <div class="property-inner-area sp1 projects-page-spacing">
    <div class="container">
      <!-- Modern Header -->
      <div class="row">
        <div class="col-lg-8 m-auto">
          <div class="project-header-modern text-center">
            <h2 class="text-anim">Our Projects</h2>
          </div>
        </div>
      </div>

      <!-- Enhanced Tab Buttons -->
      <div class="row">
        <div class="col-12">
          <div class="project-tabs">
            <button class="project-tab-btn active" onclick="showProjects('ongoing')">
              Ongoing Projects <span class="count-badge">5</span>
            </button>
            <button class="project-tab-btn" onclick="showProjects('completed')">
              Completed Projects <span class="count-badge">9</span>
            </button>
            <button class="project-tab-btn" onclick="showProjects('upcoming')">
              Upcoming Projects <span class="count-badge">3</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Ongoing Projects -->
      <div class="row mt-4 project-content active" id="ongoing-projects">
        <% projects.ongoing.forEach(project => { %>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="property-boxarea" style="background: #262731 !important; border: none !important;">
            <div class="img1">
              <img src="<%= project.image %>" alt="<%= project.name %>">
            </div>
            <div class="content-area">
              <a href="<%= project.slug.startsWith('/') ? project.slug : '/projects/' + project.slug %>" style="color: #ffffff !important;"><%= project.name %></a>
              <ul>
                <li style="color: #ffffff !important; background: transparent !important;">
                  <img src="/assets/img/icons/location1.svg" alt="" style="filter: brightness(0) invert(1) !important;">
                  <%= project.location %>
                </li>
              </ul>
              <p style="color: #ffffff !important;"><%= project.description %></p>
              <div class="price-area">
                <div class="btn-area1 w-100 text-center">
                  <a href="<%= project.slug.startsWith('/') ? project.slug : '/projects/' + project.slug %>" class="header-btn1 w-100">View Project</a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Completed Projects -->
      <div class="row mt-4 project-content" id="completed-projects">
        <% projects.completed.forEach(project => { %>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="property-boxarea" style="background: #262731 !important; border: none !important;">
            <div class="img1">
              <img src="<%= project.image %>" alt="<%= project.name %>">
            </div>
            <div class="content-area">
              <% if (project.slug) { %>
                <a href="<%= project.slug.startsWith('/') ? project.slug : '/projects/' + project.slug %>" style="color: #ffffff !important;"><%= project.name %></a>
              <% } else { %>
                <a style="color: #ffffff !important;"><%= project.name %></a>
              <% } %>
              <% if (project.location) { %>
              <ul>
                <li style="color: #ffffff !important; background: transparent !important;">
                  <img src="/assets/img/icons/location1.svg" alt="" style="filter: brightness(0) invert(1) !important;">
                  <%= project.location %>
                </li>
              </ul>
              <% } %>
              <% if (project.description) { %>
              <p style="color: #ffffff !important;"><%= project.description %></p>
              <% } %>
              <% if (project.slug) { %>
              <div class="price-area">
                <div class="btn-area1 w-100 text-center">
                  <a href="<%= project.slug.startsWith('/') ? project.slug : '/projects/' + project.slug %>" class="header-btn1 w-100">View Project</a>
                </div>
              </div>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Upcoming Projects -->
      <div class="row mt-4 project-content" id="upcoming-projects">
        <div class="col-12">
          <div class="upcoming-content-modern text-center" style="background: #262731 !important; border: none !important;">
            <h4 style="color: #E67E22 !important;">Exciting New Projects Coming Soon!</h4>
            <p style="color: #ffffff !important;">We are thrilled to announce our upcoming premium developments in prime locations:</p>
            <div class="upcoming-projects-list mt-4" style="max-width: 800px; margin: 0 auto; text-align: left;">
              <div style="background: rgba(239, 130, 6, 0.15); padding: 20px; border-radius: 15px; margin-bottom: 15px; border-left: 4px solid #E67E22;">
                <h5 style="color: #E67E22; font-weight: 600; margin-bottom: 10px;">🏢 Two High-Rise Projects</h5>
                <p style="color: #ffffff; margin: 0;">Strategically located in Whitefield, these premium high-rise developments will offer modern amenities and exceptional connectivity.</p>
              </div>
              <div style="background: rgba(239, 130, 6, 0.15); padding: 20px; border-radius: 15px; border-left: 4px solid #E67E22;">
                <h5 style="color: #E67E22; font-weight: 600; margin-bottom: 10px;">🏡 Exclusive Villa Project</h5>
                <p style="color: #ffffff; margin: 0;">A luxurious villa community in Whitefield, designed for those who seek privacy, space, and sophisticated living.</p>
              </div>
              <div class="mt-4" style="background: rgba(239, 130, 6, 0.2); padding: 15px; border-radius: 10px; border-left: 3px solid #E67E22;">
                <p style="color: #ffffff; font-size: 14px; margin: 0;"><strong style="color: #E67E22;">Note:</strong> RERA approval is currently in progress. Project names and detailed specifications will be disclosed upon approval.</p>
              </div>
            </div>
            <div class="btn-area1 mt-4">
              <a href="/contact" class="header-btn1">Get Notified <img src="/assets/img/icons/arrow1.svg" alt=""></a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<!--===== PROPERTY AREA ENDS =======-->

<script>
function showProjects(type) {
  // Hide all project contents
  document.querySelectorAll('.project-content').forEach(content => {
    content.classList.remove('active');
  });

  // Remove active class from all buttons
  document.querySelectorAll('.project-tab-btn').forEach(btn => {
    btn.classList.remove('active');
  });

  // Show selected project content with delay for animation
  setTimeout(() => {
    document.getElementById(type + '-projects').classList.add('active');
  }, 100);

  // Add active class to clicked button
  event.target.classList.add('active');

  // Smooth scroll to projects section
  document.querySelector('.project-tabs').scrollIntoView({
    behavior: 'smooth',
    block: 'nearest'
  });
}
</script>

<!--===== CTA AREA STARTS =======-->
<div class="cta1-section-area sp1">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5">
        <div class="cta-header heading1">
          <h2>We're Here To Find Your New Home Project.</h2>
        </div>
      </div>
      <div class="col-lg-3"></div>
      <div class="col-lg-4">
        <div class="cta-btn-area">
          <a href="/contact" class="header-btn1">Get a Quote <img src="/assets/img/icons/arrow1.svg" alt=""></a>
          <a href="/projects" class="header-btn1 btn1" style="background: #E67E22; border-color: #E67E22;">Our Projects <img src="/assets/img/icons/arrow1.svg" alt=""></a>
        </div>
      </div>
    </div>
  </div>
</div>
<!--===== CTA AREA ENDS =======-->

<%- include('partials/footer') %>
