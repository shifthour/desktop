{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/anahata-project/_next/static/(.*)",
      "dest": "/public/anahata-project/_next/static/$1"
    },
    {
      "src": "/anahata-project/(.*)",
      "dest": "/public/anahata-project/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
