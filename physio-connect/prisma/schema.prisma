generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Physiotherapist {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  photo         String   @default("")
  gender        String   // "male" | "female"
  experience    Int
  bio           String   @db.Text
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  clinicName    String
  locationArea  String
  locationCity  String
  locationLat   Float
  locationLng   Float
  verified      Boolean  @default(false)
  totalSessions Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  specializations PhysioSpecialization[]
  qualifications  Qualification[]
  visitTypes      PhysioVisitType[]
  services        Service[]
  reviews         Review[]
  bookings        Booking[]

  @@index([slug])
  @@index([locationCity])
  @@index([rating])
}

model Specialization {
  id    String @id @default(cuid())
  name  String @unique
  icon  String @default("")
  count Int    @default(0)
  image String @default("")

  physios PhysioSpecialization[]
}

model PhysioSpecialization {
  physioId         String
  specializationId String

  physio         Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)
  specialization Specialization  @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([physioId, specializationId])
}

model Qualification {
  id       String @id @default(cuid())
  physioId String
  text     String
  sortOrder Int   @default(0)

  physio Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)

  @@index([physioId])
}

model PhysioVisitType {
  physioId  String
  visitType String // "clinic" | "home" | "online"

  physio Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)

  @@id([physioId, visitType])
}

model Service {
  id          String @id @default(cuid())
  physioId    String
  name        String
  duration    Int
  price       Float
  description String @db.Text
  sortOrder   Int    @default(0)

  physio   Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([physioId])
}

model Review {
  id          String   @id @default(cuid())
  physioId    String
  patientName String
  rating      Int
  date        String
  text        String   @db.Text
  verified    Boolean  @default(false)

  physio Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)

  @@index([physioId])
}

model Booking {
  id           String   @id @default(cuid())
  physioId     String
  physioName   String
  patientName  String
  patientEmail String
  patientPhone String
  serviceId    String
  serviceName  String
  date         String
  time         String
  duration     Int
  fee          Float
  platformFee  Float
  status       String   @default("pending") // "confirmed" | "pending" | "cancelled" | "completed"
  reason       String?
  createdAt    DateTime @default(now())

  physio  Physiotherapist @relation(fields: [physioId], references: [id], onDelete: Cascade)
  service Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([physioId])
  @@index([status])
}
