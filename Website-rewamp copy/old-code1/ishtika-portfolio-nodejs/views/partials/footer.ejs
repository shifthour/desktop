<style>
    .footer-logo-area form input {
    font-family: var(--ztc-family-font2);
    font-size: var(--ztc-font-size-font-s16);
    font-weight: var(--ztc-weight-regular);
    color: var(--ztc-text-text-3);
    width: 235px;
    border: 1px solid #EAEBEB;
    border-radius: 8px;
    padding: 18px 12px;
    height: 52px;
}

/* Modern Footer Typography */
.footer1-section-area {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
}

.footer1-section-area .footer-logo-area p {
    font-size: 15px;
    line-height: 1.7;
    font-weight: 400;
    letter-spacing: 0.01em;
    opacity: 0.85;
    color: #E67E22;
}

.footer1-section-area .footer-header h3 {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
    text-transform: none;
    color: #E67E22;
}

.footer1-section-area .footer-header ul li a {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.8;
    letter-spacing: 0.01em;
    opacity: 0.8;
    transition: all 0.2s ease;
    color: #E67E22;
}

.footer1-section-area .footer-header ul li a:hover {
    opacity: 1;
    transform: translateX(2px);
}

.footer1-section-area .copyright .pera p {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    opacity: 0.7;
    color: #E67E22;
}

.footer1-section-area .copyright ul li a {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    opacity: 0.7;
    color: #E67E22;
}
</style>

<!--===== FOOTER AREA STARTS =======-->
<div class="footer1-section-area">
  <div class="container">
    <div class="row">
      <div class="col-lg-4 col-md-6">
        <div class="footer-logo-area">
          <img style="max-width:150px;" src="/assets/img/logo/logo1.png" alt="Ishtika Homes logo">
          <div class="space32"></div>
          <p><%= companyInfo.description %></p>

          <ul>
            <li><a href="<%= companyInfo.social.facebook %>"><i class="fa-brands fa-facebook-f"></i></a></li>
            <li><a href="<%= companyInfo.social.instagram %>"><i class="fa-brands fa-instagram"></i></a></li>
            <li><a href="<%= companyInfo.social.linkedin %>"><i class="fa-brands fa-linkedin-in"></i></a></li>
            <li><a href="<%= companyInfo.social.youtube %>"><i class="fa-brands fa-youtube"></i></a></li>
          </ul>
        </div>
      </div>

      <div class="col-lg-3 col-md-5">
        <div class="footer-header ">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/gallery">Gallery</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>

      <div class="col-lg-5 col-md-7">
        <div class="footer-header">
          <h3>Contact Information</h3>
          <ul>
            <li><span><img src="/assets/img/icons/location1.svg" alt="Location icon"></span><a href="#" style="width:90%"><%= companyInfo.address %></a></li>
            <li><span><img src="/assets/img/icons/call1.svg" alt="Phone icon"></span><a href="tel:7338628777">Bengaluru: <%= companyInfo.phone.bengaluru %></a></li>
            <li><span><img src="/assets/img/icons/call1.svg" alt="Phone icon"></span><a href="tel:9686658656">Bellary: <%= companyInfo.phone.bellary %></a></li>
            <li><span><img src="/assets/img/icons/mail1.svg" alt="Email icon"></span><a href="mailto:<%= companyInfo.email %>"><%= companyInfo.email %></a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="space50 d-lg-block d-none"></div>
    <div class="space30 d-lg-none d-block"></div>
    <div class="row">
      <div class="col-lg-12">
        <div class="copyright">
          <div class="pera">
            <p>©Copyright 2025 Ishtika Homes. All rights reserved</p>
          </div>
          <ul>
            <li><a href="/policy">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
<!--===== FOOTER AREA ENDS =======-->

<!--===== JS SCRIPT LINK =======-->
<script src="/assets/js/plugins/bootstrap.min.js" defer></script>
<script src="/assets/js/plugins/fontawesome.js" defer></script>
<script src="/assets/js/plugins/aos.js" defer></script>
<script src="/assets/js/plugins/counter.js" defer></script>
<script src="/assets/js/plugins/sidebar.js" defer></script>
<script src="/assets/js/plugins/magnific-popup.js" defer></script>
<script src="/assets/js/plugins/mobilemenu.js" defer></script>
<script src="/assets/js/plugins/owlcarousel.min.js" defer></script>
<script src="/assets/js/plugins/nice-select.js" defer></script>
<script src="/assets/js/plugins/waypoints.js" defer></script>
<script src="/assets/js/plugins/slick-slider.js" defer></script>
<script src="/assets/js/plugins/circle-progress.js" defer></script>
<script src="/assets/js/plugins/gsap.min.js" defer></script>
<script src="/assets/js/plugins/ScrollTrigger.min.js" defer></script>
<script src="/assets/js/plugins/Splitetext.js" defer></script>
<script src="/assets/js/main.js" defer></script>


<script>
    $(document).ready(function() {
    $('.popup-img').magnificPopup({
        type: 'image',
        closeOnContentClick: true,
        mainClass: 'mfp-img-mobile',
        image: {
            verticalFit: true
        }
    });
});

</script>
<script>
    const currentLocation = window.location.pathname.split("/").pop();
    const menuItems = document.querySelectorAll('.main-menu li a');

    menuItems.forEach(item => {
        const linkLocation = item.getAttribute('href');
        if (linkLocation === currentLocation) {
            item.parentElement.classList.add('active');
        }
    });
</script>
</body>

</html>
