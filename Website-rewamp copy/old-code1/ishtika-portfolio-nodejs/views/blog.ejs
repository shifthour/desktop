  </div>
</div>

<script>
  // Handle blog link clicks - show coming soon message
  document.addEventListener('DOMContentLoaded', function() {
    const blogLinks = document.querySelectorAll('.blog-card-link, .blog-featured-link');

    blogLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        // Create and show toast notification
        const toast = document.createElement('div');
        toast.innerHTML = '<strong>Coming Soon!</strong><br>Full articles will be available shortly.';
        toast.style.cssText = 'position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg, #E67E22, #f39c12); color: white; padding: 20px 30px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); z-index: 9999; text-align: center; font-size: 16px; animation: slideUp 0.3s ease;';
        document.body.appendChild(toast);

        // Remove toast after 3 seconds
        setTimeout(function() {
          toast.style.animation = 'slideDown 0.3s ease';
          setTimeout(function() {
            toast.remove();
          }, 300);
        }, 3000);
      });
    });
  });
</script>

<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateX(-50%) translateY(20px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  @keyframes slideDown {
    from { opacity: 1; transform: translateX(-50%) translateY(0); }
    to { opacity: 0; transform: translateX(-50%) translateY(20px); }
  }
</style>

