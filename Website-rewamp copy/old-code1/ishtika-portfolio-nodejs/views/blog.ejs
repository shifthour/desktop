          <a href="/contact" class="header-btn1">Get a Quote <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></a>
          <a href="/projects" class="header-btn1 btn1" style="background: #E67E22; border-color: #E67E22;">Browse Projects <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></a>
        </div>
