<%- include('partials/header') %>

<style>
  /* Modern Background with Gradient */
  .gallery1-section-area {
    background: linear-gradient(135deg, #faf8f3 0%, #ffffff 100%);
    position: relative;
    overflow: hidden;
  }

  .gallery1-section-area::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(239, 130, 6, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(239, 130, 6, 0.03) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Modern Glassmorphism Filter Buttons */
  ul li button {
    color: #E67E22 !important;
    font-family: var(--ztc-family-font2) !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    display: inline-block !important;
    border-radius: 25px !important;
    background: rgba(255, 255, 255, 0.8) !important;
    backdrop-filter: blur(10px) !important;
    padding: 10px 24px !important;
    border: 2px solid rgba(239, 130, 6, 0.3) !important;
    cursor: pointer !important;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08) !important;
    position: relative !important;
    overflow: hidden !important;
  }

  ul li button::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(239, 130, 6, 0.1);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  ul li button:hover::before {
    width: 300px;
    height: 300px;
  }

  ul li button:hover {
    background: rgba(255, 255, 255, 0.95) !important;
    border-color: rgba(239, 130, 6, 0.3) !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 25px rgba(239, 130, 6, 0.2) !important;
  }

  ul li button.active {
    background: linear-gradient(135deg, #E67E22 0%, #ff9d42 100%) !important;
    color: #ffffff !important;
    border-color: #E67E22 !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 25px rgba(239, 130, 6, 0.4) !important;
  }

  /* Mobile filter button optimization */
  @media (max-width: 768px) {
    ul li button {
      min-width: 44px !important;
      min-height: 44px !important;
      padding: 12px 20px !important;
      font-size: 13px !important;
      margin: 4px !important;
    }

    .nav.nav-pills {
      flex-wrap: wrap !important;
      justify-content: center !important;
      gap: 8px !important;
    }
  }

  @media (max-width: 480px) {
    ul li button {
      padding: 10px 16px !important;
      font-size: 12px !important;
      min-width: 44px !important;
      min-height: 44px !important;
    }
  }

  /* Enhanced Image Cards */
  .img1 {
    height: 280px;
    overflow: hidden;
    border-radius: 15px;
    position: relative;
  }

  .img1 img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .galler-author-area {
    position: relative;
    border-radius: 15px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .galler-author-area::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(239, 130, 6, 0.1) 0%, rgba(255, 157, 66, 0.1) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
    pointer-events: none;
  }

  .galler-author-area:hover::before {
    opacity: 1;
  }

  .galler-author-area:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 60px rgba(239, 130, 6, 0.25);
  }

  .galler-author-area:hover .img1 img {
    transform: scale(1.15);
  }

  /* Image Overlay Effect */
  .img1::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .galler-author-area:hover .img1::after {
    opacity: 1;
  }

  /* Enhanced Content Area */
  .content-area {
    padding: 20px;
    position: relative;
    z-index: 2;
  }

  .content-area a {
    color: #E67E22 !important;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .galler-author-area:hover .content-area a {
    color: #ff9d42 !important;
  }

  /* Smooth Grid Animations */
  .gallery-item {
    display: none !important;
    animation: fadeOut 0.3s ease-out;
  }

  .gallery-item.show {
    display: flex !important;
    animation: fadeInUp 0.5s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-20px);
    }
  }

  /* Stagger animation for gallery items */
  .gallery-item.show:nth-child(1) { animation-delay: 0.05s; }
  .gallery-item.show:nth-child(2) { animation-delay: 0.1s; }
  .gallery-item.show:nth-child(3) { animation-delay: 0.15s; }
  .gallery-item.show:nth-child(4) { animation-delay: 0.2s; }
  .gallery-item.show:nth-child(5) { animation-delay: 0.25s; }
  .gallery-item.show:nth-child(6) { animation-delay: 0.3s; }
  .gallery-item.show:nth-child(7) { animation-delay: 0.35s; }
  .gallery-item.show:nth-child(8) { animation-delay: 0.4s; }
  .gallery-item.show:nth-child(9) { animation-delay: 0.45s; }

  /* Modern Gallery Header */
  .gallery-header h2 {
    font-size: 48px;
    font-weight: 700;
    background: linear-gradient(135deg, #333 0%, #E67E22 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 15px;
  }

  .gallery-subtitle {
    font-size: 18px;
    color: #E67E22 !important;
    font-weight: 400;
    margin-bottom: 30px;
  }

  /* Add expand icon on hover */
  .img1::before {
    content: '\f065';
    font-family: 'Font Awesome 5 Free';
    font-weight: 900;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    color: white;
    font-size: 32px;
    z-index: 10;
    transition: transform 0.3s ease;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .galler-author-area:hover .img1::before {
    transform: translate(-50%, -50%) scale(1);
  }
</style>

<!--===== GALLERY AREA STARTS =======-->
<div class="gallery1-section-area gallery sp1" style="padding-top: 150px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 m-auto">
        <div class="gallery-header text-center heading2 mb-0">
          <h2 class="text-anim">Our Gallery</h2>
          <p class="gallery-subtitle">Explore our stunning collection of completed and ongoing projects</p>

          <!-- Filter Buttons -->
          <ul class="nav nav-pills justify-content-center gap-2 mt-4" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
              <button id="all" class="nav-link active filter-btn" data-filter="all">
                All
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="anahata" class="nav-link filter-btn" data-filter="anahata">
                Anahata
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="krishna" class="nav-link filter-btn" data-filter="krishna">
                Krishna
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="vashishta" class="nav-link filter-btn" data-filter="vashishta">
                Vashishta
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="naadam" class="nav-link filter-btn" data-filter="naadam">
                Naadam
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="vyasa" class="nav-link filter-btn" data-filter="vyasa">
                Vyasa
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button id="agastya" class="nav-link filter-btn" data-filter="agastya">
                Agastya
              </button>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Gallery Images -->
    <div class="row mt-5 gallery-filter">
      <% galleryImages.forEach((item, index) => { %>
      <div class="col-lg-4 col-md-6 mb-4 gallery-item <%= item.project %> show" data-aos="fade-up" data-aos-duration="<%= 800 + (index % 3 * 100) %>">
        <div class="galler-author-area">
          <div class="img1">
            <a href="<%= item.image %>" class="popup-img">
              <img src="<%= item.image %>" alt="<%= item.name %> - project gallery image">
            </a>
          </div>

          <div class="content-area">
            <a href="<%= item.image %>" class="popup-img"><%= item.name %></a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
<!--===== GALLERY AREA ENDS =======-->

<!--===== CTA AREA STARTS =======-->
<div class="cta1-section-area sp1">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5">
        <div class="cta-header heading1">
          <h2>We're Here To Find Your New Home Project.</h2>
        </div>
      </div>
      <div class="col-lg-3"></div>
      <div class="col-lg-4">
        <div class="cta-btn-area">
          <a href="/contact" class="header-btn1">Get a Quote <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></a>
          <a href="/projects" class="header-btn1 btn1" style="background: #E67E22; border-color: #E67E22;">Our Projects <img src="/assets/img/icons/arrow1.svg" alt="Arrow icon"></a>
        </div>
      </div>
    </div>
  </div>
</div>
<!--===== CTA AREA ENDS =======-->

<script>
  // Gallery Filter Functionality
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');

    console.log('Total gallery items:', galleryItems.length);
    console.log('Total filter buttons:', filterButtons.length);

    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        console.log('Filter clicked:', filter);

        // Update active button
        filterButtons.forEach(btn => btn.classList.remove('active'));
        this.classList.add('active');

        // Filter gallery items
        let visibleCount = 0;
        galleryItems.forEach(item => {
          if (filter === 'all') {
            item.classList.add('show');
            visibleCount++;
          } else {
            if (item.classList.contains(filter)) {
              item.classList.add('show');
              visibleCount++;
            } else {
              item.classList.remove('show');
            }
          }
        });

        console.log('Visible items after filter:', visibleCount);
      });
    });
  });
</script>

<%- include('partials/footer') %>
