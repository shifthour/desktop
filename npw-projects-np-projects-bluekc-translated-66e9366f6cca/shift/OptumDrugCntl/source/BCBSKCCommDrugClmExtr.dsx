Then 
If BCBSKCComm.CMPND_CD <> 2 Then ((BCBSKCComm.INGR_CST_SUB_AMT+ Trim(BCBSKCComm.CLNT_GNRL_PRPS_AREA[28,11])) - (BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT)) Else 0.00
Else 0.00
=+=+=+=
         Group "0"
         ParsedDerivation " If (BCBSKCComm.SRC_SYS_CD = 'OPTUMRX') Then  If BCBSKCComm.CMPND_CD <> 2 Then ((BCBSKCComm.INGR_CST_SUB_AMT + Trim(BCBSKCComm.CLNT_GNRL_PRPS_AREA[28, 11])) - (BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT)) Else 0.00 Else 0.00"
