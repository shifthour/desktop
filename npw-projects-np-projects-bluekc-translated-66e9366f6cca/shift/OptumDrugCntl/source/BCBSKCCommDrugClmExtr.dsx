         Name "FoundOptumRXPrescProvDeaNo"
         Expression =+=+=+=
If Transform.SRC_SYS_CD = 'OPTUMRX' THEN
     If (IsNull(dea_no.PROV_DEA_SK) = @FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK<> 1  ) Then "Y"
