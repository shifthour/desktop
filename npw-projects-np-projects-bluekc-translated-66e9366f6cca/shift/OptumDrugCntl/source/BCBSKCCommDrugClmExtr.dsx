         Group "0"
         ParsedDerivation " If Trim(BCBSKCComm.CMPND_CD) = 2 then '99999999999' else  if (Isnull(BCBSKCComm.NDC) = @TRUE or Len(Trim(BCBSKCComm.NDC)) = 0) then BCBSKCComm.NDC else Trim(BCBSKCComm.NDC)"
