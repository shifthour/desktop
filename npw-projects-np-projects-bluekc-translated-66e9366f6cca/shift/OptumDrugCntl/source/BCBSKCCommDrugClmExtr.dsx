         Value =+=+=+=
SELECT
       PRCT.NTNL_PROV_ID,
       MPPNG.SRC_CD,
       PRCT.CMN_PRCT_SK,
       MIN(DEA.PROV_DEA_SK)

FROM 
devl.PROV_DEA DEA,
devl.CMN_PRCT PRCT,
devl.CD_MPPNG MPPNG

WHERE
PRCT.SRC_SYS_CD_SK = MPPNG.CD_MPPNG_SK
AND PRCT.CMN_PRCT_SK = DEA.CMN_PRCT_SK

GROUP BY
PRCT.CMN_PRCT_SK,
PRCT.NTNL_PROV_ID,
MPPNG.SRC_CD
