         ParsedDerivation " If (BCBSKCComm.SRC_SYS_CD = 'OPTUMRX') Then BCBSKCComm.PDX_TYP Else 'NA'"
         SourceColumn "BCBSKCComm.SRC_SYS_CD;BCBSKCComm.PDX_TYP"
         SortKey "0"
         SortType "0"
         TableDef "Saved\\DrugClmPK\\Pkey"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
