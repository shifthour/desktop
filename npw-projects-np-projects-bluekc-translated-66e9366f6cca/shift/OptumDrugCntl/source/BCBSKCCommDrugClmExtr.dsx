      BEGIN DSSUBRECORD
         Name "PRSCRB_PROV_DEA_ID"
         Description "The Prescribing Provider Drug Enforcement Agency Identifier attribute is a unique value issued by the Drug Enforcement Agency (DEA) that represents a provider who is allowed to prescribe drugs."
         SqlType "12"
         Precision "20"
         Scale "0"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
 If  ( IsNull(dea_no.PROV_DEA_SK)=@FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK <> 1) 
     Then Trim(Transform.PRESCRIBER_ID) 
     Else
          If (IsNull(hf_dea.DEA_NO)=@FALSE and hf_dea.DEA_NO <> "UNK" AND hf_dea.DEA_NO <> "NA" ) 
          Then Trim(hf_dea.DEA_NO) 
          else  Trim(Transform.PRESCRIBER_ID) 
=+=+=+=
         Group "0"
         ParsedDerivation " If (IsNull(dea_no.PROV_DEA_SK) = @FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK <> 1) Then Trim(Transform.PRESCRIBER_ID) Else  If (IsNull(hf_dea.DEA_NO) = @FALSE and hf_dea.DEA_NO <> \"UNK\" AND hf_dea.DEA_NO <> \"NA\") Then Trim(hf_dea.DEA_NO) else Trim(Transform.PRESCRIBER_ID)"
         SourceColumn "dea_no.PROV_DEA_SK;Transform.PRESCRIBER_ID;hf_dea.DEA_NO"
