      BEGIN DSSUBRECORD
         Name "PRSCRB_PROV_DEA"
         SqlType "12"
         Precision "20"
         Scale "0"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "20"
         Derivation =+=+=+=
If Transform.SRC_SYS_CD = 'OPTUMRX'  THEN
     If  ( IsNull(dea_no.PROV_DEA_SK)=@FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK <> 1) 
     Then Trim(Transform.PRESCRIBER_ID) 
     Else
          If (IsNull(hf_dea.DEA_NO)=@FALSE and hf_dea.DEA_NO <> "UNK" AND hf_dea.DEA_NO <> "NA" ) 
          Then Trim(hf_dea.DEA_NO) 
          else  Trim(Transform.PRESCRIBER_ID) 
ELSE
If (IsNull(dea_no.PROV_DEA_SK) = @FALSE Or Len(Trim(dea_no.PROV_DEA_SK)) > 0) 
Then Trim(Transform.PRESCRIBER_ID) 
Else
     If IsNull(hf_dea.DEA_NO) = @TRUE 
     Then 
          If (IsNull(Transform.PRESCRIBER_ID)=@FALSE Or Len(Trim(Transform.PRESCRIBER_ID))>0)
          Then Trim(Transform.PRESCRIBER_ID)
          Else 'UNK' 
     Else hf_dea.DEA_NO

=+=+=+=
         Group "0"
         ParsedDerivation " If Transform.SRC_SYS_CD = 'OPTUMRX' THEN  If (IsNull(dea_no.PROV_DEA_SK) = @FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK <> 1) Then Trim(Transform.PRESCRIBER_ID) Else  If (IsNull(hf_dea.DEA_NO) = @FALSE and hf_dea.DEA_NO <> \"UNK\" AND hf_dea.DEA_NO <> \"NA\") Then Trim(hf_dea.DEA_NO) else Trim(Transform.PRESCRIBER_ID) ELSE  If (IsNull(dea_no.PROV_DEA_SK) = @FALSE Or Len(Trim(dea_no.PROV_DEA_SK)) > 0) Then Trim(Transform.PRESCRIBER_ID) Else  If IsNull(hf_dea.DEA_NO) = @TRUE Then  If (IsNull(Transform.PRESCRIBER_ID) = @FALSE Or Len(Trim(Transform.PRESCRIBER_ID)) > 0) Then Trim(Transform.PRESCRIBER_ID) Else 'UNK' Else hf_dea.DEA_NO"
         SourceColumn "Transform.SRC_SYS_CD;dea_no.PROV_DEA_SK;Transform.PRESCRIBER_ID;hf_dea.DEA_NO"
         SortKey "0"
         SortType "0"
         TableDef "DataStage7_MetaBroker\\CRF\\DrugClmCrf"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
