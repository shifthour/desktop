          If (IsNull(hf_dea.DEA_NO) = @FALSE and hf_dea.DEA_NO <> "UNK" AND hf_dea.DEA_NO <> "NA" ) Then "Y"
          Else "N"
ELSE "N"



=+=+=+=
         SqlType "3"
         ParsedExpression " If Transform.SRC_SYS_CD = 'OPTUMRX' THEN  If (IsNull(dea_no.PROV_DEA_SK) = @FALSE and dea_no.PROV_DEA_SK <> 0 and dea_no.PROV_DEA_SK <> 1) Then \"Y\" Else  If (IsNull(hf_dea.DEA_NO) = @FALSE and hf_dea.DEA_NO <> \"UNK\" AND hf_dea.DEA_NO <> \"NA\") Then \"Y\" Else \"N\" ELSE \"N\""
         SourceColumn "Transform.SRC_SYS_CD;dea_no.PROV_DEA_SK;hf_dea.DEA_NO"
