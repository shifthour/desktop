      BEGIN DSSUBRECORD
         Name "PROV_DEA_SK"
         SqlType "4"
         Precision "10"
         Scale "0"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If BCBSKCComm.SRC_SYS_CD='OPTUMRX'   then 
     	If  	Len(Trim(BCBSKCComm.PRSCRBR_ID)) <> 0 	and 
     	     	Trim(BCBSKCComm.PRSCRBR_ID) <> "NA" 	and 
     	     	Trim(BCBSKCComm.PRSCRBR_ID) <> "UNK" 	then
          			If IsNull(hf_dea.PROV_DEA_SK)=@FALSE  Then hf_dea.PROV_DEA_SK 
          			Else
     				If  	Len(Trim(BCBSKCComm.PRSCRBR_NTNL_PROV_ID)) <> 0 	and  
     	     	     	     	     	Trim(BCBSKCComm.PRSCRBR_NTNL_PROV_ID) <> "NA" 		and 
     	     	     	     	     	Trim(BCBSKCComm.PRSCRBR_NTNL_PROV_ID) <> "UNK" 	then          
     	     	     	                                               If IsNull(hf_prct_facets_2.PROV_DEA_SK)=@FALSE 	Then hf_prct_facets_2.PROV_DEA_SK 
          					               Else 
          					               If IsNull(hf_prct_vcac_2.PROV_DEA_SK)=@FALSE 	Then hf_prct_vcac_2.PROV_DEA_SK 
          					             Else 	
          					              If IsNull(hf_npi_min_dea_2.PROV_DEA_SK)=@FALSE 	Then hf_npi_min_dea_2.PROV_DEA_SK 
          					               Else 0 
				ELSE 0
                   ELSE
		If  	Len(Trim(BCBSKCComm.PRSCRBR_NTNL_PROV_ID)) <> 0 	and  
		Trim(BCBSKCComm.PRSCRBR_NTNL_PROV_ID) <> "NA" 		and 
