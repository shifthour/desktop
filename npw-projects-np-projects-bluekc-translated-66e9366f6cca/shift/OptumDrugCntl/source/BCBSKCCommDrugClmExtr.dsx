description=\"Statement to be executed when deleting rows from the database\" label=\"Delete statement\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Table\" required=\"false\" type=\"string\"/></Property><Property description=\"List of statement parameters\" hidden=\"true\" label=\"Parameter list\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Parameters\" required=\"false\" type=\"category\"><Property description=\"Statement parameter represented as a comma delimited triplet containing ORCHESTRATE variable name, corresponding field name, and table name\" label=\"Parameter\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Parameter\" required=\"false\" type=\"string\"/></Property><Property description=\"Statement to be executed when deleting rows from the database\" hidden=\"true\" label=\"Delete statement\" maxOccurs=\"1\" minOccurs=\"0\" name=\"WhereClause\" required=\"false\" type=\"string\"/></Property><Property contexts=\"target\" default=\"1\" description=\"Source of the user-defined SQL statements\" filterProperty=\"/Usage/WriteMode\" filterValue=\"7\" label=\"User-defined SQL\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UserDefinedSQL\" required=\"true\" type=\"int\"><Value code=\"1\">Statements</Value><Value code=\"2\">File</Value><Property description=\"SQL statements to be executed for each input row\" filterProperty=\"/Usage/SQL/UserDefinedSQL\" filterValue=\"1\" label=\"Statements\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"Statements\" required=\"true\" type=\"string\"/><Property description=\"File on the conductor node that contains SQL statements to be executed for each input row\" filterProperty=\"/Usage/SQL/UserDefinedSQL\" filterValue=\"2\" label=\"File\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"File\" required=\"true\" type=\"string\"><Property description=\"IANA character set name\" label=\"Character set\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"CharacterSet\" required=\"false\" type=\"string\"/></Property><Property default=\"true\" description=\"Abort the statement sequence when an error occurs\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Do not abort the job when a DB2 Warning is encountered, report as an information messsage.\" label=\"Treat warnings as info\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SuppressWarnings\" required=\"false\" type=\"bool\"/></Property><Property contexts=\"source\" default=\"false\" description=\"Enable or disable partitioned reads by using the selected partitioning method.\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" label=\"Enable partitioned reads\" name=\"EnablePartitioning\" required=\"false\" type=\"bool\"><Property contexts=\"source\" default=\"1\" description=\"The method to use for partitioned reads.\" label=\"Partitioned reads method\" name=\"PartitioningMethod\" required=\"false\" type=\"int\"><Value code=\"0\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Modulus</Value><Value code=\"1\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Minimum and maximum range</Value><Value code=\"2\">DB2 connector</Value><Property description=\"Specifies the table that is used by the selected partitioned reads method.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"1 2\" label=\"Table name\" name=\"TableName\" required=\"true\" type=\"string\"/><Property description=\"Specifies the key column that is used by the selected partitioned reads method. This column must a numeric data type.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"0 1\" label=\"Column name\" maxLength=\"256\" minLength=\"1\" name=\"KeyField\" required=\"true\" type=\"string\"/><Property default=\"true\" description=\"Specifies whether the connector should modify the SELECT statement at run-time and generate the required partitioning clause\" label=\"Generate partitioning SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"GenPartitioningSQL\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\">2</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/GenerateSQL\">false</FilterProperty></Filter></Property></Property></Property></Property><Property contexts=\"target\" default=\"0\" description=\"Select the action to perform on the database table\" label=\"Table action\" maxOccurs=\"1\" minOccurs=\"0\" name=\"TableAction\" required=\"true\" type=\"int\"><Value code=\"0\">Append</Value><Value code=\"1\">Create</Value><Value code=\"2\">Replace</Value><Value code=\"3\">Truncate</Value><Property contexts=\"target\" default=\"true\" description=\"Specifies whether to generate a create table statement at runtime\" filterProperty=\"/Usage/TableAction\" filterValue=\"1 2\" label=\"Generate create statement at runtime\" maxOccurs=\"1\" name=\"GenerateCreateStatement\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property callout=\"generateSQL\" calloutDescription=\"Generate a create table statement\" calloutLabel=\"Generate\" calloutRequiresConnection=\"true\" calloutType=\"builder\" contexts=\"target\" default=\"\" description=\"A statement to be executed when creating the target database table\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement\" filterValue=\"false\" label=\"Create statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"CreateStatement\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"statementType\">CreateTableSQL</CalloutArgument></Property></Property><Property contexts=\"target\" default=\"true\" description=\"Specifies whether to generate a drop table statement at runtime\" filterProperty=\"/Usage/TableAction\" filterValue=\"2\" label=\"Generate drop statement at runtime\" maxOccurs=\"1\" minOccurs=\"0\" name=\"GenerateDropStatement\" required=\"false\" type=\"bool\"><Property default=\"false\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property callout=\"generateSQL\" calloutDescription=\"Generate a drop table statement\" calloutLabel=\"Generate\" calloutType=\"builder\" contexts=\"target\" default=\"\" description=\"A statement to be executed when dropping the target database table\" filterProperty=\"/Usage/TableAction/GenerateDropStatement\" filterValue=\"false\" label=\"Drop statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"DropStatement\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"statementType\">DropTableSQL</CalloutArgument></Property></Property><Property contexts=\"target\" default=\"true\" description=\"Specifies whether to generate a truncate table statement at runtime\" filterProperty=\"/Usage/TableAction\" filterValue=\"3\" label=\"Generate truncate statement at runtime\" maxOccurs=\"1\" name=\"GenerateTruncateStatement\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property callout=\"generateSQL\" calloutDescription=\"Generate a truncate table statement\" calloutLabel=\"Generate\" calloutRequiresConnection=\"true\" calloutType=\"builder\" contexts=\"target\" default=\"\" description=\"A statement to be executed when truncating the database table\" filterProperty=\"/Usage/TableAction/GenerateTruncateStatement\" filterValue=\"false\" label=\"Truncate statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"TruncateStatement\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"statementType\">TruncateTableSQL</CalloutArgument></Property></Property></Property><Property description=\"Transaction properties\" inputLinkCountConstraint=\"single\" label=\"Transaction\" name=\"Transaction\" transactionModels=\"local\" type=\"category\"><Property default=\"2000\" description=\"Number of records per transaction. The value 0 means all available records\" inputLinkCountConstraint=\"single\" label=\"Record count\" maxValue=\"999999999\" minValue=\"0\" name=\"RecordCount\" required=\"false\" transactionModels=\"local\" type=\"int\"/><Property contexts=\"target\" default=\"0\" description=\"Specify the amount of time to pass before a commit is issued. If you set a small value you force frequent commits and therefore if your program terminates unexpectedly, your table can still contain partial results. However, you may pay a performance penalty because of the high frequency of commits. If you set a large value, DB2 must log a correspondingly large amount of rollback information which may also slow your job.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"2 3 4\" label=\"Time Commit Interval\" maxOccurs=\"1\" minOccurs=\"1\" minValue=\"0\" name=\"TimeInterval\" required=\"false\" type=\"int\"/><Property contexts=\"source request\" default=\"0\" description=\"Specify settings for the end of wave handling. None means EOW markers are never inserted, Before means EOW markers are inserted before committing the transaction, After means EOW markers are inserted after committing the transaction\" engines=\"ee\" filterChildPropertiesOnValue=\"1 2\" label=\"End of wave\" name=\"EndOfWave\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Before</Value><Value code=\"2\">After</Value><Property default=\"false\" description=\"Specifies whether to insert an EOW marker for the last set of records when the number is less than the specified transaction record count value\" label=\"End of data\" name=\"EndOfData\" required=\"false\" type=\"bool\"/></Property></Property><Property default=\"false\" description=\"Transaction grouping allows operations on multiple links to be executed within a single transaction.\" engines=\"se\" inputLinkCountConstraint=\"multiple\" label=\"Enable transaction grouping\" maxOccurs=\"1\" minOccurs=\"0\" name=\"EnableTransactionGrouping\" required=\"false\" scope=\"stage\" specialFilter=\"1\" type=\"bool\"/><Property contexts=\"target\" description=\"Transaction grouping settings\" engines=\"se\" inputLinkCountConstraint=\"multiple\" label=\"Transaction grouping\" maxOccurs=\"1\" minOccurs=\"0\" name=\"TransactionGrouping\" required=\"false\" scope=\"link\" specialFilter=\"1\" type=\"category\"><Property default=\"0\" description=\"The action to be taken when a link is skipped\" label=\"Action on skip\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ActionOnSkip\" required=\"false\" type=\"int\"><Value code=\"0\">Continue</Value><Value code=\"1\">Rollback</Value></Property><Property default=\"1\" description=\"The action to be taken when a failure occurs on a link\" label=\"Action on failure\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ActionOnFailure\" required=\"false\" type=\"int\"><Value code=\"0\">Continue</Value><Value code=\"1\">Rollback</Value></Property></Property><Property description=\"Session properties\" label=\"Session\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Session\" required=\"false\" scope=\"all\" type=\"category\"><Property default=\"1\" description=\"Specifies the isolation level that is used for all database transactions.\" label=\"Isolation level\" maxOccurs=\"1\" minOccurs=\"0\" name=\"IsolationLevel\" required=\"true\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Read uncommitted</Value><Value code=\"1\">Cursor stability</Value><Value code=\"2\">Read stability</Value><Value code=\"3\">Repeatable read</Value></Property><Property default=\"0\" description=\"Specifies whether the connector commits transactions manually, or allows the database to commit transactions automatically at its discretion.\" label=\"Auto commit mode\" maxOccurs=\"1\" minOccurs=\"0\" name=\"AutocommitMode\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Off</Value><Value code=\"1\">On</Value></Property><Property default=\"2000\" description=\"The array size to be used for all read and write database operations\" label=\"Array size\" maxOccurs=\"1\" minOccurs=\"0\" minValue=\"1\" name=\"ArraySize\" required=\"false\" type=\"int\"/><Property description=\"Properties that affect schema reconciliation\" label=\"Schema reconciliation\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SchemaReconciliation\" required=\"false\" type=\"category\"><Property default=\"true\" description=\"Fail if the sizes of numeric and string fields are not compatible when validating the design schema against the database\" label=\"Fail on size mismatch\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnSizeMismatch\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Fail if the types of fields are not compatible when validating the design schema against the database\" label=\"Fail on type mismatch\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnTypeMismatch\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Fail if the code pages of fields are not compatible when validating the design schema against the database\" hidden=\"true\" label=\"Fail on code page mismatch\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnCodePageMismatch\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"true\" description=\"Drop fields that don't exist in the input schema\" label=\"Drop unmatched fields\" maxOccurs=\"1\" minOccurs=\"0\" name=\"DropUnmatchedFields\" required=\"false\" type=\"bool\"/></Property><Property contexts=\"target\" default=\"true\" description=\"Fail the job if a write operation to the target is unsuccessful\" engines=\"ee\" filterForRejectLinks=\"absent\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Fail on row error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnRowErrorPX\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"false\" description=\"Fail the job if a write operation to the target is unsuccessful\" engines=\"se\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Fail on row error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnRowErrorSE\" required=\"false\" type=\"bool\"/><Property contexts=\"source request\" default=\"false\" description=\"Enables/disables the ability to specify LOB columns to be passed using locator (reference) information. LOB columns not specified will be passed inline\" filterChildPropertiesOnValue=\"true\" label=\"Enable LOB references\" name=\"PassLobLocator\" required=\"false\" type=\"bool\"><Property callout=\"lobCandidateColumns\" calloutDescription=\"Choose columns containing LOBs to be passed by reference (locator). Columns that are not selected will be passed inline\" calloutLabel=\"Available columns\" calloutType=\"builder\" default=\"\" description=\"Use to choose columns containing LOBs to be passed by locator (reference)\" label=\"Columns\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Column\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property><Property contexts=\"request\" default=\"0\" description=\"Specifies the type of message logged when the lookup query returns more than one match for a set of keys\" engines=\"se\" label=\"Log multiple matches\" name=\"LogMultipleMatches\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Informational</Value><Value code=\"2\">Warning</Value><Value code=\"3\">Fatal</Value></Property><Property contexts=\"target\" default=\"0\" description=\"Specifies whether to enable the insert buffering optimization in partitioned database environments.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0\" label=\"Insert buffering\" name=\"InsertBuffering\" required=\"false\" type=\"int\"><Value code=\"0\">Default</Value><Value code=\"1\">Off</Value><Value code=\"2\">On</Value><Value code=\"3\">Ignore duplicates</Value><Property contexts=\"target\" default=\"0\" description=\"Specifies whether arrays should be inserted atomically.  Insert buffering with non-atomic arrays does not report errors accurately.\" filterProperty=\"/Usage/Session/InsertBuffering\" filterValue=\"0 2 3\" label=\"Atomic arrays\" name=\"AtomicArrays\" required=\"false\" type=\"int\"><Value code=\"0\">Auto</Value><Value code=\"1\">No</Value><Value code=\"2\">Yes</Value><Value code=\"3\">Simulated</Value></Property></Property></Property><Property contexts=\"target\" description=\"Properties that affect logging\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Logging\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Logging\" required=\"false\" type=\"category\"><Property default=\"false\" description=\"Specifies whether to log column values for the first row that fails to be written\" filterChildPropertiesOnValue=\"true\" label=\"Log column values on first row error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogColumnValues\" required=\"false\" type=\"bool\"><Property default=\"false\" description=\"Specifies whether to log key columns or all columns for failing statements\" label=\"Log key values only\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogKeysOnly\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the delimiter to use between columns\" label=\"Column delimiter\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Delimiter\" required=\"false\" type=\"int\"><Value code=\"0\">Space</Value><Value code=\"1\">Newline</Value><Value code=\"2\">Tab</Value><Value code=\"3\">Comma</Value></Property></Property></Property><Property default=\"false\" description=\"Before/After SQL properties\" filterChildPropertiesOnValue=\"true\" label=\"Before/After SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"BeforeAfter\" required=\"false\" type=\"bool\"><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once before any data is processed.\" label=\"Before SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"before\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the Before SQL statement property.\" label=\"Read Before SQL statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileBeforeSQL\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once after all data is processed.\" label=\"After SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"after\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the After SQL statement property.\" label=\"Read After SQL statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileAfterSQL\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once on each node before any data is processed on that node.\" engines=\"ee\" label=\"Before SQL (node)\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"beforeNode\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the Before SQL (node) statement property.\" label=\"Read Before SQL (node) statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileBeforeSQLNode\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once one each node after all data is processed on that node.\" engines=\"ee\" label=\"After SQL (node)\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"afterNode\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the After SQL (node) statement property.\" label=\"Read After SQL (node) statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileAfterSQLNode\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property></Property><Property contexts=\"target\" default=\"0\" deprecated=\"false\" description=\"Determines how records should be ordered across multiple links.\" engines=\"ee\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" inputLinkCountConstraint=\"multiple\" label=\"Record ordering\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"RecordOrdering\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">All records</Value><Value code=\"1\">First record</Value><Value code=\"2\">Ordered</Value><Property default=\"false\" description=\"A column to be used for sorting.\" filterContexts=\"all\" filterEngines=\"all\" filterProperty=\"/Usage/RecordOrdering\" filterValue=\"2\" hidden=\"false\" label=\"Key column\" maxOccurs=\"unbounded\" minOccurs=\"1\" multiline=\"false\" name=\"KeyColumn\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"category\"><Property callout=\"columns\" calloutDescription=\"Choose columns to define cross-link ordering\" calloutLabel=\"Available columns\" calloutType=\"builder\" description=\"The name of a column to be used for sorting.\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" label=\"Column name\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"ColumnName\" required=\"true\" scope=\"stage\" transactionModels=\"local\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"columnSelection\">commonInput</CalloutArgument></Property><Property default=\"0\" description=\"Specifies whether sorting should be in ascending or descending order.\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" label=\"Sort order\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"SortOrder\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Ascending</Value><Value code=\"1\">Descending</Value></Property><Property default=\"0\" description=\"Specifies whether null values should appear before or after non-null values.\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" label=\"Null order\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"NullOrder\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Before</Value><Value code=\"1\">After</Value></Property><Property default=\"false\" description=\"Specifies whether strings should be compared using a case sensitive or insensitive comparison.\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" label=\"Case sensitive\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"CaseSensitive\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"bool\"/></Property></Property><Property default=\"2\" description=\"Specifies the type of reoptimization that is done by DB2.\" label=\"Reoptimization\" name=\"ReOptimization\" required=\"false\" scope=\"stage\" type=\"int\"><Value code=\"2\">None</Value><Value code=\"3\">Once</Value><Value code=\"4\">Always</Value></Property><Property default=\"1\" description=\"Specifies the lock wait strategy that is used when a lock cannot be obtained immediately.\" filterChildPropertiesOnValue=\"3\" filterContexts=\"target\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Lock wait mode\" name=\"LockWaitMode\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Return an SQLCODE and SQLSTATE</Value><Value code=\"1\">Use the lock timeout database configuration parameter</Value><Value code=\"2\">Wait indefinitely</Value><Value code=\"3\">User specified</Value><Property description=\"Time to wait for a lock\" label=\"Lock wait time\" maxValue=\"32767\" minValue=\"1\" name=\"LockWaitModeTime\" required=\"true\" type=\"int\"/></Property><Property contexts=\"target request\" description=\"Specifies the pad character that is used in the WHERE clause for string columns that are smaller than the column size.\" label=\"Pad character\" maxLength=\"256\" minLength=\"1\" name=\"PadCharacter\" required=\"false\" type=\"string\"/><Property contexts=\"target\" default=\"false\" description=\"By default the connector runs one player process per database partition. If you want to force the connector to run fewer player processes, set this property to Yes\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" filterProperty=\"/Usage/WriteMode\" filterValue=\"6\" label=\"Limit parallelism\" name=\"LimitParallelism\" required=\"false\" type=\"bool\"><Property contexts=\"target\" description=\"The total number of player processes across all processing nodes.\" label=\"Total number of player processes\" minValue=\"1\" name=\"PlayerProcessLimit\" required=\"true\" type=\"int\"/></Property><Property contexts=\"target\" default=\"false\" description=\"Determines whether the target table is on DB2 for z/OS.\" filterChildPropertiesOnValue=\"true\" filterProperty=\"/Usage/WriteMode\" filterValue=\"6\" label=\"Bulk load to DB2 on z/OS\" name=\"LoadToZOS\" required=\"false\" transactionModels=\"local\" type=\"bool\"><Property default=\"0\" description=\"Load method to be used for loading input data into DB2 for z/OS.\" filterProperty=\"/Usage/LoadToZOS/Transfer/TransferType\" filterValue=\"0\" label=\"Load method\" name=\"LoadMethod\" required=\"false\" type=\"int\"><Value code=\"0\">MVS dataset(s)</Value><Value code=\"1\">Batch pipe(s)</Value><Value code=\"2\">USS pipe(s)</Value></Property><Property description=\"Transfer properties\" label=\"Transfer\" name=\"Transfer\" required=\"false\" type=\"category\"><Property default=\"0\" description=\"Determines the method of transferring data to the z/OS machine.\" label=\"Transfer type\" name=\"TransferType\" required=\"false\" type=\"int\"><Value code=\"0\">ftp</Value><Value code=\"1\">sftp</Value></Property><Property description=\"Name of the target machine to which the data is sent.\" label=\"Transfer to\" maxLength=\"256\" minLength=\"1\" name=\"TransferTo\" required=\"true\" type=\"string\"/><Property description=\"Determines the user name for transferring.\" label=\"User\" maxLength=\"256\" minLength=\"1\" name=\"User\" required=\"false\" type=\"string\"/><Property description=\"Determines the password for transferring.\" label=\"Password\" maxLength=\"256\" minLength=\"1\" name=\"Password\" required=\"false\" type=\"protectedstring\"/><Property description=\"The presence of this option indicates that HFS files is to be used and gives the directory name where the files will be created.  The value should be a fully qualified HFS directory name.\" filterProperty=\"/Usage/LoadToZOS/Transfer/TransferType\" filterValue=\"1\" label=\"HFS file directory\" maxLength=\"512\" minLength=\"1\" name=\"USSFileDirectory\" required=\"true\" type=\"string\"/><Property description=\"User-entered command sent just before data transfer begins.  FTP example:  quote site vcount=7 datakeepalive=60\" label=\"Transfer command\" maxLength=\"2000\" minLength=\"1\" name=\"TransferCmd\" required=\"false\" type=\"string\"/><Property default=\"true\" description=\"Select Yes to try to establish a connection again when the initial attempt to connect is unsuccessful.\" filterChildPropertiesOnValue=\"true\" label=\"Retry on connection failure\" name=\"RetryConnection\" required=\"false\" type=\"bool\"><Property default=\"3\" description=\"Enter the number of times to try to establish a connection after a failure on the initial attempt.\" label=\"Number of retries\" maxValue=\"999999999\" minValue=\"1\" name=\"RetryCount\" required=\"true\" type=\"int\"/><Property default=\"10\" description=\"Enter the time in seconds to wait between retries to establish a connection.\" label=\"Interval between retries\" maxValue=\"999999999\" minValue=\"1\" name=\"RetryInterval\" required=\"true\" type=\"int\"/></Property></Property><Property description=\"This option identifies a prefix to be used when creating MVS dataset names.  If omitted, the transfer user name is used.\" label=\"DSN prefix\" maxLength=\"256\" minLength=\"1\" name=\"DSNPrefix\" required=\"false\" type=\"string\"/><Property description=\"If the data is to be transferred to a Batch pipes system on z/OS, this option identifies its name.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"1\" label=\"Batch pipe system ID\" maxLength=\"256\" minLength=\"1\" name=\"BatchPipeSystemID\" required=\"true\" type=\"string\"/><Property description=\"The presence of this option indicates that USS piping is to be used and gives the directory name where the pipes will be created.  The value should be a fully qualified USS directory name.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"2\" label=\"USS pipe directory\" maxLength=\"512\" minLength=\"1\" name=\"USSPipeDirectory\" required=\"true\" type=\"string\"/><Property default=\"false\" description=\"LOAD will not actually be executed, only MVS datasets are created.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"0\" label=\"File(s) only\" name=\"FilesOnly\" required=\"false\" type=\"bool\"/><Property default=\"SYSDA\" description=\"This option specifies the device type to be used for various datasets that the LOAD utility may need.  If omitted, the default is SYSDA.\" label=\"Device type\" maxLength=\"8\" minLength=\"1\" name=\"DeviceType\" required=\"false\" type=\"string\"/><Property description=\"If this option is present, then only the indicated partition will be loaded.  If this option is omitted, all partitions of the DB2 for z/OS database table will be loaded.\" label=\"Partition number\" minValue=\"1\" name=\"PartitionNumber\" required=\"false\" type=\"int\"/><Property default=\"1000\" description=\"This option specifies an estimated count of the total number of rows to be loaded into all partitions combined.  This estimate is used to calculate the amount of disk space which will be needed on z/OS for various datasets.  If not present, a row estimate of 1000 is used.\" label=\"Row count estimate\" minValue=\"0\" name=\"RowCountEstimate\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"This option requests that statistics be displayed at the end of the load.\" label=\"Statistics\" name=\"Statistics\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">All</Value><Value code=\"2\">Index</Value><Value code=\"3\">Table</Value></Property><Property default=\"DB2ZLOAD\" description=\"This is a unique identifier within DB2 for the execution of the LOAD utility.  The default value is DB2ZLOAD.\" label=\"Utility ID\" maxLength=\"16\" minLength=\"1\" name=\"UtilityID\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Indicates whether logging is to occur during the load process.\" label=\"Load with logging\" name=\"LoadWithLogging\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Specifies whether or not the table space is set to the copy-pending status.  (Applicable only when Load with logging = No)\" filterProperty=\"/Usage/LoadToZOS/LoadWithLogging\" filterValue=\"false\" label=\"Set copy-pending\" name=\"SetCopyPending\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the input dataset encoding\" label=\"Encoding\" name=\"Encoding\" required=\"false\" type=\"int\"><Value code=\"0\">EBCDIC</Value><Value code=\"1\">ASCII</Value><Value code=\"2\">UNICODE</Value><Value code=\"3\">CCSID</Value><Property description=\"The IANA character set name for the encoding.  If not specified, ibm-1047-s390 will be used for EBCDIC, ASCII for ASCII, and UTF-16BE for UNICODE.\" label=\"Character set\" maxLength=\"256\" minLength=\"1\" name=\"CharacterSet\" required=\"false\" type=\"string\"/><Property description=\"The IANA character set name for the graphic encoding.  If not specified, UTF-16BE is the default.\" label=\"Graphic character set\" maxLength=\"256\" minLength=\"1\" name=\"GraphicCharacterSet\" required=\"false\" type=\"string\"/><Property description=\"Specifies the coded character set identifier (CCSID) for SBCS data, Mixed data, and DBCS data in the input file.\" filterProperty=\"/Usage/LoadToZOS/Encoding\" filterValue=\"3\" label=\"CCSID\" maxLength=\"256\" minLength=\"1\" name=\"CCSID\" required=\"true\" type=\"string\"/></Property><