      Constraint =+=+=+=
Transform.SRC_SYS_CD = "OPTUMRX" and
(
         (FoundOptumRXPrescProvDeaNo = "N")  
   Or  (
            (FoundOptumRXPrescProvDeaNo = "Y" and        
                (
                 Len(Trim(Transform.PRSCRBR_NTNL_PROV_ID))>0 and 
                    (Trim(Transform.PRSCRBR_NTNL_PROV_ID)='NA' or 
                     Trim(Transform.PRSCRBR_NTNL_PROV_ID)='UNK')
                 )
             )
         )
)

=+=+=+=
      Reject "0"
      ErrorPin "0"
      RowLimit "0"
