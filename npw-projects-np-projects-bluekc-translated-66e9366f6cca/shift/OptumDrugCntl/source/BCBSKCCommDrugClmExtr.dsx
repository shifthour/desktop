      BEGIN DSSUBRECORD
         Name "AVG_WHLSL_PRICE_AMT"
         Description "The Average Wholesale Price Amount attribute contains the average price at which the wholesalers will sell this drug to physicians, pharmacies, and other customers."
         SqlType "3"
         Precision "13"
         Scale "2"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "15"
         Derivation =+=+=+=
If BCBSKCComm.SRC_SYS_CD='OPTUMRX'
 THEN (If Isnull(BCBSKCComm.FULL_AVG_WHLSL_PRICE) = @TRUE  or Trim(BCBSKCComm.FULL_AVG_WHLSL_PRICE)='' Then 0.00 Else If(BCBSKCComm.CLM_TYP = 'R' and BCBSKCComm.FULL_AVG_WHLSL_PRICE > 0) Then (-1*BCBSKCComm.FULL_AVG_WHLSL_PRICE) Else BCBSKCComm.FULL_AVG_WHLSL_PRICE)
 ELSE If BCBSKCComm.SRC_SYS_CD='MEDIMPACT' Then BCBSKCComm.FULL_AVG_WHLSL_PRICE Else  0.00
=+=+=+=
         Group "0"
         ParsedDerivation " If BCBSKCComm.SRC_SYS_CD = 'OPTUMRX' THEN ( If Isnull(BCBSKCComm.FULL_AVG_WHLSL_PRICE) = @TRUE or Trim(BCBSKCComm.FULL_AVG_WHLSL_PRICE) = '' Then 0.00 Else  If (BCBSKCComm.CLM_TYP = 'R' and BCBSKCComm.FULL_AVG_WHLSL_PRICE > 0) Then (-1 * BCBSKCComm.FULL_AVG_WHLSL_PRICE) Else BCBSKCComm.FULL_AVG_WHLSL_PRICE) ELSE  If BCBSKCComm.SRC_SYS_CD = 'MEDIMPACT' Then BCBSKCComm.FULL_AVG_WHLSL_PRICE Else 0.00"
         SourceColumn "BCBSKCComm.SRC_SYS_CD;BCBSKCComm.FULL_AVG_WHLSL_PRICE;BCBSKCComm.CLM_TYP"
         SortKey "0"
         SortType "0"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
         SignOption "0"
         SortingOrder "0"
         ArrayHandling "0"
         SyncIndicator "0"
         PadChar ""
         ExtendedPrecision "0"
         TaggedSubrec "0"
         OccursVarying "0"
         PKeyIsCaseless "0"
