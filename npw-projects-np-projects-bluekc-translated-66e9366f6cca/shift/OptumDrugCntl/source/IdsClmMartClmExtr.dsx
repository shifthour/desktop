      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
R.SRC_SYS_CD_SK = FCLTY.SRC_SYS_CD_SK
and R.CLM_ID = FCLTY.CLM_ID
and FCLTY.GNRT_DRG_SK = DRG.DRG_SK

=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT CLM_SK,ADMS_DT_SK,DSCHG_DT_SK,LOS_DAYS,FCLTY_BILL_TYP_TX,SUBMT_DRG_CD FROM #IDSInstance#.CLM_SK_EXTR R,#IDSInstance#.FCLTY_CLM CLM WHERE R.CLM_SK = CLM.CLM_SK
and R.DEST_CD = 'ClmQuest'
and R.EXTR_CD = 'PaidClaims'
and R.CLM_CAT_CD = 'HEALTH';
=+=+=+=
      END DSSUBRECORD
