   BEGIN DSRECORD
      Identifier "V0S39P23"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "external_mbr"
      Partner "V0S40|V0S40P42"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.CLM_EXTRNL_MBRSH M,#$IDSOwner#.CD_MPPNG NG1"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
R.SRC_SYS_CD_SK = M.SRC_SYS_CD_SK 
and R.CLM_ID  = M.CLM_ID 
and CLM_EXTRNL_MBRSH_SUB_ST_CD_SK = CD_MPPNG_SK

=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT R.CLM_SK,MBR_BRTH_DT_SK,GRP_NM,MBR_FIRST_NM,MBR_MIDINIT,MBR_LAST_NM,SUB_FIRST_NM,SUB_MIDINIT,SUB_ADDR_LN_1,SUB_ADDR_LN_2,SUB_CITY_NM,TRGT_CD,SUB_POSTAL_CD,SUB_LAST_NM,SUB_GRP_BASE_NO FROM #IDSOwner#.CLM_ID_EXTR R,#IDSOwner#.CLM_EXTRNL_MBRSH M,#IDSOwner#.CD_MPPNG NG1 WHERE R.CLM_SK = M.CLM_SK
 
and R.DEST_CD = '#dest#'
and R.EXTR_CD = '#extr#'
and R.CLM_CAT_CD = '#clm_cat#'
and CLM_EXTRNL_MBRSH_SUB_ST_CD_SK = CD_MPPNG_SK
;
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "AFTERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTAFTERSQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "GENSQL"
         Value "Yes"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "TABLE"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.CLM_EXTRNL_MBRSH M,#$IDSOwner#.CD_MPPNG NG1"
      END DSSUBRECORD
