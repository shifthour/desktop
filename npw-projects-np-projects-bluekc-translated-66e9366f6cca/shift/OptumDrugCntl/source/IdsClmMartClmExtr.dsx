   BEGIN DSRECORD
      Identifier "V0S39P45"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "pca_clmchk"
      Partner "V0S40|V0S40P77"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR DRVR, #$IDSOwner#.CLM CLM, #$IDSOwner#.CLM_CHK CLMCHK, #$IDSOwner#.CLNDR_DT DT, #$IDSOwner#.CD_MPPNG CD_MPPNG, #$IDSOwner#.CD_MPPNG CD_MPPNG2, #$IDSOwner#.CD_MPPNG CD_MPPNG3"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
CLM.CLM_SK = CLMCHK.CLM_SK and 
CLMCHK.PCA_CHK_IN = 'Y' and 
DRVR.CLM_ID = CLM.CLM_ID AND 
CLMCHK.CHK_PD_DT_SK = DT.CLNDR_DT_SK and
CLMCHK.CLM_CHK_LOB_CD_SK = CD_MPPNG.CD_MPPNG_SK and 
CLMCHK.CLM_CHK_PAYE_TYP_CD_SK = CD_MPPNG2.CD_MPPNG_SK and 
CLMCHK.CLM_CHK_PAYMT_METH_CD_SK = CD_MPPNG3.CD_MPPNG_SK;
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SQLBUILDERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT CLM.CLM_SK,CHK_NET_PAYMT_AMT,CHK_NO,CHK_SEQ_NO,CHK_PAYE_NM,CHK_PAYMT_REF_ID,DT.CLNDR_DT,CD_MPPNG.TRGT_CD,CD_MPPNG.TRGT_CD_NM,CD_MPPNG2.TRGT_CD,CD_MPPNG2.TRGT_CD_NM FROM #$IDSOwner#.W_WEBDM_ETL_DRVR R, #$IDSOwner#.CLM CLM FULL OUTER JOIN #$IDSOwner#.CLM_CHK CLMCHK ON CLM.CLM_SK = CLMCHK.CLM_SK , #$IDSOwner#.CLNDR_DT DT, #$IDSOwner#.CD_MPPNG CD_MPPNG, #$IDSOwner#.CD_MPPNG CD_MPPNG2 WHERE R.SRC_SYS_CD_SK = CLMCHK.SRC_SYS_CD_SK 
and R.CLM_ID = CLMCHK.CLM_ID 
and CD_MPPNG.TRGT_CD = 'PCA'
and CLMCHK.CHK_PD_DT_SK = DT.CLNDR_DT_SK and
CLMCHK.CLM_CHK_LOB_CD_SK = CD_MPPNG.CD_MPPNG_SK and CLMCHK.CLM_CHK_PAYMT_METH_CD_SK = CD_MPPNG2.CD_MPPNG_SK;
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "AFTERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTAFTERSQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "GENSQL"
         Value "Yes"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "TABLE"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR DRVR, #$IDSOwner#.CLM CLM, #$IDSOwner#.CLM_CHK CLMCHK, #$IDSOwner#.CLNDR_DT DT, #$IDSOwner#.CD_MPPNG CD_MPPNG, #$IDSOwner#.CD_MPPNG CD_MPPNG2, #$IDSOwner#.CD_MPPNG CD_MPPNG3"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "XMLProperties"
         Value =+=+=+=
