   BEGIN DSRECORD
      Identifier "V0S39P31"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "mbr"
      Partner "V0S40|V0S40P57"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.MBR MBR,#$IDSOwner#.CD_MPPNG CD_MPPNG,#$IDSOwner#.CD_MPPNG CD_MPPNG2"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
MBR.MBR_GNDR_CD_SK=CD_MPPNG.CD_MPPNG_SK and
MBR.MBR_RELSHP_CD_SK=CD_MPPNG2.CD_MPPNG_SK
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SQLBUILDERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT MBR.MBR_SK,MBR.BRTH_DT_SK,CD_MPPNG.TRGT_CD,CD_MPPNG.TRGT_CD_NM,CD_MPPNG2.TRGT_CD 

FROM  #$IDSOwner#.MBR MBR,
            #$IDSOwner#.CD_MPPNG CD_MPPNG,
            #$IDSOwner#.CD_MPPNG CD_MPPNG2, 
            #$IDSOwner#.W_WEBDM_ETL_DRVR R,
            #$IDSOwner#.CLM CLM

WHERE MBR.MBR_GNDR_CD_SK=CD_MPPNG.CD_MPPNG_SK 
      AND MBR.MBR_RELSHP_CD_SK=CD_MPPNG2.CD_MPPNG_SK
      AND R.SRC_SYS_CD_SK = CLM.SRC_SYS_CD_SK  
      AND R.CLM_ID = CLM.CLM_ID                                    
      AND CLM.MBR_SK = MBR.MBR_SK                       


=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "AFTERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTAFTERSQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "GENSQL"
         Value "No"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "TABLE"
         Value "#$IDSOwner#.MBR MBR,#$IDSOwner#.CD_MPPNG CD_MPPNG,#$IDSOwner#.CD_MPPNG CD_MPPNG2"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "XMLProperties"
         Value =+=+=+=
