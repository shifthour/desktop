   BEGIN DSRECORD
      Identifier "V0S39P10"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "drug_clm"
      Partner "V0S40|V0S40P20"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.DRUG_CLM CLM,#$IDSOwner#.NDC NDC, #$IDSOwner#.PROV_DEA DEA, #$IDSOwner#.CMN_PRCT PRCT"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
R.SRC_SYS_CD_SK = CLM.SRC_SYS_CD_SK 
and R.CLM_ID = CLM.CLM_ID 
and CLM.NDC_SK = NDC.NDC_SK
and CLM.PRSCRB_PROV_DEA_SK = DEA.PROV_DEA_SK
and DEA.CMN_PRCT_SK = PRCT.CMN_PRCT_SK
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT CLM_SK,NDC,RX_ORIG_QTY,RX_NO,DRUG_LABEL_NM FROM #IDSInstance#.CLM_ID_EXTR R,#IDSInstance#.DRUG_CLM CLM,#IDSInstance#.NDC NDC WHERE R.CLM_SK = CLM.CLM_SK
and R.DEST_CD = '#dest#'
and R.EXTR_CD = '#extr#'
and R.CLM_CAT_CD = '#clm_cat#'
and R.CLM_SK = CLM.CLM_SK
 and CLM.NDC_SK = NDC.NDC_SK;
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "AFTERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTAFTERSQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "GENSQL"
         Value "Yes"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "TABLE"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.DRUG_CLM CLM,#$IDSOwner#.NDC NDC, #$IDSOwner#.PROV_DEA DEA, #$IDSOwner#.CMN_PRCT PRCT"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "XMLProperties"
         Value =+=+=+=
<?xml version='1.0' encoding='UTF-16'?><Properties version='1.1'><Common><Context type='int'><![CDATA[1]]></Context><Variant type='string'><![CDATA[9.1]]></Variant><PartitionType type='int'><![CDATA[-1]]></PartitionType><DescriptorVersion type='string'><![CDATA[1.0]]></DescriptorVersion><RCP type='int'><![CDATA[0]]></RCP></Common><Usage><WriteMode type='int'><![CDATA[0]]></WriteMode><PrefixForExpressionColumns type='string'><![CDATA[EXPR]]></PrefixForExpressionColumns><TableAction type='int'><![CDATA[0]]></TableAction><BeforeAfter type='bool'><![CDATA[false]]><before type='string'><![CDATA[]]><FailOnError type='bool'><![CDATA[false]]></FailOnError></before><after type='string'><![CDATA[]]><FailOnError type='bool'><![CDATA[false]]></FailOnError></after></BeforeAfter><Session><SchemaReconciliation><FailOnSizeMismatch type='bool'><![CDATA[false]]></FailOnSizeMismatch><FailOnTypeMismatch type='bool'><![CDATA[false]]></FailOnTypeMismatch><FailOnCodePageMismatch type='bool'><![CDATA[false]]></FailOnCodePageMismatch></SchemaReconciliation><ArraySize type='int'><![CDATA[10000]]></ArraySize></Session><MigratedJob type='bool'><![CDATA[true]]></MigratedJob><Transaction><RecordCount type='int'><![CDATA[0]]></RecordCount></Transaction><TableName type='string'><![CDATA[#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.DRUG_CLM CLM,#$IDSOwner#.NDC NDC, #$IDSOwner#.PROV_DEA DEA, #$IDSOwner#.CMN_PRCT PRCT]]></TableName><SQL><SelectStatement type='string'><![CDATA[SELECT CLM.CLM_SK as CLM_SK,NDC as NDC,RX_SUBMT_QTY,RX_NO as RX_NO,DRUG_LABEL_NM as DRUG_LABEL_NM,CMN_PRCT_ID as CMN_PRCT_ID,FIRST_NM as FIRST_NM,LAST_NM as LAST_NM,MBR_DIFF_PD_AMT,RX_ALW_QTY,PROV_NM FROM #$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.DRUG_CLM CLM,#$IDSOwner#.NDC NDC, #$IDSOwner#.PROV_DEA DEA, #$IDSOwner#.CMN_PRCT PRCT WHERE R.SRC_SYS_CD_SK = CLM.SRC_SYS_CD_SK 
and R.CLM_ID = CLM.CLM_ID 
and CLM.NDC_SK = NDC.NDC_SK
and CLM.PRSCRB_PROV_DEA_SK = DEA.PROV_DEA_SK
and DEA.CMN_PRCT_SK = PRCT.CMN_PRCT_SK]]><WhereClause type='string'><![CDATA[R.SRC_SYS_CD_SK = CLM.SRC_SYS_CD_SK 
and R.CLM_ID = CLM.CLM_ID 
and CLM.NDC_SK = NDC.NDC_SK
and CLM.PRSCRB_PROV_DEA_SK = DEA.PROV_DEA_SK
and DEA.CMN_PRCT_SK = PRCT.CMN_PRCT_SK]]></WhereClause></SelectStatement></SQL></Usage></Properties>
=+=+=+=
      END DSSUBRECORD
