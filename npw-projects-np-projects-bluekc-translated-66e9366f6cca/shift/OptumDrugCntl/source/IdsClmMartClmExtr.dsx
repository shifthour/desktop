e><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property><Property default=\"1\" description=\"This option specifies the abnormal termination disposition of the dataset(s) used by the LOAD utility.\" label=\"Abnormal termination\" name=\"AbnormalTermination\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property></Property><Property default=\"0\" description=\"Specifies the z/OS disk space allocation unit type\" label=\"Space type\" name=\"SpaceType\" required=\"false\" type=\"int\"><Value code=\"0\">Cylinders</Value><Value code=\"1\">Tracks</Value></Property><Property description=\"Specifies the z/OS disk primary space allocation parameters in the range from 1 to 1677215.\" label=\"Primary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"PrimaryAllocation\" required=\"false\" type=\"int\"/><Property description=\"Specifies the z/OS disk secondary space allocation parameters in the range from 1 to 1677215.\" label=\"Secondary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"SecondaryAllocation\" required=\"false\" type=\"int\"/></Property></Property></Property><Property contexts=\"target\" description=\"Specifies the properties that control the bulk load operations.\" label=\"Load control\" name=\"LoadControl\" required=\"false\" transactionModels=\"local\" type=\"category\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">6</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadToZOS\">false</FilterProperty></Filter><Property default=\"0\" description=\"Specifies the mode where the load operates.\" filterProperty=\"/Usage/TableAction\" filterValue=\"0\" label=\"Load mode\" name=\"LoadMode\" required=\"false\" type=\"int\"><Value code=\"0\">Insert</Value><Value code=\"1\">Replace</Value><Value code=\"2\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Restart</Value><Value code=\"3\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Terminate</Value></Property><Property default=\"0\" description=\"Specifies which DB2 load phase is to be restarted. The original input data needs to be reproduced for restarting the Load phase. Build and Delete phases ignore the input data.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"2\" label=\"Restart phase\" name=\"RestartPhase\" required=\"false\" type=\"int\"><Value code=\"0\">Load</Value><Value code=\"1\">Build</Value><Value code=\"2\">Delete</Value></Property><Property default=\"false\" description=\"Indicates whether there are any LOB or XML columns in the target DB2 table.\" label=\"Bulk load with LOB or XML column(s)\" name=\"BulkloadWithLobXML\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"Determines the load method to use.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load method\" name=\"LoadMethod\" required=\"false\" type=\"int\"><Value code=\"0\">Sequential File(s)</Value><Value code=\"1\">Named Pipe(s)</Value></Property><Property description=\"Name of tables where rows that violate constraints will be stored.\" label=\"Exception table name\" maxLength=\"512\" minLength=\"1\" name=\"ExceptionTable\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction\">0 3</FilterProperty></Filter></Property><Property default=\"90\" description=\"Specifies the time in seconds to attempt opening a socket for the load operation before timing out.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load timeout\" minValue=\"0\" name=\"LoadTimeout\" required=\"false\" type=\"int\"/><Property default=\"false\" description=\"Indicates whether input files should be created without executing the load operation.\" label=\"File(s) only\" name=\"FilesOnly\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property description=\"Specifies the location where the command file and data file (used by the load operation) should be created.\" label=\"Directory for data and command files\" maxLength=\"512\" minLength=\"1\" name=\"DataFilePath\" required=\"true\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"true\" description=\"Select Yes to remove the intermediate data file after completing the load operation.\" filterProperty=\"/Usage/LoadControl/FilesOnly\" filterValue=\"false\" label=\"Remove intermediate data file\" name=\"RemoveIntermediateDataFile\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the format of the data in the data file.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type\" name=\"FileType\" required=\"false\" type=\"int\"><Value code=\"0\">ASC</Value><Value code=\"1\">DEL</Value></Property><Property description=\"A list of fully qualified paths or devices to identify the location of the individual LOB files to be loaded.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Lob Path List\" maxLength=\"512\" minLength=\"1\" name=\"LobPathList\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Select Yes to add the WITHOUT PROMPTING parameter to the LOAD command in the generated command file.\" label=\"Without pro