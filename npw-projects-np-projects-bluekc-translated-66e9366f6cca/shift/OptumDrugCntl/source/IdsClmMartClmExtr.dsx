$IDSOwner#.CD_MPPNG CD_MPPNG2, #$IDSOwner#.CD_MPPNG CD_MPPNG3 WHERE CLM.CLM_SK = CLMCHK.CLM_SK and 
CLMCHK.PCA_CHK_IN = 'Y' and 
DRVR.CLM_ID = CLM.CLM_ID AND 
