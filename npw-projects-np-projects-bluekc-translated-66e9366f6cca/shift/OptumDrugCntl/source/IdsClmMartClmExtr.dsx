   BEGIN DSRECORD
      Identifier "V0S39P26"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "billSvcGrp"
      Partner "V0S284|V0S284P2"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.W_WEBDM_ETL_DRVR R,#$IDSOwner#.CLM_PROV V,#$IDSOwner#.CD_MPPNG NG1,#$IDSOwner#.PROV PROV,#$IDSOwner#.PROV_BILL_SVC_ASSOC ASSOC,#$IDSOwner#.CLM CLM"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
R.SRC_SYS_CD_SK = V.SRC_SYS_CD_SK 
and R.CLM_ID = V.CLM_ID
and V.CLM_PROV_ROLE_TYP_CD_SK = NG1.CD_MPPNG_SK
 
and NG1.TRGT_CD = 'PD'
and V.PROV_SK = PROV.PROV_SK

 
and REL_GRP_PROV_SK = ASSOC.PROV_SK
and SVC_STRT_DT_SK between ASSOC.EFF_DT_SK and ASSOC.END_DT_SK
and CLM.SRC_SYS_CD_SK = R.SRC_SYS_CD_SK
and CLM.CLM_ID = R.CLM_ID

=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT CLM.CLM_SK, PROV_BILL_SVC_ID, NG1.TRGT_CD

FROM #$IDSOwner#.W_WEBDM_ETL_DRVR R,
           #$IDSOwner#.CLM_PROV V,
           #$IDSOwner#.CD_MPPNG NG1,
           #$IDSOwner#.PROV PROV,
           #$IDSOwner#.PROV_BILL_SVC_ASSOC ASSOC,
           #$IDSOwner#.CLM CLM 

WHERE R.SRC_SYS_CD_SK = V.SRC_SYS_CD_SK 
      AND R.CLM_ID = V.CLM_ID
      AND V.CLM_PROV_ROLE_TYP_CD_SK = NG1.CD_MPPNG_SK
      AND V.PROV_SK = PROV.PROV_SK
      AND PROV.REL_GRP_PROV_SK = ASSOC.PROV_SK
      AND CLM.SVC_STRT_DT_SK between ASSOC.EFF_DT_SK and ASSOC.END_DT_SK
      AND CLM.SRC_SYS_CD_SK = R.SRC_SYS_CD_SK
      AND CLM.CLM_ID = R.CLM_ID
;
=+=+=+=
      END DSSUBRECORD
