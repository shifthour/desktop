         Name "where"
         Value =+=+=+=
\(2)\(2)0\(1)\(3)where\(2)SRC_SYS_CD =  '#SrcSysCd#'  AND
SRC_CLCTN_CD = '#SrcSysCd#'  AND
SRC_DOMAIN_NM = 'MEDIA TYPE' AND
TRGT_CLCTN_CD = 'IDS'  AND
TRGT_DOMAIN_NM = 'MEDIA TYPE'\(2)0\(1)\(3)\(3)target\(2)0\(2)0\(1)\(3)where\(2)SRC_SYS_CD = '#SrcSysCd#' AND
SRC_CLCTN_CD = '#SrcSysCd#' AND
SRC_DOMAIN_NM = 'PHARMACY MESSAGE REPONSE TYPE' AND
TRGT_CLCTN_CD = 'IDS'  AND
TRGT_DOMAIN_NM = 'PHARMACY MESSAGE REPONSE TYPE' AND
SRC_CD='R' AND
SRC_CD_NM='REJECT'
\(2)0\(1)\(3)\(3)target\(2)1\(2)0\(1)\(3)where\(2)SRC_SYS_CD = '#SrcSysCd#'  AND
 SRC_CLCTN_CD =  '#SrcSysCd#' 
AND  SRC_DOMAIN_NM = 'PHARMACY TRANSACTION TYPE' 
AND TRGT_CLCTN_CD = 'IDS' AND SRC_CD_NM = 'PHARMACY CLAIM'\(2)0\(1)\(3)\(3)target\(2)2\(2)0\(1)\(3)where\(2)SRC_SYS_CD = '#SrcSysCd#'   AND
SRC_CLCTN_CD = '#SrcSysCd#'   AND 
SRC_DOMAIN_NM = 'PHARMACY RESPONSE REASON'  AND 
TRGT_CLCTN_CD = 'IDS' AND 
TRGT_DOMAIN_NM = 'PHARMACY RESPONSE REASON'\(2)0\(1)\(3)\(3)target\(2)3\(2)0
=+=+=+=
      END DSSUBRECORD
