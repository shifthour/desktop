      msg$ = DSMakeMsg("DSTAGE_JSG_M_0044\\Unhandled failure (%1) encountered executing command %2", x$V962S0:@FM:"cd ")
      msg$id = "@DeniedPkeyFile"; GoTo L$ERROR
