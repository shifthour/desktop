   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0063\\%1 (JOB %2) finished, status=%3[E]", "IdsMbrPdxDeniedClmLoad":@FM:jb$V953S3:@FM:job$V953S3$status))
