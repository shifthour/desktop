   End
   If b$InErrorRef$V953S3 Or (job$V953S3$status <> DSJS.RUNOK And job$V953S3$status <> DSJS.RUNWARN) Then Goto L$V953S3$SKIPPED
   cp$value = Lower(job$V953S3$status)
   cp$value<2> = Lower(job$V953S3$userstatus)
   dummy$ = DSCheckPointSetValue(DSJ.ME, h$V953S3$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0025\\Checkpointed run of job '%1'", jb$V953S3), "@IdsMbrPdxDeniedClmLoad")
**************************************************
L$V953S3$SKIPPED:
   If b$Abandoning Then GoTo L$WAITFORJOB
   GoSub L$V953S0$START
   If b$V953S3skipping Then GoTo L$V953S1$RETURN$1
   GoTo L$WAITFORJOB
**************************************************
L$V0S675$START:
*** Sequencer "Sequencer_675": wait until inputs ready
   seq$V0S675$status = 1
   seq$V0S675$count += 1
   If seq$V0S675$count < 1 Then Return
   seq$V0S675$status = 2
   GoTo L$V0S677$START
L$V0S675$RETURN$1:
   Return
**************************************************
L$V0S677$START:
*** Activity "DeniedClaimsLandingFile": Execute command
   x$V0S677$cp = "x$V0S677"
   If DSCheckPointGetValue(DSJ.ME, x$V0S677$cp, cp$value) = DSJE.NOERROR Then
   x$masked$cmd = "cd "
   x$masked$output = ''
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0023\\Skipped execution of command '%1' on restart", x$masked$cmd), "@DeniedClaimsLandingFile")
      x$V0S677 = Raise(cp$value<1>)
      x$V0S677$output = Raise(cp$value<2>)
      IdV0S677%%Result1%%12 = x$V0S677
      IdV0S677%%Name%%13 = "cd "
      IdV0S677%%Result2%%14 = x$V0S677$output
      summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0062\\%1 (COMMAND %2) skipped", "DeniedClaimsLandingFile":@FM:"cd "))
      Goto L$V0S677$SKIPPED
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0059\\%1 (COMMAND %2) started", "DeniedClaimsLandingFile":@FM:"cd "))
   p$V0S677$1 = ($FilePath:"/verified; mv -f ":SrcSysCd:"_DeniedClaims_Landing.dat.":RunID:"   processed/;    compress -f   processed/":SrcSysCd:"_DeniedClaims_Landing.dat.":RunID:" ")
   x$cmd = "cd ":" ":p$V0S677$1
   x$type = (If System(91) = 1 Then "NT" Else "UNIX")
   Call DSExecute(x$type, x$cmd, x$V0S677$output, x$V0S677)
   x$masked$cmd = x$cmd
   x$masked$output = x$V0S677$output
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0007\\Executed: %1<L>Reply=%2<L>Output from command ====><L>%3", x$masked$cmd:@FM:x$V0S677:@FM:Lower(x$masked$output)), "@DeniedClaimsLandingFile")
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0064\\%1 finished, reply=%2", "DeniedClaimsLandingFile":@FM:x$V0S677))
   IdV0S677%%Result1%%12 = x$V0S677
   IdV0S677%%Name%%13 = "cd "
   IdV0S677%%Result2%%14 = x$V0S677$output
   If x$V0S677 <> 0 Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0043\\Command %1 did not finish OK, reply = '%2'", "cd ":@FM:x$V0S677), "@DeniedClaimsLandingFile")
   End
   If (x$V0S677 <> 0) Then
      err$source = "DeniedClaimsLandingFile"; err$number = 1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0044\\Unhandled failure (%1) encountered executing command %2", x$V0S677:@FM:"cd ")
      msg$id = "@DeniedClaimsLandingFile"; GoTo L$ERROR
   End
   x$masked$cmd = "cd "
   x$masked$output = ''
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
   If b$InErrorRef Or (x$V0S677 <> 0) Then Goto L$V0S677$SKIPPED
   cp$value = Lower(x$V0S677)
   cp$value<2> = Lower(x$V0S677$output)
   dummy$ = DSCheckPointSetValue(DSJ.ME, x$V0S677$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0027\\Checkpointed execution of command '%1'", x$masked$cmd), "@DeniedClaimsLandingFile")
**************************************************
L$V0S677$SKIPPED:
   GoTo L$V962S0$START
L$V0S677$RETURN$1:
   GoTo L$V0S675$RETURN$1
**************************************************
L$V962S0$START:
*** Activity "DeniedPkeyFile": Execute command
   x$V962S0$cp = "x$V962S0"
   If DSCheckPointGetValue(DSJ.ME, x$V962S0$cp, cp$value) = DSJE.NOERROR Then
   x$masked$cmd = "cd "
   x$masked$output = ''
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0023\\Skipped execution of command '%1' on restart", x$masked$cmd), "@DeniedPkeyFile")
      x$V962S0 = Raise(cp$value<1>)
