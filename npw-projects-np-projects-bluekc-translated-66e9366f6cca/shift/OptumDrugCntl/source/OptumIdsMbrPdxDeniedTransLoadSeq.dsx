      IdV962S0%%Result1%%15 = x$V962S0
      IdV962S0%%Name%%16 = "cd "
      IdV962S0%%Result2%%17 = x$V962S0$output
      summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0062\\%1 (COMMAND %2) skipped", "DeniedPkeyFile":@FM:"cd "))
      Goto L$V962S0$SKIPPED
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0059\\%1 (COMMAND %2) started", "DeniedPkeyFile":@FM:"cd "))
   p$V962S0$1 = ($FilePath:"/key/; mv -f MBR_PDX_DENIED_TRANS.":SrcSysCd:".pkey.":RunID:".dat processed/; compress -f   processed/MBR_PDX_DENIED_TRANS.":SrcSysCd:".pkey.":RunID:".dat")
   x$cmd = "cd ":" ":p$V962S0$1
   x$type = (If System(91) = 1 Then "NT" Else "UNIX")
   Call DSExecute(x$type, x$cmd, x$V962S0$output, x$V962S0)
   x$masked$cmd = x$cmd
   x$masked$output = x$V962S0$output
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0007\\Executed: %1<L>Reply=%2<L>Output from command ====><L>%3", x$masked$cmd:@FM:x$V962S0:@FM:Lower(x$masked$output)), "@DeniedPkeyFile")
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0064\\%1 finished, reply=%2", "DeniedPkeyFile":@FM:x$V962S0))
   IdV962S0%%Result1%%15 = x$V962S0
   IdV962S0%%Name%%16 = "cd "
   IdV962S0%%Result2%%17 = x$V962S0$output
   If x$V962S0 <> 0 Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0043\\Command %1 did not finish OK, reply = '%2'", "cd ":@FM:x$V962S0), "@DeniedPkeyFile")
   End
   If (x$V962S0 <> 0) Then
