      x$V971S0$output = Raise(cp$value<2>)
      IdV971S0%%Result1%%155 = x$V971S0
      IdV971S0%%Name%%156 = "cd  "
      IdV971S0%%Result2%%157 = x$V971S0$output
      summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0062\\%1 (COMMAND %2) skipped", "MvClmLandExtr":@FM:"cd  "))
      Goto L$V971S0$SKIPPED
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0059\\%1 (COMMAND %2) started", "MvClmLandExtr":@FM:"cd  "))
   p$V971S0$1 = ($FilePath:"/verified; mv -f PDX_CLM_STD_INPT_Land_":IdV184S11%%UserVar%%4:".dat.":IdV604S0%%UserVar%%16:"   processed/;    compress -f   processed/PDX_CLM_STD_INPT_Land_":IdV184S11%%UserVar%%4:".dat.":IdV604S0%%UserVar%%16)
   x$cmd = "cd  ":" ":p$V971S0$1
   x$type = (If System(91) = 1 Then "NT" Else "UNIX")
   Call DSExecute(x$type, x$cmd, x$V971S0$output, x$V971S0)
   x$masked$cmd = x$cmd
   x$masked$output = x$V971S0$output
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0007\\Executed: %1<L>Reply=%2<L>Output from command ====><L>%3", x$masked$cmd:@FM:x$V971S0:@FM:Lower(x$masked$output)), "@MvClmLandExtr")
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0064\\%1 finished, reply=%2", "MvClmLandExtr":@FM:x$V971S0))
   IdV971S0%%Result1%%155 = x$V971S0
   IdV971S0%%Name%%156 = "cd  "
   IdV971S0%%Result2%%157 = x$V971S0$output
   If x$V971S0 <> 0 Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0043\\Command %1 did not finish OK, reply = '%2'", "cd  ":@FM:x$V971S0), "@MvClmLandExtr")
   End
   If (x$V971S0 <> 0) Then
      err$source = "MvClmLandExtr"; err$number = 1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0044\\Unhandled failure (%1) encountered executing command %2", x$V971S0:@FM:"cd  ")
      msg$id = "@MvClmLandExtr"; GoTo L$ERROR
   End
   x$masked$cmd = "cd  "
   x$masked$output = ''
   Call DSMaskExecArgs(x$masked$cmd, x$masked$output)
   If b$InErrorRef Or (x$V971S0 <> 0) Then Goto L$V971S0$SKIPPED
   cp$value = Lower(x$V971S0)
   cp$value<2> = Lower(x$V971S0$output)
   dummy$ = DSCheckPointSetValue(DSJ.ME, x$V971S0$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0027\\Checkpointed execution of command '%1'", x$masked$cmd), "@MvClmLandExtr")
**************************************************
L$V971S0$SKIPPED:
   GoTo L$V970S6$RETURN$1
**************************************************
L$WAITFORJOB:
   If handle$list = "" Then GoTo L$FINISH
   handle$ = DSWaitForJob(handle$list)
   If handle$ = 0 Then handle$ = handle$list<1>
   Locate handle$ In handle$list Setting index$ Then
      id$ = id$list<index$>
      Del id$list<index$>; Del handle$list<index$>
      b$Abandoning = abort$list<index$>; Del abort$list<index$>
      loop$context = context$list<index$>; Del context$list<index$>
      Del jobnames$list<index$>
      Begin Case
      Case id$ = "V184S0"
         GoTo L$V184S0$FINISHED
      Case id$ = "V254S7"
         GoTo L$V254S7$FINISHED
      Case id$ = "V254S11"
         GoTo L$V254S11$FINISHED
      Case id$ = "V0S109"
         GoTo L$V0S109$FINISHED
      Case id$ = "V603S3"
         GoTo L$V603S3$FINISHED
      Case id$ = "V603S5"
         GoTo L$V603S5$FINISHED
      Case id$ = "V0S217"
         GoTo L$V0S217$FINISHED
      Case id$ = "V0S223"
         GoTo L$V0S223$FINISHED
      Case id$ = "V618S4"
         GoTo L$V618S4$FINISHED
      Case id$ = "V618S6"
         GoTo L$V618S6$FINISHED
      Case id$ = "V618S7"
         GoTo L$V618S7$FINISHED
      Case id$ = "V628S2"
         GoTo L$V628S2$FINISHED
      Case id$ = "V643S4"
         GoTo L$V643S4$FINISHED
      Case id$ = "V663S2"
         GoTo L$V663S2$FINISHED
      Case id$ = "V970S1"
         GoTo L$V970S1$FINISHED
      End Case
   End
* Error if fall though
   handle$list = ""
   err$source = "@Coordinator"; err$number = -1
   msg$ = DSMakeMsg("DSTAGE_JSG_M_0008\\Error calling DSWaitForJob(), code=%1[E]", handle$)
   msg$id = "@Coordinator"; GoTo L$ERROR
**************************************************
L$ERROR:
   Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0009\\Controller problem: %1", msg$), msg$id)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0052\\Exception raised: %1", msg$id:", ":msg$))
   If Not(b$InErrorRef) Then
      dummy$ = DSCheckPointSetValue(DSJ.ME, "!", DSMakeMsg("DSTAGE_JSG_M_0031\\Failed at: %1, Reason=%2", err$source:@FM:msg$))
   End
   abort$list = Ifs(handle$list, Str(1:@FM, DCount(handle$list, @FM)), "")
   b$Abandoning = @True
   GoTo L$WAITFORJOB
L$ABORT:
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0055\\Sequence failed (restartable)", ""))
   x$masked$summary = summary$
   Call DSMaskExecArgs(x$masked$summary, '')
   Call DSLogInfo(x$masked$summary, "@Coordinator")
   Call DSLogFatal(DSMakeMsg("DSTAGE_JSG_M_0014\\Sequence job (restartable) will abort due to previous unrecoverable errors", ""), "@Coordinator")
**************************************************
L$FINISH:
   If b$Abandoning Then GoTo L$ABORT
*** At successful exit remove checkpoint record
   If Not(b$InErrorRef) And DSCheckPointExists(DSJ.ME, cp$dtm) Then
      dummy$ = DSCheckPointDelete(DSJ.ME)
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0018\\Removed checkpoint record at successful completion of sequence", ""), "@Coordinator")
   End
   If (seq$V63S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_2A"), "@Coordinator")
   End
   If (seq$V65S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_1B"), "@Coordinator")
   End
   If (seq$V184S4$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any1"), "@Coordinator")
   End
   If (seq$V184S5$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any2"), "@Coordinator")
   End
   If (seq$V254S1$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_3A"), "@Coordinator")
   End
   If (seq$V254S13$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "If_4B"), "@Coordinator")
   End
   If (seq$V0S148$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any5"), "@Coordinator")
   End
   If (seq$V0S149$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any6"), "@Coordinator")
   End
   If loop$V0S151$entered And Not(loop$V0S151$done) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0075\\Note: Loop '%1' was started, but did not complete all its iterations", "StartLoop"), "@Coordinator")
   End
   If (seq$V0S169$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any8"), "@Coordinator")
   End
   If (seq$V618S1$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_5C"), "@Coordinator")
   End
   If (seq$V618S8$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_5B"), "@Coordinator")
   End
   If (seq$V618S9$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_5A"), "@Coordinator")
   End
   If (seq$V628S3$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Any9"), "@Coordinator")
   End
   If (seq$V631S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop1"), "@Coordinator")
   End
   If (seq$V632S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop2"), "@Coordinator")
   End
   If (seq$V636S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop10"), "@Coordinator")
   End
   If (seq$V637S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop11"), "@Coordinator")
   End
   If (seq$V639S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop15"), "@Coordinator")
   End
   If (seq$V640S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Loop14"), "@Coordinator")
   End
   If (seq$V643S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_1C"), "@Coordinator")
   End
   If (seq$V663S4$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_11A"), "@Coordinator")
   End
   If (seq$V970S2$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_5D"), "@Coordinator")
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0054\\Sequence finished OK", ""))
   x$masked$summary = summary$
   Call DSMaskExecArgs(x$masked$summary, '')
   Call DSLogInfo(x$masked$summary, "@Coordinator")
   L$EXIT: Return To L$EXIT
 

