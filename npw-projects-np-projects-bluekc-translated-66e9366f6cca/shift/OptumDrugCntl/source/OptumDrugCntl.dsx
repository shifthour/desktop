   loop$V0S151 = 0
   loop$V0S151$sep = Char(0)
   loop$V0S151$list = EReplace(IdV0S132%%UserVar%%13, ",", loop$V0S151$sep)
   loop$V0S151$final = DCount(loop$V0S151$list, loop$V0S151$sep)
   If (loop$V0S151$sep = '') Then
      err$source = "StartLoop"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0033\\Loop specifies empty list separator - cannot execute", "")
      msg$id = "@StartLoop"; GoTo L$ERROR
   End
