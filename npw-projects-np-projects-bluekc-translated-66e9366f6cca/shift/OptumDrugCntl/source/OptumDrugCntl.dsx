      err$source = "StartLoop"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0034\\Loop specifies empty iteration list - cannot execute", "")
      msg$id = "@StartLoop"; GoTo L$ERROR
   End
   loop$V0S151$entered = @True
   loop$V0S151$done = @False
   loop$V0S151$returned = @False
   loop$V0S156$triggered = @False
   loop$prevcontexts<1> = loop$context
   loop$context = 2
   gosub$stack = 1
**************************************************
L$V0S151$REPEAT:
* Test loop variables to see if repeat needed
   Loop While gosub$stack > 1
      Return To L$V0S151$UNWIND
   L$V0S151$UNWIND:
      gosub$stack -= 1
   Repeat
   loop$V0S151 += 1
   If loop$V0S151 > loop$V0S151$final Then loop$V0S151$done = @True
   If loop$V0S151$done Then GoTo L$V0S156$COMPLETE
