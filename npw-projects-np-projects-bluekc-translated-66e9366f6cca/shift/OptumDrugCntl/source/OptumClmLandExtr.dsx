   BEGIN DSRECORD
      Identifier "V168S5P1"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "MBR"
      Partner "V168S6|V168S6P1"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "PROD.MBR MBR,PROD.SUB SUB,PROD.W_DRUG_ENR DRUG"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value "DRUG.MBR_UNIQ_KEY = MBR.MBR_UNIQ_KEY AND MBR.SUB_SK = SUB.SUB_SK"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SQLBUILDERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "FULLYGENSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT 
       CLM_ID,
       MBR_UNIQ_KEY,
       Order

FROM 

((SELECT 
      DRUG.CLM_ID,
      ENR.MBR_UNIQ_KEY,
      MAX(ENR.TERM_DT_SK) TERM_DT_SK,
      MAX(ENR.EFF_DT_SK) EFF_DT_SK,
      1 as Order
FROM
     PROD.MBR_ENR ENR,
     PROD.CD_MPPNG CD1,
     PROD.W_DRUG_ENR_MATCH DRUG
WHERE
     ENR.MBR_ENR_CLS_PLN_PROD_CAT_CD_SK = CD1.CD_MPPNG_SK AND
     CD1.TRGT_CD IN ('MED', 'MED1') AND
     ENR.ELIG_IN = 'Y' AND
     ENR.MBR_UNIQ_KEY = DRUG.MBR_UNIQ_KEY AND
     ENR.EFF_DT_SK <= DRUG.FILL_DT_SK AND
     ENR.TERM_DT_SK >= DRUG.FILL_DT_SK
GROUP BY
     DRUG.CLM_ID,
     ENR.MBR_UNIQ_KEY )


UNION

(SELECT 
      DRUG.CLM_ID,
      ENR.MBR_UNIQ_KEY,
      MAX(ENR.TERM_DT_SK) TERM_DT_SK,
      MAX(ENR.EFF_DT_SK) EFF_DT_SK,
      2 as Order
FROM
     PROD.MBR_ENR ENR,
     PROD.CD_MPPNG CD1,
     PROD.W_DRUG_ENR_MATCH DRUG
WHERE
     ENR.MBR_ENR_CLS_PLN_PROD_CAT_CD_SK = CD1.CD_MPPNG_SK AND
     CD1.TRGT_CD IN ('MED', 'MED1') AND
     ENR.ELIG_IN = 'Y' AND
     ENR.MBR_UNIQ_KEY = DRUG.MBR_UNIQ_KEY
GROUP BY
     DRUG.CLM_ID,
     ENR.MBR_UNIQ_KEY)

UNION

(SELECT 
      DRUG.CLM_ID,
      ENR.MBR_UNIQ_KEY,
      MAX(ENR.TERM_DT_SK) TERM_DT_SK,
      MAX(ENR.EFF_DT_SK) EFF_DT_SK,
      3 as Order
FROM
     PROD.MBR_ENR ENR,
     PROD.CD_MPPNG CD1,
     PROD.W_DRUG_ENR_MATCH DRUG
WHERE
     ENR.MBR_ENR_CLS_PLN_PROD_CAT_CD_SK = CD1.CD_MPPNG_SK AND
     CD1.TRGT_CD IN ('MED', 'MED1') AND
     ENR.ELIG_IN = 'N' AND
     ENR.MBR_UNIQ_KEY = DRUG.MBR_UNIQ_KEY
GROUP BY
     DRUG.CLM_ID,
     ENR.MBR_UNIQ_KEY))
     
ORDER BY
CLM_ID,
Order,
TERM_DT_SK,
EFF_DT_SK,
MBR_UNIQ_KEY
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
