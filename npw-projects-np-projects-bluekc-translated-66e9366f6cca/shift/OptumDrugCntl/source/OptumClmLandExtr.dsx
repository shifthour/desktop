      BEGIN DSSUBRECORD
         Name "FULL_AVG_WHLSL_PRICE"
         Description "Full AWP (average wholesale price). Format = s9(7)v99"
         SqlType "3"
         Precision "13"
         Scale "2"
         Nullable "1"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If Extract.COMPOUNDCD = 2                                                                                                                                                                                      Then Fix((Extract.USUALNCUST + Extract.CLTDISPFEE + Extract.CLTSLSTAX),2)
Else Fix(((Extract.AWPUNITCST * Extract.DECIMALQTY) + Extract.CLTDISPFEE + Extract.CLTSLSTAX ),2)

 
=+=+=+=
