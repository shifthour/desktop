      BEGIN DSSUBRECORD
         Name "DRUG_TYP"
         Description =+=+=+=
Code to indicate the type of drug dispensed
0=Not Specified
1=Single Source Brand
2=Branded Generic
3=Generic
4=O.T.C. (Medical supplies)
5=M/S Brand	

For code indicating OTC or Federal Legend.
=+=+=+=
         SqlType "2"
         Precision "1"
         Scale "0"
         Nullable "1"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And (Trim(Extract.MULTSRCCDE) = 'M' or Trim(Extract.MULTSRCCDE) ='N')) Then '1'
Else If  ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And Trim(Extract.MULTSRCCDE) = 'Y') Then '3'
Else If  ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And Trim(Extract.MULTSRCCDE) = 'O') Then '5'
Else If (Trim(Extract.GENINDOVER) = 'M' or Trim(Extract.GENINDOVER) ='N') Then '1'
Else If Trim(Extract.GENINDOVER) = 'Y' Then '3'
Else If Trim(Extract.GENINDOVER) = 'O' Then '5'
Else '0'
=+=+=+=
         Group "0"
         ParsedDerivation " If ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And (Trim(Extract.MULTSRCCDE) = 'M' or Trim(Extract.MULTSRCCDE) = 'N')) Then '1' Else  If ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And Trim(Extract.MULTSRCCDE) = 'Y') Then '3' Else  If ((IsNull(Extract.GENINDOVER) = @TRUE or Len(Trim(Extract.GENINDOVER)) = 0) And Trim(Extract.MULTSRCCDE) = 'O') Then '5' Else  If (Trim(Extract.GENINDOVER) = 'M' or Trim(Extract.GENINDOVER) = 'N') Then '1' Else  If Trim(Extract.GENINDOVER) = 'Y' Then '3' Else  If Trim(Extract.GENINDOVER) = 'O' Then '5' Else '0'"
         SourceColumn "Extract.GENINDOVER;Extract.MULTSRCCDE"
         SortKey "0"
         SortType "0"
         TableDef "DB2/UDB\\BCBSKC Common\\PDX_CLM_STD_INPT"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
         SignOption "0"
         SortingOrder "0"
         ArrayHandling "0"
         SyncIndicator "0"
         PadChar ""
         ColumnReference "DRUG_TYP"
         ExtendedPrecision "0"
         TaggedSubrec "0"
         OccursVarying "0"
         PKeyIsCaseless "0"
         SCDPurpose "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PRSCRBR_LAST_NM"
         Description "Prescriber Last Name"
         SqlType "12"
         Precision "75"
         Scale "0"
         Nullable "1"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If Len(Extract.PRESLSTNME) = 0 and Len(Extract.PRESFSTNME) = 0  then 'UNK'
Else If Len(Extract.PRESFSTNME) <> 0 and Len(Extract.PRESLSTNME) = 0 Then Extract.PRESFSTNME
Else If Len(Extract.PRESFSTNME) = 0 and  Len(Extract.PRESLSTNME) <> 0  Then Extract.PRESLSTNME
Else Extract.PRESFSTNME:' ':Extract.PRESLSTNME

=+=+=+=
         Group "0"
         ParsedDerivation " If Len(Extract.PRESLSTNME) = 0 and Len(Extract.PRESFSTNME) = 0 then 'UNK' Else  If Len(Extract.PRESFSTNME) <> 0 and Len(Extract.PRESLSTNME) = 0 Then Extract.PRESFSTNME Else  If Len(Extract.PRESFSTNME) = 0 and Len(Extract.PRESLSTNME) <> 0 Then Extract.PRESLSTNME Else Extract.PRESFSTNME : ' ' : Extract.PRESLSTNME"
         SourceColumn "Extract.PRESLSTNME;Extract.PRESFSTNME"
         SortKey "0"
         SortType "0"
         TableDef "DB2/UDB\\BCBSKC Common\\PDX_CLM_STD_INPT"
