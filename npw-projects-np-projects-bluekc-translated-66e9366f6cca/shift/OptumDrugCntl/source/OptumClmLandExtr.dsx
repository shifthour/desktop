      BEGIN DSSUBRECORD
         Name "PRESCDEAID"
         Description =+=+=+=
The corresponding DEA ID associated with the Submitted Prescriber
ID. The standard DEA ID is 9 characters. However, there is at least
one extra character indicating licensing at the end of the standard DEA
ID.
=+=+=+=
         SqlType "1"
         Precision "15"
         Scale "0"
         Nullable "1"
         KeyPosition "0"
         DisplaySize "0"
         Derivation "If (LEN( Trim( Extract.PRESCRIBER)) <> 0 and trim(Extract.PRESCRIDQL = '12'))  then Extract.PRESCRIBER else if Len(Trim(Extract.PRESCDEAID)) <> 0 then Trim(Extract.PRESCDEAID) else 'NA' "
         Group "0"
         ParsedDerivation " If (LEN(Trim(Extract.PRESCRIBER)) <> 0 and trim(Extract.PRESCRIDQL = '12')) then Extract.PRESCRIBER else  if Len(Trim(Extract.PRESCDEAID)) <> 0 then Trim(Extract.PRESCDEAID) else 'NA'"
         SourceColumn "Extract.PRESCRIBER;Extract.PRESCRIDQL;Extract.PRESCDEAID"
         SortKey "0"
         SortType "0"
         TableDef "Saved\\verified\\PDX_CLM_STD_INPT_Land_Denied_update"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
         SignOption "0"
         SortingOrder "0"
         ArrayHandling "0"
         SyncIndicator "0"
         PadChar ""
         ColumnReference "PRESCDEAID"
         ExtendedPrecision "0"
         TaggedSubrec "0"
         OccursVarying "0"
         PKeyIsCaseless "0"
         SCDPurpose "0"
      END DSSUBRECORD
