   BEGIN DSRECORD
      Identifier "V168S12"
      OLEType "CTransformerStage"
      Readonly "0"
      Name "MapToAllDownstreamCommonFiles"
      NextID "10"
      InputPins "V168S12P1"
      OutputPins "V168S12P2|V168S12P3|V168S12P4|V168S12P5|V168S12P6|V168S12P7|V168S12P8|V168S12P9"
      ValidationStatus "0"
      StageType "CTransformerStage"
      BlockSize "0"
      StageVars "CStageVar"
      BEGIN DSSUBRECORD
         Name "svServicingProviderIDisNABP"
         Expression "If Trim( Extract.SRVPROVIDQ) = '07' then \"Y\" else \"N\""
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If Trim(Extract.SRVPROVIDQ) = '07' then \"Y\" else \"N\""
         SourceColumn "Extract.SRVPROVIDQ"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svServicingProviderIDisNPI"
         Expression "If Trim( Extract.SRVPROVIDQ) = '01'  and ProviderNPIValidator( Extract.SRVPROVID) = 'Y'  then 'Y' ELSE 'N' "
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If Trim(Extract.SRVPROVIDQ) = '01' and ProviderNPIValidator(Extract.SRVPROVID) = 'Y' then 'Y' ELSE 'N'"
         SourceColumn "Extract.SRVPROVIDQ;Extract.SRVPROVID"
         Transform "ProviderNPIValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svServicingProviderNCPDP"
         Expression "If Trim(Extract.PRVNCPDPID) > 0 then 'Y' else 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If Trim(Extract.PRVNCPDPID) > 0 then 'Y' else 'N'"
         SourceColumn "Extract.PRVNCPDPID"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svNPIProvhasNPI"
         Expression " if ProviderNPIValidator (Extract.NPIPROV) = 'Y'  then 'Y' ELSE 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " if ProviderNPIValidator(Extract.NPIPROV) = 'Y' then 'Y' ELSE 'N'"
         SourceColumn "Extract.NPIPROV"
         Transform "ProviderNPIValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svPrescribingIDisDEA"
         Expression "If ( trim(Extract.PRESCRIDQL = '12')  AND ProviderDEAValidator( Extract.PRESCRIBER ) = 'Y') then 'Y' else 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If (trim(Extract.PRESCRIDQL = '12') AND ProviderDEAValidator(Extract.PRESCRIBER) = 'Y') then 'Y' else 'N'"
         SourceColumn "Extract.PRESCRIDQL;Extract.PRESCRIBER"
         Transform "ProviderDEAValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svPrescribingIDisNPI"
         Expression "If ( trim(Extract.PRESCRIDQL = '01')  AND  ProviderNPIValidator( Extract.PRESCRIBER ) = 'Y') then 'Y' else 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If (trim(Extract.PRESCRIDQL = '01') AND ProviderNPIValidator(Extract.PRESCRIBER) = 'Y') then 'Y' else 'N'"
         SourceColumn "Extract.PRESCRIDQL;Extract.PRESCRIBER"
         Transform "ProviderNPIValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svPrescribingDEAIDisDEA"
         Expression =+=+=+=
if  ProviderDEAValidator( Extract.PRESCDEAID ) = 'Y'  then 'Y' 
    else 'N'
=+=+=+=
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " if ProviderDEAValidator(Extract.PRESCDEAID) = 'Y' then 'Y' else 'N'"
         SourceColumn "Extract.PRESCDEAID"
         Transform "ProviderDEAValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svNPIPresciberHasNPI"
         Expression " if ProviderNPIValidator (Extract.NPIPRESCR) = 'Y'  then 'Y' ELSE 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " if ProviderNPIValidator(Extract.NPIPRESCR) = 'Y' then 'Y' ELSE 'N'"
         SourceColumn "Extract.NPIPRESCR"
         Transform "ProviderNPIValidator"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svDEAsMatchTest"
         Expression "If   ( svPrescribingIDisDEA = 'Y'  and  svPrescribingDEAIDisDEA = 'Y' and trim(Extract.PRESCRIBER) = trim(Extract.PRESCDEAID))  then 'Y' else 'N'"
         InitialValue "\"N\""
         SqlType "3"
         ParsedExpression " If (svPrescribingIDisDEA = 'Y' and svPrescribingDEAIDisDEA = 'Y' and trim(Extract.PRESCRIBER) = trim(Extract.PRESCDEAID)) then 'Y' else 'N'"
         SourceColumn "Extract.PRESCRIBER;Extract.PRESCDEAID"
         StageVars "svPrescribingIDisDEA;svPrescribingDEAIDisDEA"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svServiceIDToUse"
         Expression "If svServicingProviderIDisNABP = 'Y' then Extract.SRVPROVID else if svServicingProviderNCPDP = 'Y' then Extract.PRVNCPDPID else  \"NA\""
         InitialValue "\"NA\""
         SqlType "3"
         ParsedExpression " If svServicingProviderIDisNABP = 'Y' then Extract.SRVPROVID else  if svServicingProviderNCPDP = 'Y' then Extract.PRVNCPDPID else \"NA\""
         SourceColumn "Extract.SRVPROVID;Extract.PRVNCPDPID"
         StageVars "svServicingProviderIDisNABP;svServicingProviderNCPDP"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svServiceNPIToUse"
         Expression "if svServicingProviderIDisNPI = 'Y' then tRIM(Extract.SRVPROVID)  else if svNPIProvhasNPI = 'Y' then Trim(Extract.NPIPROV)  else \"NA\""
         InitialValue "\"NA\""
         SqlType "3"
         ParsedExpression " if svServicingProviderIDisNPI = 'Y' then tRIM(Extract.SRVPROVID) else  if svNPIProvhasNPI = 'Y' then Trim(Extract.NPIPROV) else \"NA\""
         SourceColumn "Extract.SRVPROVID;Extract.NPIPROV"
         StageVars "svServicingProviderIDisNPI;svNPIProvhasNPI"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svPrescriberDEAtoUse"
         Expression "If svPrescribingIDisDEA = 'Y' then Trim(Extract.PRESCRIBER) else if svPrescribingDEAIDisDEA = 'Y' then Trim(Extract.PRESCDEAID) else  \"NA\""
         InitialValue "\"NA\""
         SqlType "3"
         ParsedExpression " If svPrescribingIDisDEA = 'Y' then Trim(Extract.PRESCRIBER) else  if svPrescribingDEAIDisDEA = 'Y' then Trim(Extract.PRESCDEAID) else \"NA\""
         SourceColumn "Extract.PRESCRIBER;Extract.PRESCDEAID"
         StageVars "svPrescribingIDisDEA;svPrescribingDEAIDisDEA"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svPrescriberNPItoUse"
         Expression "If svPrescribingIDisNPI = 'Y' then Trim(Extract.PRESCRIBER) else if svNPIPresciberHasNPI = 'Y' then Trim(Extract.NPIPRESCR)  else \"NA\""
         InitialValue "\"NA\""
         SqlType "3"
         ParsedExpression " If svPrescribingIDisNPI = 'Y' then Trim(Extract.PRESCRIBER) else  if svNPIPresciberHasNPI = 'Y' then Trim(Extract.NPIPRESCR) else \"NA\""
         SourceColumn "Extract.PRESCRIBER;Extract.NPIPRESCR"
         StageVars "svPrescribingIDisNPI;svNPIPresciberHasNPI"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
