      BEGIN DSSUBRECORD
         Name "svServicingProvID"
         Expression =+=+=+=
If IsNull(Extract.PDX_NO) = @FALSE then Extract.PDX_NO else 
If IsNull(natln_prov.NTNL_PROV_ID) = @FALSE then natln_prov.PROV_ID else 'UNK'

=+=+=+=
         SqlType "3"
         ParsedExpression " If IsNull(Extract.PDX_NO) = @FALSE then Extract.PDX_NO else  If IsNull(natln_prov.NTNL_PROV_ID) = @FALSE then natln_prov.PROV_ID else 'UNK'"
         SourceColumn "Extract.PDX_NO;natln_prov.NTNL_PROV_ID;natln_prov.PROV_ID"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svAllowedAmt"
         Expression "If Trim(Extract.CLNT_GNRL_PRPS_AREA[61,2])   <> '01' Then ( ((Extract.SLS_TAX_AMT + Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT))  - Extract.OTHR_PAYOR_AMT )  Else  (Extract.INGR_CST_AMT  + Extract.DISPNS_FEE_AMT  + Extract.SLS_TAX_AMT)"
         SqlType "3"
         ParsedExpression " If Trim(Extract.CLNT_GNRL_PRPS_AREA[61, 2]) <> '01' Then (((Extract.SLS_TAX_AMT + Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT)) - Extract.OTHR_PAYOR_AMT) Else (Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT + Extract.SLS_TAX_AMT)"
         SourceColumn "Extract.CLNT_GNRL_PRPS_AREA;Extract.SLS_TAX_AMT;Extract.INGR_CST_AMT;Extract.DISPNS_FEE_AMT;Extract.OTHR_PAYOR_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svChrgAmt"
         Expression "If Extract.SRC_SYS_CD =  'OPTUMRX' Then Extract.FULL_AVG_WHLSL_PRICE  Else If Extract.SRC_SYS_CD = 'MEDIMPACT' Then Extract.CLM_AMT Else 0.00"
         SqlType "3"
         ParsedExpression " If Extract.SRC_SYS_CD = 'OPTUMRX' Then Extract.FULL_AVG_WHLSL_PRICE Else  If Extract.SRC_SYS_CD = 'MEDIMPACT' Then Extract.CLM_AMT Else 0.00"
         SourceColumn "Extract.SRC_SYS_CD;Extract.FULL_AVG_WHLSL_PRICE;Extract.CLM_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svCnsdChrgAmt"
         Expression "If Extract.SRC_SYS_CD =  'OPTUMRX' Then Extract.FULL_AVG_WHLSL_PRICE Else If Extract.SRC_SYS_CD = 'MEDIMPACT' Then Extract.CLM_AMT Else 0.00"
         SqlType "3"
         ParsedExpression " If Extract.SRC_SYS_CD = 'OPTUMRX' Then Extract.FULL_AVG_WHLSL_PRICE Else  If Extract.SRC_SYS_CD = 'MEDIMPACT' Then Extract.CLM_AMT Else 0.00"
         SourceColumn "Extract.SRC_SYS_CD;Extract.FULL_AVG_WHLSL_PRICE;Extract.CLM_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svNdc"
         Expression " If IsNull(Trim(Extract.NDC)) = @True Then 'UNK' Else Extract.NDC"
         SqlType "3"
         ParsedExpression " If IsNull(Trim(Extract.NDC)) = @True Then 'UNK' Else Extract.NDC"
         SourceColumn "Extract.NDC"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svCoinsAmt"
         Expression "If Extract.SRC_SYS_CD =  'OPTUMRX' Then Extract.COPAY_PCT_AMT Else 0.00"
         SqlType "3"
         ParsedExpression " If Extract.SRC_SYS_CD = 'OPTUMRX' Then Extract.COPAY_PCT_AMT Else 0.00"
         SourceColumn "Extract.SRC_SYS_CD;Extract.COPAY_PCT_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svMIAllowedAmt"
         Expression "If Extract.OTHR_COV_CD = '2' Then  (Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT + Extract.SLS_TAX_AMT) - Extract.OTHR_PAYOR_AMT Else Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT + Extract.SLS_TAX_AMT"
         SqlType "3"
         ParsedExpression " If Extract.OTHR_COV_CD = '2' Then (Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT + Extract.SLS_TAX_AMT) - Extract.OTHR_PAYOR_AMT Else Extract.INGR_CST_AMT + Extract.DISPNS_FEE_AMT + Extract.SLS_TAX_AMT"
         SourceColumn "Extract.OTHR_COV_CD;Extract.INGR_CST_AMT;Extract.DISPNS_FEE_AMT;Extract.SLS_TAX_AMT;Extract.OTHR_PAYOR_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      StageVarsMinimised "0"
      LoopVarsMaximised "0"
      MaxLoopIterations "0"
   END DSRECORD
