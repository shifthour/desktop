tList\" calloutDescription=\"Lists the detected databases. The value for the Instance property does not affect the databases that are detected. The list includes only the databases for the currently configured, active DB2 instance in the DB2 Connector environment.\" calloutLabel=\"Database\" calloutType=\"enumerator\" description=\"Specifies the name of the database/location to connect to.\" label=\"Database/Location\" maxLength=\"256\" minLength=\"1\" name=\"Database\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">Databases</CalloutArgument></Property><Property description=\"Specifies the user name to use for connecting to the database.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"false\" transactionModels=\"local\" type=\"string\"/><Property description=\"Specifies the password to use for connecting to the database.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"false\" transactionModels=\"local\" type=\"protectedstring\"/><Property description=\"Specifies the full path to the DB2 client library file. If not specified, the system default library name for the currently configured DB2 environment is used.\" label=\"DB2 client library file\" maxLength=\"256\" minLength=\"1\" name=\"DB2ClientLibFile\" required=\"false\" transactionModels=\"local\" type=\"string\"/><Property default=\"false\" description=\"Select this option if you want to provide alternate connection settings to use on the conductor node. The stage is configured to run in parallel mode.\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" label=\"Alternate conductor settings\" name=\"Conductor\" required=\"false\" type=\"bool\"><Property description=\"Specifies the name of the instance to use as active instance for running parallel jobs and on the conductor node. If not specified, the value of the DB2INSTANCE environment variable on the conductor node is used. You must specify the same value for this property in all of the DB2 Connector stages in the job.\" label=\"Instance\" maxLength=\"256\" minLength=\"1\" name=\"Instance\" required=\"false\" transactionModels=\"local\" type=\"string\"/><Property callout=\"getList\" calloutDescription=\"Lists the detected databases. The value for the Instance property does not affect the databases that are detected. The list includes only the databases for the currently configured, active DB2 instance in the DB2 Connector environment.\" calloutLabel=\"Database\" calloutType=\"enumerator\" description=\"Specifies the name of the database/location to connect to for running parallel jobs and on the conductor node. If not specified, the default database/location for the active instance on the conductor node is used (specified through the DB2DBDFT DB2 registry variable).\" label=\"Database/Location\" maxLength=\"256\" minLength=\"1\" name=\"Database\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">Databases</CalloutArgument></Property><Property description=\"Specifies the user name to use for connecting to the database for running parallel jobs and on the conductor node.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"false\" type=\"string\"/><Property description=\"Specifies the password to use for connecting to the database for running parallel jobs and on the conductor node.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"false\" type=\"protectedstring\"/><Property description=\"Specifies the full path to the DB2 client library file on the conductor node. If not specified, the system default library name for the currently configured DB2 environment is used.\" label=\"DB2 client library file\" maxLength=\"256\" minLength=\"1\" name=\"DB2ClientLibFile\" required=\"false\" transactionModels=\"local\" type=\"string\"/></Property><Property default=\"false\" description=\"Setting this property to Yes causes the connector player processes to use a modified Database name property. Using this property requires advanced configuration of the DB2 client. See the connector documentation for more information.\" engines=\"ee\" label=\"Use direct connections\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UseDirectConnections\" required=\"false\" transactionModels=\"local\" type=\"bool\"/><Property default=\"true\" description=\"Setting this property to No causes the connector conductor process to disconnect from the database while player processes run. The conductor reconnects when the player processes are complete. Setting this property to Yes causes the connector conductor process to remain connected for the duration of the job.\" engines=\"ee\" label=\"Keep conductor connection alive\" maxOccurs=\"1\" minOccurs=\"1\" name=\"KeepConductorConnectionAlive\" required=\"false\" transactionModels=\"local\" type=\"bool\"/></Connection><Usage><Property contexts=\"all\" default=\"false\" description=\"Specifies whether the job has been migrated or not\" hidden=\"true\" label=\"Migrated Job\" maxOccurs=\"1\" minOccurs=\"1\" name=\"MigratedJob\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"0\" description=\"The mode to be used when writing to a database table\" label=\"Write mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"WriteMode\" required=\"true\" type=\"int\"><Value code=\"0\">Insert</Value><Value code=\"8\">Insert new rows only</Value><Value code=\"1\">Update</Value><Value code=\"2\">Delete</Value><Value code=\"3\">Insert then update</Value><Value code=\"4\">Update then insert</Value><Value code=\"5\">Delete then insert</Value><Value code=\"6\" transactionModels=\"local\">Bulk load</Value><Value code=\"7\">User-defined SQL</Value></Property><Property contexts=\"all\" default=\"false\" description=\"Specifies