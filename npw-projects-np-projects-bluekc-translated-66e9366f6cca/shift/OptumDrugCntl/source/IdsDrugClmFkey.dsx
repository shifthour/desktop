      BEGIN DSSUBRECORD
         Name "AdjustedClaim"
         Expression =+=+=+=
iF (
    (Key.CLM_STTUS_CD = '11' and Key.SRC_SYS_CD = 'ARGUS') 
or (Key.CLM_STTUS_CD = '70' and Key.SRC_SYS_CD = 'ARGUS')   
or (Key.CLM_STTUS_CD = 'R' and Key.SRC_SYS_CD = 'ESI') 
or (Key.CLM_STTUS_CD = 'X' and Key.SRC_SYS_CD = 'OPTUMRX') 
or (Key.CLM_STTUS_CD = 'X' and Key.SRC_SYS_CD = 'WELLDYNERX') 
or (Key.CLM_STTUS_CD = 'R' and Key.SRC_SYS_CD = 'MEDTRAK') 
or ((Key.CLM_STTUS_CD = '3' or Key.CLM_STTUS_CD = '4')and Key.SRC_SYS_CD = 'BCBSSC')
) THEN @TRUE else @FALSE

=+=+=+=
         SqlType "3"
         ParsedExpression " iF ((Key.CLM_STTUS_CD = '11' and Key.SRC_SYS_CD = 'ARGUS') or (Key.CLM_STTUS_CD = '70' and Key.SRC_SYS_CD = 'ARGUS') or (Key.CLM_STTUS_CD = 'R' and Key.SRC_SYS_CD = 'ESI') or (Key.CLM_STTUS_CD = 'X' and Key.SRC_SYS_CD = 'OPTUMRX') or (Key.CLM_STTUS_CD = 'X' and Key.SRC_SYS_CD = 'WELLDYNERX') or (Key.CLM_STTUS_CD = 'R' and Key.SRC_SYS_CD = 'MEDTRAK') or ((Key.CLM_STTUS_CD = '3' or Key.CLM_STTUS_CD = '4') and Key.SRC_SYS_CD = 'BCBSSC')) THEN @TRUE else @FALSE"
         SourceColumn "Key.CLM_STTUS_CD;Key.SRC_SYS_CD"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
