         Expression "If (Trim(Key.SRC_SYS_CD) = \"ESI\"  or Trim(Key.SRC_SYS_CD) = \"MEDIMPACT\" OR  Trim(Key.SRC_SYS_CD) = \"WELLDYNERX\" Or Trim(Key.SRC_SYS_CD) = \"MCSOURCE\" Or Trim(Key.SRC_SYS_CD) = \"MCAID\" Or Trim(Key.SRC_SYS_CD) = \"MEDTRAK\" Or Trim(Key.SRC_SYS_CD) = \"BCBSSC\" Or Trim(Key.SRC_SYS_CD) = \"BCA\" Or Trim(Key.SRC_SYS_CD) = \"BCBSA\" Or Trim(Key.SRC_SYS_CD) = \"SAVRX\" Or Trim(Key.SRC_SYS_CD) = \"LDI\" Or Trim(Key.SRC_SYS_CD) = \"CVS\" Or Trim(Key.SRC_SYS_CD)=\"OPTUMRX\")   then GetFkeyCodes (\"FDB\", Key.DRUG_CLM_SK, \"NDC DRUG ABUSE CONTROL\", TRIM( Key.DRUG_CLM_LGL_STTUS_CD), Logging)   else   GetFkeyCodes (Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"DRUG CLAIM LEGAL STATUS\", Key.DRUG_CLM_LGL_STTUS_CD, Logging)"
         SqlType "3"
         ParsedExpression " If (Trim(Key.SRC_SYS_CD) = \"ESI\" or Trim(Key.SRC_SYS_CD) = \"MEDIMPACT\" OR Trim(Key.SRC_SYS_CD) = \"WELLDYNERX\" Or Trim(Key.SRC_SYS_CD) = \"MCSOURCE\" Or Trim(Key.SRC_SYS_CD) = \"MCAID\" Or Trim(Key.SRC_SYS_CD) = \"MEDTRAK\" Or Trim(Key.SRC_SYS_CD) = \"BCBSSC\" Or Trim(Key.SRC_SYS_CD) = \"BCA\" Or Trim(Key.SRC_SYS_CD) = \"BCBSA\" Or Trim(Key.SRC_SYS_CD) = \"SAVRX\" Or Trim(Key.SRC_SYS_CD) = \"LDI\" Or Trim(Key.SRC_SYS_CD) = \"CVS\" Or Trim(Key.SRC_SYS_CD) = \"OPTUMRX\") then GetFkeyCodes(\"FDB\", Key.DRUG_CLM_SK, \"NDC DRUG ABUSE CONTROL\", TRIM(Key.DRUG_CLM_LGL_STTUS_CD), Logging) else GetFkeyCodes(Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"DRUG CLAIM LEGAL STATUS\", Key.DRUG_CLM_LGL_STTUS_CD, Logging)"
         SourceColumn "Key.SRC_SYS_CD;Key.DRUG_CLM_SK;Key.DRUG_CLM_LGL_STTUS_CD"
         Transform "GetFkeyCodes"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
