      BEGIN DSSUBRECORD
         Name "McpartdCovdrugCd"
         Expression "If (Key.SRC_SYS_CD = 'ESI' Or Key.SRC_SYS_CD = 'OPTUMRX' Or Key.SRC_SYS_CD = 'MEDIMPACT' Or  Key.SRC_SYS_CD = 'ARGUS' Or Key.SRC_SYS_CD = 'MEDTRAK' Or Key.SRC_SYS_CD = 'BCBSSC' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') Then  GetFkeyCodes ( Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"MEDICARE PART D COVERED DRUG\", Key.DRUG_CLM_MCPARTD_COVDRUG_CD, Logging) Else 1"
         SqlType "3"
         ParsedExpression " If (Key.SRC_SYS_CD = 'ESI' Or Key.SRC_SYS_CD = 'OPTUMRX' Or Key.SRC_SYS_CD = 'MEDIMPACT' Or Key.SRC_SYS_CD = 'ARGUS' Or Key.SRC_SYS_CD = 'MEDTRAK' Or Key.SRC_SYS_CD = 'BCBSSC' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') Then GetFkeyCodes(Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"MEDICARE PART D COVERED DRUG\", Key.DRUG_CLM_MCPARTD_COVDRUG_CD, Logging) Else 1"
