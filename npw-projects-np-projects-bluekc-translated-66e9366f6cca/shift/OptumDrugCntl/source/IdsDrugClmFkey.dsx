         SqlType "3"
         ParsedExpression " If Trim(Key.SRC_SYS_CD) = \"MCSOURCE\" Then 'NA' Else GetFkeyDate('IDS', Key.DRUG_CLM_SK, Key.ADJ_DT, Logging)"
