      BEGIN DSSUBRECORD
         Name "PdsNtwkCd"
         Expression =+=+=+=
If Key.SRC_SYS_CD = 'OPTUMRX' 
Then (If (Key.PDX_NTWK_ID = 'NA' Or Key.PDX_NTWK_ID = 'UNK' )
      Then GetFkeyCodes (Key.SRC_SYS_CD,  Key.DRUG_CLM_SK, "PHARMACY NETWORK", Key.PDX_NTWK_ID, Logging) 
	  Else GetFkeyCodes (Key.SRC_SYS_CD,  Key.DRUG_CLM_SK, "PHARMACY NETWORK", Key.PDX_NTWK_ID[4,4], Logging)
	  )
Else GetFkeyCodes (Key.SRC_SYS_CD,  Key.DRUG_CLM_SK, "PHARMACY NETWORK", Key.PDX_NTWK_ID, Logging) 
=+=+=+=
         SqlType "3"
         ParsedExpression " If Key.SRC_SYS_CD = 'OPTUMRX' Then ( If (Key.PDX_NTWK_ID = 'NA' Or Key.PDX_NTWK_ID = 'UNK') Then GetFkeyCodes(Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"PHARMACY NETWORK\", Key.PDX_NTWK_ID, Logging) Else GetFkeyCodes(Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"PHARMACY NETWORK\", Key.PDX_NTWK_ID[4, 4], Logging)) Else GetFkeyCodes(Key.SRC_SYS_CD, Key.DRUG_CLM_SK, \"PHARMACY NETWORK\", Key.PDX_NTWK_ID, Logging)"
