         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svAllowAmt"
         Expression "If Trim(BCBSKCComm.CLNT_GNRL_PRPS_AREA[61,2])   <> '01' Then ( ((BCBSKCComm.SLS_TAX_AMT + BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT))  - BCBSKCComm.OTHR_PAYOR_AMT )  Else  (BCBSKCComm.INGR_CST_AMT  + BCBSKCComm.DISPNS_FEE_AMT  + BCBSKCComm.SLS_TAX_AMT)"
         SqlType "3"
         ParsedExpression " If Trim(BCBSKCComm.CLNT_GNRL_PRPS_AREA[61, 2]) <> '01' Then (((BCBSKCComm.SLS_TAX_AMT + BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT)) - BCBSKCComm.OTHR_PAYOR_AMT) Else (BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT + BCBSKCComm.SLS_TAX_AMT)"
         SourceColumn "BCBSKCComm.CLNT_GNRL_PRPS_AREA;BCBSKCComm.SLS_TAX_AMT;BCBSKCComm.INGR_CST_AMT;BCBSKCComm.DISPNS_FEE_AMT;BCBSKCComm.OTHR_PAYOR_AMT"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svMIAllowAmt"
         Expression "If BCBSKCComm.OTHR_COV_CD = '2' Then ( BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT + BCBSKCComm.SLS_TAX_AMT ) - BCBSKCComm.OTHR_PAYOR_AMT Else  BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT + BCBSKCComm.SLS_TAX_AMT"
         SqlType "3"
         ParsedExpression " If BCBSKCComm.OTHR_COV_CD = '2' Then (BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT + BCBSKCComm.SLS_TAX_AMT) - BCBSKCComm.OTHR_PAYOR_AMT Else BCBSKCComm.INGR_CST_AMT + BCBSKCComm.DISPNS_FEE_AMT + BCBSKCComm.SLS_TAX_AMT"
         SourceColumn "BCBSKCComm.OTHR_COV_CD;BCBSKCComm.INGR_CST_AMT;BCBSKCComm.DISPNS_FEE_AMT;BCBSKCComm.SLS_TAX_AMT;BCBSKCComm.OTHR_PAYOR_AMT"
