mpting\" name=\"WithoutPrompting\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"/tmp\" description=\"Specifies the location where the named pipe used by the load operation should be created. This property applies to Unix systems only.\" label=\"Directory for named pipe (Unix only)\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForNamedPipe\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">1</FilterProperty></Filter></Property><Property description=\"Specifies the modifiers used with the 'MODIFIED BY' keyword of the DB2 load utility\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type modifiers\" name=\"FileTypeModifiers\" required=\"false\" type=\"category\"><Property description=\"Specifies a fully qualified file path to use with the 'dumpfile' file type modifier. If no path is specified, the 'dumpfile' modifier is not used\" label=\"Dump file\" maxLength=\"512\" minLength=\"1\" name=\"DumpFile\" required=\"false\" type=\"string\"/></Property><Property default=\"false\" description=\"Clean-up on failures during stage execution.\" label=\"Clean-up on failure\" name=\"CleanupOnFail\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of records to load before establishing a consistency point.\" label=\"Save count\" minValue=\"0\" name=\"SaveCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of warnings that are allowed before the load operation stops.\" label=\"Warning count\" minValue=\"0\" name=\"WarningCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"The number of physical records to be loaded. Allows a user to load only the first rowcnt rows in a file.\" label=\"Row Count\" minValue=\"0\" name=\"IRowCount\" required=\"false\" type=\"int\"/><Property default=\"loadMsgs.out\" description=\"Specifies the file where DB2 writes diagnostic messages.\" label=\"Message file\" maxLength=\"256\" minLength=\"1\" name=\"MessageFile\" required=\"true\" type=\"string\"/><Property description=\"Specifies the path name that is used by the DB2 server to store temporary files.\" label=\"Temporary files directory\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForTmpFiles\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Specifies the type of statistics that are gathered for the table.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"1\" label=\"Statistics\" name=\"Statistics\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"The load transaction is marked as non-recoverable.\" label=\"Non-recoverable load\" name=\"NonRecoverableTX\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the method that is used for making a copy of the loaded data.\" filterProperty=\"/Usage/LoadControl/NonRecoverableTX\" filterValue=\"false\" label=\"Copy loaded data\" name=\"CopyLoadedData\" required=\"false\" type=\"int\"><Value code=\"0\">No copy</Value><Value code=\"1\">Use device or directory</Value><Value code=\"2\">Use shared library</Value><Value code=\"3\">Use Tivoli to make a copy</Value><Property default=\"\" description=\"A comma-separated list of devices or directories where the copy is generated.\" filterProperty=\"/Usage/LoadControl/CopyLoadedData\" filterValue=\"1\" label=\"Loaded data copy location\" maxLength=\"512\" minLength=\"1\" name=\"CopyToDeviceOrDirectory\" required=\"true\" type=\"string\"/><Property default=\"\" description=\"Specifies the name o