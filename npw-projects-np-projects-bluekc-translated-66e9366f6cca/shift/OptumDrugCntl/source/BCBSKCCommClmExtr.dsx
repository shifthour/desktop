      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT 
SUB_UNIQ_KEY,
ALPHA_PFX_CD 
FROM 
#$IDSOwner#.MBR MBR,
#$IDSOwner#.SUB SUB,
#$IDSOwner#.ALPHA_PFX PFX,
#$IDSOwner#.W_DRUG_ENR DRUG 

WHERE 
DRUG.MBR_UNIQ_KEY = MBR.MBR_UNIQ_KEY
AND MBR.SUB_SK = SUB.SUB_SK 
AND SUB.ALPHA_PFX_SK = PFX.ALPHA_PFX_SK
=+=+=+=
