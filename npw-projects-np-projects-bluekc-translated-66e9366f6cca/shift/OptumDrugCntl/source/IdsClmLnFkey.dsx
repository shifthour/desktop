      BEGIN DSSUBRECORD
         Name "ClmLnLobCdSk"
         Expression =+=+=+=
If (ClmLn1.SRC_SYS_CD = 'DENTAQUEST' 
	or ClmLn1.SRC_SYS_CD = 'SOLUTRAN' 
	or ClmLn1.SRC_SYS_CD = 'LVNGHLTH'  
	or ClmLn1.SRC_SYS_CD = 'EYEMED'
	or ClmLn1.SRC_SYS_CD = 'NATIONBFTSBBB'
	or ClmLn1.SRC_SYS_CD = 'NATIONBFTSOTC'
	or ClmLn1.SRC_SYS_CD = 'NATIONBFTSRWD'
	or ClmLn1.SRC_SYS_CD = 'NATIONBFTSHRNG' 
	or ClmLn1.SRC_SYS_CD = 'NATIONBFTSFLEX' 
	or svSBVSrcSysCd = 'SBV') 
Then GetFkeyCodes('FACETS', ClmLn1.CLM_LN_SK, "CLAIM LINE LOB", ClmLn1.CLM_LN_LOB_CD, Logging)  
Else GetFkeyCodes(svCdMpngSrcSysCd, ClmLn1.CLM_LN_SK, "CLAIM LINE LOB", ClmLn1.CLM_LN_LOB_CD, Logging)
=+=+=+=
         SqlType "3"
         ParsedExpression " If (ClmLn1.SRC_SYS_CD = 'DENTAQUEST' or ClmLn1.SRC_SYS_CD = 'SOLUTRAN' or ClmLn1.SRC_SYS_CD = 'LVNGHLTH' or ClmLn1.SRC_SYS_CD = 'EYEMED' or ClmLn1.SRC_SYS_CD = 'NATIONBFTSBBB' or ClmLn1.SRC_SYS_CD = 'NATIONBFTSOTC' or ClmLn1.SRC_SYS_CD = 'NATIONBFTSRWD' or ClmLn1.SRC_SYS_CD = 'NATIONBFTSHRNG' or ClmLn1.SRC_SYS_CD = 'NATIONBFTSFLEX' or svSBVSrcSysCd = 'SBV') Then GetFkeyCodes('FACETS', ClmLn1.CLM_LN_SK, \"CLAIM LINE LOB\", ClmLn1.CLM_LN_LOB_CD, Logging) Else GetFkeyCodes(svCdMpngSrcSysCd, ClmLn1.CLM_LN_SK, \"CLAIM LINE LOB\", ClmLn1.CLM_LN_LOB_CD, Logging)"
         SourceColumn "ClmLn1.SRC_SYS_CD;ClmLn1.CLM_LN_SK;ClmLn1.CLM_LN_LOB_CD"
