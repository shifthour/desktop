      BEGIN DSSUBRECORD
         Name "SVC_END_DT_SK"
         Description "The Service End Date SK attribute is the unique identifier assigned to the ending date for the service."
         SqlType "1"
         Precision "10"
         Scale "0"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If (ClmLn1.SRC_SYS_CD = 'BCA' OR ClmLn1.SRC_SYS_CD='EYEMED')
Then if SvcEndDt='UNK'  
	Then '2199-12-31'   
	Else SvcEndDt 
Else SvcEndDt
=+=+=+=
         Group "0"
         ParsedDerivation " If (ClmLn1.SRC_SYS_CD = 'BCA' OR ClmLn1.SRC_SYS_CD = 'EYEMED') Then  if SvcEndDt = 'UNK' Then '2199-12-31' Else SvcEndDt Else SvcEndDt"
