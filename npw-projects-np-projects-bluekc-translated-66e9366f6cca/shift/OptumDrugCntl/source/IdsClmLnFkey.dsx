         Name "ClmLnEobExcdSk"
         Expression "If ClmLn1.SRC_SYS_CD = 'LVNGHLTH' Then GetFkeyExcd(\"FACETS\", ClmLn1.CLM_LN_SK,  ClmLn1.CLM_LN_EOB_EXCD , Logging)  Else GetFkeyExcd(SrcSysCd, ClmLn1.CLM_LN_SK,  ClmLn1.CLM_LN_EOB_EXCD , Logging)"
         SqlType "3"
         ParsedExpression " If ClmLn1.SRC_SYS_CD = 'LVNGHLTH' Then GetFkeyExcd(\"FACETS\", ClmLn1.CLM_LN_SK, ClmLn1.CLM_LN_EOB_EXCD, Logging) Else GetFkeyExcd(SrcSysCd, ClmLn1.CLM_LN_SK, ClmLn1.CLM_LN_EOB_EXCD, Logging)"
         SourceColumn "ClmLn1.SRC_SYS_CD;ClmLn1.CLM_LN_SK;ClmLn1.CLM_LN_EOB_EXCD"
