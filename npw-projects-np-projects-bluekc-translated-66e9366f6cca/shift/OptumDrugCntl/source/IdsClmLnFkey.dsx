   BEGIN DSRECORD
      Identifier "V54S1"
      OLEType "CTransformerStage"
      Readonly "0"
      Name "Trns1"
      NextID "9"
      InputPins "V54S1P7"
      OutputPins "V54S1P2|V54S1P3|V54S1P4|V54S1P6|V54S1P8"
      ValidationStatus "0"
      StageType "CTransformerStage"
      BlockSize "0"
      StageVars "CStageVar"
      BEGIN DSSUBRECORD
         Name "svEMRSrcSysCd"
         Expression =+=+=+=
IF (Trim(ClmLn1.SRC_SYS_CD)='CLAYPLATTE' OR
Trim(ClmLn1.SRC_SYS_CD)='JAYHAWK' OR 
Trim(ClmLn1.SRC_SYS_CD)='ENCOMPASS' OR 
Trim(ClmLn1.SRC_SYS_CD)='LIBERTYHOSP' OR 
Trim(ClmLn1.SRC_SYS_CD)='MERITAS' OR 
Trim(ClmLn1.SRC_SYS_CD)='NORTHLAND' OR 
Trim(ClmLn1.SRC_SYS_CD)='OLATHEMED' OR 
Trim(ClmLn1.SRC_SYS_CD)='PROVIDENCE' OR 
Trim(ClmLn1.SRC_SYS_CD)='PROVSTLUKES' OR 
Trim(ClmLn1.SRC_SYS_CD)='SUNFLOWER' OR 
Trim(ClmLn1.SRC_SYS_CD)='TRUMAN' OR 
Trim(ClmLn1.SRC_SYS_CD)='UNTDMEDGRP' OR 
Trim(ClmLn1.SRC_SYS_CD)='MOSAIC' OR 
Trim(ClmLn1.SRC_SYS_CD)='BARRYPOINTE' OR 
Trim(ClmLn1.SRC_SYS_CD)='PRIMEMO' OR 
Trim(ClmLn1.SRC_SYS_CD)='SPIRA' OR 
Trim(ClmLn1.SRC_SYS_CD)='NONSTDSUPLMTDATA' OR 
Trim(ClmLn1.SRC_SYS_CD)='HCA' OR
Trim(ClmLn1.SRC_SYS_CD)='LEAWOODFMLYCARE' OR 
Trim(ClmLn1.SRC_SYS_CD)='CHILDRENSMERCY' OR 
Trim(ClmLn1.SRC_SYS_CD)='CENTRUSHEALTH' OR 
Trim(ClmLn1.SRC_SYS_CD)='MOHEALTH' OR 
Trim(ClmLn1.SRC_SYS_CD)='GOLDENVALLEY' OR 
Trim(ClmLn1.SRC_SYS_CD)='JEFFERSON' OR 
Trim(ClmLn1.SRC_SYS_CD)='WESTMOMEDCNTR' OR 
Trim(ClmLn1.SRC_SYS_CD)='BLUESPRINGS' OR 
Trim(ClmLn1.SRC_SYS_CD)='EXCELSIOR' OR 
Trim(ClmLn1.SRC_SYS_CD)='HARRISONVILLE' OR
Trim(ClmLn1.SRC_SYS_CD)='ASCENTIST')
THEN 'EMR' ELSE ''
=+=+=+=
         SqlType "3"
         ParsedExpression " IF (Trim(ClmLn1.SRC_SYS_CD) = 'CLAYPLATTE' OR Trim(ClmLn1.SRC_SYS_CD) = 'JAYHAWK' OR Trim(ClmLn1.SRC_SYS_CD) = 'ENCOMPASS' OR Trim(ClmLn1.SRC_SYS_CD) = 'LIBERTYHOSP' OR Trim(ClmLn1.SRC_SYS_CD) = 'MERITAS' OR Trim(ClmLn1.SRC_SYS_CD) = 'NORTHLAND' OR Trim(ClmLn1.SRC_SYS_CD) = 'OLATHEMED' OR Trim(ClmLn1.SRC_SYS_CD) = 'PROVIDENCE' OR Trim(ClmLn1.SRC_SYS_CD) = 'PROVSTLUKES' OR Trim(ClmLn1.SRC_SYS_CD) = 'SUNFLOWER' OR Trim(ClmLn1.SRC_SYS_CD) = 'TRUMAN' OR Trim(ClmLn1.SRC_SYS_CD) = 'UNTDMEDGRP' OR Trim(ClmLn1.SRC_SYS_CD) = 'MOSAIC' OR Trim(ClmLn1.SRC_SYS_CD) = 'BARRYPOINTE' OR Trim(ClmLn1.SRC_SYS_CD) = 'PRIMEMO' OR Trim(ClmLn1.SRC_SYS_CD) = 'SPIRA' OR Trim(ClmLn1.SRC_SYS_CD) = 'NONSTDSUPLMTDATA' OR Trim(ClmLn1.SRC_SYS_CD) = 'HCA' OR Trim(ClmLn1.SRC_SYS_CD) = 'LEAWOODFMLYCARE' OR Trim(ClmLn1.SRC_SYS_CD) = 'CHILDRENSMERCY' OR Trim(ClmLn1.SRC_SYS_CD) = 'CENTRUSHEALTH' OR Trim(ClmLn1.SRC_SYS_CD) = 'MOHEALTH' OR Trim(ClmLn1.SRC_SYS_CD) = 'GOLDENVALLEY' OR Trim(ClmLn1.SRC_SYS_CD) = 'JEFFERSON' OR Trim(ClmLn1.SRC_SYS_CD) = 'WESTMOMEDCNTR' OR Trim(ClmLn1.SRC_SYS_CD) = 'BLUESPRINGS' OR Trim(ClmLn1.SRC_SYS_CD) = 'EXCELSIOR' OR Trim(ClmLn1.SRC_SYS_CD) = 'HARRISONVILLE' OR Trim(ClmLn1.SRC_SYS_CD) = 'ASCENTIST') THEN 'EMR' ELSE ''"
         SourceColumn "ClmLn1.SRC_SYS_CD"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svSBVSrcSysCd"
         Expression =+=+=+=
IF (Trim(ClmLn1.SRC_SYS_CD)='DOMINION' OR
              Trim(ClmLn1.SRC_SYS_CD)='MARC')
              THEN 'SBV' 
 ELSE ''

=+=+=+=
         SqlType "3"
         ParsedExpression " IF (Trim(ClmLn1.SRC_SYS_CD) = 'DOMINION' OR Trim(ClmLn1.SRC_SYS_CD) = 'MARC') THEN 'SBV' ELSE ''"
         SourceColumn "ClmLn1.SRC_SYS_CD"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "svCdMpngSrcSysCd"
         Expression "If ClmLn1.SRC_SYS_CD = 'BCBSA' Then 'BCA' Else If  ( ClmLn1.SRC_SYS_CD = 'LUMERIS' ) then 'FACETS' else Trim(ClmLn1.SRC_SYS_CD)"
         SqlType "3"
         ParsedExpression " If ClmLn1.SRC_SYS_CD = 'BCBSA' Then 'BCA' Else  If (ClmLn1.SRC_SYS_CD = 'LUMERIS') then 'FACETS' else Trim(ClmLn1.SRC_SYS_CD)"
         SourceColumn "ClmLn1.SRC_SYS_CD"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SrcSysCd"
         Expression "Trim(ClmLn1.SRC_SYS_CD)"
         SqlType "3"
         ParsedExpression "Trim(ClmLn1.SRC_SYS_CD)"
         SourceColumn "ClmLn1.SRC_SYS_CD"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SrcSysCdSk"
         Description "GetFkeyCodes(\"IDS\", lnkClmProv.CLM_PROV_SK, \"SOURCE SYSTEM\", lnkClmProv.SRC_SYS_CD, \"Y\")"
         Expression "GetFkeyCodes(\"IDS\", ClmLn1.CLM_LN_SK, \"SOURCE SYSTEM\", ClmLn1.SRC_SYS_CD, Logging)"
         SqlType "3"
         ParsedExpression "GetFkeyCodes(\"IDS\", ClmLn1.CLM_LN_SK, \"SOURCE SYSTEM\", ClmLn1.SRC_SYS_CD, Logging)"
         SourceColumn "ClmLn1.CLM_LN_SK;ClmLn1.SRC_SYS_CD"
         Transform "GetFkeyCodes"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "ClmSk"
         Expression "GetFkeyClm (SrcSysCd, ClmLn1.CLM_LN_SK, trim ( ClmLn1.CLM_ID) , Logging)"
         SqlType "3"
         ParsedExpression "GetFkeyClm(SrcSysCd, ClmLn1.CLM_LN_SK, trim(ClmLn1.CLM_ID), Logging)"
         SourceColumn "ClmLn1.CLM_LN_SK;ClmLn1.CLM_ID"
         StageVars "SrcSysCd"
         Transform "GetFkeyClm"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "sProcCd"
         Expression "If ClmLn1.PROC_CD_TYP_CD <> \"ICD10\" Then ClmLn1.PROC_CD[1,5] else ClmLn1.PROC_CD"
         SqlType "3"
         ParsedExpression " If ClmLn1.PROC_CD_TYP_CD <> \"ICD10\" Then ClmLn1.PROC_CD[1, 5] else ClmLn1.PROC_CD"
         SourceColumn "ClmLn1.PROC_CD_TYP_CD;ClmLn1.PROC_CD"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "ProcCdSk"
         Expression =+=+=+=
If Trim(sProcCd) = 'UNK' Then 0 
Else If Trim(sProcCd) = 'NA' Then 1 
Else GetFkeyProcCd("FACETS", ClmLn1.CLM_LN_SK, sProcCd, ClmLn1.PROC_CD_TYP_CD, ClmLn1.PROC_CD_CAT_CD, Logging)
=+=+=+=
         SqlType "3"
         ParsedExpression " If Trim(sProcCd) = 'UNK' Then 0 Else  If Trim(sProcCd) = 'NA' Then 1 Else GetFkeyProcCd(\"FACETS\", ClmLn1.CLM_LN_SK, sProcCd, ClmLn1.PROC_CD_TYP_CD, ClmLn1.PROC_CD_CAT_CD, Logging)"
         SourceColumn "ClmLn1.CLM_LN_SK;ClmLn1.PROC_CD_TYP_CD;ClmLn1.PROC_CD_CAT_CD"
         StageVars "sProcCd"
         Transform "GetFkeyProcCd"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SvcProvSk"
         Expression =+=+=+=
If Trim(ClmLn1.SVC_PROV_ID) = 'UNK' Then 0

Else If Trim(ClmLn1.SVC_PROV_ID) = 'NA' Then 1
Else if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSOTC' ) Then GetFkeyProv("NATIONBFTSOTC", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSBBB' ) Then GetFkeyProv("NATIONBFTSBBB", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSRWD' ) Then GetFkeyProv("NATIONBFTSRWD", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSHRNG' ) Then GetFkeyProv("NATIONBFTSHRNG", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSFLEX' ) Then GetFkeyProv("NATIONBFTSFLEX", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'DOMINION' ) Then GetFkeyProv("DOMINION", ClmLn1.CLM_LN_SK,  trim (Convert('ABCDEFGHIJKLMNOPQRSTUVWXYZ','',ClmLn1.SVC_PROV_ID)) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'MARC' ) Then GetFkeyProv("MARC", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)

                                                                                                                                                                                                                               Else If  (ClmLn1.SRC_SYS_CD = 'EYEMED' ) Then GetFkeyProv("EYEMED", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else if (ClmLn1.SRC_SYS_CD = 'SOLUTRAN' ) Then GetFkeyProv("SOLUTRAN", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else If ClmLn1.SRC_SYS_CD = 'BCBSSC' and ClmLn1.MED_PDX_IND = 'MED' Then GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)

Else If ClmLn1.SRC_SYS_CD = 'BCBSSC' Then GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)

Else If ClmLn1.SRC_SYS_CD = "BCA" and GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) ,'X') <> 0 Then GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) , Logging)

Else If ClmLn1.SRC_SYS_CD = "BCA" and GetFkeyProv("BCA", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) ,'X') <> 0 Then GetFkeyProv("BCA", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) , Logging)

Else If ClmLn1.SRC_SYS_CD = "BCA" and GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) ,'X') <> 0 Then GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) , Logging)

                    			 
Else If ClmLn1.SRC_SYS_CD = "BCBSA"  and ClmLn1.MED_PDX_IND = 'MED' Then GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)

Else If ClmLn1.SRC_SYS_CD = "BCBSA"  Then GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim( ClmLn1.SVC_PROV_ID) , Logging)
                    			 

Else If (	ClmLn1.SRC_SYS_CD = 'ESI'	Or 
                ClmLn1.SRC_SYS_CD = 'OPTUMRX'	Or                                                                                                                                                ClmLn1.SRC_SYS_CD = 'MEDIMPACT'	Or
	ClmLn1.SRC_SYS_CD = "WELLDYNERX"  	Or 
	ClmLn1.SRC_SYS_CD = "PCS" 		Or
                ClmLn1.SRC_SYS_CD = "CAREMARK" 	Or
	ClmLn1.SRC_SYS_CD = "ARGUS"                        Or 
                ClmLn1.SRC_SYS_CD = "MCSOURCE"                Or
                ClmLn1.SRC_SYS_CD = "MCAID"                         Or
                ClmLn1.SRC_SYS_CD = "MEDTRAK"                   Or
                ClmLn1.SRC_SYS_CD = "SAVRX"                        Or               
                ClmLn1.SRC_SYS_CD = "LDI"                              Or               
                ClmLn1.SRC_SYS_CD = "CVS"                          
	)  then  
If ((ClmLn1.SRC_SYS_CD = "MCAID" Or ClmLn1.SRC_SYS_CD = "PCS" Or ClmLn1.SRC_SYS_CD = "CAREMARK") And 
GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , "X") = 0)
Then 
GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging) 
Else 
GetFkeyProv("NABP", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)  
Else  
GetFkeyProv("FACETS", ClmLn1.CLM_LN_SK,  trim ( ClmLn1.SVC_PROV_ID) , Logging)
=+=+=+=
         SqlType "3"
         ParsedExpression " If Trim(ClmLn1.SVC_PROV_ID) = 'UNK' Then 0 Else  If Trim(ClmLn1.SVC_PROV_ID) = 'NA' Then 1 Else  if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSOTC') Then GetFkeyProv(\"NATIONBFTSOTC\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSBBB') Then GetFkeyProv(\"NATIONBFTSBBB\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSRWD') Then GetFkeyProv(\"NATIONBFTSRWD\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSHRNG') Then GetFkeyProv(\"NATIONBFTSHRNG\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'NATIONBFTSFLEX') Then GetFkeyProv(\"NATIONBFTSFLEX\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'DOMINION') Then GetFkeyProv(\"DOMINION\", ClmLn1.CLM_LN_SK, trim(Convert('ABCDEFGHIJKLMNOPQRSTUVWXYZ', '', ClmLn1.SVC_PROV_ID)), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'MARC') Then GetFkeyProv(\"MARC\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If (ClmLn1.SRC_SYS_CD = 'EYEMED') Then GetFkeyProv(\"EYEMED\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  if (ClmLn1.SRC_SYS_CD = 'SOLUTRAN') Then GetFkeyProv(\"SOLUTRAN\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = 'BCBSSC' and ClmLn1.MED_PDX_IND = 'MED' Then GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = 'BCBSSC' Then GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = \"BCA\" and GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), 'X') <> 0 Then GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = \"BCA\" and GetFkeyProv(\"BCA\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), 'X') <> 0 Then GetFkeyProv(\"BCA\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = \"BCA\" and GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), 'X') <> 0 Then GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = \"BCBSA\" and ClmLn1.MED_PDX_IND = 'MED' Then GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If ClmLn1.SRC_SYS_CD = \"BCBSA\" Then GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else  If (ClmLn1.SRC_SYS_CD = 'ESI' Or ClmLn1.SRC_SYS_CD = 'OPTUMRX' Or ClmLn1.SRC_SYS_CD = 'MEDIMPACT' Or ClmLn1.SRC_SYS_CD = \"WELLDYNERX\" Or ClmLn1.SRC_SYS_CD = \"PCS\" Or ClmLn1.SRC_SYS_CD = \"CAREMARK\" Or ClmLn1.SRC_SYS_CD = \"ARGUS\" Or ClmLn1.SRC_SYS_CD = \"MCSOURCE\" Or ClmLn1.SRC_SYS_CD = \"MCAID\" Or ClmLn1.SRC_SYS_CD = \"MEDTRAK\" Or ClmLn1.SRC_SYS_CD = \"SAVRX\" Or ClmLn1.SRC_SYS_CD = \"LDI\" Or ClmLn1.SRC_SYS_CD = \"CVS\") then  If ((ClmLn1.SRC_SYS_CD = \"MCAID\" Or ClmLn1.SRC_SYS_CD = \"PCS\" Or ClmLn1.SRC_SYS_CD = \"CAREMARK\") And GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), \"X\") = 0) Then GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else GetFkeyProv(\"NABP\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging) Else GetFkeyProv(\"FACETS\", ClmLn1.CLM_LN_SK, trim(ClmLn1.SVC_PROV_ID), Logging)"
         SourceColumn "ClmLn1.SVC_PROV_ID;ClmLn1.SRC_SYS_CD;ClmLn1.CLM_LN_SK;ClmLn1.MED_PDX_IND"
         Transform "GetFkeyProv"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
