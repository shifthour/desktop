      BEGIN DSSUBRECORD
         Name "CLM_LN_SK"
         Description "The Claim Line SK attribute is the generated unique identifier for the detail information for claim line items.  It serves as the primary table when reporting information on claim line data, including date of service, type and place of service, service rendered and procedure code modifier as well as the outcome of claims processing such as price used, disallowed and benefit amounts.  It is linked to the indicative claim information via the Claim Identifier."
         SqlType "4"
         Precision "10"
         Scale "0"
         Nullable "0"
         KeyPosition "1"
         DisplaySize "0"
         Group "0"
         SortKey "0"
         SortType "0"
         TableDef "Saved\\Collector\\LoadFile"
         AllowCRLF "0"
         LevelNo "0"
