   BEGIN DSRECORD
      Identifier "V0S111P5"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "orig_clm_hash"
      Description =+=+=+=
SELECT 
ADJ_DRVR.CLM_ID, 
'A02', A02_CLM.CLM_SK, A02_DRUG_CLM.CLM_ID, A02_CLM.CLM_ID, MAP1.TRGT_CD, A02_DRUG_CLM.VNDR_CLM_NO,
'A08', A08_CLM.CLM_SK, A08_DRUG_CLM.CLM_ID, A08_CLM.CLM_ID, MAP2.TRGT_CD, A08_DRUG_CLM.VNDR_CLM_NO
FROM  DEVL.W_DRUG_CLM    ADJ_DRVR,
          DEVL.DRUG_CLM   	  A02_DRUG_CLM, 
      	DEVL.DRUG_CLM         A08_DRUG_CLM,
      	DEVL.CLM        	  A02_CLM,
      	DEVL.CLM        	  A08_CLM,
     	 DEVL.CD_MPPNG   	  MAP1,
     	 DEVL.CD_MPPNG   	  MAP2
WHERE     	   ADJ_DRVR.SRC_SYS_CD       IN ( 'OPTUMRX')
      	AND    ADJ_DRVR.SRC_SYS_CD_SK   =  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK     =  A08_DRUG_CLM.DRUG_CLM_SK
          AND    ADJ_DRVR.DRUG_CLM_SK     =  A08_CLM.CLM_SK  
      	AND A08_CLM.CLM_STTUS_CD_SK 	=  MAP2.CD_MPPNG_SK
      	AND MAP2.TRGT_CD		        = 'A08'

         AND trim (A08_DRUG_CLM.VNDR_CLM_NO) 	= trim(A02_DRUG_CLM.VNDR_CLM_NO)
         AND trim (A08_DRUG_CLM.RX_NO )          = trim(A02_DRUG_CLM.RX_NO)
         and trim (A08_DRUG_CLM.RFL_NO)          = TRIM(A02_DRUG_CLM.RFL_NO)
     	AND A08_DRUG_CLM.FILL_DT_SK 		    = A02_DRUG_CLM.FILL_DT_SK
         AND A08_DRUG_CLM.FILL_DT_SK             = A02_CLM.SVC_STRT_DT_SK
    
         AND trim (A08_CLM.SUB_ID)           	= trim (A02_CLM.SUB_ID)
         AND trim (A08_CLM.MBR_SFX_NO)           = trim (A02_CLM.MBR_SFX_NO)

         AND ADJ_DRVR.SRC_SYS_CD_SK              =  A02_CLM.SRC_SYS_CD_SK
         AND A08_DRUG_CLM.CLM_SK      		   <> A02_DRUG_CLM.CLM_SK 
         AND A02_DRUG_CLM.CLM_SK      	       =  A02_CLM.CLM_SK
         AND A02_CLM.CLM_STTUS_CD_SK 		    =  MAP1.CD_MPPNG_SK
         and A08_DRUG_CLM.CLM_ID = '192894500225003999R' 
         AND A02_DRUG_CLM.LAST_UPDT_RUN_CYC_EXCTN_SK = 170
         AND MAP1.TRGT_CD			= 'A02'





SELECT 
A02_CLM.CLM_SK,  
A02_CLM.SRC_SYS_CD_SK, 
A02_CLM.CLM_ID, 
A08_CLM.CLM_SK, 
A08_CLM.CLM_ID

FROM   #$IDSOwner#.W_DRUG_CLM    ADJ_DRVR,
           #$IDSOwner#.DRUG_CLM   	  A02_DRUG_CLM, 
      	#$IDSOwner#.DRUG_CLM         A08_DRUG_CLM,
      	#$IDSOwner#.CLM        	  A02_CLM,
      	#$IDSOwner#.CLM        	  A08_CLM,
     	#$IDSOwner#.CD_MPPNG   	  MAP1,
     	#$IDSOwner#.CD_MPPNG   	  MAP2

WHERE     	ADJ_DRVR.SRC_SYS_CD                	IN ( 'OPTUMRX')
      	AND    ADJ_DRVR.SRC_SYS_CD_SK 	 	=  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK                	=  A08_DRUG_CLM.DRUG_CLM_SK  
      	AND A08_CLM.CLM_STTUS_CD_SK 		=  MAP2.CD_MPPNG_SK
      	AND MAP2.TRGT_CD		              = 'A08'
        AND A08_DRUG_CLM.VNDR_CLM_NO	=  A02_DRUG_CLM.VNDR_CLM_NO      
        AND A08_DRUG_CLM.RX_NO              	=  A02_DRUG_CLM.RX_NO
      	AND A08_DRUG_CLM.FILL_DT_SK 		=  A02_DRUG_CLM.FILL_DT_SK
      	AND A08_DRUG_CLM.CLM_SK      		<> A02_DRUG_CLM.CLM_SK 
        AND  A08_CLM.SUB_ID                		= A02_CLM.SUB_ID
        AND A08_CLM.MBR_SFX_NO                               = A02_CLM.MBR_SFX_NO
        AND A02_DRUG_CLM.CLM_SK      	                = A02_CLM.CLM_SK
      	AND A02_CLM.CLM_STTUS_CD_SK 		=  MAP1.CD_MPPNG_SK
      	AND MAP1.TRGT_CD			= 'A02'
      	AND A02_CLM.ADJ_TO_CLM_ID	 	= 'NA'
=+=+=+=
      Partner "V0S132|V0S132P1"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#IDSInstance#.CLM CLM, #IDSInstance#.P_DRUG_CLM ADJ,#IDSInstance#.CLM_PROV PROV,#IDSInstance#.DRUG_CLM D,#IDSInstance#.CD_MPPNG G"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM devl.W_DRUG_CLM    ADJ,
            devl.DRUG_CLM           D 
WHERE ADJ.SRC_SYS_CD            = 'PCS' 
      AND ADJ.SRC_SYS_CD_SK      = D.SRC_SYS_CD_SK 
      AND ADJ.RX_NO                       = D.RX_NO 
      AND ADJ.FILL_DT_SK               = D.FILL_DT_SK
      AND ADJ.CLM_SK                    <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
FROM   devl.W_DRUG_CLM ADJ,
             devl.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'WELLDYNERX' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM devl.W_DRUG_CLM ADJ,
            devl.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'MEDTRAK' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      /*AND ADJ.FILL_DT_SK = D.FILL_DT_SK*/
      AND ADJ.CLM_SK <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM devl.W_DRUG_CLM ADJ,
            devl.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'BCBSSC' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK


UNION
SELECT 
A02_CLM.CLM_SK,  
A02_CLM.SRC_SYS_CD_SK, 
A02_CLM.CLM_ID, 
A08_CLM.CLM_SK, 
A08_CLM.CLM_ID

FROM   devl.W_DRUG_CLM    ADJ_DRVR,
           devl.DRUG_CLM   	  A02_DRUG_CLM, 
      	devl.DRUG_CLM         A08_DRUG_CLM,
      	devl.CLM        	  A02_CLM,
      	devl.CLM        	  A08_CLM,
     	devl.CD_MPPNG   	  MAP1,
     	devl.CD_MPPNG   	  MAP2

WHERE     	ADJ_DRVR.SRC_SYS_CD                	=   'ESI'
      	AND    ADJ_DRVR.SRC_SYS_CD_SK 	 	=  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK                	=  A08_DRUG_CLM.DRUG_CLM_SK  
                AND A08_DRUG_CLM.CLM_SK      	                = A08_CLM.CLM_SK
     	AND A08_CLM.PAYMT_REF_ID                     	<> 'NA'
      	AND A08_CLM.CLM_STTUS_CD_SK 		=  MAP2.CD_MPPNG_SK
      	AND MAP2.TRGT_CD		              = 'A08'

                 AND A08_DRUG_CLM.VNDR_CLM_NO	=  A02_DRUG_CLM.VNDR_CLM_NO      
                AND A08_DRUG_CLM.RX_NO              	=  A02_DRUG_CLM.RX_NO
      	AND A08_DRUG_CLM.FILL_DT_SK 		=  A02_DRUG_CLM.FILL_DT_SK
      	AND A08_DRUG_CLM.CLM_SK      		<> A02_DRUG_CLM.CLM_SK 
               AND  A08_CLM.SUB_ID                		= A02_CLM.SUB_ID
                AND A08_CLM.MBR_SFX_NO                               = A02_CLM.MBR_SFX_NO
      	
                AND A02_DRUG_CLM.CLM_SK      	                = A02_CLM.CLM_SK
      	AND A02_CLM.CLM_STTUS_CD_SK 		=  MAP1.CD_MPPNG_SK
      	AND MAP1.TRGT_CD			= 'A02'
      	AND A02_CLM.ADJ_TO_CLM_ID	 	= 'NA'
                AND (
                  ( A02_CLM.RCVD_DT_SK < A08_CLM.RCVD_DT_SK  )
                  OR 
                  ( A02_CLM.RCVD_DT_SK = A08_CLM.RCVD_DT_SK
                    AND NOT EXISTS 	(SELECT NO_PRIOR_A02_CLM.CLM_SK 
     	 			FROM  	devl.DRUG_CLM                            NO_PRIOR_A02_DRUG_CLM, 
     	 			            devl.CLM                                      NO_PRIOR_A02_CLM,
     	 			            devl.CD_MPPNG                            MAP3
				WHERE   NO_PRIOR_A02_DRUG_CLM.VNDR_CLM_NO 	=  A08_DRUG_CLM.VNDR_CLM_NO
      				AND 	NO_PRIOR_A02_DRUG_CLM.RX_NO        	=  A08_DRUG_CLM.RX_NO
     				AND 	NO_PRIOR_A02_DRUG_CLM.FILL_DT_SK   	=  A08_DRUG_CLM.FILL_DT_SK
      				AND 	NO_PRIOR_A02_DRUG_CLM.CLM_SK       	<> A08_DRUG_CLM.CLM_SK
      				AND        NO_PRIOR_A02_DRUG_CLM.CLM_SK                =  NO_PRIOR_A02_CLM.CLM_SK
      				AND        NO_PRIOR_A02_CLM.SUB_ID                               = A08_CLM.SUB_ID
      				 AND        NO_PRIOR_A02_CLM.MBR_SFX_NO                   =  A08_CLM.MBR_SFX_NO  
     				AND 	NO_PRIOR_A02_CLM.CLM_STTUS_CD_SK 	=  MAP3.CD_MPPNG_SK
    				AND 	MAP3.TRGT_CD				= 'A02'
      				AND 	NO_PRIOR_A02_CLM.ADJ_TO_CLM_ID	= 'NA'
      				 AND       NO_PRIOR_A02_CLM.CLM_SK          	               <>  A02_CLM.CLM_SK
				AND	NO_PRIOR_A02_CLM.RCVD_DT_SK                  < A02_CLM.RCVD_DT_SK)
              )
            )




=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "BEFORESQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTBEFORESQL"
         Value "YES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "AFTERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "CONTAFTERSQL"
         Value "YES"
      END DSSUBRECORD
