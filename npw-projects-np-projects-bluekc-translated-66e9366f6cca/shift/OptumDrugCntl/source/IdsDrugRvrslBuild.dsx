   BEGIN DSRECORD
      Identifier "V23A0"
      OLEType "CAnnotation"
      Readonly "0"
      Name "V23A0"
      NextID "0"
      AnnotationType "0"
      AnnotationText "For IDS drug Claims: need to determine if the ClmR is for a claim in the input file or for a claim already loaded to IDS from a previous run.    If there is a claim on the IDS CLM table for the same person, drug, fill date AND that claim's status is A02 then the reversal is for that claim.   If there is no A02 claim on the IDS CLM table, then begin assuming the ClaimR is for a claim on the input file.   If the ClmR is for the claimon the input file, then they both should have the same Received Dt."
      TextFont "MS Sans Serif\\10\\0\\0\\0\\400\\0"
      TextHorizontalJustification "1"
      TextVerticalJustification "1"
      TextColor "0"
      BackgroundColor "8454143"
      BackgroundTransparent "0"
      BorderVisible "1"
   END DSRECORD
