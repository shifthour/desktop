alue code=\"3\">Uncatalog</Value></Property><Property default=\"1\" description=\"This option specifies the abnormal termination disposition of the dataset(s) used by the LOAD utility.\" label=\"Abnormal termination\" name=\"AbnormalTermination\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property></Property><Property default=\"0\" description=\"Specifies the z/OS disk space allocation unit type\" label=\"Space type\" name=\"SpaceType\" required=\"false\" type=\"int\"><Value code=\"0\">Cylinders</Value><Value code=\"1\">Tracks</Value></Property><Property description=\"Specifies the z/OS disk primary space allocation parameters in the range from 1 to 1677215.\" label=\"Primary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"PrimaryAllocation\" required=\"false\" type=\"int\"/><Property description=\"Specifies the z/OS disk secondary space allocation parameters in the range from 1 to 1677215.\" label=\"Secondary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"SecondaryAllocation\" required=\"false\" type=\"int\"/></Property><Property description=\"Work2 dataset attributes\" label=\"Work2 dataset\" name=\"Work2DataSet\" required=\"false\" type=\"category\"><Property description=\"Dataset name used by the Load utility.\" label=\"Dataset name\" maxLength=\"256\" minLength=\"1\" name=\"DatasetName\" required=\"false\" type=\"string\"/><Property description=\"Specifies the number of buffers to use\" label=\"Number of buffers\" maxValue=\"99\" minValue=\"1\" name=\"NumberOfBuffers\" required=\"false\" type=\"int\"/><Property description=\"Specifies the device number, device type (generic), or group name for the data set.\" label=\"Unit\" maxLength=\"256\" minLength=\"1\" name=\"Unit\" required=\"false\" type=\"string\"/><Property description=\"Specifies the SMS data class.  The name must be a valid SMS data class and must not exceed 8 characters in length.\" label=\"Data class\" maxLength=\"8\" minLength=\"1\" name=\"DataClass\" required=\"false\" type=\"string\"/><Property description=\"Specifies the SMS management class.  The name must be a valid SMS management class and must not exceed 8 characters in length.\" label=\"Management class\" maxLength=\"8\" minLength=\"1\" name=\"ManagementClass\" required=\"false\" type=\"string\"/><Property description=\"Specifies the SMS storage class.  The name must be a valid SMS storage class and must not exceed 8 characters in length.\" label=\"Storage class\" maxLength=\"8\" minLength=\"1\" name=\"StorageClass\" required=\"false\" type=\"string\"/><Property description=\"Specifies a list of volume serial numbers for this allocation.  The value should be a string value or a comma-separated list of string values.  The value or list of values may be entered by the user with or without enclosing parentheses.  In the TEMPLATE statement, however, the parentheses are required.  So, if the user does not enter them, the syntax generator should add them.\" label=\"Volume(s)\" maxLength=\"256\" minLength=\"1\" name=\"Volumes\" required=\"false\" type=\"string\"/><Property description=\"File disposition properties\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"0\" label=\"File disposition\" name=\"FileDisposition\" required=\"false\" type=\"category\"><Property default=\"0\" description=\"This option specifies the disposition status of the dataset(s) used by the LOAD utility.\" label=\"Status\" name=\"Status\" required=\"false\" type=\"int\"><Value code=\"0\">Replace</Value><Value code=\"1\">New</Value><Value code=\"2\">Old</Value><Value code=\"3\">Share</Value><Value code=\"4\">Append</Value></Property><Property default=\"1\" description=\"This option specifies the normal termination disposition of the dataset(s) used by the LOAD utility.\" label=\"Normal termination\" name=\"NormalTermination\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property><Property default=\"1\" description=\"This option specifies the abnormal termination disposition of the dataset(s) used by the LOAD utility.\" label=\"Abnormal termination\" name=\"AbnormalTermination\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property></Property><Property default=\"0\" description=\"Specifies the z/OS disk space allocation unit type\" label=\"Space type\" name=\"SpaceType\" required=\"false\" type=\"int\"><Value code=\"0\">Cylinders</Value><Value code=\"1\">Tracks</Value></Property><Property description=\"Specifies the z/OS disk primary space allocation parameters in the range from 1 to 1677215.\" label=\"Primary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"PrimaryAllocation\" required=\"false\" type=\"int\"/><Property description=\"Specifies the z/OS disk secondary space allocation parameters in the range from 1 to 1677215.\" label=\"Secondary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"SecondaryAllocation\" required=\"false\" type=\"int\"/></Property></Property></Property><Property contexts=\"target\" description=\"Specifies the properties that control the bulk load operations.\" label=\"Load control\" name=\"LoadControl\" required=\"false\" transactionModels=\"local\" type=\"category\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">6</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadToZOS\">false</FilterProperty></Filter><Property default=\"0\" description=\"Specifies the mode where the load operates.\" filterProperty=\"/Usage/TableAction\" filterValue=\"0\" label=\"Load mode\" name=\"LoadMode\" required=\"false\" type=\"int\"><Value code=\"0\">Insert</Value><Value code=\"1\">Replace</Value><Value code=\"2\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Restart</Value><Value code=\"3\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Terminate</Value></Property><Property default=\"0\" description=\"Specifies which DB2 load phase is to be restarted. The original input data needs to be reproduced for restarting the Load phase. Build and Delete phases ignore the input data.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"2\" label=\"Restart phase\" name=\"RestartPhase\" required=\"false\" type=\"int\"><Value code=\"0\">Load</Value><Value code=\"1\">Build</Value><Value code=\"2\">Delete</Value></Property><Property default=\"false\" description=\"Indicates whether there are any LOB or XML columns in the target DB2 table.\" label=\"Bulk load with LOB or XML column(s)\" name=\"BulkloadWithLobXML\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"Determines the load method to use.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load method\" name=\"LoadMethod\" required=\"false\" type=\"int\"><Value code=\"0\">Sequential File(s)</Value><Value code=\"1\">Named Pipe(s)</Value></Property><Property description=\"Name of tables where rows that violate constraints will be stored.\" label=\"Exception table name\" maxLength=\"512\" minLength=\"1\" name=\"ExceptionTable\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction\">0 3</FilterProperty></Filter></Property><Property default=\"90\" description=\"Specifies the time in seconds to attempt opening a socket for the load operation before timing out.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load timeout\" minValue=\"0\" name=\"LoadTimeout\" required=\"false\" type=\"int\"/><Property default=\"false\" description=\"Indicates whether input files should be created without executing the load operation.\" label=\"File(s) only\" name=\"FilesOnly\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property description=\"Specifies the location where the command file and data file (used by the load operation) should be created.\" label=\"Directory for data and command files\" maxLength=\"512\" minLength=\"1\" name=\"DataFilePath\" required=\"true\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"true\" description=\"Select Yes to remove the intermediate data file after completing the load operation.\" filterProperty=\"/Usage/LoadControl/FilesOnly\" filterValue=\"false\" label=\"Remove intermediate data file\" name=\"RemoveIntermediateDataFile\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the format of the data in the data file.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type\" name=\"FileType\" required=\"false\" type=\"int\"><Value code=\"0\">ASC</Value><Value code=\"1\">DEL</Value></Property><Property description=\"A list of fully qualified paths or devices to identify the location of the individual LOB files to be loaded.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Lob Path List\" maxLength=\"512\" minLength=\"1\" name=\"LobPathList\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Select Yes to add the WITHOUT PROMPTING parameter to the LOAD command in the generated command file.\" label=\"Without prompting\" name=\"WithoutPrompting\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"/tmp\" description=\"Specifies the location where the named pipe used by the load operation should be created. This property applies to Unix systems only.\" label=\"Directory for named pipe (Unix only)\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForNamedPipe\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">1</FilterProperty></Filter></Property><Property description=\"Specifies the modifiers used with the 'MODIFIED BY' keyword of the DB2 load utility\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type modifiers\" name=\"FileTypeModifiers\" required=\"false\" type=\"category\"><Property description=\"Specifies a fully qualified file path to use with the 'dumpfile' file type modifier. If no path is specified, the 'dumpfile' modifier is not used\" label=\"Dump file\" maxLength=\"512\" minLength=\"1\" name=\"DumpFile\" required=\"false\" type=\"string\"/></Property><Property default=\"false\" description=\"Clean-up on failures during stage execution.\" label=\"Clean-up on failure\" name=\"CleanupOnFail\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of records to load before establishing a consistency point.\" label=\"Save count\" minValue=\"0\" name=\"SaveCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of warnings that are allowed before the load operation stops.\" label=\"Warning count\" minValue=\"0\" name=\"WarningCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"The number of physical records to be loaded. Allows a user to load only the first rowcnt rows in a file.\" label=\"Row Count\" minValue=\"0\" name=\"IRowCount\" required=\"false\" type=\"int\"/><Property default=\"loadMsgs.out\" description=\"Specifies the file where DB2 writes diagnostic messages.\" label=\"Message file\" maxLength=\"256\" minLength=\"1\" name=\"MessageFile\" required=\"true\" type=\"string\"/><Property description=\"Specifies the path name that is used by the DB2 server to store temporary files.\" label=\"Temporary files directory\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForTmpFiles\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Specifies the type of statistics that are gathered for the table.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"1\" label=\"Statistics\" name=\"Statistics\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"The load transaction is marked as non-recoverable.\" label=\"Non-recoverable load\" name=\"NonRecoverableTX\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the method that is used for making a copy of the loaded data.\" filterProperty=\"/Usage/LoadControl/NonRecoverableTX\" filterValue=\"false\" label=\"Copy loaded data\" name=\"CopyLoadedData\" required=\"false\" type=\"int\"><Value code=\"0\">No copy</Value><Value code=\"1\">Use device or directory</Value><Value code=\"2\">Use shared library</Value><Value code=\"3\">Use Tivoli to make a copy</Value><Property default=\"\" description=\"A comma-separated list of devices or directories where the copy is generated.\" filterProperty=\"/Usage/LoadControl/CopyLoadedData\" filterValue=\"1\" label=\"Loaded data copy location\" maxLength=\"512\" minLength=\"1\" name=\"CopyToDeviceOrDirectory\" required=\"true\" type=\"string\"/><Property default=\"\" description=\"Specifies the name of the library that is used to generate the copy.\" filterProperty=\"/Usage/LoadControl/CopyLoadedData\" filterValue=\"2\" label=\"Library used to copy\" maxLength=\"256\" minLength=\"1\" name=\"CopyLoadLibraryName\" required=\"true\" type=\"string\"/></Property><Property default=\"false\" description=\"If selected, the table remains in quiesced exclusive state after the load operation.\" hidden=\"true\" label=\"Hold quiesce\" name=\"HoldQuiesce\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of pages (size 4KB) that are used as buffered space for transferring data within the load utility.\" label=\"Data buffer size\" minValue=\"0\" name=\"DataBufferSize\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of pages (size 4KB) of memory that are used for sorting index keys during a load operation.\" filterProperty=\"/Usage/LoadControl/IndexingMode\" filterValue=\"0 1 2\" label=\"Sort buffer size\" minValue=\"0\" name=\"SortBufferSize\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of processes or threads that the load utility spawns for processing records.\" label=\"CPU parallelism\" minValue=\"0\" name=\"CPUParallelism\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of processes or threads that the load utility spawns for writing data.\" label=\"Disk parallelism\" minValue=\"0\" name=\"DiskParallelism\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies whether indexes are rebuilt or extended incrementally.\" label=\"Indexing mode\" name=\"IndexingMode\" required=\"false\" type=\"int\"><Value code=\"0\">Automatic selection</Value><Value code=\"1\">Rebuild table indexes</Value><Value code=\"2\">Extend existing indexes</Value><Value code=\"3\">Do not update table indexes</Value></Property><Property default=\"0\" description=\"Specifies the level of access on the table that is to be loaded.\" filterChildPropertiesOnValue=\"1\" label=\"Allow access mode\" name=\"AllowAccessMode\" required=\"false\" type=\"int\"><Value code=\"0\">No access</Value><Value code=\"1\">Read</Value><Property description=\"Specifies the table space that is used for building a shadow copy of the index if the indexes are being rebuilt.\" label=\"Name of table space\" maxLength=\"256\" minLength=\"1\" name=\"TableSpace\" required=\"false\" type=\"string\"/></Property><Property default=\"1\" description=\"Specifies whether the check pending state of the loaded table is immediately cascaded to all descendants.\" label=\"Check pending cascade\" name=\"CheckPendingCascade\" required=\"false\" type=\"int\"><Value code=\"0\">Immediate</Value><Value code=\"1\">Deferred</Value></Property><Property default=\"false\" description=\"If selected, the load operation forces off other applications that hold conflicting locks.\" label=\"Lock with force\" name=\"LockWithForce\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"If selected, data is loaded into a partitioned table.\" filterChildPropertiesOnValue=\"true\" label=\"Partitioned database configuration\" name=\"PartitionedDBConfig\" required=\"false\" type=\"bool\"><Property description=\"Lists the output database partition numbers.\" label=\"Output partition numbers\" maxLength=\"256\" minLength=\"1\" name=\"OutputDBPartNums\" required=\"false\" type=\"string\"/><Property description=\"Lists the partition numbers that are used in the partitioning process.\" label=\"Partitioning partition numbers\" maxLength=\"256\" minLength=\"1\" name=\"PartitioningDBPartNums\" required=\"false\" type=\"string\"/><Property default=\"25\" description=\"Specifies the maximum number of partitioning agents.\" label=\"Maximum partitioning agents\" minValue=\"1\" name=\"MaxNumPartAgents\" required=\"false\" type=\"int\"/><Property default=\"1\" description=\"Specifies the reaction of the load operation to errors that occur on individual partitions.\" label=\"Isolate partition errors\" name=\"IsolatePartErrors\" required=\"false\" type=\"int\"><Value code=\"0\">Setup errors only</Value><Value code=\"1\">Load errors only</Value><Value code=\"2\">Setup and load errors</Value><Value code=\"3\">No isolation</Value></Property><Property default=\"100\" description=\"Specifies the number of megabytes of data to load before generating a progress message.\" label=\"Status interval\" maxValue=\"4000\" minValue=\"1\" name=\"StatusInterval\" required=\"false\" type=\"int\"/><Property description=\"Specifies the range of TCP ports that are used to create sockets for internal communications.\" filterChildPropertiesOnValue=\"true\" label=\"Port range\" name=\"PortRange\" required=\"false\" type=\"bool\"><Property description=\"Lower port number of the port range\" label=\"Lower port number\" maxValue=\"65535\" minValue=\"0\" name=\"MinValue\" required=\"true\" type=\"int\"/><Property description=\"Higher port number of the port range\" label=\"Higher port number\" maxValue=\"65535\" minValue=\"0\" name=\"MaxValue\" required=\"true\" type=\"int\"/></Property><Property default=\"false\" description=\"If selected, data records are checked for truncation at input and output.\" label=\"Check truncation\" name=\"CheckTruncation\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of records to trace in a dump of the data conversion process and the output of the hashing values.\" label=\"Trace\" minValue=\"0\" name=\"Trace\" required=\"false\" type=\"int\"/><Property description=\"Specifies the name of the partitioned distribution file.\" label=\"Partitioned distribution file\" maxLength=\"256\" minLength=\"1\" name=\"DistFile\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"If selected, the partition map header is not included in the partition file.\" hidden=\"true\" label=\"Omit header\" name=\"OmitHeader\" required=\"false\" type=\"bool\"/><Property default=\"-1\" description=\"Specifies the database partition where statistics are collected.\" filterProperty=\"/Usage/LoadControl/Statistics\" filterValue=\"true\" label=\"Partition collecting statistics\" maxValue=\"32767\" minValue=\"-1\" name=\"RunStatDBPartnum\" required=\"false\" type=\"int\"/></Property></Property><Property contexts=\"source\" default=\"false\" description=\"Select Yes to limit the number of rows that are returned by the connector.\" filterChildPropertiesOnValue=\"true\" label=\"Limit number of returned rows\" name=\"LimitRows\" required=\"false\" type=\"bool\"><Property default=\"1000\" description=\"Enter the maximum number of rows that will be returned by the connector.\" label=\"Limit\" minValue=\"1\" name=\"Limit\" required=\"false\" type=\"int\"/></Property></Usage></Properties><MetaBag><MetaProperty Name=\"InputLinkOrder\" Owner=\"APT\" Value=\"#\"/><MetaProperty Name=\"OutputLinkOrder\" Owner=\"APT\" Value=\"!#\"/></MetaBag><ModelMappings><DataConnection><ConnectionString>/Connection/Database</ConnectionString><Username>/Connection/Username</Username><Password>/Connection/Password</Password><Private name=\"Instance\">/Connection/Instance</Private><Private name=\"DB2ClientLibFile\" usage=\"runtime\">/Connection/DB2ClientLibFile</Private><Private name=\"Conductor\" usage=\"runtime\">/Connection/Conductor</Private><Private name=\"ConductorInstance\" usage=\"runtime\">/Connection/Conductor/Instance</Private><Private name=\"ConductorDatabase\" usage=\"runtime\">/Connection/Conductor/Database</Private><Private name=\"ConductorUsername\" usage=\"runtime\">/Connection/Conductor/Username</Private><Private name=\"ConductorPassword\" usage=\"runtime\">/Connection/Conductor/Password</Private><Private name=\"ConductorDB2ClientLibFile\" usage=\"runtime\">/Connection/Conductor/DB2ClientLibFile</Private></DataConnection></ModelMappings></asc:Connector>"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "XMLProperties"
         Value =+=+=+=
<?xml version='1.0' encoding='UTF-16'?><Properties version='1.1'><Common><Context type='int'>1</Context><Variant type='string'>9.1</Variant><DescriptorVersion type='string'>1.0</DescriptorVersion><PartitionType type='int'>-1</PartitionType><RCP type='int'>0</RCP></Common><Connection><Database type='string'><![CDATA[#$IDSDB#]]></Database><Username type='string'><![CDATA[#$IDSAcct#]]></Username><Password type='string'><![CDATA[#$IDSPW#]]></Password></Connection><Usage><MigratedJob type='bool'><![CDATA[1]]></MigratedJob><GenerateSQL type='bool'><![CDATA[0]]></GenerateSQL><EnableQuotedIDs type='bool'><![CDATA[0]]></EnableQuotedIDs><XMLColumnAsLOB type='bool'><![CDATA[0]]></XMLColumnAsLOB><PrefixForExpressionColumns type='string'><![CDATA[EXPR]]></PrefixForExpressionColumns><SQL><SelectStatement modified='1' type='string'><![CDATA[SELECT 
A02_CLM.CLM_SK,  
A02_CLM.SRC_SYS_CD_SK, 
A02_CLM.CLM_ID, 
A08_CLM.CLM_SK, 
A08_CLM.CLM_ID
FROM  #$IDSOwner#.W_DRUG_CLM         	ADJ_DRVR,
          #$IDSOwner#.DRUG_CLM   	     	  A02_DRUG_CLM, 
      	#$IDSOwner#.DRUG_CLM             	 A08_DRUG_CLM,
      	#$IDSOwner#.CLM        	      	 A02_CLM,
      	#$IDSOwner#.CLM        	     	  A08_CLM,
     	 #$IDSOwner#.CD_MPPNG   	  MAP1,
     	 #$IDSOwner#.CD_MPPNG   	  MAP2
WHERE     	   ADJ_DRVR.SRC_SYS_CD       IN ( 'MEDIMPACT')
      	AND    ADJ_DRVR.SRC_SYS_CD_SK   =  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK       =  A08_DRUG_CLM.DRUG_CLM_SK
                AND    ADJ_DRVR.DRUG_CLM_SK       =  A08_CLM.CLM_SK  
      	AND    A08_CLM.CLM_STTUS_CD_SK  =  MAP2.CD_MPPNG_SK
      	AND    MAP2.TRGT_CD	                  = 'A08'

         AND trim (A08_DRUG_CLM.VNDR_CLM_NO) 	= trim(A02_DRUG_CLM.VNDR_CLM_NO)
         AND trim (A08_DRUG_CLM.RX_NO )          = trim(A02_DRUG_CLM.RX_NO)
         and trim (A08_DRUG_CLM.RFL_NO)          = TRIM(A02_DRUG_CLM.RFL_NO)
     	AND A08_DRUG_CLM.FILL_DT_SK 		    = A02_DRUG_CLM.FILL_DT_SK
         AND A08_DRUG_CLM.FILL_DT_SK             = A02_CLM.SVC_STRT_DT_SK
         AND trim (A08_CLM.SUB_ID)           	= trim (A02_CLM.SUB_ID)
         AND trim (A08_CLM.MBR_SFX_NO)           = trim (A02_CLM.MBR_SFX_NO)

         AND ADJ_DRVR.SRC_SYS_CD_SK              =  A02_CLM.SRC_SYS_CD_SK
         AND A08_DRUG_CLM.CLM_SK       	   <> A02_DRUG_CLM.CLM_SK 
         AND A02_DRUG_CLM.CLM_SK      	       =  A02_CLM.CLM_SK
         AND A02_CLM.CLM_STTUS_CD_SK          =  MAP1.CD_MPPNG_SK
         AND SUBSTRING(ADJ_DRVR.CLM_ID, 1, LENGTH (ADJ_DRVR.CLM_ID)-1)  = TRIM(A02_CLM.CLM_ID )       
         AND MAP1.TRGT_CD  IN ( 'A02', 'A09' )

UNION 

SELECT 
A02_CLM.CLM_SK,  
A02_CLM.SRC_SYS_CD_SK, 
A02_CLM.CLM_ID, 
A08_CLM.CLM_SK, 
A08_CLM.CLM_ID
FROM  #$IDSOwner#.W_DRUG_CLM         	ADJ_DRVR,
          #$IDSOwner#.DRUG_CLM   	     	  A02_DRUG_CLM, 
      	#$IDSOwner#.DRUG_CLM             	 A08_DRUG_CLM,
      	#$IDSOwner#.CLM        	      	 A02_CLM,
      	#$IDSOwner#.CLM        	     	  A08_CLM,
     	 #$IDSOwner#.CD_MPPNG   	  MAP1,
     	 #$IDSOwner#.CD_MPPNG   	  MAP2
WHERE     	   ADJ_DRVR.SRC_SYS_CD       IN ( 'OPTUMRX')
      	AND    ADJ_DRVR.SRC_SYS_CD_SK   =  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK       =  A08_DRUG_CLM.DRUG_CLM_SK
                AND    ADJ_DRVR.DRUG_CLM_SK       =  A08_CLM.CLM_SK  
      	AND    A08_CLM.CLM_STTUS_CD_SK  =  MAP2.CD_MPPNG_SK
      	AND    MAP2.TRGT_CD	                  = 'A08'

         AND trim (A08_DRUG_CLM.VNDR_CLM_NO) 	= trim(A02_DRUG_CLM.VNDR_CLM_NO)
         AND trim (A08_DRUG_CLM.RX_NO )          = trim(A02_DRUG_CLM.RX_NO)
         and trim (A08_DRUG_CLM.RFL_NO)          = TRIM(A02_DRUG_CLM.RFL_NO)
     	AND A08_DRUG_CLM.FILL_DT_SK 		    = A02_DRUG_CLM.FILL_DT_SK
         AND A08_DRUG_CLM.FILL_DT_SK             = A02_CLM.SVC_STRT_DT_SK
         AND trim (A08_CLM.SUB_ID)           	= trim (A02_CLM.SUB_ID)
         AND trim (A08_CLM.MBR_SFX_NO)           = trim (A02_CLM.MBR_SFX_NO)

         AND ADJ_DRVR.SRC_SYS_CD_SK              =  A02_CLM.SRC_SYS_CD_SK
         AND A08_DRUG_CLM.CLM_SK       	   <> A02_DRUG_CLM.CLM_SK 
         AND A02_DRUG_CLM.CLM_SK      	       =  A02_CLM.CLM_SK
         AND A02_CLM.CLM_STTUS_CD_SK          =  MAP1.CD_MPPNG_SK
         AND SUBSTRING(ADJ_DRVR.CLM_ID, 1, LENGTH (ADJ_DRVR.CLM_ID)-1)  = TRIM(A02_CLM.CLM_ID )       
         AND MAP1.TRGT_CD  IN ( 'A02', 'A09' )
      

union
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM    ADJ,
            #$IDSOwner#.DRUG_CLM           D 
WHERE ADJ.SRC_SYS_CD            = 'PCS' 
      AND ADJ.SRC_SYS_CD_SK      = D.SRC_SYS_CD_SK 
      AND ADJ.RX_NO                       = D.RX_NO 
      AND ADJ.FILL_DT_SK               = D.FILL_DT_SK
      AND ADJ.CLM_SK                    <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
FROM   #$IDSOwner#.W_DRUG_CLM ADJ,
             #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'WELLDYNERX' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM ADJ,
            #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'MEDTRAK' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      /*AND ADJ.FILL_DT_SK = D.FILL_DT_SK*/
      AND ADJ.CLM_SK <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM ADJ,
            #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'BCBSSC' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK


UNION
SELECT 
A02_CLM.CLM_SK,  
A02_CLM.SRC_SYS_CD_SK, 
A02_CLM.CLM_ID, 
A08_CLM.CLM_SK, 
A08_CLM.CLM_ID

FROM   #$IDSOwner#.W_DRUG_CLM    ADJ_DRVR,
           #$IDSOwner#.DRUG_CLM   	  A02_DRUG_CLM, 
      	#$IDSOwner#.DRUG_CLM         A08_DRUG_CLM,
      	#$IDSOwner#.CLM        	  A02_CLM,
      	#$IDSOwner#.CLM        	  A08_CLM,
     	#$IDSOwner#.CD_MPPNG   	  MAP1,
     	#$IDSOwner#.CD_MPPNG   	  MAP2

WHERE     	ADJ_DRVR.SRC_SYS_CD                	IN ('ESI')
      	AND    ADJ_DRVR.SRC_SYS_CD_SK 	 	=  A08_DRUG_CLM.SRC_SYS_CD_SK
      	AND    ADJ_DRVR.DRUG_CLM_SK                	=  A08_DRUG_CLM.DRUG_CLM_SK  
                AND A08_DRUG_CLM.CLM_SK      	                = A08_CLM.CLM_SK
     	AND A08_CLM.PAYMT_REF_ID                     	<> 'NA'
      	AND A08_CLM.CLM_STTUS_CD_SK 		=  MAP2.CD_MPPNG_SK
      	AND MAP2.TRGT_CD		              = 'A08'

                 AND A08_DRUG_CLM.VNDR_CLM_NO	=  A02_DRUG_CLM.VNDR_CLM_NO      
                AND A08_DRUG_CLM.RX_NO              	=  A02_DRUG_CLM.RX_NO
      	AND A08_DRUG_CLM.FILL_DT_SK 		=  A02_DRUG_CLM.FILL_DT_SK
      	AND A08_DRUG_CLM.CLM_SK      		<> A02_DRUG_CLM.CLM_SK 
               AND  A08_CLM.SUB_ID                		= A02_CLM.SUB_ID
                AND A08_CLM.MBR_SFX_NO                               = A02_CLM.MBR_SFX_NO
      	
                AND A02_DRUG_CLM.CLM_SK      	                = A02_CLM.CLM_SK
      	AND A02_CLM.CLM_STTUS_CD_SK 		=  MAP1.CD_MPPNG_SK
      	AND MAP1.TRGT_CD			= 'A02'
      	AND A02_CLM.ADJ_TO_CLM_ID	 	= 'NA'
                AND (
                  ( A02_CLM.RCVD_DT_SK < A08_CLM.RCVD_DT_SK  )
                  OR 
                  ( A02_CLM.RCVD_DT_SK = A08_CLM.RCVD_DT_SK
                    AND NOT EXISTS 	(SELECT NO_PRIOR_A02_CLM.CLM_SK 
     	 			FROM  	#$IDSOwner#.DRUG_CLM                            NO_PRIOR_A02_DRUG_CLM, 
     	 			            #$IDSOwner#.CLM                                      NO_PRIOR_A02_CLM,
     	 			            #$IDSOwner#.CD_MPPNG                            MAP3
				WHERE   NO_PRIOR_A02_DRUG_CLM.VNDR_CLM_NO 	=  A08_DRUG_CLM.VNDR_CLM_NO
      				AND 	NO_PRIOR_A02_DRUG_CLM.RX_NO        	=  A08_DRUG_CLM.RX_NO
     				AND 	NO_PRIOR_A02_DRUG_CLM.FILL_DT_SK   	=  A08_DRUG_CLM.FILL_DT_SK
      				AND 	NO_PRIOR_A02_DRUG_CLM.CLM_SK       	<> A08_DRUG_CLM.CLM_SK
      				AND        NO_PRIOR_A02_DRUG_CLM.CLM_SK                =  NO_PRIOR_A02_CLM.CLM_SK
      				AND        NO_PRIOR_A02_CLM.SUB_ID                               = A08_CLM.SUB_ID
      				 AND        NO_PRIOR_A02_CLM.MBR_SFX_NO                   =  A08_CLM.MBR_SFX_NO  
     				AND 	NO_PRIOR_A02_CLM.CLM_STTUS_CD_SK 	=  MAP3.CD_MPPNG_SK
    				AND 	MAP3.TRGT_CD				= 'A02'
      				AND 	NO_PRIOR_A02_CLM.ADJ_TO_CLM_ID	= 'NA'
      				 AND       NO_PRIOR_A02_CLM.CLM_SK          	               <>  A02_CLM.CLM_SK
				AND	NO_PRIOR_A02_CLM.RCVD_DT_SK                  < A02_CLM.RCVD_DT_SK)
              )
            )

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM ADJ,
            #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'SAVRX' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK


UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM ADJ,
            #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'LDI' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK

UNION
SELECT D.CLM_SK,ADJ.SRC_SYS_CD_SK,D.CLM_ID,ADJ.CLM_SK,ADJ.CLM_ID
 FROM #$IDSOwner#.W_DRUG_CLM ADJ,
            #$IDSOwner#.DRUG_CLM D 
WHERE ADJ.SRC_SYS_CD = 'CVS' 
      AND ADJ.SRC_SYS_CD_SK = D.SRC_SYS_CD_SK 
      AND ADJ.VNDR_CLM_NO = D.VNDR_CLM_NO
      AND ADJ.CLM_SK <> D.CLM_SK
