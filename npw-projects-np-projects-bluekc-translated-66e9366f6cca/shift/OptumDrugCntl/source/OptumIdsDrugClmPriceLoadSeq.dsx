      msg$ = DSMakeMsg("DSTAGE_JSG_M_0002\\Error calling DSSetParam(%1), code=%2[E]", "$IDSDB2ArraySize":@FM:err$code)
      msg$id = "@OptumIdsMbrPdxDrugClmPriceLoad"; GoTo L$ERROR
   End
   p$V953S3$7 = ($IDSDB2RecordCount)
   err$code = DSSetParam(h$V953S3, "$IDSDB2RecordCount", p$V953S3$7)
   If (err$code <> DSJE.NOERROR) Then
      err$source = "OptumIdsMbrPdxDrugClmPriceLoad"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0002\\Error calling DSSetParam(%1), code=%2[E]", "$IDSDB2RecordCount":@FM:err$code)
      msg$id = "@OptumIdsMbrPdxDrugClmPriceLoad"; GoTo L$ERROR
   End
   p$V953S3$8 = ($IDSOwner)
   err$code = DSSetParam(h$V953S3, "$IDSOwner", p$V953S3$8)
   If (err$code <> DSJE.NOERROR) Then
      err$source = "OptumIdsMbrPdxDrugClmPriceLoad"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0002\\Error calling DSSetParam(%1), code=%2[E]", "$IDSOwner":@FM:err$code)
      msg$id = "@OptumIdsMbrPdxDrugClmPriceLoad"; GoTo L$ERROR
   End
   err$code = DSRunJob(h$V953S3, DSJ.RUNNORMAL)
   If (err$code <> DSJE.NOERROR) Then
      err$source = "OptumIdsMbrPdxDrugClmPriceLoad"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0003\\Error calling DSRunJob(%1), code=%2[E]", jb$V953S3:@FM:err$code)
      msg$id = "@OptumIdsMbrPdxDrugClmPriceLoad"; GoTo L$ERROR
   End
   handle$list<-1> = h$V953S3
   id$list<-1> = "V953S3"
   GoTo L$V953S1$RETURN$1
**************************************************
L$V953S3$FINISHED:
   job$V953S3$status = DSGetJobInfo(h$V953S3, DSJ.JOBSTATUS)
   job$V953S3$userstatus = DSGetJobInfo(h$V953S3, DSJ.USERSTATUS)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0063\\%1 (JOB %2) finished, status=%3[E]", "OptumIdsMbrPdxDrugClmPriceLoad":@FM:jb$V953S3:@FM:job$V953S3$status))
   IdV953S3%%Result2%%3 = job$V953S3$userstatus
   IdV953S3%%Result1%%4 = job$V953S3$status
   IdV953S3%%Name%%5 = jb$V953S3
   If (job$V953S3$status <> DSJS.RUNOK) Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0030\\Job %1 did not finish OK, status = '%2'", jb$V953S3:@FM:DSTranslateCode(job$V953S3$status)), "@OptumIdsMbrPdxDrugClmPriceLoad")
   End
   rpt$V953S3 = DSMakeJobReport(h$V953S3, 1, "CRLF")
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0004\\Report on job: %1<L>%2", jb$V953S3:@FM:rpt$V953S3), "@OptumIdsMbrPdxDrugClmPriceLoad")
   dummy$ = DSDetachJob(h$V953S3)
   If (job$V953S3$status <> DSJS.RUNOK And job$V953S3$status <> DSJS.RUNWARN And Not(b$Abandoning)) Then
      err$source = "OptumIdsMbrPdxDrugClmPriceLoad"; err$number = 1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0024\\Unhandled abort encountered in job %1", jb$V953S3)
      msg$id = "@OptumIdsMbrPdxDrugClmPriceLoad"; GoTo L$ERROR
   End
   If b$InErrorRef$V953S3 Or (job$V953S3$status <> DSJS.RUNOK And job$V953S3$status <> DSJS.RUNWARN) Then Goto L$V953S3$SKIPPED
   cp$value = Lower(job$V953S3$status)
   cp$value<2> = Lower(job$V953S3$userstatus)
   dummy$ = DSCheckPointSetValue(DSJ.ME, h$V953S3$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0025\\Checkpointed run of job '%1'", jb$V953S3), "@OptumIdsMbrPdxDrugClmPriceLoad")
**************************************************
L$V953S3$SKIPPED:
   If b$Abandoning Then GoTo L$WAITFORJOB
   GoSub L$V953S0$START
   If b$V953S3skipping Then GoTo L$V953S1$RETURN$1
   GoTo L$WAITFORJOB
**************************************************
L$V952S5$START:
*** Decision "If_1B"
   b$V952S5else = @True
   If (Count (ExclusionList, ";": "OptumIdsMbrPdxDrugClmPriceFkey" :";") = 0) Then b$V952S5else = @False; GoTo L$V952S1$START
L$V952S5$RETURN$1:
   If b$V952S5else Then GoSub L$V952S4$START
   GoTo L$RETURN$1
**************************************************
L$WAITFORJOB:
   If handle$list = "" Then GoTo L$FINISH
   handle$ = DSWaitForJob(handle$list)
   If handle$ = 0 Then handle$ = handle$list<1>
   Locate handle$ In handle$list Setting index$ Then
      id$ = id$list<index$>
      Del id$list<index$>; Del handle$list<index$>
      b$Abandoning = abort$list<index$>; Del abort$list<index$>
      Begin Case
      Case id$ = "V952S1"
         GoTo L$V952S1$FINISHED
      Case id$ = "V953S3"
         GoTo L$V953S3$FINISHED
      End Case
   End
* Error if fall though
   handle$list = ""
   err$source = "@Coordinator"; err$number = -1
   msg$ = DSMakeMsg("DSTAGE_JSG_M_0008\\Error calling DSWaitForJob(), code=%1[E]", handle$)
   msg$id = "@Coordinator"; GoTo L$ERROR
**************************************************
L$ERROR:
   Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0009\\Controller problem: %1", msg$), msg$id)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0052\\Exception raised: %1", msg$id:", ":msg$))
   If Not(b$InErrorRef) Then
      dummy$ = DSCheckPointSetValue(DSJ.ME, "!", DSMakeMsg("DSTAGE_JSG_M_0031\\Failed at: %1, Reason=%2", err$source:@FM:msg$))
   End
   abort$list = Ifs(handle$list, Str(1:@FM, DCount(handle$list, @FM)), "")
   b$Abandoning = @True
   GoTo L$WAITFORJOB
L$ABORT:
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0055\\Sequence failed (restartable)", ""))
   x$masked$summary = summary$
   Call DSMaskExecArgs(x$masked$summary, '')
   Call DSLogInfo(x$masked$summary, "@Coordinator")
   Call DSLogFatal(DSMakeMsg("DSTAGE_JSG_M_0014\\Sequence job (restartable) will abort due to previous unrecoverable errors", ""), "@Coordinator")
**************************************************
L$FINISH:
   If b$Abandoning Then GoTo L$ABORT
*** At successful exit remove checkpoint record
   If Not(b$InErrorRef) And DSCheckPointExists(DSJ.ME, cp$dtm) Then
      dummy$ = DSCheckPointDelete(DSJ.ME)
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0018\\Removed checkpoint record at successful completion of sequence", ""), "@Coordinator")
   End
   If (seq$V952S4$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_1B"), "@Coordinator")
   End
   If (seq$V953S0$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Or_1C"), "@Coordinator")
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0054\\Sequence finished OK", ""))
   x$masked$summary = summary$
   Call DSMaskExecArgs(x$masked$summary, '')
   Call DSLogInfo(x$masked$summary, "@Coordinator")
   L$EXIT: Return To L$EXIT
 

