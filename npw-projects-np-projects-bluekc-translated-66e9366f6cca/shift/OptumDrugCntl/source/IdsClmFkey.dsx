Trim(ClmCrfIn1.SRC_SYS_CD)='MERITAS' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='NORTHLAND' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='OLATHEMED' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='PROVIDENCE' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='PROVSTLUKES' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='SUNFLOWER' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='TRUMAN' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='UNTDMEDGRP' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='MOSAIC' OR 
Trim(ClmCrfIn1.SRC_SYS_CD)='MOSAICLIFECARE' OR 
