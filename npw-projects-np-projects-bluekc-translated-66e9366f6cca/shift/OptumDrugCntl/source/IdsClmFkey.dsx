THEN 'EMR' ELSE ''
=+=+=+=
         SqlType "3"
         ParsedExpression " If (Trim(ClmCrfIn1.SRC_SYS_CD) = 'CLAYPLATTE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'JAYHAWK' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'ENCOMPASS' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'LIBERTYHOSP' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'MERITAS' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'NORTHLAND' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'OLATHEMED' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'PROVIDENCE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'PROVSTLUKES' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'SUNFLOWER' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'TRUMAN' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'UNTDMEDGRP' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'MOSAIC' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'MOSAICLIFECARE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'BARRYPOINTE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'PRIMEMO' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'SPIRA' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'LEAWOODFMLYCARE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'HCA' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'NONSTDSUPLMTDATA' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'CHILDRENSMERCY' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'CENTRUSHEALTH' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'MOHEALTH' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'GOLDENVALLEY' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'JEFFERSON' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'WESTMOMEDCNTR' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'BLUESPRINGS' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'EXCELSIOR' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'HARRISONVILLE' OR Trim(ClmCrfIn1.SRC_SYS_CD) = 'ASCENTIST') THEN 'EMR' ELSE ''"
