roperty default=\"false\" description=\"Specifies whether strings should be compared using a case sensitive or insensitive comparison.\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" label=\"Case sensitive\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"CaseSensitive\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"bool\"/></Property></Property><Property default=\"2\" description=\"Specifies the type of reoptimization that is done by DB2.\" label=\"Reoptimization\" name=\"ReOptimization\" required=\"false\" scope=\"stage\" type=\"int\"><Value code=\"2\">None</Value><Value code=\"3\">Once</Value><Value code=\"4\">Always</Value></Property><Property default=\"1\" description=\"Specifies the lock wait strategy that is used when a lock cannot be obtained immediately.\" filterChildPropertiesOnValue=\"3\" filterContexts=\"target\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Lock wait mode\" name=\"LockWaitMode\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"int\"><Value code=\"0\">Return an SQLCODE and SQLSTATE</Value><Value code=\"1\">Use the lock timeout database configuration parameter</Value><Value code=\"2\">Wait indefinitely</Value><Value code=\"3\">User specified</Value><Property description=\"Time to wait for a lock\" label=\"Lock wait time\" maxValue=\"32767\" minValue=\"1\" name=\"LockWaitModeTime\" required=\"true\" type=\"int\"/></Property><Property contexts=\"target request\" description=\"Specifies the pad character that is used in the WHERE clause for string columns that are smaller than the column size.\" label=\"Pad character\" maxLength=\"256\" minLength=\"1\" name=\"PadCharacter\" required=\"false\" type=\"string\"/><Property contexts=\"target\" default=\"false\" description=\"By default the connector runs one player process per database partition. If you want to force the connector to run fewer player processes, set this property to Yes\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" filterProperty=\"/Usage/WriteMode\" filterValue=\"6\" label=\"Limit parallelism\" name=\"LimitParallelism\" required=\"false\" type=\"bool\"><Property contexts=\"target\" description=\"The total number of player processes across all processing nodes.\" label=\"Total number of player processes\" minValue=\"1\" name=\"PlayerProcessLimit\" required=\"true\" type=\"int\"/></Property><Property contexts=\"target\" default=\"false\" description=\"Determines whether the target table is on DB2 for z/OS.\" filterChildPropertiesOnValue=\"true\" filterProperty=\"/Usage/WriteMode\" filterValue=\"6\" label=\"Bulk load to DB2 on z/OS\" name=\"LoadToZOS\" required=\"false\" transactionModels=\"local\" type=\"bool\"><Property default=\"0\" description=\"Load method to be used for loading input data into DB2 for z/OS.\" filterProperty=\"/Usage/LoadToZOS/Transfer/TransferType\" filterValue=\"0\" label=\"Load method\" name=\"LoadMethod\" required=\"false\" type=\"int\"><Value code=\"0\">MVS dataset(s)</Value><Value code=\"1\">Batch pipe(s)</Value><Value code=\"2\">USS pipe(s)</Value></Property><Property description=\"Transfer properties\" label=\"Transfer\" name=\"Transfer\" required=\"false\" type=\"category\"><Property default=\"0\" description=\"Determines the method of transferring data to the z/OS machine.\" label=\"Transfer type\" name=\"TransferType\" required=\"false\" type=\"int\"><Value code=\"0\">ftp</Value><Value code=\"1\">sftp</Value></Property><Property description=\"Name of the target machine to which the data is sent.\" label=\"Transfer to\" maxLength=\"256\" minLength=\"1\" name=\"TransferTo\" required=\"true\" type=\"string\"/><Property description=\"Determines the user name for transferring.\" label=\"User\" maxLength=\"256\" minLength=\"1\" name=\"User\" required=\"false\" type=\"string\"/><Property description=\"Determines the password for transferring.\" label=\"Password\" maxLength=\"256\" minLength=\"1\" name=\"Password\" required=\"false\" type=\"protectedstring\"/><Property description=\"The presence of this option indicates that HFS files is to be used and gives the directory name where the files will be created.  The value should be a fully qualified HFS directory name.\" filterProperty=\"/Usage/LoadToZOS/Transfer/TransferType\" filterValue=\"1\" label=\"HFS file directory\" maxLength=\"512\" minLength=\"1\" name=\"USSFileDirectory\" required=\"true\" type=\"string\"/><Property description=\"User-entered command sent just before data transfer begins.  FTP example:  quote site vcount=7 datakeepalive=60\" label=\"Transfer command\" maxLength=\"2000\" minLength=\"1\" name=\"TransferCmd\" required=\"false\" type=\"string\"/><Property default=\"true\" description=\"Select Yes to try to establish a connection again when the initial attempt to connect is unsuccessful.\" filterChildPropertiesOnValue=\"true\" label=\"Retry on connection failure\" name=\"RetryConnection\" required=\"false\" type=\"bool\"><Property default=\"3\" description=\"Enter the number of times to try to establish a connection after a failure on the initial attempt.\" label=\"Number of retries\" maxValue=\"999999999\" minValue=\"1\" name=\"RetryCount\" required=\"true\" type=\"int\"/><Property default=\"10\" description=\"Enter the time in seconds to wait between retries to establish a connection.\" label=\"Interval between retries\" maxValue=\"999999999\" minValue=\"1\" name=\"RetryInterval\" required=\"true\" type=\"int\"/></Property></Property><Property description=\"This option identifies a prefix to be used when creating MVS dataset names.  If omitted, the transfer user name is used.\" label=\"DSN prefix\" maxLength=\"256\" minLength=\"1\" name=\"DSNPrefix\" required=\"false\" type=\"string\"/><Property description=\"If the data is to be transferred to a Batch pipes system on z/OS, this option identifies its name.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"1\" label=\"Batch pipe system ID\" maxLength=\"256\" minLength=\"1\" name=\"BatchPipeSystemID\" required=\"true\" type=\"string\"/><Property description=\"The presence of this option indicates that USS piping is to be used and gives the directory name where the pipes will be created.  The value should be a fully qualified USS directory name.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"2\" label=\"USS pipe directory\" maxLength=\"512\" minLength=\"1\" name=\"USSPipeDirectory\" required=\"true\" type=\"string\"/><Property default=\"false\" description=\"LOAD will not actually be executed, only MVS datasets are created.\" filterProperty=\"/Usage/LoadToZOS/LoadMethod\" filterValue=\"0\" label=\"File(s) only\" name=\"FilesOnly\" required=\"false\" type=\"bool\"/><Property default=\"SYSDA\" description=\"This option specifies the device type to be used for various datasets that the LOAD utility may need.  If omitted, the default is SYSDA.\" label=\"Device type\" maxLength=\"8\" minLength=\"1\" name=\"DeviceType\" required=\"false\" type=\"string\"/><Property description=\"If this option is present, then only the indicated partition will be loaded.  If this option is omitted, all partitions of the DB2 for z/OS database table will be loaded.\" label=\"Partition number\" minValue=\"1\" name=\"PartitionNumber\" required=\"false\" type=\"int\"/><Property default=\"1000\" description=\"This option specifies an estimated count of the total number of rows to be loaded into all partitions combined.  This estimate is used to calculate the amount of disk space which will be needed on z/OS for various datasets.  If not present, a row estimate of 1000 is used.\" label=\"Row count estimate\" minValue=\"0\" name=\"RowCountEstimate\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"This option requests that statistics be displayed at the end of the load.\" label=\"Statistics\" name=\"Statistics\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">All</Value><Value code=\"2\">Index</Value><Value code=\"3\">Table</Value></Property><Property default=\"DB2ZLOAD\" description=\"This is a unique identifier within DB2 for the execution of the LOAD utility.  The default value is DB2ZLOAD.\" label=\"Utility ID\" maxLength=\"16\" minLength=\"1\" name=\"UtilityID\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Indicates whether logging is to occur during the load process.\" label=\"Load with logging\" name=\"LoadWithLogging\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Specifies whether or not the table space is set to the copy-pending status.  (Applicable only when Load with logging = No)\" filterProperty=\"/Usage/LoadToZOS/LoadWithLogging\" filterValue=\"false\" label=\"Set copy-pending\" name=\"SetCopyPending\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the input dataset encoding\" label=\"Encoding\" name=\"Encoding\" required=\"false\" type=\"int\"><Value code=\"0\">EBCDIC</Value><Value code=\"1\">ASCII</Value><Value code=\"2\">UNICODE</Value><Value code=\"3\">CCSID</Value><Property description=\"The IANA character set name for the encoding.  If not specified, ibm-1047-s390 will be used for EBCDIC, ASCII for ASCII, and UTF-16BE for UNICODE.\" label=\"Character set\" maxLength=\"256\" minLength=\"1\" name=\"CharacterSet\" required=\"false\" type=\"string\"/><Property description=\"The IANA character set name for the graphic encoding.  If not specified, UTF-16BE is the default.\" label=\"Graphic character set\" maxLength=\"256\" minLength=\"1\" name=\"GraphicCharacterSet\" required=\"false\" type=\"string\"/><Property description=\"Specifies the coded character set identifier (CCSID) for SBCS data, Mixed data, and DBCS data in the input file.\" filterProperty=\"/Usage/LoadToZOS/Encoding\" filterValue=\"3\" label=\"CCSID\" maxLength=\"256\" minLength=\"1\" name=\"CCSID\" required=\"true\" type=\"string\"/></Property><