         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SQLBUILDERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT
MOD.CLM_LN_PROC_CD_MOD_SK,
MOD.SRC_SYS_CD_SK,
MOD.CLM_ID,
MOD.CLM_LN_SEQ_NO,
'UNK' AS CLM_LN_PROC_CD_MOD_ORDNL_CD,
VARCHAR(CURRENT DATE),
VARCHAR(CURRENT DATE),
'UNK' AS CLM_LN_PROC_CD_MOD_ORDNL_NM,
MOD.PROC_CD_MOD_TX,
MOD.CRT_RUN_CYC_EXCTN_SK,
MOD.LAST_UPDT_RUN_CYC_EXCTN_SK,
MOD.CLM_LN_PROC_CD_MOD_ORDNL_CD_SK,
MOD.CLM_LN_SK
FROM
#IDSOwner#.CLM_LN_PROC_CD_MOD MOD,
#IDSOwner#.W_EDW_ETL_DRVR DRVR
WHERE
MOD.SRC_SYS_CD_SK = DRVR.SRC_SYS_CD_SK AND
MOD.CLM_ID = DRVR.CLM_ID
=+=+=+=
      END DSSUBRECORD
