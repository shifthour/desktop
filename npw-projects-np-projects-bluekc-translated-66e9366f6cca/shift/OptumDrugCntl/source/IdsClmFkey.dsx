      BEGIN DSSUBRECORD
         Name "SvcProvDomain"
         Expression =+=+=+=
If ClmCrfIn1.SRC_SYS_CD = "NPS" 
then If Upcase(ClmCrfIn1.CLM_SUBTYP_CD)='PR' 
     Then "SERVICE PROVIDER TYPE" 
     Else if (Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = "IP" or
             Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = "OP") 
          Then "PROVIDER FACILITY TYPE" 
          Else "NA"
else If ClmCrfIn1.SRC_SYS_CD = "FACETS"
     then if ClmCrfIn1.PRPR_ENTITY = "F" 
          then "PROVIDER FACILITY TYPE"
          else if (ClmCrfIn1.PRPR_ENTITY = "I" or
                  ClmCrfIn1.PRPR_ENTITY = "P" or
                  ClmCrfIn1.PRPR_ENTITY = "G")
               then "SERVICE PROVIDER TYPE"
               else "NA"
  else If (ClmCrfIn1.SRC_SYS_CD = "ESI" or ClmCrfIn1.SRC_SYS_CD = "OPTUMRX" or ClmCrfIn1.SRC_SYS_CD = "MEDIMPACT" or ClmCrfIn1.SRC_SYS_CD = "WELLDYNERX" Or ClmCrfIn1.SRC_SYS_CD = "MCAID" Or ClmCrfIn1.SRC_SYS_CD = "MEDTRAK" Or ClmCrfIn1.SRC_SYS_CD = "BCBSSC" Or ClmCrfIn1.SRC_SYS_CD = "BCA" Or ClmCrfIn1.SRC_SYS_CD = "BCBSA" Or ClmCrfIn1.SRC_SYS_CD = "SAVRX" Or ClmCrfIn1.SRC_SYS_CD = "LDI" Or ClmCrfIn1.SRC_SYS_CD = "CVS" Or ClmCrfIn1.SRC_SYS_CD =  "LVNGHLTH" Or ClmCrfIn1.SRC_SYS_CD = "SOLUTRAN" Or ClmCrfIn1.SRC_SYS_CD[1,9] ="NATIONBFT")
     then   "SERVICE PROVIDER TYPE"   else "NA"
=+=+=+=
         InitialValue "1"
         SqlType "3"
         ParsedExpression " If ClmCrfIn1.SRC_SYS_CD = \"NPS\" then  If Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = 'PR' Then \"SERVICE PROVIDER TYPE\" Else  if (Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = \"IP\" or Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = \"OP\") Then \"PROVIDER FACILITY TYPE\" Else \"NA\" else  If ClmCrfIn1.SRC_SYS_CD = \"FACETS\" then  if ClmCrfIn1.PRPR_ENTITY = \"F\" then \"PROVIDER FACILITY TYPE\" else  if (ClmCrfIn1.PRPR_ENTITY = \"I\" or ClmCrfIn1.PRPR_ENTITY = \"P\" or ClmCrfIn1.PRPR_ENTITY = \"G\") then \"SERVICE PROVIDER TYPE\" else \"NA\" else  If (ClmCrfIn1.SRC_SYS_CD = \"ESI\" or ClmCrfIn1.SRC_SYS_CD = \"OPTUMRX\" or ClmCrfIn1.SRC_SYS_CD = \"MEDIMPACT\" or ClmCrfIn1.SRC_SYS_CD = \"WELLDYNERX\" Or ClmCrfIn1.SRC_SYS_CD = \"MCAID\" Or ClmCrfIn1.SRC_SYS_CD = \"MEDTRAK\" Or ClmCrfIn1.SRC_SYS_CD = \"BCBSSC\" Or ClmCrfIn1.SRC_SYS_CD = \"BCA\" Or ClmCrfIn1.SRC_SYS_CD = \"BCBSA\" Or ClmCrfIn1.SRC_SYS_CD = \"SAVRX\" Or ClmCrfIn1.SRC_SYS_CD = \"LDI\" Or ClmCrfIn1.SRC_SYS_CD = \"CVS\" Or ClmCrfIn1.SRC_SYS_CD = \"LVNGHLTH\" Or ClmCrfIn1.SRC_SYS_CD = \"SOLUTRAN\" Or ClmCrfIn1.SRC_SYS_CD[1, 9] = \"NATIONBFT\") then \"SERVICE PROVIDER TYPE\" else \"NA\""
         SourceColumn "ClmCrfIn1.SRC_SYS_CD;ClmCrfIn1.CLM_SUBTYP_CD;ClmCrfIn1.PRPR_ENTITY"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SvcProvTypCdSk"
         Expression =+=+=+=
If SvcProvDomain = 'NA' then 1 

Else If Trim(ClmCrfIn1.CLM_SVC_PROV_TYP_CD) = 'UNK' then 0 

Else If Trim(ClmCrfIn1.CLM_SVC_PROV_TYP_CD) = 'NA' then 1 

else if SvcProvDomain = 'SERVICE PROVIDER TYPE' then GetFkeyProvTyp("FACETS", ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_TYP_CD, Logging) 

else GetFkeyFcltyTyp("FACETS", ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_TYP_CD, Logging)
=+=+=+=
         InitialValue "1"
         SqlType "3"
         ParsedExpression " If SvcProvDomain = 'NA' then 1 Else  If Trim(ClmCrfIn1.CLM_SVC_PROV_TYP_CD) = 'UNK' then 0 Else  If Trim(ClmCrfIn1.CLM_SVC_PROV_TYP_CD) = 'NA' then 1 else  if SvcProvDomain = 'SERVICE PROVIDER TYPE' then GetFkeyProvTyp(\"FACETS\", ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_TYP_CD, Logging) else GetFkeyFcltyTyp(\"FACETS\", ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_TYP_CD, Logging)"
         SourceColumn "ClmCrfIn1.CLM_SVC_PROV_TYP_CD;ClmCrfIn1.CLM_SK"
         StageVars "SvcProvDomain"
         Transform "GetFkeyProvTyp;GetFkeyFcltyTyp"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SvcProvSpecCdSk"
         Expression =+=+=+=
If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' and Trim(ClmCrfIn1.CLM_SVC_PROV_SPEC_CD) = 'UNK' Then 0

Else If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' and Trim(ClmCrfIn1.CLM_SVC_PROV_SPEC_CD) = 'NA' Then 1

Else If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' Then 
GetFkeyProvSpec(ClmCrfIn1.SRC_SYS_CD,ClmCrfIn1.CLM_SK,ClmCrfIn1.CLM_SVC_PROV_SPEC_CD,Logging)

Else If ( Upcase(ClmCrfIn1.CLM_SUBTYP_CD)='I' OR 
             Upcase(ClmCrfIn1.CLM_SUBTYP_CD)='O' OR  
             Upcase(ClmCrfIn1.CLM_SUBTYP_CD)='IP' OR  
             Upcase(ClmCrfIn1.CLM_SUBTYP_CD)='OP' )
  Then 1
Else If ClmCrfIn1.SRC_SYS_CD = 'LVNGHLTH' Then GetFkeyProvSpec("FACETS",ClmCrfIn1.CLM_SK,ClmCrfIn1.CLM_SVC_PROV_SPEC_CD,Logging)

Else If svSBVSrcSysCd='SBV' Then 1

Else GetFkeyProvSpec(ClmCrfIn1.SRC_SYS_CD,ClmCrfIn1.CLM_SK,ClmCrfIn1.CLM_SVC_PROV_SPEC_CD,Logging)
=+=+=+=
         InitialValue "1"
         SqlType "3"
         ParsedExpression " If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' and Trim(ClmCrfIn1.CLM_SVC_PROV_SPEC_CD) = 'UNK' Then 0 Else  If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' and Trim(ClmCrfIn1.CLM_SVC_PROV_SPEC_CD) = 'NA' Then 1 Else  If ClmCrfIn1.SRC_SYS_CD = 'BCBSSC' Then GetFkeyProvSpec(ClmCrfIn1.SRC_SYS_CD, ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_SPEC_CD, Logging) Else  If (Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = 'I' OR Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = 'O' OR Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = 'IP' OR Upcase(ClmCrfIn1.CLM_SUBTYP_CD) = 'OP') Then 1 Else  If ClmCrfIn1.SRC_SYS_CD = 'LVNGHLTH' Then GetFkeyProvSpec(\"FACETS\", ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_SPEC_CD, Logging) Else  If svSBVSrcSysCd = 'SBV' Then 1 Else GetFkeyProvSpec(ClmCrfIn1.SRC_SYS_CD, ClmCrfIn1.CLM_SK, ClmCrfIn1.CLM_SVC_PROV_SPEC_CD, Logging)"
         SourceColumn "ClmCrfIn1.SRC_SYS_CD;ClmCrfIn1.CLM_SVC_PROV_SPEC_CD;ClmCrfIn1.CLM_SK;ClmCrfIn1.CLM_SUBTYP_CD"
         StageVars "svSBVSrcSysCd"
         Transform "GetFkeyProvSpec"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
