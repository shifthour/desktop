get\" default=\"0\" description=\"Specifies whether to enable the insert buffering optimization in partitioned database environments.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0\" label=\"Insert buffering\" name=\"InsertBuffering\" required=\"false\" type=\"int\"><Value code=\"0\">Default</Value><Value code=\"1\">Off</Value><Value code=\"2\">On</Value><Value code=\"3\">Ignore duplicates</Value><Property contexts=\"target\" default=\"0\" description=\"Specifies whether arrays should be inserted atomically.  Insert buffering with non-atomic arrays does not report errors accurately.\" filterProperty=\"/Usage/Session/InsertBuffering\" filterValue=\"0 2 3\" label=\"Atomic arrays\" name=\"AtomicArrays\" required=\"false\" type=\"int\"><Value code=\"0\">Auto</Value><Value code=\"1\">No</Value><Value code=\"2\">Yes</Value><Value code=\"3\">Simulated</Value></Property></Property></Property><Property contexts=\"target\" description=\"Properties that affect logging\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 1 2 3 4 5 7 8\" label=\"Logging\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Logging\" required=\"false\" type=\"category\"><Property default=\"false\" description=\"Specifies whether to log column values for the first row that fails to be written\" filterChildPropertiesOnValue=\"true\" label=\"Log column values on first row error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogColumnValues\" required=\"false\" type=\"bool\"><Property default=\"false\" description=\"Specifies whether to log key columns or all columns for failing statements\" label=\"Log key values only\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogKeysOnly\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the delimiter to use between columns\" label=\"Column delimiter\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Delimiter\" required=\"false\" type=\"int\"><Value code=\"0\">Space</Value><Value code=\"1\">Newline</Value><Value code=\"2\">Tab</Value><Value code=\"3\">Comma</Value></Property></Property></Property><Property default=\"false\" description=\"Before/After SQL properties\" filterChildPropertiesOnValue=\"true\" label=\"Before/After SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"BeforeAfter\" required=\"false\" type=\"bool\"><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once before any data is processed.\" label=\"Before SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"before\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the Before SQL statement property.\" label=\"Read Before SQL statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileBeforeSQL\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once after all data is processed.\" label=\"After SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"after\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the After SQL statement property.\" label=\"Read After SQL statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileAfterSQL\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once on each node before any data is processed on that node.\" engines=\"ee\" label=\"Before SQL (node)\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"beforeNode\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the Before SQL (node) statement property.\" label=\"Read Before SQL (node) statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileBeforeSQLNode\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property><Property default=\"\" description=\"Enter the SQL statement or the fully-qualified name of the file that contains the SQL statement to run once one each node after all data is processed on that node.\" engines=\"ee\" label=\"After SQL (node)\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"afterNode\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"Select Yes to read the SQL statement from the file that is specified in the After SQL (node) statement property.\" label=\"Read After SQL (node) statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFileAfterSQLNode\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/></Property></Property><Property contexts=\"target\" default=\"0\" deprecated=\"false\" description=\"Determines how records should be ordered across multiple links.\" engines=\"ee\" filterContexts=\"all\" filterEngines=\"all\" hidden=\"false\" inputLinkCountConstraint=\"multiple\" label=\"Record ordering\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\"