e><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property><Property default=\"1\" description=\"This option specifies the abnormal termination disposition of the dataset(s) used by the LOAD utility.\" label=\"Abnormal termination\" name=\"AbnormalTermination\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Delete</Value><Value code=\"2\">Catalog</Value><Value code=\"3\">Uncatalog</Value></Property></Property><Property default=\"0\" description=\"Specifies the z/OS disk space allocation unit type\" label=\"Space type\" name=\"SpaceType\" required=\"false\" type=\"int\"><Value code=\"0\">Cylinders</Value><Value code=\"1\">Tracks</Value></Property><Property description=\"Specifies the z/OS disk primary space allocation parameters in the range from 1 to 1677215.\" label=\"Primary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"PrimaryAllocation\" required=\"false\" type=\"int\"/><Property description=\"Specifies the z/OS disk secondary space allocation parameters in the range from 1 to 1677215.\" label=\"Secondary allocation\" maxValue=\"1677215\" minValue=\"1\" name=\"SecondaryAllocation\" required=\"false\" type=\"int\"/></Property></Property></Property><Property contexts=\"target\" description=\"Specifies the properties that control the bulk load operations.\" label=\"Load control\" name=\"LoadControl\" required=\"false\" transactionModels=\"local\" type=\"category\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">6</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadToZOS\">false</FilterProperty></Filter><Property default=\"0\" description=\"Specifies the mode where the load operates.\" filterProperty=\"/Usage/TableAction\" filterValue=\"0\" label=\"Load mode\" name=\"LoadMode\" required=\"false\" type=\"int\"><Value code=\"0\">Insert</Value><Value code=\"1\">Replace</Value><Value code=\"2\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Restart</Value><Value code=\"3\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"0\">Terminate</Value></Property><Property default=\"0\" description=\"Specifies which DB2 load phase is to be restarted. The original input data needs to be reproduced for restarting the Load phase. Build and Delete phases ignore the input data.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"2\" label=\"Restart phase\" name=\"RestartPhase\" required=\"false\" type=\"int\"><Value code=\"0\">Load</Value><Value code=\"1\">Build</Value><Value code=\"2\">Delete</Value></Property><Property default=\"false\" description=\"Indicates whether there are any LOB or XML columns in the target DB2 table.\" label=\"Bulk load with LOB or XML column(s)\" name=\"BulkloadWithLobXML\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"Determines the load method to use.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load method\" name=\"LoadMethod\" required=\"false\" type=\"int\"><Value code=\"0\">Sequential File(s)</Value><Value code=\"1\">Named Pipe(s)</Value></Property><Property description=\"Name of tables where rows that violate constraints will be stored.\" label=\"Exception table name\" maxLength=\"512\" minLength=\"1\" name=\"ExceptionTable\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction\">0 3</FilterProperty></Filter></Property><Property default=\"90\" description=\"Specifies the time in seconds to attempt opening a socket for the load operation before timing out.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Load timeout\" minValue=\"0\" name=\"LoadTimeout\" required=\"false\" type=\"int\"/><Property default=\"false\" description=\"Indicates whether input files should be created without executing the load operation.\" label=\"File(s) only\" name=\"FilesOnly\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property description=\"Specifies the location where the command file and data file (used by the load operation) should be created.\" label=\"Directory for data and command files\" maxLength=\"512\" minLength=\"1\" name=\"DataFilePath\" required=\"true\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"true\" description=\"Select Yes to remove the intermediate data file after completing the load operation.\" filterProperty=\"/Usage/LoadControl/FilesOnly\" filterValue=\"false\" label=\"Remove intermediate data file\" name=\"RemoveIntermediateDataFile\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the format of the data in the data file.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type\" name=\"FileType\" required=\"false\" type=\"int\"><Value code=\"0\">ASC</Value><Value code=\"1\">DEL</Value></Property><Property description=\"A list of fully qualified paths or devices to identify the location of the individual LOB files to be loaded.\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"Lob Path List\" maxLength=\"512\" minLength=\"1\" name=\"LobPathList\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Select Yes to add the WITHOUT PROMPTING parameter to the LOAD command in the generated command file.\" label=\"Without prompting\" name=\"WithoutPrompting\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">0</FilterProperty></Filter></Property><Property default=\"/tmp\" description=\"Specifies the location where the named pipe used by the load operation should be created. This property applies to Unix systems only.\" label=\"Directory for named pipe (Unix only)\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForNamedPipe\" required=\"false\" type=\"string\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/BulkloadWithLobXML\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/LoadControl/LoadMethod\">1</FilterProperty></Filter></Property><Property description=\"Specifies the modifiers used with the 'MODIFIED BY' keyword of the DB2 load utility\" filterProperty=\"/Usage/LoadControl/BulkloadWithLobXML\" filterValue=\"false\" label=\"File type modifiers\" name=\"FileTypeModifiers\" required=\"false\" type=\"category\"><Property description=\"Specifies a fully qualified file path to use with the 'dumpfile' file type modifier. If no path is specified, the 'dumpfile' modifier is not used\" label=\"Dump file\" maxLength=\"512\" minLength=\"1\" name=\"DumpFile\" required=\"false\" type=\"string\"/></Property><Property default=\"false\" description=\"Clean-up on failures during stage execution.\" label=\"Clean-up on failure\" name=\"CleanupOnFail\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of records to load before establishing a consistency point.\" label=\"Save count\" minValue=\"0\" name=\"SaveCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of warnings that are allowed before the load operation stops.\" label=\"Warning count\" minValue=\"0\" name=\"WarningCount\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"The number of physical records to be loaded. Allows a user to load only the first rowcnt rows in a file.\" label=\"Row Count\" minValue=\"0\" name=\"IRowCount\" required=\"false\" type=\"int\"/><Property default=\"loadMsgs.out\" description=\"Specifies the file where DB2 writes diagnostic messages.\" label=\"Message file\" maxLength=\"256\" minLength=\"1\" name=\"MessageFile\" required=\"true\" type=\"string\"/><Property description=\"Specifies the path name that is used by the DB2 server to store temporary files.\" label=\"Temporary files directory\" maxLength=\"512\" minLength=\"1\" name=\"DirectoryForTmpFiles\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"Specifies the type of statistics that are gathered for the table.\" filterProperty=\"/Usage/LoadControl/LoadMode\" filterValue=\"1\" label=\"Statistics\" name=\"Statistics\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"The load transaction is marked as non-recoverable.\" label=\"Non-recoverable load\" name=\"NonRecoverableTX\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the method that is used for making a copy of the loaded data.\" filterProperty=\"/Usage/LoadControl/NonRecoverableTX\" filterValue=\"false\" label=\"Copy loaded data\" name=\"CopyLoadedData\" required=\"false\" type=\"int\"><Value code=\"0\">No copy</Value><Value code=\"1\">Use device or directory</Value><Value code=\"2\">Use shared library</Value><Value code=\"3\">Use Tivoli to make a copy</Value><Property default=\"\" description=\"A comma-separated list of devices or directories where the copy is generated.\" filterProperty=\"/Usage/LoadControl/CopyLoadedData\" filterValue=\"1\" label=\"Loaded data copy location\" maxLength=\"512\" minLength=\"1\" name=\"CopyToDeviceOrDirectory\" required=\"true\" type=\"string\"/><Property default=\"\" description=\"Specifies the name of the library that is used to generate the copy.\" filterProperty=\"/Usage/LoadControl/CopyLoadedData\" filterValue=\"2\" label=\"Library used to copy\" maxLength=\"256\" minLength=\"1\" name=\"CopyLoadLibraryName\" required=\"true\" type=\"string\"/></Property><Property default=\"false\" description=\"If selected, the table remains in quiesced exclusive state after the load operation.\" hidden=\"true\" label=\"Hold quiesce\" name=\"HoldQuiesce\" required=\"false\" type=\"bool\"/><Property default=\"0\" description=\"Specifies the number of pages (size 4KB) that are used as buffered space for transferring data within the load utility.\" label=\"Data buffer size\" minValue=\"0\" name=\"DataBufferSize\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of pages (size 4KB) of memory that are used for sorting index keys during a load operation.\" filterProperty=\"/Usage/LoadControl/IndexingMode\" filterValue=\"0 1 2\" label=\"Sort buffer size\" minValue=\"0\" name=\"SortBufferSize\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of processes or threads that the load utility spawns for processing records.\" label=\"CPU parallelism\" minValue=\"0\" name=\"CPUParallelism\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies the number of processes or threads that the load utility spawns for writing data.\" label=\"Disk parallelism\" minValue=\"0\" name=\"DiskParallelism\" required=\"false\" type=\"int\"/><Property default=\"0\" description=\"Specifies whether indexes are rebuilt or extended incrementally.\" label=\"Indexing mode\" name=\"IndexingMode\" required=\"false\" type=\"int\"><Value code=\"0\">Automatic selection</Value><Value code=\"1\">Rebuild table indexes</Value><Value code=\"2\">Extend existing indexes</Value><Value code=\"3\">Do not update table indexes</Value></Property><Property default=\"0\" description=\"Specifies the level of access on the table that is to be loaded.\" filterChildPropertiesOnValue=\"1\" label=\"Allow access mode\" name=\"AllowAccessMode\" required=\"false\" type=\"int\"><Value code=\"0\">No access</Value><Value code=\"1\">Read</Value><Property description=\"Specifies the table space that is used for building a shadow copy of the index if the indexes are being rebuilt.\" label=\"Name of table space\" maxLength=\"256\" minLength=\"1\" name=\"TableSpace\" required=\"false\" type=\"string\"/></Property><Property default=\"1\" description=\"Specifies whether the check pending state of the loaded table is immediately cascaded to all descendants.\" label=\"Check pending cascade\" name=\"CheckPendingCascade\" required=\"false\" type=\"int\"><Value code=\"0\">Immediate</Value><Value code=\"1\">Deferred</Value></Property><Property default=\"false\" description=\"If selected, the load operation forces off other applications that hold conflicting locks.\" label=\"Lock with force\" name=\"LockWithForce\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"If selected, data is loaded into a partitioned table.\" filterChildPropertiesOnValue=\"true\" label=\"Partitioned database configuration\" name=\"PartitionedDBConfig\" required=\"false\" type=\"bool\"><Property description=\"Lists the output database partition numbers.\" label=\"Output partition numbers\" maxLength=\"256\" minLength=\"1\" name=\"OutputDBPartNums\" required=\"false\" type=\"string\"/><Property description=\"Lists the partition numbers that are used in the partitioning process.\" label=\"Partitioning partition numbers\" maxLength=\"256\" minLength=\"1\" name=\"PartitioningDBPartNums\" required=\"false\" type=\"string\"/><Property default=\"25\" description=\"Specifies the maximum number of partitioning agents.\" label=\"Maximum partitioning agents\" minValue=\"1\" name=\"MaxNumPartAgents\" required=\"false\" type=\"int\"/><Property default=\"1\" description=\"Specifies the reaction of the load operation to e