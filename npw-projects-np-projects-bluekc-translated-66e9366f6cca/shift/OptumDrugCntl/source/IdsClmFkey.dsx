   BEGIN DSRECORD
      Identifier "V25S1"
      OLEType "CTransformerStage"
      Readonly "0"
      Name "Trans2"
      NextID "12"
      InputPins "V25S1P2|V25S1P11"
      OutputPins "V25S1P3|V25S1P10"
      ValidationStatus "0"
      StageType "CTransformerStage"
      BlockSize "0"
      StageVars "CStageVar"
      BEGIN DSSUBRECORD
         Name "svClmMnths"
         Expression "If IsNull( ClmRvversalPaidDtUpdate.STTUS_DT ) Or Len(Trim( ClmRvversalPaidDtUpdate.STTUS_DT)) <= 0 Then 1 Else MonthDiff(ClmRvversalPaidDtUpdate.STTUS_DT, FORMAT.DATE(@Date,'DATE','CURRENT','CCYY-MM-DD'))"
         SqlType "3"
         ParsedExpression " If IsNull(ClmRvversalPaidDtUpdate.STTUS_DT) Or Len(Trim(ClmRvversalPaidDtUpdate.STTUS_DT)) <= 0 Then 1 Else MonthDiff(ClmRvversalPaidDtUpdate.STTUS_DT, FORMAT.DATE(@Date, 'DATE', 'CURRENT', 'CCYY-MM-DD'))"
         SourceColumn "ClmRvversalPaidDtUpdate.STTUS_DT"
         Transform "MonthDiff;FORMAT.DATE"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "UpdateAdjFromFound"
         Expression "If  (IsNull(Clm1.CLM_SK)=@FALSE) and (Len(Trim(Clm1.CLM_ID))>0)  and ( Clm1.CLM_STTUS_CD_SK =  GetFkeyCodes(\"FACETS\", ClmRvversalPaidDtUpdate.CLM_SK, \"CLAIM STATUS\", \"R\" , \"X\")) then @TRUE else @FALSE  and Trim(Clm1.PD_DT_SK) = \"NA\""
         SqlType "3"
         ParsedExpression " If (IsNull(Clm1.CLM_SK) = @FALSE) and (Len(Trim(Clm1.CLM_ID)) > 0) and (Clm1.CLM_STTUS_CD_SK = GetFkeyCodes(\"FACETS\", ClmRvversalPaidDtUpdate.CLM_SK, \"CLAIM STATUS\", \"R\", \"X\")) then @TRUE else @FALSE and Trim(Clm1.PD_DT_SK) = \"NA\""
         SourceColumn "Clm1.CLM_SK;Clm1.CLM_ID;Clm1.CLM_STTUS_CD_SK;ClmRvversalPaidDtUpdate.CLM_SK;Clm1.PD_DT_SK"
         Transform "GetFkeyCodes"
         Precision "0"
         ColScale "0"
         ExtendedPrecision "0"
      END DSSUBRECORD
      StageVarsMinimised "0"
      LoopVarsMaximised "0"
      MaxLoopIterations "0"
   END DSRECORD
