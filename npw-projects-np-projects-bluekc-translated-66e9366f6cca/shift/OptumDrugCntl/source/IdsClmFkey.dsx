<?xml version='1.0' encoding='UTF-16'?><Properties version='1.1'><Common><Context type='int'><![CDATA[2]]></Context><Variant type='string'><![CDATA[9.1]]></Variant><PartitionType type='int'><![CDATA[-1]]></PartitionType><DescriptorVersion type='string'><![CDATA[1.0]]></DescriptorVersion><RCP type='int'><![CDATA[0]]></RCP></Common><Usage><WriteMode type='int'><![CDATA[1]]></WriteMode><PrefixForExpressionColumns type='string'><![CDATA[EXPR]]></PrefixForExpressionColumns><TableAction type='int'><![CDATA[0]]><GenerateCreateStatement type='bool'><![CDATA[true]]><CreateStatement type='string'><![CDATA[CREATE TABLE #IDSInstance#.CLM (
