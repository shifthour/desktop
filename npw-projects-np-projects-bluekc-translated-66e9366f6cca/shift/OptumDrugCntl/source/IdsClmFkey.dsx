   BEGIN DSRECORD
      Identifier "V269S0P1"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "Lkp_SK_FROM"
      Partner "V0S227|V0S227P5"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "#$IDSOwner#.CLM CLM"
