se\" type=\"string\"/></Property><Property default=\"true\" description=\"Abort the statement sequence when an error occurs\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Do not abort the job when a DB2 Warning is encountered, report as an information messsage.\" label=\"Treat warnings as info\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SuppressWarnings\" required=\"false\" type=\"bool\"/></Property><Property contexts=\"source\" default=\"false\" description=\"Enable or disable partitioned reads by using the selected partitioning method.\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" label=\"Enable partitioned reads\" name=\"EnablePartitioning\" required=\"false\" type=\"bool\"><Property contexts=\"source\" default=\"1\" description=\"The method to use for partitioned reads.\" label=\"Partitioned reads method\" name=\"PartitioningMethod\" required=\"false\" type=\"int\"><Value code=\"0\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Modulus</Value><Value code=\"1\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Minimum and maximum range</Value><Value code=\"2\">DB2 connector</Value><Property description=\"Specifies the table that is used by the selected partitioned reads method.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"1 2\" label=\"Table name\" name=\"TableName\" required=\"true\" type=\"string\"/><Property description=\"Specifies the key column that is used by the selected partitioned reads method. This column must a numeric data type.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"0 1\" label=\"Column name\" maxLength=\"256\" minLength=\"1\" name=\"KeyField\" required=\"true\" type=\"string\"/><Property default=\"true\" description=\"Specifies whether the connector should modify the SELECT statement at run-time and generate the