If   lnkProv1.NTNL_PROV_ID = 'NA' 
Then
	1
Else
	If IsNull(lnkProv1.NTNL_PROV_ID) =@TRUE
	then
		0
	Else
		svNtnlProvSK                 
=+=+=+=
         Group "0"
         ParsedDerivation " If lnkProv1.NTNL_PROV_ID = 'NA' Then 1 Else  If IsNull(lnkProv1.NTNL_PROV_ID) = @TRUE then 0 Else svNtnlProvSK"
