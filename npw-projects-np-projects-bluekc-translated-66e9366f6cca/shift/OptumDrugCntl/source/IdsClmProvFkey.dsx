   BEGIN DSRECORD
      Identifier "V0S20"
      OLEType "CTransformerStage"
      Readonly "0"
      Name "ForeignKey"
      NextID "9"
      InputPins "V0S20P1"
      OutputPins "V0S20P3|V0S20P4|V0S20P5|V0S20P6|V0S20P7"
      ValidationStatus "0"
      StageType "CTransformerStage"
      BlockSize "0"
      StageVars "CStageVar"
      BEGIN DSSUBRECORD
         Name "SrcSysCdProv"
         Description "Get source system code to be used for provider foreign key"
         Expression "SrcSysCdProvFkey(Key.SRC_SYS_CD)"
         SqlType "3"
         ParsedExpression " If IsNull((Key.SRC_SYS_CD)) or Len(Trim((Key.SRC_SYS_CD))) = 0 Then \"UNK\" Else  If Trim((Key.SRC_SYS_CD)) = 'PCS' then 'NABP' else  If Trim((Key.SRC_SYS_CD)) = 'CAREMARK' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'ARGUS' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'ESI' then 'NABP' else  If Trim((Key.SRC_SYS_CD)) = 'OPTUMRX' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'WELLDYNERX' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'MCSOURCE' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'MCAID' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'MEDTRAK' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'BCBSSC' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'BCA' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'PCT' then 'FACETS' else  If Trim((Key.SRC_SYS_CD)) = 'BCBSA' then 'FACETS' Else  If Trim((Key.SRC_SYS_CD)) = 'LUMERIS' Then 'FACETS' else  if Trim((Key.SRC_SYS_CD)) = 'SAVRX' then 'NABP' else  if Trim((Key.SRC_SYS_CD)) = 'LDI' then 'NABP' Else  If Trim((Key.SRC_SYS_CD)) = 'EYEMED' Then 'EYEMED' else  if Trim((Key.SRC_SYS_CD)) = 'CVS' then 'NABP' else  If Trim((Key.SRC_SYS_CD)) = 'MEDIMPACT' then 'NABP' else 'FACETS'"
         SourceColumn "Key.SRC_SYS_CD"
         Transform "\(1B)SrcSysCdProvFkey"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "ClmProvRoleSk"
         Description "GetFkeyCodes(\"IDS\", lnkClmProv.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", lnkClmProv.CLM_PROV_ROLE_TYP_CD, \"Y\")"
         Expression =+=+=+=
If Key.SRC_SYS_CD='BCBSA' Then GetFkeyCodes('BCA', Key.CLM_PROV_SK, "CLAIM PROVIDER ROLE TYPE", Key.CLM_PROV_ROLE_TYP_CD, Logging) else If Key.SRC_SYS_CD='LUMERIS' Then GetFkeyCodes('FACETS', Key.CLM_PROV_SK, "CLAIM PROVIDER ROLE TYPE", Key.CLM_PROV_ROLE_TYP_CD, Logging)
Else If (Key.SRC_SYS_CD='OPTUMRX' Or Key.SRC_SYS_CD='MEDIMPACT'  And (Key.CLM_PROV_ROLE_TYP_CD='PCP' Or Key.CLM_PROV_ROLE_TYP_CD='PRSCRB')) Then GetFkeyCodes('FACETS', Key.CLM_PROV_SK, "CLAIM PROVIDER ROLE TYPE", Key.CLM_PROV_ROLE_TYP_CD, Logging)

Else If Key.SRC_SYS_CD='DENTAQUEST' AND (Key.CLM_PROV_ROLE_TYP_CD='BILL' OR Key.CLM_PROV_ROLE_TYP_CD='SVC') Then GetFkeyCodes(Key.SRC_SYS_CD, Key.CLM_PROV_SK, "CLAIM PROVIDER ROLE TYPE", Key.CLM_PROV_ROLE_TYP_CD, Logging)


Else GetFkeyCodes(Key.SRC_SYS_CD, Key.CLM_PROV_SK, "CLAIM PROVIDER ROLE TYPE", Key.CLM_PROV_ROLE_TYP_CD, Logging)

=+=+=+=
         SqlType "3"
         ParsedExpression " If Key.SRC_SYS_CD = 'BCBSA' Then GetFkeyCodes('BCA', Key.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", Key.CLM_PROV_ROLE_TYP_CD, Logging) else  If Key.SRC_SYS_CD = 'LUMERIS' Then GetFkeyCodes('FACETS', Key.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", Key.CLM_PROV_ROLE_TYP_CD, Logging) Else  If (Key.SRC_SYS_CD = 'OPTUMRX' Or Key.SRC_SYS_CD = 'MEDIMPACT' And (Key.CLM_PROV_ROLE_TYP_CD = 'PCP' Or Key.CLM_PROV_ROLE_TYP_CD = 'PRSCRB')) Then GetFkeyCodes('FACETS', Key.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", Key.CLM_PROV_ROLE_TYP_CD, Logging) Else  If Key.SRC_SYS_CD = 'DENTAQUEST' AND (Key.CLM_PROV_ROLE_TYP_CD = 'BILL' OR Key.CLM_PROV_ROLE_TYP_CD = 'SVC') Then GetFkeyCodes(Key.SRC_SYS_CD, Key.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", Key.CLM_PROV_ROLE_TYP_CD, Logging) Else GetFkeyCodes(Key.SRC_SYS_CD, Key.CLM_PROV_SK, \"CLAIM PROVIDER ROLE TYPE\", Key.CLM_PROV_ROLE_TYP_CD, Logging)"
         SourceColumn "Key.SRC_SYS_CD;Key.CLM_PROV_SK;Key.CLM_PROV_ROLE_TYP_CD"
         Transform "GetFkeyCodes"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "ClmSk"
         Description "GetFkeyClm(lnkClmProv.SRC_SYS_CD, lnkClmProv.CLM_PROV_SK, lnkClmProv.CLM_ID, \"Y\")"
         Expression "GetFkeyClm(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.CLM_ID, Logging)"
         SqlType "3"
         ParsedExpression "GetFkeyClm(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.CLM_ID, Logging)"
         SourceColumn "Key.SRC_SYS_CD;Key.CLM_PROV_SK;Key.CLM_ID"
         Transform "GetFkeyClm"
         Precision "18"
         ColScale "4"
         ExtendedPrecision "0"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "ProvSk"
         Description "GetFkeyProv(lSrcSysCdProvSk, lnkClmProv.CLM_PROV_SK, lnkClmProv.PROV_ID, \"Y\")"
         Expression =+=+=+=
If Trim(Key.PROV_ID) = 'UNK' Then 0

Else If Trim(Key.PROV_ID) = 'NA' Then 1


Else If ( Key.CLM_PROV_ROLE_TYP_CD = "PCP" ) 
Or 
(
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = "OPTUMRX" )  Or                                                             ( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = "MEDIMPACT" )  Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = "ESI" ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'WELLDYNERX' ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'MCSOURCE' ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'MCAID' ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'PCS' ) Or 
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'CAREMARK' ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'MEDTRAK' ) Or 
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'BCBSSC' ) Or
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND Key.SRC_SYS_CD = 'BCA' ))
 Then  
	GetFkeyProv("FACETS", Key.CLM_PROV_SK, Key.PROV_ID, Logging)  

Else If 
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') and GetFkeyProv("NABP", Key.CLM_PROV_SK, Key.PROV_ID, "X") <> 0 ) Then 
	GetFkeyProv("NABP", Key.CLM_PROV_SK, Key.PROV_ID, Logging)  

Else If 
( Key.CLM_PROV_ROLE_TYP_CD = "PRSCRB" AND (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS')  and GetFkeyProv("FACETS", Key.CLM_PROV_SK, Key.PROV_ID, "X") <> 0 ) Then 
	GetFkeyProv("FACETS", Key.CLM_PROV_SK, Key.PROV_ID, Logging)  


Else 
If ((( Key.CLM_PROV_ROLE_TYP_CD = "SVC" AND Key.SRC_SYS_CD = 'MCAID' ) Or 
      ( Key.CLM_PROV_ROLE_TYP_CD = "SVC" AND Key.SRC_SYS_CD = 'PCS' ) Or 
      ( Key.CLM_PROV_ROLE_TYP_CD = "SVC" AND Key.SRC_SYS_CD = 'CAREMARK' )) 
And 
      GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, "X") = 0) 
Then 
GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, Logging) 
Else 
If Key.SRC_SYS_CD = 'BCBSSC'
Then If (GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, "X") <> 0) Then
GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, Logging) 
Else
GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging)
Else If (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') Then If  (GetFkeyProv("NABP", Key.CLM_PROV_SK, Key.PROV_ID, "X") = 0) 
	     			Then GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging)
	     			Else GetFkeyProv("NABP", Key.CLM_PROV_SK, Key.PROV_ID, Logging)	
Else If  Key.SRC_SYS_CD = 'BCA' Then If  (GetFkeyProv('BCA', Key.CLM_PROV_SK, Key.PROV_ID, "X") = 0) 
	     			Then GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging)
	     			Else GetFkeyProv('BCA', Key.CLM_PROV_SK, Key.PROV_ID, Logging)     

Else If Key.SRC_SYS_CD='DENTAQUEST' Then GetFkeyProv(Key.SRC_SYS_CD,Key.CLM_PROV_SK, Key.PROV_ID, Logging)

Else If Key.SRC_SYS_CD='SOLUTRAN' Then GetFkeyProv(Key.SRC_SYS_CD,Key.CLM_PROV_SK, Key.PROV_ID, Logging)		

Else If Key.SRC_SYS_CD [1,6] = 'NATION' Then GetFkeyProv(Key.SRC_SYS_CD,Key.CLM_PROV_SK, Key.PROV_ID, Logging)

Else If Key.SRC_SYS_CD='DOMINION' Then GetFkeyProv(Key.SRC_SYS_CD,Key.CLM_PROV_SK, Key.PROV_ID, Logging)
              
Else If Key.SRC_SYS_CD='MARC' Then GetFkeyProv(Key.SRC_SYS_CD,Key.CLM_PROV_SK, Key.PROV_ID, Logging)

Else GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging)
=+=+=+=
         SqlType "3"
         ParsedExpression " If Trim(Key.PROV_ID) = 'UNK' Then 0 Else  If Trim(Key.PROV_ID) = 'NA' Then 1 Else  If (Key.CLM_PROV_ROLE_TYP_CD = \"PCP\") Or ((Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = \"OPTUMRX\") Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = \"MEDIMPACT\") Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = \"ESI\") Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'WELLDYNERX') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'MCSOURCE') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'MCAID') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'PCS') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'CAREMARK') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'MEDTRAK') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'BCBSSC') Or (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND Key.SRC_SYS_CD = 'BCA')) Then GetFkeyProv(\"FACETS\", Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') and GetFkeyProv(\"NABP\", Key.CLM_PROV_SK, Key.PROV_ID, \"X\") <> 0) Then GetFkeyProv(\"NABP\", Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If (Key.CLM_PROV_ROLE_TYP_CD = \"PRSCRB\" AND (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') and GetFkeyProv(\"FACETS\", Key.CLM_PROV_SK, Key.PROV_ID, \"X\") <> 0) Then GetFkeyProv(\"FACETS\", Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If (((Key.CLM_PROV_ROLE_TYP_CD = \"SVC\" AND Key.SRC_SYS_CD = 'MCAID') Or (Key.CLM_PROV_ROLE_TYP_CD = \"SVC\" AND Key.SRC_SYS_CD = 'PCS') Or (Key.CLM_PROV_ROLE_TYP_CD = \"SVC\" AND Key.SRC_SYS_CD = 'CAREMARK')) And GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, \"X\") = 0) Then GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'BCBSSC' Then  If (GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, \"X\") <> 0) Then GetFkeyProv('FACETS', Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If (Key.SRC_SYS_CD = 'BCBSA' Or Key.SRC_SYS_CD = 'SAVRX' Or Key.SRC_SYS_CD = 'LDI' Or Key.SRC_SYS_CD = 'CVS') Then  If (GetFkeyProv(\"NABP\", Key.CLM_PROV_SK, Key.PROV_ID, \"X\") = 0) Then GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else GetFkeyProv(\"NABP\", Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'BCA' Then  If (GetFkeyProv('BCA', Key.CLM_PROV_SK, Key.PROV_ID, \"X\") = 0) Then GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else GetFkeyProv('BCA', Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'DENTAQUEST' Then GetFkeyProv(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'SOLUTRAN' Then GetFkeyProv(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD[1, 6] = 'NATION' Then GetFkeyProv(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'DOMINION' Then GetFkeyProv(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else  If Key.SRC_SYS_CD = 'MARC' Then GetFkeyProv(Key.SRC_SYS_CD, Key.CLM_PROV_SK, Key.PROV_ID, Logging) Else GetFkeyProv(SrcSysCdProv, Key.CLM_PROV_SK, Key.PROV_ID, Logging)"
         SourceColumn "Key.PROV_ID;Key.CLM_PROV_ROLE_TYP_CD;Key.SRC_SYS_CD;Key.CLM_PROV_SK"
         StageVars "SrcSysCdProv"
         Transform "GetFkeyProv"
         Precision "18"
         ColScale "4"
