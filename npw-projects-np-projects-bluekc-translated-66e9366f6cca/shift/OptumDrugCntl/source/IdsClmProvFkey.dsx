      BEGIN DSSUBRECORD
         Name "ErrCount"
         Description "GetFkeyErrorCnt( lnkClmProv.CLM_PROV_SK )"
         Expression "GetFkeyErrorCnt( Key.CLM_PROV_SK )"
         InitialValue "0"
         SqlType "3"
         ParsedExpression "GetFkeyErrorCnt(Key.CLM_PROV_SK)"
         SourceColumn "Key.CLM_PROV_SK"
         Transform "GetFkeyErrorCnt"
         Precision "0"
