      BEGIN DSSUBRECORD
         Name "NTNL_PROV_SK"
         SqlType "4"
         Precision "10"
         Scale "0"
         Nullable "0"
         KeyPosition "0"
         DisplaySize "0"
         Derivation =+=+=+=
If (Key.CLM_PROV_ROLE_TYP_CD='PCP'  or Key.SRC_SYS_CD='FACETS' or Key.SRC_SYS_CD='LVNGHLTH'  ) 
Then  If svNtnlProvSK=0 
	Then 1 
	Else svNtnlProvSK   
Else If   Key.NTNL_PROV_ID = 'NA' 
	Then 1
	Else If IsNull(Key.NTNL_PROV_ID) =@TRUE
		then 0
		Else svNtnlProvSK
=+=+=+=
         Group "0"
         ParsedDerivation " If (Key.CLM_PROV_ROLE_TYP_CD = 'PCP' or Key.SRC_SYS_CD = 'FACETS' or Key.SRC_SYS_CD = 'LVNGHLTH') Then  If svNtnlProvSK = 0 Then 1 Else svNtnlProvSK Else  If Key.NTNL_PROV_ID = 'NA' Then 1 Else  If IsNull(Key.NTNL_PROV_ID) = @TRUE then 0 Else svNtnlProvSK"
         SourceColumn "Key.CLM_PROV_ROLE_TYP_CD;Key.SRC_SYS_CD;Key.NTNL_PROV_ID"
         SortKey "0"
         SortType "0"
         AllowCRLF "0"
         LevelNo "0"
         Occurs "0"
         PadNulls "0"
         SignOption "0"
         SortingOrder "0"
         StageVars "svNtnlProvSK"
         ArrayHandling "0"
