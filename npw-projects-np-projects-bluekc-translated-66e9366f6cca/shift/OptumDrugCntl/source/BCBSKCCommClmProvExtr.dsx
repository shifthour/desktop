         Value "<?xml version=\"1.0\"?><asc:Connector xmlns:asc=\"http://www.ibm.com\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" schemaVersion=\"1.0\" version=\"1.0\" xsi:schemaLocation=\"http://www.ibm.com ../CC_Common/XML/CC_Connector.xsd\"><MetaData><Id>DB2Connector</Id><Type>database</Type><DisplayName>DB2 Connector</DisplayName><Description><ShortVersion>IBM InfoSphere DB2 Connector</ShortVersion><LongVersion>IBM InfoSphere DB2 Connector. Use this connector to access data in DB2 tables.</LongVersion></Description><Author>IBM Corp.</Author><Vendor>IBM Corp.</Vendor><Copyright>Licensed Materials - Property of IBM (C) Copyright IBM Corp. 2005, 2011 All Rights Reserved.</Copyright><Icons><SmallVersion>[Path to small icon]</SmallVersion><LargeVersion>[Path to large icon]</LargeVersion></Icons><DependentLibraries/><ImportClasses/></MetaData><Variants><Variant><Name>9.1</Name><Library>ccdb2</Library><Version>1.0</Version></Variant></Variants><Capabilities><SupportedEngines>ee se</SupportedEngines><SupportedPlatforms><Platform level=\"XP\" mode=\"32\">windows</Platform></SupportedPlatforms><SupportedContexts>source target request</SupportedContexts><SupportedTransactionModels><Local/></SupportedTransactionModels><SupportsBrowsing>source target request</SupportsBrowsing><SupportsPartitioning>DB2 connector</SupportsPartitioning><SupportedSQLBuilderGrammars><Grammar id=\"DSPXDB2UDB71DML\" label=\"DB2 UDB 7.1 SQL syntax\"/><Grammar id=\"DSPXDB2UDB82DML\" label=\"DB2 UDB 8.2 SQL syntax\"/></SupportedSQLBuilderGrammars><Listener>none</Listener><ConnectionScope>thread</ConnectionScope><Reject><SupportedContexts>target request</SupportedContexts><RejectConditions><Error code=\"0\">SQL error</Error><Error code=\"1\">Row not updated.</Error></RejectConditions><DataElements><DataElement>ERRORCODE</DataElement><DataElement>ERRORTEXT</DataElement></DataElements></Reject><SeCapabilities><RepositoryLocation>\\Stage Types\\Server\\Database</RepositoryLocation><StageType>passive</StageType><SupportsRef>true</SupportsRef><InputLinks max=\"-1\" min=\"0\"/><OutputLinks max=\"-1\" min=\"0\"/><RejectLinks max=\"0\" min=\"0\"/><SuperIconName>DB2 UDB</SuperIconName><SuperIconDefaultPriority>90</SuperIconDefaultPriority><HelpFileName>db2conn.chm</HelpFileName></SeCapabilities><PxCapabilities><RepositoryLocation>\\Stage Types\\Parallel\\Database</RepositoryLocation><StageType>passive</StageType><SupportsRef>true</SupportsRef><InputLinks max=\"-1\" min=\"0\"/><RejectLinks max=\"-1\" min=\"0\"/><SuperIconName>DB2 UDB</SuperIconName><SuperIconDefaultPriority>90</SuperIconDefaultPriority><HelpFileName>db2conn.chm</HelpFileName><SupportedLookupTypes/></PxCapabilities></Capabilities><MetaDataImport><Connection><Property description=\"Specifies the name of the instance to use as the active instance at run time. If not specified, the value of the DB2INSTANCE environment variable is used.\" label=\"Instance\" maxLength=\"256\" minLength=\"1\" name=\"Instance\" required=\"false\" type=\"string\"/><Property callout=\"getList\" calloutDescription=\"Lists the detected databases. The value for the Instance property does not affect the databases that are detected. The list includes only the databases for the currently configured, active DB2 instance in the DB2 Connector environment.\" calloutLabel=\"Database\" calloutType=\"enumerator\" description=\"Specifies the name of the database/location to connect to.\" label=\"Database/Location\" maxLength=\"256\" minLength=\"1\" name=\"Database\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">Databases</CalloutArgument></Property><Property description=\"Specifies the user name to use for connecting to the database.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"false\" type=\"string\"/><Property description=\"Specifies the password to use for connecting to the database.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"false\" type=\"protectedstring\"/></Connection><SchemaClasses><Class description=\"Specifies the import schema for the data collection (database table or view).\" label=\"Data collection\" name=\"DataCollection\"><Connection/><Group description=\"Specify the search criteria for the data collections that are available to import.\" label=\"Filter\" name=\"Filter\"><Property callout=\"getList\" calloutDescription=\"Select the schema where you want to look for the objects to import.\" calloutLabel=\"Choose schema\" calloutType=\"enumerator\" copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/schema\" description=\"Select the database schema that is associated with the objects to import.\" label=\"Schema\" maxOccurs=\"1\" minOccurs=\"0\" name=\"schema\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataSchemas</CalloutArgument></Property><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeViews\" default=\"true\" description=\"Specify whether to include views in the list of objects to be imported.\" label=\"Include views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeViews\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeTables\" default=\"true\" description=\"Specify whether to include tables in the list of objects to be imported.\" label=\"Include tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeTables\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeNicknames\" default=\"false\" description=\"Specify whether to include nicknames in the list of objects to be imported. This option requires support for federated databases.\" label=\"Include nicknames\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeNicknames\" required=\"fa