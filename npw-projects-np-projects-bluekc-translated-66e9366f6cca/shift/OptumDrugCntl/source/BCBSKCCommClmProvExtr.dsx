   BEGIN DSRECORD
      Identifier "V29S0P1"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "HmoExtr"
      Partner "V0S69|V0S69P1"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
         Name "SOURCETABLES"
         Value "devl.MBR_PCP MBR_PCP,devl.MBR_ENR MBR_ENR,devl.MBR MBR,devl.CD_MPPNG MPPNG,devl.CD_MPPNG MPPNG2,devl.PROD PROD,devl.PROD_SH_NM PRODSH"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "PREFETCH"
         Value "10000"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "WHERE_CLAUSE"
         Value =+=+=+=
MBR_PCP.MBR_SK=MBR.MBR_SK 
AND MBR_ENR.MBR_SK=MBR.MBR_SK 
AND MBR_PCP.MBR_PCP_TYP_CD_SK=MPPNG.CD_MPPNG_SK 
AND MPPNG.TRGT_CD='PRI'
AND MBR_ENR.ELIG_IN='Y' 
AND MBR_ENR.PROD_SK=PROD.PROD_SK 
AND PROD.PROD_SH_NM_SK=PRODSH.PROD_SH_NM_SK 
AND PRODSH.PROD_SH_NM_DLVRY_METH_CD_SK=MPPNG2.CD_MPPNG_SK 
AND MPPNG2.TRGT_CD='HMO'
=+=+=+=
      END DSSUBRECORD
      BEGIN DSSUBRECORD
