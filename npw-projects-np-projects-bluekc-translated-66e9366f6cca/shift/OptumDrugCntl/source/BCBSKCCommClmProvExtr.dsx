      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "OTHER_CLAUSES"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "SQLBUILDERSQL"
      END DSSUBRECORD
      BEGIN DSSUBRECORD
         Name "USERSQL"
         Value =+=+=+=
SELECT 
DEA.DEA_NO,
PROV.PROV_ID,
PROV.TAX_ID
FROM 
devl.PROV_DEA DEA,
devl.PROV PROV

WHERE
DEA.CMN_PRCT_SK = PROV.CMN_PRCT_SK  AND
PROV.PROV_ID not in ('UNK' , 'NA') AND

DEA.CMN_PRCT_SK not in (0, 1)


ORDER BY
DEA.DEA_NO,
PROV.PROV_ID DESC
=+=+=+=
      END DSSUBRECORD
