   BEGIN DSRECORD
      Identifier "V31S0P39"
      OLEType "CCustomOutput"
      Readonly "0"
      Name "PrscrbDeaNPI5"
      Partner "V186S0|V186S0P1"
      Properties "CCustomProperty"
      BEGIN DSSUBRECORD
