          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH SourceData AS (SELECT T.MBR_ID, T.MILLIMAN_CLS, T.CT_UNIQ_INSTS, T.LAST_MO_OBSRV, T.DX_ADJOR_CONC_PCT, T.DX_ADJOR_PROSP_LAG_0_PCT, T.DX_ADJOR_PROSP_LAG_3_PCT, T.DX_ADJOR_PROSP_LAG_6_PCT, T.CX_ADJOR_CONC_PCT, T.CX_ADJOR_PROSP_LAG_0_PCT, T.CX_ADJOR_PROSP_LAG_3_PCT, T.CX_ADJOR_PROSP_LAG_6_PCT, '@{pipeline().parameters.VRSN_ID}' AS VRSN_ID FROM @{pipeline().globalParameters.gbl_param_ids_staging}.C0TMP_CblTalnIdsIndvBeMaraClnclClsExtr T), FilterLogic AS (SELECT SourceData.*, CASE WHEN MBR_ID IS NULL OR MILLIMAN_CLS IS NULL OR CT_UNIQ_INSTS IS NULL OR LAST_MO_OBSRV IS NULL OR DX_ADJOR_CONC_PCT IS NULL OR DX_ADJOR_PROSP_LAG_0_PCT IS NULL OR DX_ADJOR_PROSP_LAG_3_PCT IS NULL OR DX_ADJOR_PROSP_LAG_6_PCT IS NULL OR CX_ADJOR_CONC_PCT IS NULL OR CX_ADJOR_PROSP_LAG_0_PCT IS NULL OR CX_ADJOR_PROSP_LAG_3_PCT IS NULL OR CX_ADJOR_PROSP_LAG_6_PCT IS NULL THEN 'Y' ELSE 'N' END AS ErrInd FROM SourceData); DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.C0TMP_CblTalnIdsIndvBeMaraClnclClsExtr_Good SELECT LTRIM(RTRIM(MBR_ID)) AS MBR_ID, LTRIM(RTRIM(MILLIMAN_CLS)) AS MILLIMAN_CLS, CT_UNIQ_INSTS, LAST_MO_OBSRV, DX_ADJOR_CONC_PCT, DX_ADJOR_PROSP_LAG_0_PCT, DX_ADJOR_PROSP_LAG_3_PCT, DX_ADJOR_PROSP_LAG_6_PCT, CX_ADJOR_CONC_PCT, CX_ADJOR_PROSP_LAG_0_PCT, CX_ADJOR_PROSP_LAG_3_PCT, CX_ADJOR_PROSP_LAG_6_PCT, VRSN_ID INTO @{pipeline().globalParameters.gbl_param_ids_staging}.C0TMP_CblTalnIdsIndvBeMaraClnclClsExtr_Good FROM FilterLogic WHERE ErrInd = 'N' DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.C0TMP_CblTalnIdsIndvBeMaraClnclClsExtr_Bad SELECT MBR_ID, MILLIMAN_CLS, CT_UNIQ_INSTS, LAST_MO_OBSRV, DX_ADJOR_CONC_PCT, DX_ADJOR_PROSP_LAG_0_PCT, DX_ADJOR_PROSP_LAG_3_PCT, DX_ADJOR_PROSP_LAG_6_PCT, CX_ADJOR_CONC_PCT, CX_ADJOR_PROSP_LAG_0_PCT, CX_ADJOR_PROSP_LAG_3_PCT, CX_ADJOR_PROSP_LAG_6_PCT INTO @{pipeline().globalParameters.gbl_param_ids_staging}.C0TMP_CblTalnIdsIndvBeMaraClnclClsExtr_Bad FROM FilterLogic WHERE ErrInd