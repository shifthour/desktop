            "FilePath": {
              "value": "load",
              "type": "Expression"
            },
            "filename": {
              "value": "@concat('B_BCBSA_FEP_MBR_ENR.', pipeline().parameters.SrcSysCd, '.dat')",
              "type": "Expression"
