              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "MBR_UNIQ_KEY",
                  "type": "INT",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "PROD_SH_NM",
                  "type": "STRING",
                  "physicalType": "VARCHAR"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "FEP_MBR_ENR_EFF_DT_SK",
