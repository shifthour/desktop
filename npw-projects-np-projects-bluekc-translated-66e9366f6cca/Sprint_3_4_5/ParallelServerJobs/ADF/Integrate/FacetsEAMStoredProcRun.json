                    "text": {
                      "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.R1_TMP_FacetsEAMStoredProcRun;exec @{pipeline().globalParameters.gbl_param_EAMRPTOwner}.TMGSP_FACETS_EAM_RECON_RPT;SELECT lchStep,lchErr INTO @{pipeline().globalParameters.gbl_param_ids_staging}.R1_TMP_FacetsEAMStoredProcRun FROM @{pipeline().globalParameters.gbl_param_EAMRPTOwner}.TMG_EXEC_STAT_LOG LOGT WHERE ldtStepStartDtm=(SELECT MAX(ldtStepStartDtm) FROM @{pipeline().globalParameters.gbl_param_EAMRPTOwner}.TMG_EXEC_STAT_LOG LOG1 WHERE CONVERT(VARCHAR(10),ldtStepStartDtm,23)='@{pipeline().parameters.CurrDt}');",
                      "type": "Expression"
                    }
