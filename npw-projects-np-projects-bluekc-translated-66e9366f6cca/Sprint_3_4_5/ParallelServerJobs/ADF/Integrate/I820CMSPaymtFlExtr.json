        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Val820Dedup_TMP_I820CMSPaymtFlExtr; WITH Xfm AS (SELECT CASE WHEN T.EFT_TRACE_NUMBER IS NULL THEN '' ELSE T.EFT_TRACE_NUMBER END AS EFT_TRACE_ID, CASE WHEN T.EFT_EFFECTIVE_DATE IS NULL THEN '1753-01-01 00:00:00' ELSE SUBSTRING(T.EFT_EFFECTIVE_DATE,7,4) + '-' + SUBSTRING(T.EFT_EFFECTIVE_DATE,1,2) + '-' + SUBSTRING(T.EFT_EFFECTIVE_DATE,4,2) + ' 00:00:00' END AS EFT_EFF_DT, CASE WHEN T.EXCHANGE_TOTAL_EFT_PAYMENT_AMOUNT IS NULL THEN 0 ELSE T.EXCHANGE_TOTAL_EFT_PAYMENT_AMOUNT END AS EFT_TOT_PAYMT_AMT, CASE WHEN T.TRADING_PARTNER_ID IS NULL THEN '' ELSE dbo.trim_default(T.TRADING_PARTNER_ID) END AS TRDNG_PRTNR_ID, CASE WHEN T.CREATED_ON IS NULL THEN '1753-01-01 00:00:00' ELSE SUBSTRING(T.CREATED_ON,7,4) + '-' + SUBSTRING(T.CREATED_ON,1,2) + '-' + SUBSTRING(T.CREATED_ON,4,2) + ' 00:00:00' END AS SRC_SYS_CRT_DT, '820' AS LOAD_FILE_NM FROM @{pipeline().globalParameters.gbl_param_ids_staging}.Val820_TMP_I820CMSPaymtFlExtr T WHERE dbo.trim_default(T.EXCHANGE_ASSIGNED_SUBSCRIBER_ID) <> ''), Dedup AS (SELECT EFT_TRACE_ID, EFT_EFF_DT, EFT_TOT_PAYMT_AMT, TRDNG_PRTNR_ID, SRC_SYS_CRT_DT, LOAD_FILE_NM, ROW_NUMBER() OVER (PARTITION BY EFT_TRACE_ID ORDER BY (SELECT NULL)) AS rn FROM Xfm) SELECT EFT_TRACE_ID, EFT_EFF_DT, EFT_TOT_PAYMT_AMT, TRDNG_PRTNR_ID, SRC_SYS_CRT_DT, LOAD_FILE_NM INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Val820Dedup_TMP_I820CMSPaymtFlExtr FROM Dedup WHERE rn = 1",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
        }
      },
