              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "FilePath": {
              "value": "@concat('load')",
              "type": "Expression"
            },
            "filename": {
              "value": "@concat('MDL_DOC.', pipeline().parameters.SrcSysCd, '.pkey.', pipeline().parameters.RunID, '.dat')",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
