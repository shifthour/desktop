          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH xfm AS (SELECT SRC_SYS_CD, RISK_CAT_ID, RISK_MTHDLGY_CD, RISK_MTHDLGY_TYP_CD, RISK_CAT_LOW_SCORE_NO, RISK_CAT_HI_SCORE_NO, SUBSTRING(RTRIM(LTRIM(RISK_CAT_SCORE_RNG_EFF_DT_SK)),1,10) AS RISK_CAT_SCORE_RNG_EFF_DT_SK, SUBSTRING(RTRIM(LTRIM(RISK_CAT_SCORE_RNG_TERM_DT_SK)),1,10) AS RISK_CAT_SCORE_RNG_TERM_DT_SK, CRT_USER_ID, SUBSTRING(RTRIM(LTRIM(CRT_DT_SK)),1,10) AS CRT_DT_SK, LAST_UPDT_USER_ID, SUBSTRING(RTRIM(LTRIM(LAST_UPDT_DT_SK)),1,10) AS LAST_UPDT_DT_SK FROM @{pipeline().globalParameters.gbl_param_ids_staging}.TMP_UWSRiskCatScoreRangeExtrLoad) MERGE @{pipeline().globalParameters.gbl_param_UWSOwner}.RISK_CAT_SCORE_RNG AS T USING xfm AS S ON T.SRC_SYS_CD = S.SRC_SYS_CD AND T.RISK_CAT_ID = S.RISK_CAT_ID AND T.RISK_MTHDLGY_CD = S.RISK_MTHDLGY_CD AND T.RISK_MTHDLGY_TYP_CD = S.RISK_MTHDLGY_TYP_CD AND T.RISK_CAT_LOW_SCORE_NO = S.RISK_CAT_LOW_SCORE_NO AND T.RISK_CAT_HI_SCORE_NO = S.RISK_CAT_HI_SCORE_NO AND T.RISK_CAT_SCORE_RNG_EFF_DT_SK = S.RISK_CAT_SCORE_RNG_EFF_DT_SK WHEN MATCHED THEN UPDATE SET T.RISK_CAT_SCORE_RNG_TERM_DT_SK = S.RISK_CAT_SCORE_RNG_TERM_DT_SK, T.CRT_USER_ID = S.CRT_USER_ID, T.CRT_DT_SK = S.CRT_DT_SK, T.LAST_UPDT_USER_ID = S.LAST_UPDT_USER_ID, T.LAST_UPDT_DT_SK = S.LAST_UPDT_DT_SK WHEN NOT MATCHED THEN INSERT (SRC_SYS_CD, RISK_CAT_ID, RISK_MTHDLGY_CD, RISK_MTHDLGY_TYP_CD, RISK_CAT_LOW_SCORE_NO, RISK_CAT_HI_SCORE_NO, RISK_CAT_SCORE_RNG_EFF_DT_SK, RISK_CAT_SCORE_RNG_TERM_DT_SK, CRT_USER_ID, CRT_DT_SK, LAST_UPDT_USER_ID, LAST_UPDT_DT_SK) VALUES (S.SRC_SYS_CD, S.RISK_CAT_ID, S.RISK_MTHDLGY_CD, S.RISK_MTHDLGY_TYP_CD, S.RISK_CAT_LOW_SCORE_NO, S.RISK_CAT_HI_SCORE_NO, S.RISK_CAT_SCORE_RNG_EFF_DT_SK, S.RISK_CAT_SCORE_RNG_TERM_DT_SK, S.CRT_USER_ID, S.CRT_DT_SK, S.LAST_UPDT_USER_ID, S.LAST_UPDT_DT_SK);",
                "type": "Expression"
              }
            }
          ]
