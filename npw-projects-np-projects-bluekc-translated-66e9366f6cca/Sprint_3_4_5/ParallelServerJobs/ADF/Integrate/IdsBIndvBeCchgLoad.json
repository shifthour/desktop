{
  "name": "IdsBIndvBeCchgLoad",
  "properties": {
    "parameters": {
      "SrcSysCd": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "Copy_B_INDV_BE_CCHG",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_IDSOwner}.B_INDV_BE_CCHG",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "INDV_BE_KEY",
                  "type": "Decimal",
                  "physicalType": "decimal"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "CCHG_STRT_YR_MO_SK",
                  "type": "String",
                  "physicalType": "char"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "PRCS_YR_MO_SK",
                  "type": "String",
                  "physicalType": "char"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "Int64",
                  "physicalType": "int"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "ids",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/', 'load')",
              "param_filename": "@concat('B_INDV_BE_CCHG.', pipeline().parameters.SrcSysCd, '.dat')",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "B_INDV_BE_CCHG"
            }
          }
        ]
      }
    ],
    "folder": {
      "name": "Integrate/Jobs/DataWarehouse/MemberRisk/CCHG/IndvBeCCHG/Balancing"
    }
  },
  "Description": "PROCESSING:  This Job Loads Data from Sequential File created in xfrm Job and loads into IDS B_INDV_BE_CCHG table\n                                                                \n     \nMODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\nKalyan Neelam          2015-08-25           5460                               Initial Programming                                                                               IntegrateDev2            Bhoomi Dasari              8/30/2015\n\nAnnotations:\nRead Load File created in the FKEY job\nCopy Stage for buffer\nTruncate and Load B_INDV_BE_CCHG table\nLoad rejects are redirected into a Reject file"
}