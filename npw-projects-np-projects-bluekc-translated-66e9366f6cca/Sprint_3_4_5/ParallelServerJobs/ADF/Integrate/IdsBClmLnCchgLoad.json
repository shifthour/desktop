{
  "name": "IdsBClmLnCchgLoad",
  "properties": {
    "activities": [
      {
        "name": "Copy_B_CLM_LN_CCHG",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_IDSOwner}.B_CLM_LN_CCHG",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "CLM_ID",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "CLM_LN_SEQ_NO",
                  "type": "Int32",
                  "physicalType": "int"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "CLM_SRC_SYS_CD_SK",
                  "type": "Int32",
                  "physicalType": "int"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "PRCS_YR_MO_SK",
                  "type": "String",
                  "physicalType": "char"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 5
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "Int32",
                  "physicalType": "int"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "ids",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment,'/Jobs/DataWarehouse/MemberRisk/CCHG/ClmLnCCHG/Balancing/load')",
              "param_filename": "B_CLM_LN_CCHG.@{pipeline().parameters.SrcSysCd}.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "B_CLM_LN_CCHG"
            }
          }
        ]
      }
    ],
    "parameters": {
      "SrcSysCd": {
        "type": "string"
      }
    },
    "folder": {
      "name": "Integrate/Jobs/DataWarehouse/MemberRisk/CCHG/ClmLnCCHG/Balancing"
    }
  },
  "Description": "PROCESSING:  This Job Loads Data from Sequential File created in xfrm Job and loads into IDS B_CLM_LN_CCHG table\n                                                                \n     \nMODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\nKalyan Neelam          2015-08-25           5460                               Initial Programming                                                                               IntegrateDev2            Bhoomi Dasari              8/30/2015\n\nAnnotations:\nRead Load File created in the FKEY job\nCopy Stage for buffer\nTruncate and Load B_CLM_LN_CCHG table\nLoad rejects are redirected into a Reject file"
}