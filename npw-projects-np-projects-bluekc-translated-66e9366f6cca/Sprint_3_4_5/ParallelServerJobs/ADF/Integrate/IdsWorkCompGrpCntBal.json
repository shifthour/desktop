{
  "name": "IdsWorkCompGrpCntBal",
  "properties": {
    "parameters": {
      "ToleranceCd": {
        "type": "string"
      },
      "ExtrRunCycle": {
        "type": "string"
      },
      "RunID": {
        "type": "string"
      },
      "WorkCompOwner": {
        "type": "string"
      }
    },
    "activities": [
      {
        "name": "Copy_SrcTrgt_WorkCompGrp",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "SELECT bal.SRC_SYS_CD, grp.SRC_SYS_CD AS TRGT_SRC_SYS_CD, grp.GRP_ID AS TRGT_GRP_ID, bal.GRP_ID FROM @{pipeline().globalParameters.gbl_param_WorkCompOwner}.WORK_COMPNSTN_GRP grp FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_WorkCompOwner}.B_WORK_COMPNSTN_GRP bal ON grp.SRC_SYS_CD = bal.SRC_SYS_CD AND grp.GRP_ID = bal.GRP_ID WHERE grp.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle};",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "AzureSqlSink",
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false,
            "tableOption": "autoCreate",
            "preCopyScript": {
              "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.RefData_TMP_IdsWorkCompGrpCntBal",
              "type": "Expression"
            },
            "disableMetricsCollection": false
          }
        },
        "inputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "WORK_COMPNSTN_GRP"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_ids_staging}",
              "param_table": "RefData_TMP_IdsWorkCompGrpCntBal"
            }
          }
        ]
      },
      {
        "name": "Script_XfrmLogic",
        "type": "Script",
        "dependsOn": [
          {
            "activity": "Copy_SrcTrgt_WorkCompGrp",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.ResearchFile_TMP_IdsWorkCompGrpCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "SELECT TRGT_GRP_ID, TRGT_SRC_SYS_CD, GRP_ID, SRC_SYS_CD INTO @{pipeline().globalParameters.gbl_param_ids_staging}.ResearchFile_TMP_IdsWorkCompGrpCntBal FROM @{pipeline().globalParameters.gbl_param_ids_staging}.RefData_TMP_IdsWorkCompGrpCntBal WHERE TRGT_SRC_SYS_CD IS NULL OR SRC_SYS_CD IS NULL OR GRP_ID IS NULL OR TRGT_GRP_ID IS NULL",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Notify_TMP_IdsWorkCompGrpCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "WITH cte AS ( SELECT ROW_NUMBER() OVER(ORDER BY (SELECT 1)) AS rnk FROM @{pipeline().globalParameters.gbl_param_ids_staging}.RefData_TMP_IdsWorkCompGrpCntBal ) SELECT 'ROW COUNT BALANCING FACETS - IDS WORKERS COMP GRP OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Notify_TMP_IdsWorkCompGrpCntBal FROM cte WHERE rnk=1 AND '@{pipeline().parameters.ToleranceCd}'='OUT'",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "workcomp",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Copy_ResearchFile",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Script_XfrmLogic",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None"
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            }
          }
        },
        "inputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_ids_staging}",
              "param_table": "ResearchFile_TMP_IdsWorkCompGrpCntBal"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/balancing/research')",
              "param_filename": "FctsIdsWorkCompGrpResearch.dat.@{pipeline().parameters.RunID}",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ]
      },
      {
        "name": "Copy_ErrorNotificationFile",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Script_XfrmLogic",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None"
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            }
          }
        },
        "inputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_ids_staging}",
              "param_table": "Notify_TMP_IdsWorkCompGrpCntBal"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/balancing/notify')",
              "param_filename": "FctsIdsWorkCompMemberBalancingNotification.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "\"",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ]
      }
    ],
    "folder": {
      "name": "Integrate/Jobs/WorkersComp/Balancing"
    }
  },
  "Description": "*****************************************************************************************************************************************************************************\nCOPYRIGHT 2007 BLUE CROSS/BLUE SHIELD OF KANSAS CITY \n\n\nCALLED BY:  FctsIdsWorkCompGrpCaseBalSeq\n\nPROCESSING:\n                  This is where the actual balancing takes place and the Source and Target files are compared to see if there are any discrepancies \n\nMODIFICATIONS:\nDeveloper                          Date                 Project/Altiris #                Change Description                                         Development Project    Code Reviewer            Date Reviewed\n----------------------------------      -------------------    -----------------------------------    ---------------------------------------------------------                   ----------------------------------   ---------------------------------    -------------------------   \nAkhila Manickavelu         12/28/2016          5628-Work Comp        Originally Programmed                                        IntegrateDevl               Kalyan Neelam             2017-01-09\n\nKailashnath J                    2017-03-22          5628-Work Comp        Updated Notification File Name                            IntegrateDev2            Kalyan Neelam             2017-03-28\n\nAnnotations:\nThis job runs Balancing Full Outer Join SQL and finds out if there are any fallouts.\n\nTable name - WORK_COMPNSTN_GRP"
