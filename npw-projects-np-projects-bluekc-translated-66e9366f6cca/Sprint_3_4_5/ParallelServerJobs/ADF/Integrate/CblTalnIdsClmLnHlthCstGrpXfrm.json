              "text": {
                "value": "@concat(\n'DROP TABLE IF EXISTS ', pipeline().globalParameters.gbl_param_ids_staging, '.Z0CV_TMP_CblTalnPkeyOut; ',\n'SELECT ',\n\"('@{pipeline().parameters.SrcSysCd}' + ';' + CLM_ID + ';' + CAST(CLM_LN_SEQ_NO AS VARCHAR) + ';' + SRC_SYS_CD) AS PRI_NAT_KEY_STRING, \",\n\"CAST('@{pipeline().parameters.RunIDTimeStamp}' AS DATETIME) AS FIRST_RECYC_TS, \",\n\"0 AS CLM_LN_HLTH_CST_GRP_SK, \",\n\"CLM_ID, \",\n\"CLM_LN_SEQ_NO, \",\n\"SRC_SYS_CD AS CLM_SRC_SYS_CD, \",\n\"'@{pipeline().parameters.SrcSysCd}' AS SRC_SYS_CD, \",\n\"0 AS CRT_RUN_CYC_EXCTN_SK, \",\n\"0 AS LAST_UPDT_RUN_CYC_EXCTN_SK, \",\n\"CAST('@{pipeline().parameters.SrcSysCdSk}' AS INT) AS SRC_SYS_CD_SK, \",\n\"CASE WHEN LEN(RTRIM(LTRIM(CASE_ADM_ID)))=0 THEN 'NA' ELSE CASE_ADM_ID END AS CASE_ADM_ID, \",\n\"CASE WHEN MR_LN IS NULL THEN 'NA' ELSE UPPER(MR_LN) END AS MR_LN, \",\n\"CASE WHEN MR_LN_DTL IS NULL THEN 'NA' ELSE MR_LN_DTL END AS MR_LN_DTL, \",\n\"CASE WHEN MR_LN_CASE IS NULL THEN 'NA' ELSE MR_LN_CASE END AS MR_LN_CASE, \",\n\"MR_CASES_ADM, MR_UNIT_DAYS, MR_PROC, FCLTY_CASE_ID \",\n\"INTO \", pipeline().globalParameters.gbl_param_ids_staging, \".Z0CV_TMP_CblTalnPkeyOut \",\n\"FROM \", pipeline().globalParameters.gbl_param_ids_staging, \".Z0CV_TMP_CblTaln; \",\n\"DROP TABLE IF EXISTS \", pipeline().globalParameters.gbl_param_ids_staging, \".Z0CV_TMP_CblTalnSnapshot; \",\n\"SELECT CLM_ID, CLM_LN_SEQ_NO, CLM_SRC_SYS_CD_SK, CAST('@{pipeline().parameters.SrcSysCdSk}' AS INT) AS SRC_SYS_CD_SK \",\n\"INTO \", pipeline().globalParameters.gbl_param_ids_staging, \".Z0CV_TMP_CblTalnSnapshot \",\n\"FROM \", pipeline().globalParameters.gbl_param_ids_staging, \".Z0CV_TMP_CblTaln;\"\n)",
                "type": "Expression"
              }
            }
