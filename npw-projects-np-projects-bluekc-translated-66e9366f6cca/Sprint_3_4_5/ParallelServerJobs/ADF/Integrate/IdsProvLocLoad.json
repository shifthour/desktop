        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH cte AS ( SELECT PROV_LOC_SK,SRC_SYS_CD_SK,PROV_ID,PROV_ADDR_ID,PROV_ADDR_TYP_CD_SK,PROV_ADDR_EFF_DT_SK,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,PROV_ADDR_SK,PROV_SK,PRI_ADDR_IN,REMIT_ADDR_IN FROM @{pipeline().globalParameters.gbl_param_ids_staging}.D4AC_TMP_IdsProvLocLoad ) UPDATE @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV_LOC SET SRC_SYS_CD_SK=cte.SRC_SYS_CD_SK,PROV_ID=cte.PROV_ID,PROV_ADDR_ID=cte.PROV_ADDR_ID,PROV_ADDR_TYP_CD_SK=cte.PROV_ADDR_TYP_CD_SK,PROV_ADDR_EFF_DT_SK=cte.PROV_ADDR_EFF_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_SK=cte.LAST_UPDT_RUN_CYC_EXCTN_SK,PROV_ADDR_SK=cte.PROV_ADDR_SK,PROV_SK=cte.PROV_SK,PRI_ADDR_IN=cte.PRI_ADDR_IN,REMIT_ADDR_IN=cte.REMIT_ADDR_IN FROM cte WHERE @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV_LOC.PROV_LOC_SK=cte.PROV_LOC_SK INSERT INTO @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV_LOC(PROV_LOC_SK,SRC_SYS_CD_SK,PROV_ID,PROV_ADDR_ID,PROV_ADDR_TYP_CD_SK,PROV_ADDR_EFF_DT_SK,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,PROV_ADDR_SK,PROV_SK,PRI_ADDR_IN,REMIT_ADDR_IN) SELECT cte.PROV_LOC_SK,cte.SRC_SYS_CD_SK,cte.PROV_ID,cte.PROV_ADDR_ID,cte.PROV_ADDR_TYP_CD_SK,cte.PROV_ADDR_EFF_DT_SK,cte.CRT_RUN_CYC_EXCTN_SK,cte.LAST_UPDT_RUN_CYC_EXCTN_SK,cte.PROV_ADDR_SK,cte.PROV_SK,cte.PRI_ADDR_IN,cte.REMIT_ADDR_IN FROM cte WHERE NOT EXISTS (SELECT 1 FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV_LOC x WHERE x.PROV_LOC_SK=cte.PROV_LOC_SK)",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
