        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_raw}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment,'/landing/Jobs/ActivityFeeAnalysis')",
              "param_filename": "ActivityFeeMedDMatchCheck_@{pipeline().parameters.RunID}.csv",
              "param_col_delimiter": ",",
