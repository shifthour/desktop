      {
        "name": "Transform_Aggregate",
        "type": "Script",
        "dependsOn": [
          {
            "activity": "CopyInputFileToTemp",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.temp2_ActivityFeeMedDMatchPercent;WITH cte_agg AS (SELECT 'Totals and Match Percent:' AS Constant,SUM(INVOICE_QTY) AS Invoice_Act_Mbr_Total,SUM(TABLE_QTY) AS EDW_Act_Mbr_Total FROM @{pipeline().globalParameters.gbl_param_ids_staging}.temp_ActivityFeeMedDMatchPercent),cte_final AS (SELECT cte_agg.Constant AS Constant,' ' AS Filler1,' ' AS Filler2,' ' AS Filler3,' ' AS Filler4,CAST(cte_agg.Invoice_Act_Mbr_Total AS INT) AS Invoice_Act_Mbr_Total,CAST(cte_agg.EDW_Act_Mbr_Total AS INT) AS EDW_Act_Mbr_Total,((cte_agg.EDW_Act_Mbr_Total/cte_agg.Invoice_Act_Mbr_Total)*100) AS Match_Percent FROM cte_agg) SELECT Constant,Filler1,Filler2,Filler3,Filler4,Invoice_Act_Mbr_Total,EDW_Act_Mbr_Total,Match_Percent INTO @{pipeline().globalParameters.gbl_param_ids_staging}.temp2_ActivityFeeMedDMatchPercent FROM cte_final",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "CopyTemp2ToFile",
        "type": "Copy",
        "dependsOn": [
