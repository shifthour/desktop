              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Z999_TMP_IdsHedisMesrGapDplyFKey;WITH FILEDATA AS (SELECT HEDIS_MESR_GAP_DPLY_SK,HEDIS_MESR_NM,HEDIS_SUB_MESR_NM,HEDIS_MBR_BUCKET_ID,MOD_ID,HEDIS_MESR_GAP_DPLY_MOD_EFF_DT,SRC_SYS_CD,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,HEDIS_MESR_GAP_DPLY_MOD_TERM_DT,HEDIS_MESR_GAP_MOD_PRTY_NO,HEDIS_MESR_ABBR_ID,HEDIS_MESR_GAP_MOD_CAT_ID,HEDIS_MESR_GAP_MOD_DPLY_TX,HEDIS_MESR_GAP_MOD_SCRIPT_TX,HEDIS_MESR_MOD_KEY_ID FROM @{pipeline().globalParameters.gbl_param_ids_staging}.F834_TMP_IdsHedisMesrGapDplyFKey),DBDATA AS (SELECT HEDIS_MESR_GAP_SK,HEDIS_MESR_NM,HEDIS_SUB_MESR_NM,HEDIS_MBR_BUCKET_ID FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.HEDIS_MESR_GAP) SELECT f.HEDIS_MESR_GAP_DPLY_SK,f.HEDIS_MESR_NM,f.HEDIS_SUB_MESR_NM,f.HEDIS_MBR_BUCKET_ID,f.MOD_ID,f.HEDIS_MESR_GAP_DPLY_MOD_EFF_DT,f.SRC_SYS_CD,f.CRT_RUN_CYC_EXCTN_SK,f.LAST_UPDT_RUN_CYC_EXCTN_SK,b.HEDIS_MESR_GAP_SK,f.HEDIS_MESR_GAP_DPLY_MOD_TERM_DT,f.HEDIS_MESR_GAP_MOD_PRTY_NO,f.HEDIS_MESR_ABBR_ID,f.HEDIS_MESR_GAP_MOD_CAT_ID,f.HEDIS_MESR_MOD_KEY_ID,f.HEDIS_MESR_GAP_MOD_DPLY_TX,f.HEDIS_MESR_GAP_MOD_SCRIPT_TX INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Z999_TMP_IdsHedisMesrGapDplyFKey FROM FILEDATA f LEFT JOIN DBDATA b ON f.HEDIS_MESR_NM = b.HEDIS_MESR_NM AND f.HEDIS_SUB_MESR_NM = b.HEDIS_SUB_MESR_NM AND f.HEDIS_MBR_BUCKET_ID = b.HEDIS_MBR_BUCKET_ID",
