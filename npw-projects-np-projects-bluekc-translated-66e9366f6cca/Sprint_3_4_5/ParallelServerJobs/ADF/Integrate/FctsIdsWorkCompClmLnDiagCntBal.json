              "value": "WITH cte_src AS (SELECT clmLnDiag.CLM_ID AS TRGT_CLM_ID, clmLnDiag.CLM_LN_SEQ_NO AS TRGT_CLM_LN_SEQ_NO, clmLnDiag.SRC_SYS_CD AS TRGT_SRC_SYS_CD, clmLnDiag.CLM_LN_DIAG_ORDNL_CD AS TRGT_CLM_LN_DIAG_ORDNL_CD, bal.CLM_ID, bal.CLM_LN_SEQ_NO, bal.CLM_LN_DIAG_ORDNL_CD, bal.SRC_SYS_CD FROM @{pipeline().globalParameters.gbl_param_WorkCompOwner}.WORK_COMPNSTN_CLM_LN_DIAG clmLnDiag FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_WorkCompOwner}.B_WORK_COMPNSTN_CLM_LN_DIAG bal ON clmLnDiag.SRC_SYS_CD = bal.SRC_SYS_CD AND clmLnDiag.CLM_ID = bal.CLM_ID AND clmLnDiag.CLM_LN_SEQ_NO = bal.CLM_LN_SEQ_NO AND clmLnDiag.CLM_LN_DIAG_ORDNL_CD = bal.CLM_LN_DIAG_ORDNL_CD WHERE clmLnDiag.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle}) SELECT * FROM cte_src",
