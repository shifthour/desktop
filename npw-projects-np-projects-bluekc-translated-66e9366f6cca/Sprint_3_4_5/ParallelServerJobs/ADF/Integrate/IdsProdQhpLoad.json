              "value": "load",
              "type": "Expression"
            },
            "filename": {
              "value": "@concat('PROD_QHP.', pipeline().parameters.SrcSysCd, '.', pipeline().parameters.RunID, '.dat')",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
