              "type": "Query",
              "text": {
                "value": "WITH cte_filtered AS ( SELECT * FROM @{pipeline().globalParameters.gbl_param_ids_staging}.T1_TMP_OptumRXAccumsFinalReconLoad WHERE MBR_ELIG_IN = 'Y' AND dbo.trim_default(GRP_ID) <> '20624000' AND dbo.trim_default(GRP_ID) <> '34189000' ), cte_dedup AS ( SELECT cte_filtered.*, ROW_NUMBER() OVER (PARTITION BY MBR_ID, ACCUM_TYP_CD, FCTS_LAST_UPDT_DTM ORDER BY (SELECT NULL)) AS rn FROM cte_filtered ) DELETE FROM @{pipeline().globalParameters.gbl_param_GxCAccumReconOwner}.OPTUMRX_ACCUM_RECON; INSERT INTO @{pipeline().globalParameters.gbl_param_GxCAccumReconOwner}.OPTUMRX_ACCUM_RECON ( GRP_TYP_CD, GRP_ID, GRP_NM, PROD_ID, PROD_BILL_CMPNT_PFX, SUB_ID, MBR_ID, MBR_CK, MBR_FIRST_NM, MBR_LAST_NM, ACCUM_TYP_CD, ACCUM_EXCH_ERR, FIRST_DIFF_DT, FIRST_DIFF_AMT, FCTS_LAST_UPDT_DTM, MBR_PLN_LMT_NO, MBR_PLN_TOT_PCT, MBR_OPTUMRX_TOT_AMT, MBR_FCTS_TOT_AMT, MBR_DIFF_AMT, FMLY_PLN_LMT_NO, FMLY_PLN_TOT_PCT, FMLY_OPTUMRX_TOT_AMT, FMLY_FCTS_TOT_AMT, FMLY_DIFF_AMT, LAST_UPDT_DTM, RECON_IN, CAR_ID, MBR_ELIG_IN, MBR_EFF_DT, MBR_TERM_DT, PROD_CT ) SELECT GRP_TYP_CD, GRP_ID, GRP_NM, PROD_ID, PROD_BILL_CMPNT_PFX, SUB_ID, MBR_ID, MBR_CK, MBR_FIRST_NM, MBR_LAST_NM, ACCUM_TYP_CD, ACCUM_EXCH_ERR, FIRST_DIFF_DT, FIRST_DIFF_AMT, FCTS_LAST_UPDT_DTM, MBR_PLN_LMT_NO, MBR_PLN_TOT_PCT, MBR_OPTUMRX_TOT_AMT, MBR_FCTS_TOT_AMT, MBR_DIFF_AMT, FMLY_PLN_LMT_NO, FMLY_PLN_TOT_PCT, FMLY_OPTUMRX_TOT_AMT, FMLY_FCTS_TOT_AMT, FMLY_DIFF_AMT, LAST_UPDT_DTM, RECON_IN, CAR_ID, MBR_ELIG_IN, MBR_EFF_DT, MBR_TERM_DT, PROD_CT FROM cte_dedup WHERE rn = 1",
