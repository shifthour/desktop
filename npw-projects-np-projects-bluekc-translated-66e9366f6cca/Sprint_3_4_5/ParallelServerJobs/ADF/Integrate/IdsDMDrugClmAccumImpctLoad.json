              "type": "Query",
              "text": {
                "value": "@concat('WITH cte AS (SELECT SRC_SYS_CD, CLM_ID, NCP_COUPON_TYP_CD, NCP_COUPON_TYP_NM, CCAA_APLD_IN, CCAA_COUPON_AMT, FMLY_ACCUM_DEDCT_AMT, FMLY_ACCUM_OOP_AMT, INDV_ACCUM_DEDCT_AMT, INDV_ACCUM_OOP_AMT, INDV_APLD_DEDCT_AMT, INDV_APLD_OOP_AMT, LAST_UPDT_RUN_CYC_NO FROM ', pipeline().globalParameters.gbl_param_ids_staging, '.TMP_IdsDMDrugClmAccumImpctLoad) MERGE ', pipeline().globalParameters.gbl_param_IDSOwner, '.CLM_DM_DRUG_CLM_ACCUM_IMPCT AS T USING cte AS S ON T.SRC_SYS_CD = S.SRC_SYS_CD AND T.CLM_ID = S.CLM_ID WHEN MATCHED THEN UPDATE SET T.NCP_COUPON_TYP_CD = S.NCP_COUPON_TYP_CD, T.NCP_COUPON_TYP_NM = S.NCP_COUPON_TYP_NM, T.CCAA_APLD_IN = S.CCAA_APLD_IN, T.CCAA_COUPON_AMT = S.CCAA_COUPON_AMT, T.FMLY_ACCUM_DEDCT_AMT = S.FMLY_ACCUM_DEDCT_AMT, T.FMLY_ACCUM_OOP_AMT = S.FMLY_ACCUM_OOP_AMT, T.INDV_ACCUM_DEDCT_AMT = S.INDV_ACCUM_DEDCT_AMT, T.INDV_ACCUM_OOP_AMT = S.INDV_ACCUM_OOP_AMT, T.INDV_APLD_DEDCT_AMT = S.INDV_APLD_DEDCT_AMT, T.INDV_APLD_OOP_AMT = S.INDV_APLD_OOP_AMT, T.LAST_UPDT_RUN_CYC_NO = S.LAST_UPDT_RUN_CYC_NO WHEN NOT MATCHED THEN INSERT (SRC_SYS_CD, CLM_ID, NCP_COUPON_TYP_CD, NCP_COUPON_TYP_NM, CCAA_APLD_IN, CCAA_COUPON_AMT, FMLY_ACCUM_DEDCT_AMT, FMLY_ACCUM_OOP_AMT, INDV_ACCUM_DEDCT_AMT, INDV_ACCUM_OOP_AMT, INDV_APLD_DEDCT_AMT, INDV_APLD_OOP_AMT, LAST_UPDT_RUN_CYC_NO) VALUES (S.SRC_SYS_CD, S.CLM_ID, S.NCP_COUPON_TYP_CD, S.NCP_COUPON_TYP_NM, S.CCAA_APLD_IN, S.CCAA_COUPON_AMT, S.FMLY_ACCUM_DEDCT_AMT, S.FMLY_ACCUM_OOP_AMT, S.INDV_ACCUM_DEDCT_AMT, S.INDV_ACCUM_OOP_AMT, S.INDV_APLD_DEDCT_AMT, S.INDV_APLD_OOP_AMT, S.LAST_UPDT_RUN_CYC_NO);')",
