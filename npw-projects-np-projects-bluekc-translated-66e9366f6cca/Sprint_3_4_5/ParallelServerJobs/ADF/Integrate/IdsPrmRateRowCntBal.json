            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.RND001_TMP_IdsPrmRateRowCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "SELECT TRGT.SRC_SYS_CD_SK AS TRGT_SRC_SYS_CD_SK, TRGT.PRM_RATE_UNIQ_KEY AS TRGT_PRM_RATE_UNIQ_KEY, SRC.SRC_SYS_CD_SK AS SRC_SRC_SYS_CD_SK, SRC.PRM_RATE_UNIQ_KEY AS SRC_PRM_RATE_UNIQ_KEY INTO @{pipeline().globalParameters.gbl_param_ids_staging}.RND001_TMP_IdsPrmRateRowCntBal FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.PRM_RATE AS TRGT FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.B_PRM_RATE AS SRC ON TRGT.SRC_SYS_CD_SK = SRC.SRC_SYS_CD_SK AND TRGT.PRM_RATE_UNIQ_KEY = SRC.PRM_RATE_UNIQ_KEY WHERE TRGT.LAST_UPDT_RUN_CYC_EXCTN_SK = @{pipeline().parameters.ExtrRunCycle}",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.RND002_TMP_IdsPrmRateRowCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "SELECT TRGT_SRC_SYS_CD_SK, TRGT_PRM_RATE_UNIQ_KEY, SRC_SRC_SYS_CD_SK, SRC_PRM_RATE_UNIQ_KEY INTO @{pipeline().globalParameters.gbl_param_ids_staging}.RND002_TMP_IdsPrmRateRowCntBal FROM @{pipeline().globalParameters.gbl_param_ids_staging}.RND001_TMP_IdsPrmRateRowCntBal WHERE TRGT_SRC_SYS_CD_SK IS NULL OR TRGT_PRM_RATE_UNIQ_KEY IS NULL OR SRC_SRC_SYS_CD_SK IS NULL OR SRC_PRM_RATE_UNIQ_KEY IS NULL",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.RND003_TMP_IdsPrmRateRowCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "IF ('@{pipeline().parameters.ToleranceCd}' = 'OUT') BEGIN SELECT TOP 1 'ROW COUNT BALANCING FACETS - IDS PREMIUM RATING IS OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.RND003_TMP_IdsPrmRateRowCntBal FROM @{pipeline().globalParameters.gbl_param_ids_staging}.RND001_TMP_IdsPrmRateRowCntBal END ELSE BEGIN SELECT TOP 0 ' ' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.RND003_TMP_IdsPrmRateRowCntBal END",
                "type": "Expression"
              }
            }
          ]
        },
