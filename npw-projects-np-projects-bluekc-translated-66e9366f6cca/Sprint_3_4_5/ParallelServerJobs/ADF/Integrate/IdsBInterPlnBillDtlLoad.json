                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "Int64",
                  "physicalType": "INT"
                }
              }
            ]
          },
          "linkedServiceName": {
