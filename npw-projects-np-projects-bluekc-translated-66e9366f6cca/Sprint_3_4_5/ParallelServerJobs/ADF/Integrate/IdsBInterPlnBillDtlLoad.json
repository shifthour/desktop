              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_IDSOwner}.B_INTER_PLN_BILL_DTL",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
