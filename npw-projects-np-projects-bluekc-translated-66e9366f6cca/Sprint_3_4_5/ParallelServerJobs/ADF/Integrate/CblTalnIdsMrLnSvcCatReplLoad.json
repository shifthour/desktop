                "value": "WITH cte AS (SELECT MR_LN_SVC_CAT_SK AS MR_LN_SVC_CAT_RPLC_SK, MR_LN_ID, EFF_DT_SK, SRC_SYS_CD_SK, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, TERM_DT_SK, ACTURL_HLTH_CST_GRP_CAT_ID, CST_MDL_UNIT_OF_MESR_ID, MR_LN_DESC, MR_LN_PFX_DESC, MR_LN_BODY_DESC, MR_LN_SFX_DESC, '@{pipeline().parameters.VersionId}' AS VRSN_ID FROM @{pipeline().globalParameters.gbl_param_ids_staging}.2be7da9d_TMP_CblTalnIdsMrLnSvcCatReplLoad) MERGE @{pipeline().globalParameters.gbl_param_IDSOwner}.MR_LN_SVC_CAT_RPLC AS T USING cte AS S ON T.MR_LN_SVC_CAT_RPLC_SK = S.MR_LN_SVC_CAT_RPLC_SK WHEN MATCHED THEN UPDATE SET T.MR_LN_ID = S.MR_LN_ID, T.EFF_DT_SK = S.EFF_DT_SK, T.SRC_SYS_CD_SK = S.SRC_SYS_CD_SK, T.CRT_RUN_CYC_EXCTN_SK = S.CRT_RUN_CYC_EXCTN_SK, T.LAST_UPDT_RUN_CYC_EXCTN_SK = S.LAST_UPDT_RUN_CYC_EXCTN_SK, T.TERM_DT_SK = S.TERM_DT_SK, T.ACTURL_HLTH_CST_GRP_CAT_ID = S.ACTURL_HLTH_CST_GRP_CAT_ID, T.CST_MDL_UNIT_OF_MESR_ID = S.CST_MDL_UNIT_OF_MESR_ID, T.MR_LN_DESC = S.MR_LN_DESC, T.MR_LN_PFX_DESC = S.MR_LN_PFX_DESC, T.MR_LN_BODY_DESC = S.MR_LN_BODY_DESC, T.MR_LN_SFX_DESC = S.MR_LN_SFX_DESC, T.VRSN_ID = S.VRSN_ID WHEN NOT MATCHED THEN INSERT (MR_LN_SVC_CAT_RPLC_SK, MR_LN_ID, EFF_DT_SK, SRC_SYS_CD_SK, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, TERM_DT_SK, ACTURL_HLTH_CST_GRP_CAT_ID, CST_MDL_UNIT_OF_MESR_ID, MR_LN_DESC, MR_LN_PFX_DESC, MR_LN_BODY_DESC, MR_LN_SFX_DESC, VRSN_ID) VALUES (S.MR_LN_SVC_CAT_RPLC_SK, S.MR_LN_ID, S.EFF_DT_SK, S.SRC_SYS_CD_SK, S.CRT_RUN_CYC_EXCTN_SK, S.LAST_UPDT_RUN_CYC_EXCTN_SK, S.TERM_DT_SK, S.ACTURL_HLTH_CST_GRP_CAT_ID, S.CST_MDL_UNIT_OF_MESR_ID, S.MR_LN_DESC, S.MR_LN_PFX_DESC, S.MR_LN_BODY_DESC, S.MR_LN_SFX_DESC, S.VRSN_ID);",
