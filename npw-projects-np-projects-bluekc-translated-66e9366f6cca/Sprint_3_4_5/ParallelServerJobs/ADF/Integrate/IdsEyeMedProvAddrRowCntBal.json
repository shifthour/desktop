        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "WITH CTE1 AS (SELECT PROV_ADDR.SRC_SYS_CD_SK AS TRGT_SRC_SYS_CD_SK,PROV_ADDR.PROV_ADDR_ID AS TRGT_PROV_ADDR_ID,PROV_ADDR.PROV_ADDR_TYP_CD_SK AS TRGT_PROV_ADDR_TYP_CD_SK,PROV_ADDR.PROV_ADDR_EFF_DT_SK AS TRGT_PROV_ADDR_EFF_DT_SK,B_PROV_ADDR.SRC_SYS_CD_SK AS SRC_SYS_CD_SK,B_PROV_ADDR.PROV_ADDR_ID,B_PROV_ADDR.PROV_ADDR_TYP_CD_SK,B_PROV_ADDR.PROV_ADDR_EFF_DT_SK FROM ( @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV_ADDR PROV_ADDR FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.B_PROV_ADDR B_PROV_ADDR ON PROV_ADDR.PROV_ADDR_ID = B_PROV_ADDR.PROV_ADDR_ID AND PROV_ADDR.PROV_ADDR_TYP_CD_SK = B_PROV_ADDR.PROV_ADDR_TYP_CD_SK AND PROV_ADDR.PROV_ADDR_EFF_DT_SK = B_PROV_ADDR.PROV_ADDR_EFF_DT_SK AND PROV_ADDR.SRC_SYS_CD_SK = B_PROV_ADDR.SRC_SYS_CD_SK ) CROSS JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.CD_MPPNG MPPNG WHERE PROV_ADDR.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle} AND PROV_ADDR.SRC_SYS_CD_SK = MPPNG.CD_MPPNG_SK AND MPPNG.TRGT_CD = 'EYEMED' ) SELECT TRGT_SRC_SYS_CD_SK,TRGT_PROV_ADDR_ID,TRGT_PROV_ADDR_TYP_CD_SK,TRGT_PROV_ADDR_EFF_DT_SK,SRC_SYS_CD_SK,PROV_ADDR_ID,PROV_ADDR_TYP_CD_SK,PROV_ADDR_EFF_DT_SK INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal FROM CTE1",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal_Research",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "SELECT TRGT_SRC_SYS_CD_SK,TRGT_PROV_ADDR_ID,TRGT_PROV_ADDR_TYP_CD_SK,TRGT_PROV_ADDR_EFF_DT_SK,SRC_SYS_CD_SK,PROV_ADDR_ID,PROV_ADDR_TYP_CD_SK,PROV_ADDR_EFF_DT_SK INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal_Research FROM @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal WHERE PROV_ADDR_ID IS NULL OR TRGT_PROV_ADDR_ID IS NULL",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal_Notify",
                "type": "Expression"
              }
            },
            {
              "type": "Query",
              "text": {
                "value": "SELECT TOP 1 'ROW COUNT BALANCING EYEMED - IDS PROV ADDR OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal_Notify FROM @{pipeline().globalParameters.gbl_param_ids_staging}.Xb12_TMP_IdsEyeMedProvAddrRowCntBal WHERE '@{pipeline().parameters.ToleranceCd}' = 'OUT'",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
