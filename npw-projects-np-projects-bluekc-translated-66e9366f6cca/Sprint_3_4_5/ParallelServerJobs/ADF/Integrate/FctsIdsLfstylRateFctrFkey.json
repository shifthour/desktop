            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.TT2_TMP_FctsIdsLfstylRateFctrFkey_fail; WITH failCTE AS (SELECT LFSTYL_RATE_FCTR_SK AS PRI_SK, PRI_NAT_KEY_STRING, CAST(SRC_SYS_CD AS INT) AS SRC_SYS_CD_SK, 'FctsIdsLfstylRateFctrFkey' AS JOB_NM, 'CDLOOKUP' AS ERROR_TYP, 'CD_MPPNG' AS PHYSCL_FILE_NM, (LFSTYL_RATE_FCTR_ID + ';' + MBR_LFSTYL_BNF_CD + ';' + CAST(LFSTYL_RATE_FCTR_EFF_DT AS VARCHAR(23)) + ';' + SRC_SYS_CD) AS FRGN_NAT_KEY_STRING, FIRST_RECYC_TS, LAST_UPDT_RUN_CYC_EXCTN_SK AS JOB_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_ids_staging}.TT1_TMP_FctsIdsLfstylRateFctrFkey WHERE MBR_LFSTYL_BNF_CD_SK IS NULL) SELECT PRI_SK, PRI_NAT_KEY_STRING, SRC_SYS_CD_SK, JOB_NM, ERROR_TYP, PHYSCL_FILE_NM, FRGN_NAT_KEY_STRING, FIRST_RECYC_TS, JOB_EXCTN_SK INTO @{pipeline().globalParameters.gbl_param_ids_staging}.TT2_TMP_FctsIdsLfstylRateFctrFkey_fail FROM failCTE; DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.TT2_TMP_FctsIdsLfstylRateFctrFkey_funnel; WITH mainCTE AS (SELECT LFSTYL_RATE_FCTR_SK, LFSTYL_RATE_FCTR_ID, MBR_LFSTYL_BNF_CD, LFSTYL_RATE_FCTR_EFF_DT, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, MBR_LFSTYL_BNF_CD_SK, LFSTYL_RATE_FCTR_TERM_DT, LFSTYL_RATE_FCTR FROM @{pipeline().globalParameters.gbl_param_ids_staging}.TT1_TMP_FctsIdsLfstylRateFctrFkey WHERE MBR_LFSTYL_BNF_CD_SK IS NOT NULL), UNK AS (SELECT 0 AS LFSTYL_RATE_FCTR_SK, 'UNK' AS LFSTYL_RATE_FCTR_ID, 'UNK' AS MBR_LFSTYL_BNF_CD, '1753-01-01 00:00:00' AS LFSTYL_RATE_FCTR_EFF_DT, 'UNK' AS SRC_SYS_CD, 0 AS CRT_RUN_CYC_EXCTN_SK, 0 AS LAST_UPDT_RUN_CYC_EXCTN_SK, 0 AS MBR_LFSTYL_BNF_CD_SK, '2199-12-31 00:00:00' AS LFSTYL_RATE_FCTR_TERM_DT, 0 AS LFSTYL_RATE_FCTR), NA AS (SELECT 1 AS LFSTYL_RATE_FCTR_SK, 'NA' AS LFSTYL_RATE_FCTR_ID, 'NA' AS MBR_LFSTYL_BNF_CD, '1753-01-01 00:00:00' AS LFSTYL_RATE_FCTR_EFF_DT, 'NA' AS SRC_SYS_CD, 0 AS CRT_RUN_CYC_EXCTN_SK, 0 AS LAST_UPDT_RUN_CYC_EXCTN_SK, 1 AS MBR_LFSTYL_BNF_CD_SK, '2199-12-31 00:00:00' AS LFSTYL_RATE_FCTR_TERM_DT, 0 AS LFSTYL_RATE_FCTR), allCTE AS (SELECT * FROM mainCTE UNION ALL SELECT * FROM UNK UNION ALL SELECT * FROM NA) SELECT * INTO @{pipeline().globalParameters.gbl_param_ids_staging}.TT2_TMP_FctsIdsLfstylRateFctrFkey_funnel FROM allCTE",
                "type": "Expression"
              }
            }
