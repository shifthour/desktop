{
  "name": "IdsBProvLoad",
  "properties": {
    "activities": [
      {
        "name": "Copy_IdsBProvLoad",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_IDSOwner}.B_PROV",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "INT",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "PROV_ID",
                  "type": "STRING",
                  "physicalType": "VARCHAR"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "CMN_PRCT_SK",
                  "type": "INT",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "REL_GRP_PROV_SK",
                  "type": "INT",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 5
                },
                "sink": {
                  "name": "REL_IPA_PROV_SK",
                  "type": "INT",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 6
                },
                "sink": {
                  "name": "PROV_ENTY_CD_SK",
                  "type": "INT",
                  "physicalType": "INT"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "ids",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": {
                "value": "@concat(pipeline().globalParameters.gbl_param_environment,'/','load')",
                "type": "Expression"
              },
              "param_filename": {
                "value": "@concat('B_PROV.', pipeline().parameters.SrcSysCd, '.dat')",
                "type": "Expression"
              },
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "B_PROV"
            }
          }
        ]
      },
      {
        "name": "DB2Stats_B_PROV",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Copy_IdsBProvLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path,'/sequencer_routines/Move_File')",
            "type": "Expression"
          },
          "baseParameters": {
            "EnvProjectPath": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "FilePath": {
              "value": "'load'",
              "type": "Expression"
            },
            "filename": {
              "value": "@concat('B_PROV.', pipeline().parameters.SrcSysCd, '.dat')",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "parameters": {
      "SrcSysCd": {
        "type": "String"
      }
    },
    "annotations": [],
    "runtimeConfigurations": {},
    "folder": {
      "name": "Integrate/Jobs/DataWarehouse/Provider/Prov/Balancing"
    }
  },
  "Description": "MODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\n\nPooja Sunkara         2014-08-27               5345                             Original Programming                                                                      IntegrateWrhsDevl       Kalyan Neelam              2015-01-08\n\nAnnotations:\nRead Load File created in the FKEY job\nCopy Stage for buffer\nTruncate and Load B_PROV  table\nLoad rejects are redirected into a Reject file"
}