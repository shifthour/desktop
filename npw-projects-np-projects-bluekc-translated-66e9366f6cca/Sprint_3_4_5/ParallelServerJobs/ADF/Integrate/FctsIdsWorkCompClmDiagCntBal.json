        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH cte AS (SELECT diag.CLM_ID AS TRGT_CLM_ID, diag.CLM_DIAG_ORDNL_CD AS TRGT_CLM_DIAG_ORDNL_CD, diag.SRC_SYS_CD AS TRGT_SRC_SYS_CD, bal.CLM_ID, bal.CLM_DIAG_ORDNL_CD, bal.SRC_SYS_CD FROM @{pipeline().globalParameters.gbl_param_WorkCompOwner}.WORK_COMPNSTN_CLM_DIAG diag FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_WorkCompOwner}.B_WORK_COMPNSTN_CLM_DIAG bal ON diag.SRC_SYS_CD = bal.SRC_SYS_CD AND diag.CLM_ID = bal.CLM_ID AND diag.CLM_DIAG_ORDNL_CD = bal.CLM_DIAG_ORDNL_CD WHERE diag.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle}) DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Research_TMP_FctsIdsWorkCompClmDiagCntBal; SELECT TRGT_CLM_ID, TRGT_CLM_DIAG_ORDNL_CD, TRGT_SRC_SYS_CD, CLM_ID, CLM_DIAG_ORDNL_CD, SRC_SYS_CD INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Research_TMP_FctsIdsWorkCompClmDiagCntBal FROM cte WHERE TRGT_CLM_ID IS NULL OR CLM_ID IS NULL OR TRGT_CLM_DIAG_ORDNL_CD IS NULL OR CLM_DIAG_ORDNL_CD IS NULL OR TRGT_SRC_SYS_CD IS NULL OR SRC_SYS_CD IS NULL; DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.Notify_TMP_FctsIdsWorkCompClmDiagCntBal; SELECT 'ROW COUNT BALANCING FACETS - IDS WORKERS COMP CLM DIAG OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.Notify_TMP_FctsIdsWorkCompClmDiagCntBal FROM (SELECT 1 AS dummy) A WHERE @{pipeline().parameters.ToleranceCd} = 'OUT';",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "CopyResearchFctsIdsWorkCompClmDiagCntBal",
        "type": "Copy",
        "dependsOn": [
          {
