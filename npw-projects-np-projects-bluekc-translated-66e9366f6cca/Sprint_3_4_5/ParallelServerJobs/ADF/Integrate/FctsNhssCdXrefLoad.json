            },
            "FilePath": {
              "value": "@concat(pipeline().globalParameters.gbl_param_environment, '/', 'load/')",
              "type": "Expression"
            },
            "filename": {
              "value": "NHSS_RTRN_CD.dat",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "parameters": {},
    "folder": {
      "name": "Integrate/Jobs/codes/NHSSCDXref"
