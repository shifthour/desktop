            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH CTE AS (SELECT PROV.SRC_SYS_CD_SK AS TRGT_SRC_SYS_CD_SK, PROV.PROV_ID AS TRGT_PROV_ID, B_PROV.SRC_SYS_CD_SK AS SRC_SRC_SYS_CD_SK, B_PROV.PROV_ID AS SRC_PROV_ID FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.CD_MPPNG MPPNG, @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV PROV FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.B_PROV B_PROV ON PROV.SRC_SYS_CD_SK = B_PROV.SRC_SYS_CD_SK AND PROV.PROV_ID = B_PROV.PROV_ID WHERE PROV.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle} AND PROV.SRC_SYS_CD_SK = MPPNG.CD_MPPNG_SK AND MPPNG.TRGT_CD = 'BCA') SELECT TRGT_SRC_SYS_CD_SK, TRGT_PROV_ID, SRC_SRC_SYS_CD_SK, SRC_PROV_ID FROM CTE",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "AzureSqlSink",
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false,
            "tableOption": "autoCreate",
            "disableMetricsCollection": false,
            "preCopyScript": {
              "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.A0_TMP_IdsFepProvRowCntBal",
              "type": "Expression"
            }
