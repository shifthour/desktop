              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal;WITH cte_src_trgt AS (SELECT SRC.INDV_BE_KEY AS SRC_INDV_BE_KEY,SRC.CCHG_STRT_YR_MO_SK AS SRC_CCHG_STRT_YR_MO_SK,SRC.PRCS_YR_MO_SK AS SRC_PRCS_YR_MO_SK,SRC.SRC_SYS_CD_SK AS SRC_SRC_SYS_CD_SK,TRGT.INDV_BE_KEY AS TRGT_INDV_BE_KEY,TRGT.CCHG_STRT_YR_MO_SK AS TRGT_CCHG_STRT_YR_MO_SK,TRGT.PRCS_YR_MO_SK AS TRGT_PRCS_YR_MO_SK,TRGT.SRC_SYS_CD_SK AS TRGT_SRC_SYS_CD_SK FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.B_INDV_BE_CCHG AS SRC FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.INDV_BE_CCHG AS TRGT ON TRGT.INDV_BE_KEY = SRC.INDV_BE_KEY AND TRGT.CCHG_STRT_YR_MO_SK = SRC.CCHG_STRT_YR_MO_SK AND TRGT.PRCS_YR_MO_SK = SRC.PRCS_YR_MO_SK AND TRGT.SRC_SYS_CD_SK = SRC.SRC_SYS_CD_SK WHERE TRGT.LAST_UPDT_RUN_CYC_EXCTN_SK = @{pipeline().parameters.ExtrRunCycle}) SELECT * INTO @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal FROM cte_src_trgt;DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal_Research;SELECT SRC_INDV_BE_KEY,SRC_CCHG_STRT_YR_MO_SK,SRC_PRCS_YR_MO_SK,SRC_SRC_SYS_CD_SK,TRGT_INDV_BE_KEY,TRGT_CCHG_STRT_YR_MO_SK,TRGT_PRCS_YR_MO_SK,TRGT_SRC_SYS_CD_SK INTO @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal_Research FROM @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal WHERE SRC_INDV_BE_KEY IS NULL OR SRC_CCHG_STRT_YR_MO_SK IS NULL OR SRC_PRCS_YR_MO_SK IS NULL OR SRC_SRC_SYS_CD_SK IS NULL OR TRGT_INDV_BE_KEY IS NULL OR TRGT_CCHG_STRT_YR_MO_SK IS NULL OR TRGT_PRCS_YR_MO_SK IS NULL OR TRGT_SRC_SYS_CD_SK IS NULL;DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal_Notify;SELECT TOP 1 'ROW COUNT BALANCING FACETS - IDS INDV_BE_CCHG IS OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal_Notify FROM @{pipeline().globalParameters.gbl_param_ids_staging}.StgTmp_TMP_IdsIndvBeCchgRowCntBal WHERE '@{pipeline().parameters.ToleranceCd}'='OUT';",
                "type": "Expression"
