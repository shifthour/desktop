{
  "name": "IdsBProvLocLoad",
  "properties": {
    "parameters": {
      "SrcSysCd": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "copy_IdsBProvLocLoad",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_IDSOwner}.B_PROV_LOC",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "Int32",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "PROV_ID",
                  "type": "String",
                  "physicalType": "VARCHAR"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "PROV_ADDR_ID",
                  "type": "String",
                  "physicalType": "VARCHAR"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "PROV_ADDR_TYP_CD_SK",
                  "type": "Int32",
                  "physicalType": "INT"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 5
                },
                "sink": {
                  "name": "PROV_ADDR_EFF_DT_SK",
                  "type": "String",
                  "physicalType": "CHAR"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "ids",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "'@concat(pipeline().globalParameters.gbl_param_environment, '/load')'",
              "param_filename": "'B_PROV_LOC.@{pipeline().parameters.SrcSysCd}.dat'",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "'^'",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "B_PROV_LOC"
            }
          }
        ]
      },
      {
        "name": "db2stats_IdsBProvLocLoad",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "copy_IdsBProvLocLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path,'/sequencer_routines/Move_File')",
            "type": "Expression"
          },
          "baseParameters": {
            "EnvProjectPath": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "FilePath": {
              "value": "load",
              "type": "Expression"
            },
            "filename": {
              "value": "@concat('B_PROV_LOC.', pipeline().parameters.SrcSysCd, '.dat')",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "folder": {
      "name": "Integrate/Jobs/DataWarehouse/Provider/ProvLoc/Balancing"
    }
  },
  "Description": "MODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\n\nPooja Sunkara         2014-08-07               5345                             Original Programming                                                                      IntegrateWrhsDevl       Kalyan Neelam              2015-01-08\n\nAnnotations:\nRead Load File created in the FKEY job\nCopy Stage for buffer\nTruncate and Load B_PROV_LOC table\nLoad rejects are redirected into a Reject file"
}