        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH cte AS (SELECT PROV_SK,SRC_SYS_CD_SK,PROV_ID,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,CMN_PRCT_SK,PROV_BILL_SVC_SK,REL_GRP_PROV_SK,REL_IPA_PROV_SK,PROV_CAP_PAYMT_EFT_METH_CD_SK,PROV_CLM_PAYMT_EFT_METH_CD_SK,PROV_CLM_PAYMT_METH_CD_SK,PROV_ENTY_CD_SK,PROV_FCLTY_TYP_CD_SK,PROV_PRCTC_TYP_CD_SK,PROV_SVC_CAT_CD_SK,PROV_SPEC_CD_SK,PROV_STTUS_CD_SK,PROV_TERM_RSN_CD_SK,PROV_TYP_CD_SK,TERM_DT_SK,PAYMT_HOLD_DT_SK,CLRNGHSE_ID,EDI_DEST_ID,EDI_DEST_QLFR_TX,NTNL_PROV_ID,PROV_ADDR_ID,PROV_NM,TAX_ID,NTNL_PROV_SK,TXNMY_CD FROM @{pipeline().globalParameters.gbl_param_ids_staging}.TMP_IdsProvLoad) UPDATE T SET T.SRC_SYS_CD_SK=C.SRC_SYS_CD_SK,T.PROV_ID=C.PROV_ID,T.LAST_UPDT_RUN_CYC_EXCTN_SK=C.LAST_UPDT_RUN_CYC_EXCTN_SK,T.CMN_PRCT_SK=C.CMN_PRCT_SK,T.PROV_BILL_SVC_SK=C.PROV_BILL_SVC_SK,T.REL_GRP_PROV_SK=C.REL_GRP_PROV_SK,T.REL_IPA_PROV_SK=C.REL_IPA_PROV_SK,T.PROV_CAP_PAYMT_EFT_METH_CD_SK=C.PROV_CAP_PAYMT_EFT_METH_CD_SK,T.PROV_CLM_PAYMT_EFT_METH_CD_SK=C.PROV_CLM_PAYMT_EFT_METH_CD_SK,T.PROV_CLM_PAYMT_METH_CD_SK=C.PROV_CLM_PAYMT_METH_CD_SK,T.PROV_ENTY_CD_SK=C.PROV_ENTY_CD_SK,T.PROV_FCLTY_TYP_CD_SK=C.PROV_FCLTY_TYP_CD_SK,T.PROV_PRCTC_TYP_CD_SK=C.PROV_PRCTC_TYP_CD_SK,T.PROV_SVC_CAT_CD_SK=C.PROV_SVC_CAT_CD_SK,T.PROV_SPEC_CD_SK=C.PROV_SPEC_CD_SK,T.PROV_STTUS_CD_SK=C.PROV_STTUS_CD_SK,T.PROV_TERM_RSN_CD_SK=C.PROV_TERM_RSN_CD_SK,T.PROV_TYP_CD_SK=C.PROV_TYP_CD_SK,T.TERM_DT_SK=C.TERM_DT_SK,T.PAYMT_HOLD_DT_SK=C.PAYMT_HOLD_DT_SK,T.CLRNGHSE_ID=C.CLRNGHSE_ID,T.EDI_DEST_ID=C.EDI_DEST_ID,T.EDI_DEST_QLFR_TX=C.EDI_DEST_QLFR_TX,T.NTNL_PROV_ID=C.NTNL_PROV_ID,T.PROV_ADDR_ID=C.PROV_ADDR_ID,T.PROV_NM=C.PROV_NM,T.TAX_ID=C.TAX_ID,T.NTNL_PROV_SK=C.NTNL_PROV_SK,T.TXNMY_CD=C.TXNMY_CD FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV T JOIN cte C ON T.PROV_SK=C.PROV_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV (PROV_SK,SRC_SYS_CD_SK,PROV_ID,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,CMN_PRCT_SK,PROV_BILL_SVC_SK,REL_GRP_PROV_SK,REL_IPA_PROV_SK,PROV_CAP_PAYMT_EFT_METH_CD_SK,PROV_CLM_PAYMT_EFT_METH_CD_SK,PROV_CLM_PAYMT_METH_CD_SK,PROV_ENTY_CD_SK,PROV_FCLTY_TYP_CD_SK,PROV_PRCTC_TYP_CD_SK,PROV_SVC_CAT_CD_SK,PROV_SPEC_CD_SK,PROV_STTUS_CD_SK,PROV_TERM_RSN_CD_SK,PROV_TYP_CD_SK,TERM_DT_SK,PAYMT_HOLD_DT_SK,CLRNGHSE_ID,EDI_DEST_ID,EDI_DEST_QLFR_TX,NTNL_PROV_ID,PROV_ADDR_ID,PROV_NM,TAX_ID,NTNL_PROV_SK,TXNMY_CD) SELECT C.PROV_SK,C.SRC_SYS_CD_SK,C.PROV_ID,C.CRT_RUN_CYC_EXCTN_SK,C.LAST_UPDT_RUN_CYC_EXCTN_SK,C.CMN_PRCT_SK,C.PROV_BILL_SVC_SK,C.REL_GRP_PROV_SK,C.REL_IPA_PROV_SK,C.PROV_CAP_PAYMT_EFT_METH_CD_SK,C.PROV_CLM_PAYMT_EFT_METH_CD_SK,C.PROV_CLM_PAYMT_METH_CD_SK,C.PROV_ENTY_CD_SK,C.PROV_FCLTY_TYP_CD_SK,C.PROV_PRCTC_TYP_CD_SK,C.PROV_SVC_CAT_CD_SK,C.PROV_SPEC_CD_SK,C.PROV_STTUS_CD_SK,C.PROV_TERM_RSN_CD_SK,C.PROV_TYP_CD_SK,C.TERM_DT_SK,C.PAYMT_HOLD_DT_SK,C.CLRNGHSE_ID,C.EDI_DEST_ID,C.EDI_DEST_QLFR_TX,C.NTNL_PROV_ID,C.PROV_ADDR_ID,C.PROV_NM,C.TAX_ID,C.NTNL_PROV_SK,C.TXNMY_CD FROM cte C LEFT JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.PROV T ON T.PROV_SK=C.PROV_SK WHERE T.PROV_SK IS NULL",
                "type": "Expression"
              }
            }
