        ]
      },
      {
        "name": "Script_Aggregate",
        "type": "Script",
        "dependsOn": [
          {
            "activity": "CopyFileToTemp",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.BB44_TMP_ActivityFeeCommMatchPercent;WITH Add_Constant AS (SELECT 'Totals and Match Percent:' AS Constant, INVOICE_QTY, TABLE_QTY FROM @{pipeline().globalParameters.gbl_param_ids_staging}.AA23_TMP_ActivityFeeCommMatchPercent),Aggregate_Constant AS (SELECT Constant, SUM(INVOICE_QTY) AS Invoice_Act_Mbr_Total, SUM(TABLE_QTY) AS EDW_Act_Mbr_Total FROM Add_Constant GROUP BY Constant),Trans_Match_Percent AS (SELECT Constant, ' ' AS Filler1, ' ' AS Filler2, ' ' AS Filler3, ' ' AS Filler4, Invoice_Act_Mbr_Total, EDW_Act_Mbr_Total, ((EDW_Act_Mbr_Total*1.0)/Invoice_Act_Mbr_Total)*100 AS Match_Percent FROM Aggregate_Constant) SELECT * INTO @{pipeline().globalParameters.gbl_param_ids_staging}.BB44_TMP_ActivityFeeCommMatchPercent FROM Trans_Match_Percent",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "CopyAggrToFile",
        "type": "Copy",
        "dependsOn": [
