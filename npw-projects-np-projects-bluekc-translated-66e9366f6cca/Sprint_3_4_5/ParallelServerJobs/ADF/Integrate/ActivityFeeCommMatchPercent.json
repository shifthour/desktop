              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/', 'landing')",
              "param_filename": "@concat('ActivityFeeCommMatchCheck_', pipeline().parameters.RunID, '.csv')",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "\"",
