{
  "name": "EdwTableBkpExtr",
  "properties": {
    "parameters": {
      "RunID": {
        "type": "String"
      },
      "RunDate": {
        "type": "String"
      },
      "TableName": {
        "type": "String"
      },
      "Environment": {
        "type": "String"
      },
      "SRC_SYS_CD": {
        "type": "String"
      },
      "IDSRunCycle": {
        "type": "String"
      },
      "EDW_ENV_ID": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "Copy_EDW_To_File",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "SELECT * FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.@{pipeline().parameters.TableName} WHERE CRT_RUN_CYC_EXCTN_SK = @{pipeline().parameters.IDSRunCycle} AND LAST_UPDT_RUN_CYC_EXCTN_DT_SK < '@{pipeline().parameters.RunDate}' AND SRC_SYS_CD = '@{pipeline().parameters.SRC_SYS_CD}'",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".txt"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            }
          },
          "linkedServiceName": {
            "referenceName": "edw",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_edw",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_EDWOwner}",
              "param_table": "@{pipeline().parameters.TableName}"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_published}",
              "param_directory": {
                "value": "@concat(pipeline().parameters.Environment,'/external')",
                "type": "Expression"
              },
              "param_filename": {
                "value": "@concat(pipeline().parameters.Environment,'1.',pipeline().parameters.EDW_ENV_ID,'_',pipeline().parameters.TableName,'_',pipeline().parameters.IDSRunCycle,'_',pipeline().parameters.RunID,'.dat')",
                "type": "Expression"
              },
              "param_col_delimiter": "|",
              "param_row_delimiter": "@null",
              "param_quote": {
                "value": "\"",
                "type": "Expression"
              },
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ]
      }
    ],
    "annotations": [],
    "folder": {
      "name": "Integrate/Jobs/WebDataMart/Util"
    }
  },
  "Description": "COPYRIGHT 2024 BLUE CROSS/BLUE SHIELD OF KANSAS CITY \n\nCALLED BY: IdsEdwTableBkpCntl\n                        \nPROCESSING:   backup file is created with a temp. name for edw\n  \nMODIFICATIONS:\nDeveloper                Date                 Project/Altiris #      Change Description                                                        Development Project      Code Reviewer          Date Reviewed       \n------------------              --------------------     ------------------------      -----------------------------------------------------------------------               --------------------------------       -------------------------------   ----------------------------       \nRevathi BoojiReddy 2024-03-04      US 611552             Original Development                                                      IntegrateDev1               Jeyaprasanna            2024-04-04\n\nAnnotations:\nThis creates a backup file for edw tables before delete process\n\nEDW Tables:\nLAB_RSLT_F\nCLM_SUPLMT_DIAG_D\nMBR_BIO_MESR_RSLT_F\nEDW backup process from hit list delete file."
}