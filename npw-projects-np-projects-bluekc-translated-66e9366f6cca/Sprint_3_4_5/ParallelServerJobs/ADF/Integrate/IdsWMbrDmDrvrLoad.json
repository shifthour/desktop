{
  "name": "IdsWMbrDmDrvrLoad",
  "properties": {
    "parameters": {
      "FileName": {
        "type": "String"
      },
      "RunID": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "copy_IdsWMbrDmDrvrLoad",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "writeBehavior": "upsert",
            "sqlWriterUseTableLock": false,
            "upsertSettings": {
              "useTempDB": false,
              "keys": [
                "SUBJ_NM",
                "SRC_SYS_CD_SK",
                "KEY_VAL_INT"
              ]
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "SUBJ_NM",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "SRC_SYS_CD_SK",
                  "type": "Int64",
                  "physicalType": "Int64"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "KEY_VAL_INT",
                  "type": "Int64",
                  "physicalType": "Int64"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "CMT_GRP_NO",
                  "type": "Int64",
                  "physicalType": "Int64"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "ids",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/', 'Jobs/WebDataMart/Member/Driver/load')",
              "param_filename": "@concat(pipeline().parameters.FileName, '.dat.', pipeline().parameters.RunID)",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_ids",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_IDSOwner}",
              "param_table": "W_MBR_DM_DRVR"
            }
          }
        ]
      }
    ],
    "folder": {
      "name": "Integrate/Jobs/WebDataMart/Member/Driver"
    }
  },
  "Description": "MODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\nSrikanth Mettpalli      08/04/2013        5114                              Original Programming                                                                            EnterpriseWrhsDevl  Peter Marshall               10/24/2013     \n\nPooja Sunkara         08/01/2014        TFS#9537                     Renamed Reject file name to process correctly                                    IntegrateNewDevl        Jag Yelavarthi            2014-08-01\n\nAnnotations:\nJob Name: IdsWMbrDmDrvrLoad\nRead Load File created in the IdsDmMbrDmDriverExtr Job\nCopy Stage for buffer\nUpdate then Insert the W_MBR_DM_DRVR Data.\nLoad rejects are redirected into a Reject file"
}