          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "UPDATE T SET T.NTNL_PROV_ID=S.NTNL_PROV_ID, T.TXNMY_CD=S.TXNMY_CD, T.ENTY_LIC_ST_CD=S.ENTY_LIC_ST_CD, T.LIC_NO=S.LIC_NO, T.SRC_SYS_CD=S.SRC_SYS_CD, T.CRT_RUN_CYC_EXCTN_SK=S.CRT_RUN_CYC_EXCTN_SK, T.LAST_UPDT_RUN_CYC_EXCTN_SK=S.LAST_UPDT_RUN_CYC_EXCTN_SK, T.GRP_TXNMY_CD_SK=S.GRP_TXNMY_CD_SK, T.NTNL_PROV_SK=S.NTNL_PROV_SK, T.TXNMY_CD_SK=S.TXNMY_CD_SK, T.ENTY_LIC_ST_CD_SK=S.ENTY_LIC_ST_CD_SK, T.CUR_RCRD_IN=S.CUR_RCRD_IN, T.NTNL_PROV_TXNMY_ACTV_IN=S.NTNL_PROV_TXNMY_ACTV_IN, T.NTNL_PROV_TXNMY_PRI_IN=S.NTNL_PROV_TXNMY_PRI_IN FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY AS T JOIN @{pipeline().globalParameters.gbl_param_ids_staging}.abc123_TMP_IdsNtnlProvTxnmyLoad AS S ON T.NTNL_PROV_TXNMY_SK=S.NTNL_PROV_TXNMY_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY (NTNL_PROV_TXNMY_SK, NTNL_PROV_ID, TXNMY_CD, ENTY_LIC_ST_CD, LIC_NO, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, GRP_TXNMY_CD_SK, NTNL_PROV_SK, TXNMY_CD_SK, ENTY_LIC_ST_CD_SK, CUR_RCRD_IN, NTNL_PROV_TXNMY_ACTV_IN, NTNL_PROV_TXNMY_PRI_IN) SELECT S.NTNL_PROV_TXNMY_SK, S.NTNL_PROV_ID, S.TXNMY_CD, S.ENTY_LIC_ST_CD, S.LIC_NO, S.SRC_SYS_CD, S.CRT_RUN_CYC_EXCTN_SK, S.LAST_UPDT_RUN_CYC_EXCTN_SK, S.GRP_TXNMY_CD_SK, S.NTNL_PROV_SK, S.TXNMY_CD_SK, S.ENTY_LIC_ST_CD_SK, S.CUR_RCRD_IN, S.NTNL_PROV_TXNMY_ACTV_IN, S.NTNL_PROV_TXNMY_PRI_IN FROM @{pipeline().globalParameters.gbl_param_ids_staging}.abc123_TMP_IdsNtnlProvTxnmyLoad AS S LEFT JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY AS T ON T.NTNL_PROV_TXNMY_SK=S.NTNL_PROV_TXNMY_SK WHERE T.NTNL_PROV_TXNMY_SK IS NULL; UPDATE @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY SET CUR_RCRD_IN='N' WHERE (NTNL_PROV_TXNMY_SK, NTNL_PROV_ID) IN (SELECT TT.NTNL_PROV_TXNMY_SK, TT.NTNL_PROV_ID FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY TT WHERE TT.LAST_UPDT_RUN_CYC_EXCTN_SK<@{pipeline().parameters.IDSRunCycle} AND TT.NTNL_PROV_ID IN (SELECT PP.NTNL_PROV_ID FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY PP WHERE PP.LAST_UPDT_RUN_CYC_EXCTN_SK=@{pipeline().parameters.IDSRunCycle})); UPDATE @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY SET NTNL_PROV_TXNMY_ACTV_IN='Y' WHERE NTNL_PROV_TXNMY_SK IN (SELECT A.NTNL_PROV_TXNMY_SK FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY A, @{pipeline().globalParameters.gbl_param_IDSOwner}.NTNL_PROV_TXNMY B WHERE A.NTNL_PROV_ID=B.NTNL_PROV_ID AND A.TXNMY_CD=B.TXNMY_CD AND A.NTNL_PROV_TXNMY_ACTV_IN<>B.NTNL_PROV_TXNMY_ACTV_IN AND A.CUR_RCRD_IN='N' AND A.NTNL_PROV_TXNMY_ACTV_IN='N');",
                "type": "Expression"
              }
