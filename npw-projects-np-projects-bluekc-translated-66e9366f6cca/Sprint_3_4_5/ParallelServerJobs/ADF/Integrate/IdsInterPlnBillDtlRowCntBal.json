              "type": "Query",
              "text": {
                "value": "WITH cte_src_trgt AS (SELECT SRC.INTER_PLN_BILL_DTL_ID AS SRC_INTER_PLN_BILL_DTL_ID,SRC.BUS_OWNER_ID AS SRC_BUS_OWNER_ID,SRC.SRC_SYS_CD_SK AS SRC_SRC_SYS_CD_SK,TRGT.INTER_PLN_BILL_DTL_ID AS TRGT_INTER_PLN_BILL_DTL_ID,TRGT.BUS_OWNER_ID AS TRGT_BUS_OWNER_ID,TRGT.SRC_SYS_CD_SK AS TRGT_SRC_SYS_CD_SK FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.B_INTER_PLN_BILL_DTL AS SRC FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_IDSOwner}.INTER_PLN_BILL_DTL AS TRGT ON TRGT.INTER_PLN_BILL_DTL_ID=SRC.INTER_PLN_BILL_DTL_ID AND TRGT.BUS_OWNER_ID=SRC.BUS_OWNER_ID AND TRGT.SRC_SYS_CD_SK=SRC.SRC_SYS_CD_SK WHERE TRGT.LAST_UPDT_RUN_CYC_EXCTN_SK=@{pipeline().parameters.ExtrRunCycle}) DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.RESEARCH_TMP_IdsInterPlnBillDtlRowCntBal; SELECT SRC_INTER_PLN_BILL_DTL_ID,SRC_BUS_OWNER_ID,SRC_SRC_SYS_CD_SK,TRGT_INTER_PLN_BILL_DTL_ID,TRGT_BUS_OWNER_ID,TRGT_SRC_SYS_CD_SK INTO @{pipeline().globalParameters.gbl_param_ids_staging}.RESEARCH_TMP_IdsInterPlnBillDtlRowCntBal FROM cte_src_trgt WHERE SRC_INTER_PLN_BILL_DTL_ID IS NULL OR SRC_BUS_OWNER_ID IS NULL OR SRC_SRC_SYS_CD_SK IS NULL OR TRGT_INTER_PLN_BILL_DTL_ID IS NULL OR TRGT_BUS_OWNER_ID IS NULL OR TRGT_SRC_SYS_CD_SK IS NULL; DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.NOTIFY_TMP_IdsInterPlnBillDtlRowCntBal; WITH cte_notify AS (SELECT CASE WHEN @{pipeline().parameters.ToleranceCd}='OUT' THEN 'ROW COUNT BALANCING FACETS - IDS INTER_PLN_BILL_DTL IS OUT OF TOLERANCE' END AS NOTIFICATION) SELECT NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_ids_staging}.NOTIFY_TMP_IdsInterPlnBillDtlRowCntBal FROM cte_notify WHERE NOTIFICATION IS NOT NULL",
                "type": "Expression"
              }
            }
          ]
        },
