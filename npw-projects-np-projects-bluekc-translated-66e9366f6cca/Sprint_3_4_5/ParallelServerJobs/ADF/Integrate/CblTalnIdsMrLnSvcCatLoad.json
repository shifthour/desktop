              "text": {
                "value": "WITH cte AS (SELECT T.*, @{pipeline().parameters.VersionId} AS VRSN_ID FROM @{pipeline().globalParameters.gbl_param_ids_staging}.TMP_CblTalnIdsMrLnSvcCatLoad T) MERGE @{pipeline().globalParameters.gbl_param_IDSOwner}.MR_LN_SVC_CAT AS tgt USING cte ON tgt.MR_LN_SVC_CAT_SK = cte.MR_LN_SVC_CAT_SK WHEN MATCHED THEN UPDATE SET tgt.MR_LN_ID = cte.MR_LN_ID, tgt.EFF_DT_SK = cte.EFF_DT_SK, tgt.SRC_SYS_CD_SK = cte.SRC_SYS_CD_SK, tgt.CRT_RUN_CYC_EXCTN_SK = cte.CRT_RUN_CYC_EXCTN_SK, tgt.LAST_UPDT_RUN_CYC_EXCTN_SK = cte.LAST_UPDT_RUN_CYC_EXCTN_SK, tgt.TERM_DT_SK = cte.TERM_DT_SK, tgt.ACTURL_HLTH_CST_GRP_CAT_ID = cte.ACTURL_HLTH_CST_GRP_CAT_ID, tgt.CST_MDL_UNIT_OF_MESR_ID = cte.CST_MDL_UNIT_OF_MESR_ID, tgt.MR_LN_DESC = cte.MR_LN_DESC, tgt.MR_LN_PFX_DESC = cte.MR_LN_PFX_DESC, tgt.MR_LN_BODY_DESC = cte.MR_LN_BODY_DESC, tgt.MR_LN_SFX_DESC = cte.MR_LN_SFX_DESC, tgt.VRSN_ID = cte.VRSN_ID WHEN NOT MATCHED THEN INSERT (MR_LN_SVC_CAT_SK, MR_LN_ID, EFF_DT_SK, SRC_SYS_CD_SK, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, TERM_DT_SK, ACTURL_HLTH_CST_GRP_CAT_ID, CST_MDL_UNIT_OF_MESR_ID, MR_LN_DESC, MR_LN_PFX_DESC, MR_LN_BODY_DESC, MR_LN_SFX_DESC, VRSN_ID) VALUES (cte.MR_LN_SVC_CAT_SK, cte.MR_LN_ID, cte.EFF_DT_SK, cte.SRC_SYS_CD_SK, cte.CRT_RUN_CYC_EXCTN_SK, cte.LAST_UPDT_RUN_CYC_EXCTN_SK, cte.TERM_DT_SK, cte.ACTURL_HLTH_CST_GRP_CAT_ID, cte.CST_MDL_UNIT_OF_MESR_ID, cte.MR_LN_DESC, cte.MR_LN_PFX_DESC, cte.MR_LN_BODY_DESC, cte.MR_LN_SFX_DESC, cte.VRSN_ID);",
