        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH cte AS (SELECT clmProv.CLM_ID AS TRGT_CLM_ID, clmProv.CLM_PROV_ROLE_TYP_CD AS TRGT_CLM_PROV_ROLE_TYP_CD, clmProv.SRC_SYS_CD AS TRGT_SRC_SYS_CD, bal.CLM_ID, bal.CLM_PROV_ROLE_TYP_CD, bal.SRC_SYS_CD FROM @{pipeline().globalParameters.gbl_param_WorkCompOwner}.WORK_COMPNSTN_CLM_PROV clmProv FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_WorkCompOwner}.B_WORK_COMPNSTN_CLM_PROV bal ON clmProv.SRC_SYS_CD = bal.SRC_SYS_CD AND clmProv.CLM_ID = bal.CLM_ID AND clmProv.CLM_PROV_ROLE_TYP_CD = bal.CLM_PROV_ROLE_TYP_CD WHERE clmProv.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle}) SELECT * FROM cte",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "AzureSqlSink",
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false,
            "tableOption": "autoCreate",
            "preCopyScript": {
              "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.A01_TMP_FctsIdsWorkCompClmProvCntBal_main",
              "type": "Expression"
            }
