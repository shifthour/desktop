{
  "name": "CblTalnIdsCchgMultCatGrpExtr",
  "properties": {
    "activities": [
      {
        "name": "CopyFile_CCHG",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".ds"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "CCHG_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "CCHG_MULT_CAT_GRP_DESC",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "CCHG_SNGL_CAT_GRP_CD",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "CCHG_SNGL_CAT_GRP_MPPNG_DESC",
                  "type": "String",
                  "physicalType": "String"
                }
              }
            ]
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_with_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_raw}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/','landing')",
              "param_filename": "@{pipeline().parameters.FileName}",
              "param_col_delimiter": "|",
              "param_row_delimiter": "@null",
              "param_quote": "\"",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/','ds')",
              "param_filename": "@concat('CCHG_MULT_CAT_GRP.', pipeline().parameters.SrcSysCd, '.extr.', pipeline().parameters.RunID, '.ds')",
              "param_col_delimiter": "@null",
              "param_row_delimiter": "@null",
              "param_quote": "@null",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ]
      }
    ],
    "parameters": {
      "SrcSysCd": {
        "type": "String"
      },
      "RunID": {
        "type": "String"
      },
      "FileName": {
        "type": "String"
      }
    },
    "folder": {
      "name": "Integrate/Jobs/DataWarehouse/MemberRisk/CCHG/CchgMultCatGrp"
    }
  },
  "Description": "CALLED BY:\n\n\nPROCESSING:  This job extracts data from the CCHG_SNGL_CAT_GRP file from cobalttalon and writes to a DataSet for further processing and filters out error records. Error file will be sent back to Cobalt Talon in Seq job.\n                                                                \n     \nMODIFICATIONS:\n                                                                                                                                                                                                                  DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                         DESCRIPTION                                                                                    ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\nKalyan Neelam           2015-07-24           5460                            Initial Programming                                                                                IntegrateDev2           Bhoomi Dasari              8/30/2015\n\nNathan Reynolds        2016-09-06          TFS-13152                    Fix datatype for CCHG_SNGL_CAT_GRP_CD\n                                                                                                                                set to length 20 to avoid warnings                            IntegrateDev1           Jag Yelavarthi              2016-09-16"
}