              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.TMP1_BlueKCCommonPerceptiveAPIDocStorageStatusUpdate; DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.TMP2_BlueKCCommonPerceptiveAPIDocStorageStatusUpdate; WITH cte_data AS (SELECT 1 AS DefaultRecord), cte_transform AS (SELECT CAST(@{pipeline().parameters.COMM_SK} AS INT) AS COMM_SK, CASE WHEN @{pipeline().parameters.NoFileInd}='Y' THEN 'FAILED' WHEN dbo.trim_default(@{pipeline().parameters.PerceptiveStatus})='Successfully uploaded document' THEN 'SUCCESS' ELSE 'FAILED' END AS COMM_STTUS_CD, CASE WHEN @{pipeline().parameters.NoFileInd}='Y' THEN 'File Not Found' WHEN dbo.trim_default(@{pipeline().parameters.PerceptiveStatus})='Successfully uploaded document' THEN 'Document Storage Successful' ELSE 'Document Storage Unsuccessful' END AS COMM_STTUS_CMNT_TX, 'COMMTRNSMSN' AS COMM_SRC_SYS_CD, 'PRCPTV' AS COMM_TRGT_SYS_CD, 'PRCPTVSTS' AS COMM_TYP_CD, GETDATE() AS LAST_UPDT_DTM, GETDATE() AS COMM_SENT_DTM, @{pipeline().parameters.ATTACHMENTS} AS ATTACHMENTS FROM cte_data) SELECT COMM_SK, COMM_SRC_SYS_CD, COMM_TRGT_SYS_CD, COMM_STTUS_CD, COMM_TYP_CD, COMM_STTUS_CMNT_TX, LAST_UPDT_DTM, COMM_SENT_DTM INTO @{pipeline().globalParameters.gbl_param_ids_staging}.TMP1_BlueKCCommonPerceptiveAPIDocStorageStatusUpdate FROM cte_transform; SELECT COMM_SK, ATTACHMENTS, ' ' AS Dummy INTO @{pipeline().globalParameters.gbl_param_ids_staging}.TMP2_BlueKCCommonPerceptiveAPIDocStorageStatusUpdate FROM cte_transform",
                "type": "Expression"
              }
            }
          ]
