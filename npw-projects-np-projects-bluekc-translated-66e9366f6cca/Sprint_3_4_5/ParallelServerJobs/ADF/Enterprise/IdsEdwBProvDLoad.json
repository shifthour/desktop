{
  "name": "IdsEdwBProvDLoad",
  "properties": {
    "activities": [
      {
        "name": "Copy_IdsEdwBProvDLoad",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_EDWOwner}.B_PROV_D",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "SRC_SYS_CD",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "PROV_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "PROV_ENTY_NM",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "CMN_PRCT_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 5
                },
                "sink": {
                  "name": "PROV_REL_GRP_PROV_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 6
                },
                "sink": {
                  "name": "PROV_REL_IPA_PROV_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "edw",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/load')",
              "param_filename": "B_PROV_D.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_edw",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_EDWOwner}",
              "param_table": "B_PROV_D"
            }
          }
        ]
      },
      {
        "name": "DB2StatsSubroutine",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Copy_IdsEdwBProvDLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path,'/sequencer_routines/Move_File')",
            "type": "Expression"
          },
          "baseParameters": {
            "EnvProjectPath": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "FilePath": {
              "value": "@concat(pipeline().globalParameters.gbl_param_environment, '/load')",
              "type": "Expression"
            },
            "filename": {
              "value": "B_PROV_D.dat",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "parameters": {},
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Provider/EdwLoads/ProvD/Balancing"
    }
  },
  "Description": "MODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      ENVIRONMENT          REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\nAditya Raju               06/14/2013        5114                             Original Programming                                                                             EnterpriseWrhsDevl     Peter Marshall             8/29/2013\n\nAnnotations:\nJob Name: IdsEdwBProvDLoad\nRead Load File created in the IdsEdwProvDExtr Job\nCopy Stage for buffer\nLoad rejects are redirected into a Reject file"
}