              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.MBR_MCAID_TMP_IdsEdwMbrMcaidInfoDExtr;WITH MBR_MCAID_INFO_CTE AS (SELECT MBR_MCAID_INFO_SK, MBR_UNIQ_KEY, MCAID_EFF_DT, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, MBR_SK, MCAID_AID_CAT_CD_SK, MCAID_CNTY_NM, MCAID_PAY_CNTY_NM, MCAID_ST_NM, MCAID_AUTO_ASSIGN_IN, MCAID_LOCAL_PUBLIC_FUND_USE_IN, MCAID_LOCK_IN_PERD_IN, ATCHMT_SRC_ID_DTM, MCAID_AUTO_ASSIGN_DT, MCAID_TERM_DT FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.MBR_MCAID_INFO WHERE LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.IDSRunCycle}), CD_MPPNG_CTE AS (SELECT TRGT_CD, CD_MPPNG_SK, TRGT_CD_NM FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.CD_MPPNG), JOIN_CTE AS (SELECT MBR_C.MBR_MCAID_INFO_SK, MBR_C.MBR_UNIQ_KEY, MBR_C.MCAID_EFF_DT, MBR_C.SRC_SYS_CD, MBR_C.CRT_RUN_CYC_EXCTN_SK, MBR_C.LAST_UPDT_RUN_CYC_EXCTN_SK, MBR_C.MBR_SK, MBR_C.MCAID_AID_CAT_CD_SK, MBR_C.MCAID_CNTY_NM, MBR_C.MCAID_PAY_CNTY_NM, MBR_C.MCAID_ST_NM, MBR_C.MCAID_AUTO_ASSIGN_IN, MBR_C.MCAID_LOCAL_PUBLIC_FUND_USE_IN, MBR_C.MCAID_LOCK_IN_PERD_IN, MBR_C.ATCHMT_SRC_ID_DTM, MBR_C.MCAID_AUTO_ASSIGN_DT, MBR_C.MCAID_TERM_DT, CMPG.TRGT_CD, CMPG.TRGT_CD_NM FROM MBR_MCAID_INFO_CTE MBR_C LEFT JOIN CD_MPPNG_CTE CMPG ON MBR_C.MCAID_AID_CAT_CD_SK = CMPG.CD_MPPNG_SK), XFRM_CTE AS (SELECT MBR_MCAID_INFO_SK, MBR_UNIQ_KEY, MCAID_EFF_DT, SRC_SYS_CD, CAST('@{pipeline().parameters.EDWRunCycleDate}' as char) AS CRT_RUN_CYC_EXCTN_DT_SK, CAST('@{pipeline().parameters.EDWRunCycleDate}' as char) AS LAST_UPDT_RUN_CYC_EXCTN_DT_SK, MBR_SK, CASE WHEN TRGT_CD IS NULL OR LTRIM(RTRIM(TRGT_CD)) = '' THEN 'UNK' ELSE TRGT_CD END AS MCAID_AID_CAT_CD, CASE WHEN TRGT_CD_NM IS NULL OR LTRIM(RTRIM(TRGT_CD_NM)) = '' THEN 'UNK' ELSE TRGT_CD_NM END AS MCAID_AID_CAT_NM, MCAID_CNTY_NM, MCAID_PAY_CNTY_NM, MCAID_ST_NM, MCAID_AUTO_ASSIGN_IN, MCAID_LOCAL_PUBLIC_FUND_USE_IN, MCAID_LOCK_IN_PERD_IN, CAST(ATCHMT_SRC_ID_DTM as date) AS ATCHMT_SRC_ID_DTM, MCAID_AUTO_ASSIGN_DT, MCAID_TERM_DT, @{pipeline().parameters.EDWRunCycle} AS CRT_RUN_CYC_EXCTN_SK, @{pipeline().parameters.EDWRunCycle} AS LAST_UPDT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK AS IDS_LAST_UPDT_RUN_CYC_EXCTN_SK, MCAID_AID_CAT_CD_SK FROM JOIN_CTE) SELECT * INTO @{pipeline().globalParameters.gbl_param_ids_staging}.MBR_MCAID_TMP_IdsEdwMbrMcaidInfoDExtr FROM XFRM_CTE",
                "type": "Expression"
              }
            }
