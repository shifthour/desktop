{
  "name": "UwsPNewDirProvMsgExtr",
  "properties": {
    "activities": [
      {
        "name": "Copy_UwsPNewDirProvMsg",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH CTE_0 AS (SELECT PROV_MSG_CD, USER_ID, SUBSTRING(LAST_UPDT_DT_SK,1,10) AS LAST_UPDT_DT_SK FROM @{pipeline().globalParameters.gbl_param_UWSOwner}.NEWDIR_PROV_MSG) SELECT PROV_MSG_CD, USER_ID, LAST_UPDT_DT_SK FROM CTE_0",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "PROV_MSG_CD",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "USER_ID",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "LAST_UPDT_DT_SK",
                  "type": "String",
                  "physicalType": "char"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "uws",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_uws",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_UWSOwner}",
              "param_table": "NEWDIR_PROV_MSG"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment,'/','load')",
              "param_filename": "P_NEWDIR_PROV_MSG.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "\""
            }
          }
        ]
      }
    ],
    "parameters": {},
    "annotations": [],
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Claims/EdwLoads/PTables"
    }
  },
  "Description": "COPYRIGHT 2007 BLUE CROSS/BLUE SHIELD OF KANSAS CITY \n\n\nCALLED BY:   \n\nPROCESSING:\n                  \n                The Job loads the EDW - P_NEWDIR_PROV_MSG table.            \n\nMODIFICATIONS:\nDeveloper                          Date                 Project/Altiris #                Change Description                             Development Project    Code Reviewer            Date Reviewed\n======================================================================================================================================\nManasa Andru                  2016-01-28         TFS - 10783                 Original Programming                               EnterpriseDev1            Kalyan Neelam             2016-01-29\n\nManasa Andru                  2017-01-17         TFS - 10784           Added Substring condition for field                EnterpriseDev1            Jag Yelavarthi               2017-01-18\n                                                                                                  LAST_UPDT_DT_SK.\n\nAnnotations:\nJob Name: UwsPNewDirProvMsgExtr\nRead all the Data from UWS NEWDIR_PROV_MSG Table"
}