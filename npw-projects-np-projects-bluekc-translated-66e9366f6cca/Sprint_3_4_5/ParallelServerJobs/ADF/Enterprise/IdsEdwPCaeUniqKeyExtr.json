              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "INDV_BE_KEY",
                  "type": "DECIMAL",
                  "physicalType": "decimal"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "CAE_UNIQ_KEY",
                  "type": "INT",
                  "physicalType": "int"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "LAST_UPDT_DT",
                  "type": "DATE",
                  "physicalType": "date"
                }
              }
            ]
          },
