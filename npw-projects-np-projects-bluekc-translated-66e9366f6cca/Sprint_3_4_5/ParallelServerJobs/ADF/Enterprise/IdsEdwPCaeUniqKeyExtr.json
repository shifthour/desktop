              "value": "SELECT P_CAE_UNIQ_KEY.INDV_BE_KEY, P_CAE_UNIQ_KEY.CAE_UNIQ_KEY, P_CAE_UNIQ_KEY.LAST_UPDT_DT FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.p_cae_uniq_key P_CAE_UNIQ_KEY",
