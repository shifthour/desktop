              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.BCUSTSVC_TMP_IdsEdwCustSvcCustSvcDBalExtr; WITH snapshot AS ( SELECT SRC_SYS_CD_SK, CUST_SVC_ID, DISCLMR_IN FROM @{pipeline().globalParameters.gbl_param_ids_staging}.SNAPSHOT_TMP_IdsEdwCustSvcCustSvcDBalExtr ), cd_mppng AS ( SELECT CD_MPPNG_SK, COALESCE(TRGT_CD,'UNK') AS TRGT_CD, COALESCE(TRGT_CD_NM,'UNK') AS TRGT_CD_NM FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.CD_MPPNG ) SELECT CASE WHEN cd.TRGT_CD IS NULL OR LEN(dbo.trim_default(cd.TRGT_CD)) = 0 THEN 'NA' ELSE cd.TRGT_CD END AS SRC_SYS_CD, s.CUST_SVC_ID, s.DISCLMR_IN AS CUST_SVC_DISCLMR_IN INTO @{pipeline().globalParameters.gbl_param_ids_staging}.BCUSTSVC_TMP_IdsEdwCustSvcCustSvcDBalExtr FROM snapshot s LEFT JOIN cd_mppng cd ON cd.CD_MPPNG_SK = s.SRC_SYS_CD_SK",
                "type": "Expression"
              }
            }
          ]
        }
