              "text": {
                "value": "WITH cte AS (SELECT SRC_SYS_CD, PROV_ID, NWNW_ID AS NTWK_ID, NWPR_PFX AS PROV_NTWK_PFX_ID, NWPR_EFF_DT AS PROV_NTWK_EFF_DT_SK, PCP_IN AS PROV_NTWK_PCP_IN FROM @{pipeline().globalParameters.gbl_param_edw_staging}.TMP_IdsEdwProvNtwkDDel) DELETE D FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.PROV_NTWK_D D INNER JOIN cte ON D.SRC_SYS_CD = cte.SRC_SYS_CD AND D.PROV_ID = cte.PROV_ID AND D.NTWK_ID = cte.NTWK_ID AND D.PROV_NTWK_PFX_ID = cte.PROV_NTWK_PFX_ID AND D.PROV_NTWK_EFF_DT_SK = cte.PROV_NTWK_EFF_DT_SK AND D.PROV_NTWK_PCP_IN = cte.PROV_NTWK_PCP_IN",
                "type": "Expression"
              }
            }
          ]
        },
