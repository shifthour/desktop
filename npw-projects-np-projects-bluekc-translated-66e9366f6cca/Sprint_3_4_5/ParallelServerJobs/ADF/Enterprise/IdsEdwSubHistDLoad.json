              "text": {
                "value": "WITH cte AS (SELECT SUB_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,SUB_UNIQ_KEY,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,SUB_CALC_FMLY_MED_CNTR_CD,SUB_CALC_FMLY_MED_CNTR_NM,SUB_CALC_FMLY_MED_CNTR_CHG_IN,SUB_FULL_NM,SUB_NM_CHG_IN,SUB_INDV_BE_KEY,SUB_INDV_BE_KEY_CHG_IN,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,SUB_MKTNG_TERR_ID,SUB_MKTNG_TERR_ID_CHG_IN,SUB_SCRD_IN,SUB_CALC_FMLY_DNTL_CNTR_CD,SUB_CALC_FMLY_DNTL_CNTR_NM,SUB_CALC_FMLY_DNTL_CNTR_CHG_IN FROM @{pipeline().globalParameters.gbl_param_edw_staging}.SubHistD_TMP_IdsEdwSubHistDLoad) UPDATE t SET t.SRC_SYS_CD=c.SRC_SYS_CD,t.SUB_UNIQ_KEY=c.SUB_UNIQ_KEY,t.LAST_UPDT_RUN_CYC_EXCTN_DT_SK=c.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,t.EDW_CUR_RCRD_IN=c.EDW_CUR_RCRD_IN,t.EDW_RCRD_END_DT_SK=c.EDW_RCRD_END_DT_SK,t.SUB_CALC_FMLY_MED_CNTR_CD=c.SUB_CALC_FMLY_MED_CNTR_CD,t.SUB_CALC_FMLY_MED_CNTR_NM=c.SUB_CALC_FMLY_MED_CNTR_NM,t.SUB_CALC_FMLY_MED_CNTR_CHG_IN=c.SUB_CALC_FMLY_MED_CNTR_CHG_IN,t.SUB_FULL_NM=c.SUB_FULL_NM,t.SUB_NM_CHG_IN=c.SUB_NM_CHG_IN,t.SUB_INDV_BE_KEY=c.SUB_INDV_BE_KEY,t.SUB_INDV_BE_KEY_CHG_IN=c.SUB_INDV_BE_KEY_CHG_IN,t.LAST_UPDT_RUN_CYC_EXCTN_SK=c.LAST_UPDT_RUN_CYC_EXCTN_SK,t.SUB_MKTNG_TERR_ID=c.SUB_MKTNG_TERR_ID,t.SUB_MKTNG_TERR_ID_CHG_IN=c.SUB_MKTNG_TERR_ID_CHG_IN,t.SUB_SCRD_IN=c.SUB_SCRD_IN,t.SUB_CALC_FMLY_DNTL_CNTR_CD=c.SUB_CALC_FMLY_DNTL_CNTR_CD,t.SUB_CALC_FMLY_DNTL_CNTR_NM=c.SUB_CALC_FMLY_DNTL_CNTR_NM,t.SUB_CALC_FMLY_DNTL_CNTR_CHG_IN=c.SUB_CALC_FMLY_DNTL_CNTR_CHG_IN FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_HIST_D t JOIN cte c ON t.SUB_SK=c.SUB_SK AND t.EDW_RCRD_STRT_DT_SK=c.EDW_RCRD_STRT_DT_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_HIST_D (SUB_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,SUB_UNIQ_KEY,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,SUB_CALC_FMLY_MED_CNTR_CD,SUB_CALC_FMLY_MED_CNTR_NM,SUB_CALC_FMLY_MED_CNTR_CHG_IN,SUB_FULL_NM,SUB_NM_CHG_IN,SUB_INDV_BE_KEY,SUB_INDV_BE_KEY_CHG_IN,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,SUB_MKTNG_TERR_ID,SUB_MKTNG_TERR_ID_CHG_IN,SUB_SCRD_IN,SUB_CALC_FMLY_DNTL_CNTR_CD,SUB_CALC_FMLY_DNTL_CNTR_NM,SUB_CALC_FMLY_DNTL_CNTR_CHG_IN) SELECT c.SUB_SK,c.EDW_RCRD_STRT_DT_SK,c.SRC_SYS_CD,c.SUB_UNIQ_KEY,c.CRT_RUN_CYC_EXCTN_DT_SK,c.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,c.EDW_CUR_RCRD_IN,c.EDW_RCRD_END_DT_SK,c.SUB_CALC_FMLY_MED_CNTR_CD,c.SUB_CALC_FMLY_MED_CNTR_NM,c.SUB_CALC_FMLY_MED_CNTR_CHG_IN,c.SUB_FULL_NM,c.SUB_NM_CHG_IN,c.SUB_INDV_BE_KEY,c.SUB_INDV_BE_KEY_CHG_IN,c.CRT_RUN_CYC_EXCTN_SK,c.LAST_UPDT_RUN_CYC_EXCTN_SK,c.SUB_MKTNG_TERR_ID,c.SUB_MKTNG_TERR_ID_CHG_IN,c.SUB_SCRD_IN,c.SUB_CALC_FMLY_DNTL_CNTR_CD,c.SUB_CALC_FMLY_DNTL_CNTR_NM,c.SUB_CALC_FMLY_DNTL_CNTR_CHG_IN FROM cte c LEFT JOIN @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_HIST_D t ON t.SUB_SK=c.SUB_SK AND t.EDW_RCRD_STRT_DT_SK=c.EDW_RCRD_STRT_DT_SK WHERE t.SUB_SK IS NULL",
