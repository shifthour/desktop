        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH cteSource AS (SELECT PROV_SVC_SK, PROV_SVC_ID, ENTY_CAT_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, PROV_SVC_DESC, PROV_SVC_FLTR_ID, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.IdsEdwProvSvcDLoad_TMP) MERGE @{pipeline().globalParameters.gbl_param_EDWOwner}.PROV_SVC_D AS TARGET USING cteSource AS SOURCE ON TARGET.PROV_SVC_SK = SOURCE.PROV_SVC_SK WHEN MATCHED THEN UPDATE SET TARGET.PROV_SVC_ID = SOURCE.PROV_SVC_ID, TARGET.ENTY_CAT_ID = SOURCE.ENTY_CAT_ID, TARGET.SRC_SYS_CD = SOURCE.SRC_SYS_CD, TARGET.LAST_UPDT_RUN_CYC_EXCTN_DT_SK = SOURCE.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, TARGET.PROV_SVC_DESC = SOURCE.PROV_SVC_DESC, TARGET.PROV_SVC_FLTR_ID = SOURCE.PROV_SVC_FLTR_ID, TARGET.LAST_UPDT_RUN_CYC_EXCTN_SK = SOURCE.LAST_UPDT_RUN_CYC_EXCTN_SK WHEN NOT MATCHED THEN INSERT (PROV_SVC_SK, PROV_SVC_ID, ENTY_CAT_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, PROV_SVC_DESC, PROV_SVC_FLTR_ID, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK) VALUES (SOURCE.PROV_SVC_SK, SOURCE.PROV_SVC_ID, SOURCE.ENTY_CAT_ID, SOURCE.SRC_SYS_CD, SOURCE.CRT_RUN_CYC_EXCTN_DT_SK, SOURCE.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, SOURCE.PROV_SVC_DESC, SOURCE.PROV_SVC_FLTR_ID, SOURCE.CRT_RUN_CYC_EXCTN_SK, SOURCE.LAST_UPDT_RUN_CYC_EXCTN_SK)",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "edw",
          "type": "LinkedServiceReference"
