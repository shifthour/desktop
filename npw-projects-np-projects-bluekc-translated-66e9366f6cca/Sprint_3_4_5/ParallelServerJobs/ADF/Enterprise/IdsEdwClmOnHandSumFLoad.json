                "value": "WITH cte_incoming AS (SELECT CLM_ON_HAND_SUM_SK,SRC_SYS_CD,OPS_WORK_UNIT_ID,CLM_INVTRY_SUBTYP_CD,EXTR_DT_SK,INPT_DT_SK,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,OPS_WORK_UNIT_SK,EXTR_DT,INPT_DT,NON_FIRST_PASS_SUM_CT,SUM_CT,CLM_INVTRY_SUBTYP_NM,OPS_WORK_UNIT_DESC,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,CLM_INVTRY_SUBTYP_CD_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.T01_TMP_IdsEdwClmOnHandSumFLoad) MERGE @{pipeline().globalParameters.gbl_param_EDWOwner}.CLM_ON_HAND_SUM_F AS T USING cte_incoming AS S ON T.CLM_ON_HAND_SUM_SK=S.CLM_ON_HAND_SUM_SK WHEN MATCHED THEN UPDATE SET T.SRC_SYS_CD=S.SRC_SYS_CD,T.OPS_WORK_UNIT_ID=S.OPS_WORK_UNIT_ID,T.CLM_INVTRY_SUBTYP_CD=S.CLM_INVTRY_SUBTYP_CD,T.EXTR_DT_SK=S.EXTR_DT_SK,T.INPT_DT_SK=S.INPT_DT_SK,T.LAST_UPDT_RUN_CYC_EXCTN_DT_SK=S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,T.OPS_WORK_UNIT_SK=S.OPS_WORK_UNIT_SK,T.EXTR_DT=S.EXTR_DT,T.INPT_DT=S.INPT_DT,T.NON_FIRST_PASS_SUM_CT=S.NON_FIRST_PASS_SUM_CT,T.SUM_CT=S.SUM_CT,T.CLM_INVTRY_SUBTYP_NM=S.CLM_INVTRY_SUBTYP_NM,T.OPS_WORK_UNIT_DESC=S.OPS_WORK_UNIT_DESC,T.LAST_UPDT_RUN_CYC_EXCTN_SK=S.LAST_UPDT_RUN_CYC_EXCTN_SK,T.CLM_INVTRY_SUBTYP_CD_SK=S.CLM_INVTRY_SUBTYP_CD_SK WHEN NOT MATCHED THEN INSERT (CLM_ON_HAND_SUM_SK,SRC_SYS_CD,OPS_WORK_UNIT_ID,CLM_INVTRY_SUBTYP_CD,EXTR_DT_SK,INPT_DT_SK,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,OPS_WORK_UNIT_SK,EXTR_DT,INPT_DT,NON_FIRST_PASS_SUM_CT,SUM_CT,CLM_INVTRY_SUBTYP_NM,OPS_WORK_UNIT_DESC,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,CLM_INVTRY_SUBTYP_CD_SK) VALUES (S.CLM_ON_HAND_SUM_SK,S.SRC_SYS_CD,S.OPS_WORK_UNIT_ID,S.CLM_INVTRY_SUBTYP_CD,S.EXTR_DT_SK,S.INPT_DT_SK,S.CRT_RUN_CYC_EXCTN_DT_SK,S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,S.OPS_WORK_UNIT_SK,S.EXTR_DT,S.INPT_DT,S.NON_FIRST_PASS_SUM_CT,S.SUM_CT,S.CLM_INVTRY_SUBTYP_NM,S.OPS_WORK_UNIT_DESC,S.CRT_RUN_CYC_EXCTN_SK,S.LAST_UPDT_RUN_CYC_EXCTN_SK,S.CLM_INVTRY_SUBTYP_CD_SK);",
