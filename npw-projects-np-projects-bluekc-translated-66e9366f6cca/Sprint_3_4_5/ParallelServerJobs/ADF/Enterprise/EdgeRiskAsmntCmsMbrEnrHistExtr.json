            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_edw_staging}.TMP_OUT_EdgeRiskAsmntCmsMbrEnrHistExtr; WITH Xfrm_Trim AS ( SELECT fileIdentifier, executionZoneCode, interfaceControlReleaseNumber, generationDateTime, submissionTypeCode, insuredMemberTotalQuantity, insuredMemberProfileTotalQuantity, EnrollmentIssuerrecordIdentifier, EnrollmentIssuerissuerIdentifier, issuerInsuredMemberTotalQuantity, issuerInsuredMemberProfileTotalQuantity, CAST(includedinsuredMemberrecordIdentifier AS INT) AS includedinsuredMemberrecordIdentifier, insuredMemberIdentifier, insuredMemberBirthDate, insuredMemberGenderCode, includedinsuredMemberProfilerecordIdentifier, subscriberIndicator, subscriberIdentifier, insurancePlanIdentifier, coverageStartDate, coverageEndDate, enrollmentMaintenanceTypeCode, insurancePlanPremiumAmount, rateAreaIdentifier, MBR_UNIQ_KEY, RISK_ADJ_YR, SUB_UNIQ_KEY, MBR_RELSHP_CD, insuredMemberRace, insuredMemberEthnicity, zipCode, federalAPTC, statePremiumSubsidy, stateCSRtext, ICHRA_QSEHRA, QSEHRA_Spousal, QSEHRA_Medical FROM @{pipeline().globalParameters.gbl_param_edw_staging}.TMP_EdgeRiskAsmntCmsMbrEnrHistExtr ), Rdp_Id AS ( SELECT Xfrm_Trim.*, ROW_NUMBER() OVER (PARTITION BY EnrollmentIssuerissuerIdentifier, fileIdentifier, includedinsuredMemberrecordIdentifier ORDER BY MBR_UNIQ_KEY DESC) AS rn FROM Xfrm_Trim ), xfm_Business_Logic AS ( SELECT CAST(EnrollmentIssuerissuerIdentifier AS CHAR(10)) AS ISSUER_ID, CAST(fileIdentifier AS CHAR(10)) AS FILE_ID, includedinsuredMemberrecordIdentifier AS MBR_RCRD_ID, MBR_UNIQ_KEY, CASE WHEN insuredMemberBirthDate <> '' THEN CAST(insuredMemberBirthDate + ' 00:00:00' AS DATETIME) ELSE NULL END AS MBR_BRTH_DT, insuredMemberGenderCode AS MBR_GNDR_CD, 'U' AS MBR_PRCS_STTUS_CD, CASE WHEN generationDateTime <> '' THEN CAST(generationDateTime + ' 00:00:00' AS DATETIME) ELSE NULL END AS GNRTN_DTM, GETDATE() AS LAST_UPDT_DTM, 'SYSTEM' AS LAST_UPDT_USER_ID, CASE WHEN insuredMemberIdentifier <> '' THEN CAST(insuredMemberIdentifier AS DECIMAL(18,0)) ELSE NULL END AS MBR_INDV_BE_KEY, RISK_ADJ_YR, NULL AS AGE_MDL_TYP, NULL AS AGE_YR_NO, 0 AS TOT_MBR_MO_CT, 0 AS TOT_BILL_MO_CT, MBR_RELSHP_CD, insuredMemberRace AS MBR_RACE_CD, insuredMemberEthnicity AS MBR_ETHNCTY_CD FROM Rdp_Id WHERE rn = 1 ) SELECT * INTO @{pipeline().globalParameters.gbl_param_edw_staging}.TMP_OUT_EdgeRiskAsmntCmsMbrEnrHistExtr FROM xfm_Business_Logic",
                "type": "Expression"
              }
            }
          ]
        },
