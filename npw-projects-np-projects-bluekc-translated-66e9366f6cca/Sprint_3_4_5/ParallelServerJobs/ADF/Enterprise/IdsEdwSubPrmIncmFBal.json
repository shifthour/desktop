ubPrmIncmFBal; CREATE TABLE @{pipeline().globalParameters.gbl_param_edw_staging}.Notify_TMP_IdsEdwSubPrmIncmFBal (NOTIFICATION CHAR(100)); IF @rc>0 BEGIN INSERT INTO @{pipeline().globalParameters.gbl_param_edw_staging}.Notify_TMP_IdsEdwSubPrmIncmFBal VALUES('COLUMN SUM BALANCING IDS - EDW SUB PRM INCM F OUT OF TOLERANCE'); END",
