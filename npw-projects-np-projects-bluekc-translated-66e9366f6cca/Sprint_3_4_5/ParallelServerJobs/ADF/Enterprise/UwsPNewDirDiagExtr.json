{
  "name": "UwsPNewDirDiagExtr",
  "properties": {
    "activities": [
      {
        "name": "Copy_ODBC_NewDir_Diag_to_File",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH CTE as ( SELECT DIAG_CD, DIAG_CD_TYP_CD, USER_ID, LAST_UPDT_DT_SK FROM @{pipeline().globalParameters.gbl_param_UWSOwner}.NEWDIR_DIAG ) SELECT DIAG_CD, DIAG_CD_TYP_CD, USER_ID, SUBSTRING(LAST_UPDT_DT_SK,1,10) as LAST_UPDT_DT_SK FROM CTE",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            }
          },
          "linkedServiceName": {
            "referenceName": "uws",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_uws",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_UWSOwner}",
              "param_table": "NEWDIR_DIAG"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment, '/','load')",
              "param_filename": "P_NEWDIR_DIAG.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "\""
            }
          }
        ]
      }
    ],
    "parameters": {},
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Claims/EdwLoads/PTables"
    }
  },
  "type": "Microsoft.DataFactory/factories/pipelines",
  "Description": "COPYRIGHT 2007 BLUE CROSS/BLUE SHIELD OF KANSAS CITY \n\n\nCALLED BY:   \n\nPROCESSING:\n                  \n                The Job loads the EDW - P_NEWDIR_DIAG table.            \n\nMODIFICATIONS:\nDeveloper                          Date                 Project/Altiris #                Change Description                             Development Project    Code Reviewer            Date Reviewed\n======================================================================================================================================\nManasa Andru                  2017-01-13         TFS - 10784                 Original Programming                               EnterpriseDev1             Jag Yelavarthi             2017-01-17\n\nAnnotations:\nJob Name: UwsPNewDirDiagExtr\nRead all the Data from UWS NEWDIR_DIAG Table"
}