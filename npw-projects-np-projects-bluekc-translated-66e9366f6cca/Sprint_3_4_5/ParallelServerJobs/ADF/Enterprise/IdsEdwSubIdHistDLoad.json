                "value": "WITH cte AS (SELECT SUB_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,SUB_UNIQ_KEY,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,GRP_SK,GRP_ID,SCRD_IN,SUB_INDV_BE_KEY,SUB_ID,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK AS LST_UPD_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.d3b28_TMP_IdsEdwSubIdHistDLoad) UPDATE T SET T.SRC_SYS_CD=cte.SRC_SYS_CD,T.SUB_UNIQ_KEY=cte.SUB_UNIQ_KEY,T.LAST_UPDT_RUN_CYC_EXCTN_DT_SK=cte.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,T.EDW_CUR_RCRD_IN=cte.EDW_CUR_RCRD_IN,T.EDW_RCRD_END_DT_SK=cte.EDW_RCRD_END_DT_SK,T.GRP_SK=cte.GRP_SK,T.GRP_ID=cte.GRP_ID,T.SCRD_IN=cte.SCRD_IN,T.SUB_INDV_BE_KEY=cte.SUB_INDV_BE_KEY,T.SUB_ID=cte.SUB_ID,T.LAST_UPDT_RUN_CYC_EXCTN_SK=cte.LST_UPD_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_ID_HIST_D T JOIN cte ON T.SUB_SK=cte.SUB_SK AND T.EDW_RCRD_STRT_DT_SK=cte.EDW_RCRD_STRT_DT_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_ID_HIST_D (SUB_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,SUB_UNIQ_KEY,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,GRP_SK,GRP_ID,SCRD_IN,SUB_INDV_BE_KEY,SUB_ID,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK) SELECT c.SUB_SK,c.EDW_RCRD_STRT_DT_SK,c.SRC_SYS_CD,c.SUB_UNIQ_KEY,c.CRT_RUN_CYC_EXCTN_DT_SK,c.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,c.EDW_CUR_RCRD_IN,c.EDW_RCRD_END_DT_SK,c.GRP_SK,c.GRP_ID,c.SCRD_IN,c.SUB_INDV_BE_KEY,c.SUB_ID,c.CRT_RUN_CYC_EXCTN_SK,c.LST_UPD_RUN_CYC_EXCTN_SK FROM cte c LEFT JOIN @{pipeline().globalParameters.gbl_param_EDWOwner}.SUB_ID_HIST_D T ON T.SUB_SK=c.SUB_SK AND T.EDW_RCRD_STRT_DT_SK=c.EDW_RCRD_STRT_DT_SK WHERE T.SUB_SK IS NULL",
