                "value": "WITH CTE_SOURCE AS (SELECT CLS_PLN_DTL_SK, EDW_RCRD_STRT_DT_SK, SRC_SYS_CD, GRP_ID, CLS_ID, CLS_PLN_ID, CLS_PLN_DTL_PROD_CAT_CD, CLS_PLN_DTL_EFF_DT_SK, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, EDW_CUR_RCRD_IN, EDW_RCRD_END_DT_SK, PCA_ADM_ID, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.temp_TMP_IdsEdwClsPlnDtlHistDLoad) UPDATE T SET T.SRC_SYS_CD = S.SRC_SYS_CD, T.GRP_ID = S.GRP_ID, T.CLS_ID = S.CLS_ID, T.CLS_PLN_ID = S.CLS_PLN_ID, T.CLS_PLN_DTL_PROD_CAT_CD = S.CLS_PLN_DTL_PROD_CAT_CD, T.CLS_PLN_DTL_EFF_DT_SK = S.CLS_PLN_DTL_EFF_DT_SK, T.LAST_UPDT_RUN_CYC_EXCTN_DT_SK = S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, T.EDW_CUR_RCRD_IN = S.EDW_CUR_RCRD_IN, T.EDW_RCRD_END_DT_SK = S.EDW_RCRD_END_DT_SK, T.LAST_UPDT_RUN_CYC_EXCTN_SK = S.LAST_UPDT_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.CLS_PLN_DTL_HIST_D T JOIN CTE_SOURCE S ON T.CLS_PLN_DTL_SK = S.CLS_PLN_DTL_SK AND T.EDW_RCRD_STRT_DT_SK = S.EDW_RCRD_STRT_DT_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.CLS_PLN_DTL_HIST_D (CLS_PLN_DTL_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,GRP_ID,CLS_ID,CLS_PLN_ID,CLS_PLN_DTL_PROD_CAT_CD,CLS_PLN_DTL_EFF_DT_SK,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,PCA_ADM_ID,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK) SELECT S.CLS_PLN_DTL_SK, S.EDW_RCRD_STRT_DT_SK, S.SRC_SYS_CD, S.GRP_ID, S.CLS_ID, S.CLS_PLN_ID, S.CLS_PLN_DTL_PROD_CAT_CD, S.CLS_PLN_DTL_EFF_DT_SK, S.CRT_RUN_CYC_EXCTN_DT_SK, S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, S.EDW_CUR_RCRD_IN, S.EDW_RCRD_END_DT_SK, S.PCA_ADM_ID, S.CRT_RUN_CYC_EXCTN_SK, S.LAST_UPDT_RUN_CYC_EXCTN_SK FROM CTE_SOURCE S WHERE NOT EXISTS (SELECT 1 FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.CLS_PLN_DTL_HIST_D T WHERE T.CLS_PLN_DTL_SK = S.CLS_PLN_DTL_SK AND T.EDW_RCRD_STRT_DT_SK = S.EDW_RCRD_STRT_DT_SK);",
