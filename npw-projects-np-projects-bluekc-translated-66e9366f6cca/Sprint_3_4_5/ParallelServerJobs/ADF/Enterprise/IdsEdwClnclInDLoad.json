                "value": "WITH ORCHESTRATE AS (SELECT CLNCL_IN_SK, SRC_SYS_CD, CLNCL_IN_ID, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, BCBSKC_CLNCL_PGM_TYP_CD, BCBSKC_CLNCL_PGM_TYP_NM, CLNCL_IN_GNRL_CAT_CD, CLNCL_IN_GNRL_CAT_NM, CLNCL_IN_PRI_DSS_CD, CLNCL_IN_PRI_DSS_NM, CLNCL_IN_SH_DESC, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, BCBSKC_CLNCL_PGM_TYP_CD_SK, CLNCL_IN_GNRL_CAT_CD_SK, CLNCL_IN_PRI_DSS_CD_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.temp_IdsEdwClnclInDLoad) UPDATE @{pipeline().globalParameters.gbl_param_EDWOwner}.CLNCL_IN_D SET SRC_SYS_CD = ORCHESTRATE.SRC_SYS_CD, CLNCL_IN_ID = ORCHESTRATE.CLNCL_IN_ID, LAST_UPDT_RUN_CYC_EXCTN_DT_SK = ORCHESTRATE.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, BCBSKC_CLNCL_PGM_TYP_CD = ORCHESTRATE.BCBSKC_CLNCL_PGM_TYP_CD, BCBSKC_CLNCL_PGM_TYP_NM = ORCHESTRATE.BCBSKC_CLNCL_PGM_TYP_NM, CLNCL_IN_GNRL_CAT_CD = ORCHESTRATE.CLNCL_IN_GNRL_CAT_CD, CLNCL_IN_GNRL_CAT_NM = ORCHESTRATE.CLNCL_IN_GNRL_CAT_NM, CLNCL_IN_PRI_DSS_CD = ORCHESTRATE.CLNCL_IN_PRI_DSS_CD, CLNCL_IN_PRI_DSS_NM = ORCHESTRATE.CLNCL_IN_PRI_DSS_NM, CLNCL_IN_SH_DESC = ORCHESTRATE.CLNCL_IN_SH_DESC, LAST_UPDT_RUN_CYC_EXCTN_SK = ORCHESTRATE.LAST_UPDT_RUN_CYC_EXCTN_SK, BCBSKC_CLNCL_PGM_TYP_CD_SK = ORCHESTRATE.BCBSKC_CLNCL_PGM_TYP_CD_SK, CLNCL_IN_GNRL_CAT_CD_SK = ORCHESTRATE.CLNCL_IN_GNRL_CAT_CD_SK, CLNCL_IN_PRI_DSS_CD_SK = ORCHESTRATE.CLNCL_IN_PRI_DSS_CD_SK FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.CLNCL_IN_D T JOIN ORCHESTRATE ON T.CLNCL_IN_SK = ORCHESTRATE.CLNCL_IN_SK INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.CLNCL_IN_D (CLNCL_IN_SK, SRC_SYS_CD, CLNCL_IN_ID, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, BCBSKC_CLNCL_PGM_TYP_CD, BCBSKC_CLNCL_PGM_TYP_NM, CLNCL_IN_GNRL_CAT_CD, CLNCL_IN_GNRL_CAT_NM, CLNCL_IN_PRI_DSS_CD, CLNCL_IN_PRI_DSS_NM, CLNCL_IN_SH_DESC, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK, BCBSKC_CLNCL_PGM_TYP_CD_SK, CLNCL_IN_GNRL_CAT_CD_SK, CLNCL_IN_PRI_DSS_CD_SK) SELECT ORCHESTRATE.CLNCL_IN_S