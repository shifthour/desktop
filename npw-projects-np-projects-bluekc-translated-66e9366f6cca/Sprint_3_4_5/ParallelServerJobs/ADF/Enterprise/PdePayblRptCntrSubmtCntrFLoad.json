TOT_DTL_RCRD_CT, CUR_MO_SUBMT_DUE_AMT = S.CUR_MO_SUBMT_DUE_AMT, CRT_RUN_CYC_EXCTN_SK = S.CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK = S.LAST_UPDT_RUN_CYC_EXCTN_SK WHEN NOT MATCHED THEN INSERT (PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, FILE_ID, CNTR_SEQ_ID, SUBMT_CNTR_SEQ_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, PDE_PAYBL_RPT_CNTR_SK, CMS_CNTR_ID, SUBMT_CMS_CNTR_ID, AS_OF_YR, AS_OF_MO, FILE_CRTN_DT, FILE_CRTN_TM, RPT_ID, DRUG_COV_STTUS_CD_TX, BNFCRY_CT, CUR_MO_GROS_DRUG_CST_BELOW_AMT, CUR_MO_GROS_DRUG_CST_ABOVE_AMT, CUR_MO_TOT_GROS_DRUG_CST_AMT, CUR_MO_LOW_INCM_CST_SHARING_AMT, CUR_MO_COV_PLN_PD_AMT, TOT_DTL_RCRD_CT, CUR_MO_SUBMT_DUE_AMT, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK) VALUES (S.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, S.FILE_ID, S.CNTR_SEQ_ID, S.SUBMT_CNTR_SEQ_ID, S.SRC_SYS_CD, S.CRT_RUN_CYC_EXCTN_DT_SK, S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, S.PDE_PAYBL_RPT_CNTR_SK, S.CMS_CNTR_ID, S.SUBMT_CMS_CNTR_ID, S.AS_OF_YR, S.AS_OF_MO, S.FILE_CRTN_DT, S.FILE_CRTN_TM, S.RPT_ID, S.DRUG_COV_STTUS_CD_TX, S.BNFCRY_CT, S.CUR_MO_GROS_DRUG_CST_BELOW_AMT, S.CUR_MO_GROS_DRUG_CST_ABOVE_AMT, S.CUR_MO_TOT_GROS_DRUG_CST_AMT, S.CUR_MO_LOW_INCM_CST_SHARING_AMT, S.CUR_MO_COV_PLN_PD_AMT, S.TOT_DTL_RCRD_CT, S.CUR_MO_SUBMT_DUE_AMT, S.CRT_RUN_CYC_EXCTN_SK, S.LAST_UPDT_RUN_CYC_EXCTN_SK)",
