{
  "name": "UwsPNewDirClmSttusExtr",
  "properties": {
    "annotations": [],
    "parameters": {},
    "activities": [
      {
        "name": "CP_UwsPNewDirClmSttusExtr",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH cte AS (SELECT CLM_STTUS_CD, USER_ID, LAST_UPDT_DT_SK FROM @{pipeline().globalParameters.gbl_param_UWSOwner}.NEWDIR_CLM_STTUS) SELECT cte.CLM_STTUS_CD, cte.USER_ID, cte.LAST_UPDT_DT_SK FROM cte",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".dat"
            },
            "translator": {
              "type": "TabularTranslator",
              "typeConversion": true,
              "typeConversionSettings": {
                "allowDataTruncation": true,
                "treatBooleanAsNumber": false
              },
              "mappings": [
                {
                  "source": {
                    "physicalType": "String",
                    "ordinal": 1
                  },
                  "sink": {
                    "name": "CLM_STTUS_CD",
                    "type": "String",
                    "physicalType": "String"
                  }
                },
                {
                  "source": {
                    "physicalType": "String",
                    "ordinal": 2
                  },
                  "sink": {
                    "name": "USER_ID",
                    "type": "String",
                    "physicalType": "String"
                  }
                },
                {
                  "source": {
                    "physicalType": "String",
                    "ordinal": 3
                  },
                  "sink": {
                    "name": "LAST_UPDT_DT_SK",
                    "type": "String",
                    "physicalType": "String"
                  }
                }
              ]
            }
          },
          "linkedServiceName": {
            "referenceName": "uws",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_uws",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_UWSOwner}",
              "param_table": "NEWDIR_CLM_STTUS"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": {
                "value": "@concat(pipeline().globalParameters.gbl_param_environment, '/', 'load')",
                "type": "Expression"
              },
              "param_filename": "P_NEWDIR_CLM_STTUS.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "\""
            }
          }
        ]
      }
    ],
    "type": "pipeline",
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Claims/EdwLoads/PTables"
    }
  },
