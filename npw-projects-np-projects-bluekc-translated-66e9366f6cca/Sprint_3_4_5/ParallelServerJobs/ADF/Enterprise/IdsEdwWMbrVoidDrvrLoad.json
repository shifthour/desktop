            {
              "type": "Query",
              "text": {
                "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_EDWOwner}.W_MBR_VOID_DRVR; INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.W_MBR_VOID_DRVR (SRC_SYS_CD, MBR_UNIQ_KEY, MBR_ENR_EFF_DT_SK, PROD_ID, PRCS_DT_SK, SRC_SYS_CRT_DT, MBR_ENR_TERM_DT_SK, CLS_ID, GRP_UNIQ_KEY, SUBGRP_UNIQ_KEY, CLS_PLN_ID, ALPHA_PFX_CD) SELECT SRC_SYS_CD, MBR_UNIQ_KEY, MBR_ENR_EFF_DT_SK, PROD_ID, PRCS_DT_SK, SRC_SYS_CRT_DT, MBR_ENR_TERM_DT_SK, CLS_ID, GRP_UNIQ_KEY, SUBGRP_UNIQ_KEY, CLS_PLN_ID, ALPHA_PFX_CD FROM @{pipeline().globalParameters.gbl_param_edw_staging}.abc_TMP_IdsEdwWMbrVoidDrvrLoad; WITH cte_stg AS (SELECT MBR_UNIQ_KEY, MBR_ENR_EFF_DT_SK, PROD_ID, PRCS_DT_SK, SRC_SYS_CRT_DT, MBR_ENR_TERM_DT_SK, CLS_ID, GRP_UNIQ_KEY, SUBGRP_UNIQ_KEY, CLS_PLN_ID, ALPHA_PFX_CD FROM @{pipeline().globalParameters.gbl_param_edw_staging}.abc_TMP_IdsEdwWMbrVoidDrvrLoad) MERGE @{pipeline().globalParameters.gbl_param_EDWOwner}.W_MBR_VOID_DRVR_WKLY AS T USING cte_stg AS S ON T.MBR_UNIQ_KEY = S.MBR_UNIQ_KEY AND T.MBR_ENR_EFF_DT_SK = S.MBR_ENR_EFF_DT_SK AND T.PROD_ID = S.PROD_ID WHEN MATCHED THEN UPDATE SET T.PRCS_DT_SK = S.PRCS_DT_SK, T.SRC_SYS_CRT_DT = S.SRC_SYS_CRT_DT, T.MBR_ENR_TERM_DT_SK = S.MBR_ENR_TERM_DT_SK, T.CLS_ID = S.CLS_ID, T.GRP_UNIQ_KEY = S.GRP_UNIQ_KEY, T.SUBGRP_UNIQ_KEY = S.SUBGRP_UNIQ_KEY, T.CLS_PLN_ID = S.CLS_PLN_ID, T.ALPHA_PFX_CD = S.ALPHA_PFX_CD WHEN NOT MATCHED THEN INSERT (MBR_UNIQ_KEY, MBR_ENR_EFF_DT_SK, PROD_ID, PRCS_DT_SK, SRC_SYS_CRT_DT, MBR_ENR_TERM_DT_SK, CLS_ID, GRP_UNIQ_KEY, SUBGRP_UNIQ_KEY, CLS_PLN_ID, ALPHA_PFX_CD) VALUES (S.MBR_UNIQ_KEY, S.MBR_ENR_EFF_DT_SK, S.PROD_ID, S.PRCS_DT_SK, S.SRC_SYS_CRT_DT, S.MBR_ENR_TERM_DT_SK, S.CLS_ID, S.GRP_UNIQ_KEY, S.SUBGRP_UNIQ_KEY, S.CLS_PLN_ID, S.ALPHA_PFX_CD);",
