                "value": "WITH ORCHESTRATE AS (SELECT GRP_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,GRP_ID,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,GRP_MKTNG_TERR_ID,GRP_MKTNG_TERR_ID_CHG_IN,GRP_ST_CD,GRP_ST_CD_CHG_IN,GRP_REINST_DT_SK,GRP_REINST_DT_CHG_IN,GRP_RNWL_DT_SK,GRP_RNWL_DT_CHG_IN,GRP_TERM_DT_SK,GRP_TERM_DT_CHG_IN,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,GRP_MKT_SEG_CD,GRP_MKT_SEG_CD_CHG_IN FROM @{pipeline().globalParameters.gbl_param_edw_staging}.temp_IdsEdwGrpHistDLoad) UPDATE @{pipeline().globalParameters.gbl_param_EDWOwner}.GRP_HIST_D SET SRC_SYS_CD = O.SRC_SYS_CD,GRP_ID = O.GRP_ID,LAST_UPDT_RUN_CYC_EXCTN_DT_SK = O.LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN = O.EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK = O.EDW_RCRD_END_DT_SK,GRP_MKTNG_TERR_ID = O.GRP_MKTNG_TERR_ID,GRP_MKTNG_TERR_ID_CHG_IN = O.GRP_MKTNG_TERR_ID_CHG_IN,GRP_ST_CD = O.GRP_ST_CD,GRP_ST_CD_CHG_IN = O.GRP_ST_CD_CHG_IN,GRP_REINST_DT_SK = O.GRP_REINST_DT_SK,GRP_REINST_DT_CHG_IN = O.GRP_REINST_DT_CHG_IN,GRP_RNWL_DT_SK = O.GRP_RNWL_DT_SK,GRP_RNWL_DT_CHG_IN = O.GRP_RNWL_DT_CHG_IN,GRP_TERM_DT_SK = O.GRP_TERM_DT_SK,GRP_TERM_DT_CHG_IN = O.GRP_TERM_DT_CHG_IN,LAST_UPDT_RUN_CYC_EXCTN_SK = O.LAST_UPDT_RUN_CYC_EXCTN_SK,GRP_MKT_SEG_CD = O.GRP_MKT_SEG_CD,GRP_MKT_SEG_CD_CHG_IN = O.GRP_MKT_SEG_CD_CHG_IN FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.GRP_HIST_D T JOIN ORCHESTRATE O ON T.GRP_SK = O.GRP_SK AND T.EDW_RCRD_STRT_DT_SK = O.EDW_RCRD_STRT_DT_SK; INSERT INTO @{pipeline().globalParameters.gbl_param_EDWOwner}.GRP_HIST_D (GRP_SK,EDW_RCRD_STRT_DT_SK,SRC_SYS_CD,GRP_ID,CRT_RUN_CYC_EXCTN_DT_SK,LAST_UPDT_RUN_CYC_EXCTN_DT_SK,EDW_CUR_RCRD_IN,EDW_RCRD_END_DT_SK,GRP_MKTNG_TERR_ID,GRP_MKTNG_TERR_ID_CHG_IN,GRP_ST_CD,GRP_ST_CD_CHG_IN,GRP_REINST_DT_SK,GRP_REINST_DT_CHG_IN,GRP_RNWL_DT_SK,GRP_RNWL_DT_CHG_IN,GRP_TERM_DT_SK,GRP_TERM_DT_CHG_IN,CRT_RUN_CYC_EXCTN_SK,LAST_UPDT_RUN_CYC_EXCTN_SK,GRP_MKT_SEG_CD,GRP_MKT_SEG_CD_CHG_IN) SELECT O.GRP_SK,O.EDW_RCRD_STRT_DT_SK,O.SRC_SYS