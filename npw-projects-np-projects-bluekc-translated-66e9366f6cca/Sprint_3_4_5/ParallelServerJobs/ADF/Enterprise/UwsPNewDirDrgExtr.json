{
  "name": "UwsPNewDirDrgExtr",
  "properties": {
    "parameters": {},
    "activities": [
      {
        "name": "Copy_NewDir_Drg",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "linkedServiceName": {
            "referenceName": "uws",
            "type": "LinkedServiceReference"
          },
          "source": {
            "type": "AzureSqlSource",
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "sqlReaderQuery": {
              "value": "WITH cte_source AS ( SELECT DRG_CD, DRG_METH_CD, USER_ID, SUBSTRING(LAST_UPDT_DT_SK,1,10) AS LAST_UPDT_DT_SK FROM @{pipeline().globalParameters.gbl_param_UWSOwner}.NEWDIR_DRG ) SELECT DRG_CD, DRG_METH_CD, USER_ID, LAST_UPDT_DT_SK FROM cte_source",
              "type": "Expression"
            }
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings",
              "copyBehavior": "FlattenHierarchy"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".txt"
            }
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "DRG_CD",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "DRG_METH_CD",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "USER_ID",
                  "type": "String",
                  "physicalType": "varchar"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "LAST_UPDT_DT_SK",
                  "type": "String",
                  "physicalType": "char"
                }
              }
            ]
          }
        },
        "inputs": [
          {
            "referenceName": "ds_uws",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_UWSOwner}",
              "param_table": "NEWDIR_DRG"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": "@concat(pipeline().globalParameters.gbl_param_environment,'/load')",
              "param_filename": "P_NEWDIR_DRG.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "\""
            }
          }
        ]
      }
    ],
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Claims/EdwLoads/PTables"
    }
  },
  "Description": "COPYRIGHT 2007 BLUE CROSS/BLUE SHIELD OF KANSAS CITY \n\n\nCALLED BY:   \n\nPROCESSING:\n                  \n                The Job loads the EDW - P_NEWDIR_DRG table.            \n\nMODIFICATIONS:\nDeveloper                          Date                 Project/Altiris #                Change Description                             Development Project    Code Reviewer            Date Reviewed\n======================================================================================================================================\nManasa Andru                  2016-01-28         TFS - 10783                 Original Programming                               EnterpriseDev1            Kalyan Neelam            2016-01-29\n\nManasa Andru                  2017-01-17         TFS - 10784             Added Substring condition for field              EnterpriseDev1           Jag Yelavarthi               2017-01-18\n                                                                                                            LAST_UPDT_DT_SK\n\nAnnotations:\nJob Name: UwsPNewDirDrgExtr\nRead all the Data from UWS NEWDIR_DRG Table"
}