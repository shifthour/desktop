                "value": "WITH cte AS (SELECT PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_SK, FILE_ID, CNTR_SEQ_ID, SUBMT_CNTR_SEQ_ID, DTL_SEQ_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, CMS_CNTR_ID, SUBMT_CMS_CNTR_ID, CUR_MCARE_BNFCRY_ID, LAST_SUBMT_MCARE_BNFCRY_ID, DRUG_COV_STTUS_CD_TX, CUR_MO_GROS_DRUG_CST_BELOW_AMT/100.0 AS CUR_MO_GROS_DRUG_CST_BELOW_AMT, CUR_MO_GROS_DRUG_CST_ABOVE_AMT/100.0 AS CUR_MO_GROS_DRUG_CST_ABOVE_AMT, CUR_MO_TOT_GROS_DRUG_CST_AMT/100.0 AS CUR_MO_TOT_GROS_DRUG_CST_AMT, CUR_MO_LOW_INCM_CST_SHARING_AMT/100.0 AS CUR_MO_LOW_INCM_CST_SHARING_AMT, CUR_MO_COV_PLN_PD_AMT/100.0 AS CUR_MO_COV_PLN_PD_AMT, CUR_SUBMT_DUE_AMT/100.0 AS CUR_SUBMT_DUE_AMT, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK FROM @{pipeline().globalParameters.gbl_param_edw_staging}.XYZ_TMP_PdePayblRptCntrSubmtCntrDtlFLoad) MERGE @{pipeline().globalParameters.gbl_param_EDWOwner}.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_F AS T USING cte AS S ON T.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_SK = S.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_SK WHEN MATCHED THEN UPDATE SET T.FILE_ID = S.FILE_ID, T.CNTR_SEQ_ID = S.CNTR_SEQ_ID, T.SUBMT_CNTR_SEQ_ID = S.SUBMT_CNTR_SEQ_ID, T.DTL_SEQ_ID = S.DTL_SEQ_ID, T.SRC_SYS_CD = S.SRC_SYS_CD, T.CRT_RUN_CYC_EXCTN_DT_SK = S.CRT_RUN_CYC_EXCTN_DT_SK, T.LAST_UPDT_RUN_CYC_EXCTN_DT_SK = S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, T.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK = S.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, T.CMS_CNTR_ID = S.CMS_CNTR_ID, T.SUBMT_CMS_CNTR_ID = S.SUBMT_CMS_CNTR_ID, T.CUR_MCARE_BNFCRY_ID = S.CUR_MCARE_BNFCRY_ID, T.LAST_SUBMT_MCARE_BNFCRY_ID = S.LAST_SUBMT_MCARE_BNFCRY_ID, T.DRUG_COV_STTUS_CD_TX = S.DRUG_COV_STTUS_CD_TX, T.CUR_MO_GROS_DRUG_CST_BELOW_AMT = S.CUR_MO_GROS_DRUG_CST_BELOW_AMT, T.CUR_MO_GROS_DRUG_CST_ABOVE_AMT = S.CUR_MO_GROS_DRUG_CST_ABOVE_AMT, T.CUR_MO_TOT_GROS_DRUG_CST_AMT = S.CUR_MO_TOT_GROS_DRUG_CST_AMT, T.CUR_MO_LOW_INCM_CST_SHARING_AMT = S.CUR_MO_LOW_INCM_CST_SHARING_AMT, T.CUR_MO_COV_PLN_PD_AMT = S.CUR_MO_COV_PLN_PD_AMT, T.CUR_SUBMT_DUE_AMT = S.CUR_SUBMT_DUE_AMT, T.CRT_RUN_CYC_EXCTN_SK = S.CRT_RUN_CYC_EXCTN_SK, T.LAST_UPDT_RUN_CYC_EXCTN_SK = S.LAST_UPDT_RUN_CYC_EXCTN_SK WHEN NOT MATCHED THEN INSERT (PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_SK, FILE_ID, CNTR_SEQ_ID, SUBMT_CNTR_SEQ_ID, DTL_SEQ_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, CMS_CNTR_ID, SUBMT_CMS_CNTR_ID, CUR_MCARE_BNFCRY_ID, LAST_SUBMT_MCARE_BNFCRY_ID, DRUG_COV_STTUS_CD_TX, CUR_MO_GROS_DRUG_CST_BELOW_AMT, CUR_MO_GROS_DRUG_CST_ABOVE_AMT, CUR_MO_TOT_GROS_DRUG_CST_AMT, CUR_MO_LOW_INCM_CST_SHARING_AMT, CUR_MO_COV_PLN_PD_AMT, CUR_SUBMT_DUE_AMT, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK) VALUES (S.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_DTL_SK, S.FILE_ID, S.CNTR_SEQ_ID, S.SUBMT_CNTR_SEQ_ID, S.DTL_SEQ_ID, S.SRC_SYS_CD, S.CRT_RUN_CYC_EXCTN_DT_SK, S.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, S.PDE_PAYBL_RPT_CNTR_SUBMT_CNTR_SK, S.CMS_CNTR_ID, S.SUBMT_CMS_CNTR_ID, S.CUR_MCARE_BNFCRY_ID, S.LAST_SUBMT_MCARE_BNFCRY_ID, S.DRUG_COV_STTUS_CD_TX, S.CUR_MO_GROS_DRUG_CST_BELOW_AMT, S.CUR_MO_GROS_DRUG_CST_ABOVE_AMT, S.CUR_MO_TOT_GROS_DRUG_CST_AMT, S.CUR_MO_LOW_INCM_CST_SHARING_AMT, S.CUR_MO_COV_PLN_PD_AMT, S.CUR_SUBMT_DUE_AMT, S.CRT_RUN_CYC_EXCTN_SK, S.LAST_UPDT_RUN_CYC_EXCTN_SK)",
