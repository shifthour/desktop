        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_ids_staging}.[STG_OUT_TMP_IdsEdwCustSvcTaskDBalExtr];WITH cte_lookup AS (SELECT CD_MPPNG_SK, COALESCE(TRGT_CD,'UNK') AS TRGT_CD, COALESCE(TRGT_CD_NM,'UNK') AS TRGT_CD_NM FROM @{pipeline().globalParameters.gbl_param_IDSOwner}.CD_MPPNG), cte_source AS (SELECT SRC_SYS_CD_SK, CUST_SVC_ID, TASK_SEQ_NO, GRP_SK, CUST_ID FROM @{pipeline().globalParameters.gbl_param_ids_staging}.[STG_TMP_IdsEdwCustSvcTaskDBalExtr]), cte_join AS (SELECT s.CUST_SVC_ID, s.TASK_SEQ_NO, s.CUST_ID, l.TRGT_CD FROM cte_source s LEFT JOIN cte_lookup l ON s.SRC_SYS_CD_SK = l.CD_MPPNG_SK), cte_transform AS (SELECT CASE WHEN TRGT_CD IS NULL OR LEN(RTRIM(LTRIM(TRGT_CD)))=0 THEN 'NA' ELSE TRGT_CD END AS SRC_SYS_CD, CUST_SVC_ID, TASK_SEQ_NO AS CUST_SVC_TASK_SEQ_NO, CASE WHEN CUST_ID IS NULL OR LEN(RTRIM(LTRIM(CUST_ID)))=0 THEN ' ' ELSE CUST_ID END AS CUST_SVC_TASK_CUST_ID FROM cte_join) SELECT SRC_SYS_CD, CUST_SVC_ID, CUST_SVC_TASK_SEQ_NO, CUST_SVC_TASK_CUST_ID INTO @{pipeline().globalParameters.gbl_param_ids_staging}.[STG_OUT_TMP_IdsEdwCustSvcTaskDBalExtr] FROM cte_transform",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "ids",
          "type": "LinkedServiceReference"
        }
      },
