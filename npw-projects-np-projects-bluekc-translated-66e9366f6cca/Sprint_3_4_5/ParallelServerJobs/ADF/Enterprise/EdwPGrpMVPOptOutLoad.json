{
  "name": "EdwPGrpMVPOptOutLoad",
  "properties": {
    "parameters": {
      "EDWFilePath": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "Copy_EdwPGrpMVPOptOut",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource",
            "storeSettings": {
              "type": "AzureBlobStorageReadSettings",
              "recursive": true,
              "enablePartitionDiscovery": false
            },
            "formatSettings": {
              "type": "DelimitedTextReadSettings"
            }
          },
          "sink": {
            "type": "SqlMISink",
            "preCopyScript": {
              "value": "TRUNCATE TABLE @{pipeline().globalParameters.gbl_param_EDWOwner}.P_GRP_MVP_OPT_OUT",
              "type": "Expression"
            },
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false
          },
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            },
            "mappings": [
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 1
                },
                "sink": {
                  "name": "GRP_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 2
                },
                "sink": {
                  "name": "GRP_MVP_OPT_OUT_EFF_DT_SK",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 3
                },
                "sink": {
                  "name": "GRP_MVP_OPT_OUT_TERM_DT_SK",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 4
                },
                "sink": {
                  "name": "USER_ID",
                  "type": "String",
                  "physicalType": "String"
                }
              },
              {
                "source": {
                  "physicalType": "String",
                  "ordinal": 5
                },
                "sink": {
                  "name": "LAST_UPDT_DTM",
                  "type": "Datetime",
                  "physicalType": "DateTime"
                }
              }
            ]
          },
          "linkedServiceName": {
            "referenceName": "edw",
            "type": "LinkedServiceReference"
          }
        },
        "inputs": [
          {
            "referenceName": "ds_file_no_header",
            "type": "DatasetReference",
            "parameters": {
              "param_container": "@{pipeline().globalParameters.gbl_param_container_integrate}",
              "param_directory": {
                "value": "@concat(pipeline().globalParameters.gbl_param_environment,'/',pipeline().parameters.EDWFilePath,'/load')",
                "type": "Expression"
              },
              "param_filename": "P_GRP_MVP_OPT_OUT.dat",
              "param_col_delimiter": ",",
              "param_row_delimiter": "@null",
              "param_quote": "^",
              "param_escape_character": "@null",
              "param_null_value": "@null"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_edw",
            "type": "DatasetReference",
            "parameters": {
              "param_schema": "@{pipeline().globalParameters.gbl_param_EDWOwner}",
              "param_table": "P_GRP_MVP_OPT_OUT"
            }
          }
        ]
      }
    ],
    "folder": {
      "name": "Enterprise/Jobs/Payment Innovations/OptOutExtr"
    }
  },
  "Description": "MODIFICATIONS:\n                                                                                                                                                                                                                DATASTAGE               CODE                           DATE\nDEVELOPER             DATE                PROJECT                     DESCRIPTION                                                                                      PROJECT                    REVIEWER                 REVIEW\n-----------------------------    ----------------------     ------------------------------        -----------------------------------------------------------------------------------------------------------  ------------------------------    ------------------------------       --------------------\n\nDaniel Long              12/11/2015        5212                              New Program                                                                                         EnterpriseDev1          Jag Yelavarthi            2015-12-29\n\nAnnotations:\nLoad file created in EdwPaymentInnovationsOptOutExtr job will be loaded into the target DB2 table P_GRP_MVP_OPT_OUT\nLoad rejects are redirected into a Reject file\nRead the Load ready file created in Extract job\nJob to load the Target DB2 table P_GRP_MVP_OPT_OUT"
}