        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "WITH cte_main AS ( SELECT CustSvcF.SRC_SYS_CD, CustSvcF.CUST_SVC_ID, CustSvcF.CUST_SVC_CT, ROW_NUMBER() OVER (ORDER BY (SELECT 1)) as rownum FROM @{pipeline().globalParameters.gbl_param_EDWOwner}.CUST_SVC_F CustSvcF FULL OUTER JOIN @{pipeline().globalParameters.gbl_param_EDWOwner}.B_CUST_SVC_F BCustSvcF ON CustSvcF.SRC_SYS_CD = BCustSvcF.SRC_SYS_CD AND CustSvcF.CUST_SVC_ID = BCustSvcF.CUST_SVC_ID WHERE CustSvcF.LAST_UPDT_RUN_CYC_EXCTN_SK >= @{pipeline().parameters.ExtrRunCycle} AND CustSvcF.CUST_SVC_CT <> BCustSvcF.CUST_SVC_CT ) DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_edw_staging}.EdwEdwBCustSvcFBal_TMP_1; SELECT SRC_SYS_CD, CUST_SVC_ID, CUST_SVC_CT INTO @{pipeline().globalParameters.gbl_param_edw_staging}.EdwEdwBCustSvcFBal_TMP_1 FROM cte_main; DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_edw_staging}.EdwEdwBCustSvcFBal_TMP_2; SELECT 'COLUMN SUM BALANCING IDS - EDW CUST SVC F OUT OF TOLERANCE' AS NOTIFICATION INTO @{pipeline().globalParameters.gbl_param_edw_staging}.EdwEdwBCustSvcFBal_TMP_2 FROM cte_main WHERE rownum = 1",
                "type": "Expression"
              }
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "edw",
          "type": "LinkedServiceReference"
        }
      },
