  "name": "EdwEdwBCustSvcFBal",
  "properties": {
    "activities": [
      {
        "name": "script_EdwEdwBCustSvcFBal",
        "type": "Script",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
