              "type": "Query",
              "text": {
                "value": "WITH cte AS (SELECT dbo.trim_default(SCRCRD_WORK_TYP_ID) AS SCRCRD_WORK_TYP_ID, dbo.trim_default(SCRCRD_WORK_TYP_DESC) AS SCRCRD_WORK_TYP_DESC, 'Y' AS ACTV_IN, CAST('@{pipeline().parameters.CurrentRunDtm}' AS DATETIME) AS CRT_DTM, 'System' AS CRT_USER_ID, CAST('@{pipeline().parameters.CurrentRunDtm}' AS DATETIME) AS LAST_UPDT_DTM, 'System' AS LAST_UPDT_USER_ID FROM @{pipeline().globalParameters.gbl_param_edw_staging}.SCRCRD_WORK_TYP_TMP_ScrcrdMembershipScrcrdWorkTypLoad) MERGE @{pipeline().globalParameters.gbl_param_ScoreCardOwner}.SCRCRD_WORK_TYP AS T USING cte ON T.SCRCRD_WORK_TYP_ID = cte.SCRCRD_WORK_TYP_ID WHEN MATCHED THEN UPDATE SET T.SCRCRD_WORK_TYP_DESC = cte.SCRCRD_WORK_TYP_DESC, T.ACTV_IN = cte.ACTV_IN, T.LAST_UPDT_DTM = cte.LAST_UPDT_DTM, T.LAST_UPDT_USER_ID = cte.LAST_UPDT_USER_ID WHEN NOT MATCHED THEN INSERT (SCRCRD_WORK_TYP_ID, SCRCRD_WORK_TYP_DESC, ACTV_IN, CRT_DTM, CRT_USER_ID, LAST_UPDT_DTM, LAST_UPDT_USER_ID) VALUES (cte.SCRCRD_WORK_TYP_ID, cte.SCRCRD_WORK_TYP_DESC, cte.ACTV_IN, cte.CRT_DTM, cte.CRT_USER_ID, cte.LAST_UPDT_DTM, cte.LAST_UPDT_USER_ID);",
                "type": "Expression"
              }
            }
          ]
        },
