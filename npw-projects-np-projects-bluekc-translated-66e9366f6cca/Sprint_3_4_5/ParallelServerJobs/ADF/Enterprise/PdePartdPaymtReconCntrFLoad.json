UE_AMT, Target.CRT_RUN_CYC_EXCTN_SK = Source.CRT_RUN_CYC_EXCTN_SK, Target.LAST_UPDT_RUN_CYC_EXCTN_SK = Source.LAST_UPDT_RUN_CYC_EXCTN_SK WHEN NOT MATCHED THEN INSERT (PDE_PARTD_PAYMT_RECON_CNTR_SK, FILE_ID, CNTR_SEQ_ID, SRC_SYS_CD, CRT_RUN_CYC_EXCTN_DT_SK, LAST_UPDT_RUN_CYC_EXCTN_DT_SK, CMS_CNTR_ID, AS_OF_YR, AS_OF_MO, FILE_CRTN_DT, FILE_CRTN_TM, RPT_ID, DRUG_COV_STTUS_CD_TX, BNFCRY_CT, NET_GROS_DRUG_CST_BELOW_AMT, NET_GROS_DRUG_CST_ABOVE_AMT, NET_TOT_GROS_DRUG_CST_AMT, NET_LOW_INCM_CST_SHARING_AMT, NET_COV_PLN_PD_AMT, TOT_DTL_RCRD_CT, SUBMT_DUE_AMT, CRT_RUN_CYC_EXCTN_SK, LAST_UPDT_RUN_CYC_EXCTN_SK) VALUES (Source.PDE_PARTD_PAYMT_RECON_CNTR_SK, Source.FILE_ID, Source.CNTR_SEQ_ID, Source.SRC_SYS_CD, Source.CRT_RUN_CYC_EXCTN_DT_SK, Source.LAST_UPDT_RUN_CYC_EXCTN_DT_SK, Source.CMS_CNTR_ID, Source.AS_OF_YR, Source.AS_OF_MO, Source.FILE_CRTN_DT, Source.FILE_CRTN_TM, Source.RPT_ID, Source.DRUG_COV_STTUS_CD_TX, Source.BNFCRY_CT, Source.NET_GROS_DRUG_CST_BELOW_AMT, Source.NET_GROS_DRUG_CST_ABOVE_AMT, Source.NET_TOT_GROS_DRUG_CST_AMT, Source.NET_LOW_INCM_CST_SHARING_AMT, Source.NET_COV_PLN_PD_AMT, Source.TOT_DTL_RCRD_CT, Source.SUBMT_DUE_AMT, Source.CRT_RUN_CYC_EXCTN_SK, Source.LAST_UPDT_RUN_CYC_EXCTN_SK);",
