{
  "name": "FctsClmPrereqSeq_3",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/claim/SeqFacets"
    },
    "parameters": {
      "RunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "BeginDate": {
        "type": "String",
        "defaultValue": ""
      },
      "EndDate": {
        "type": "String",
        "defaultValue": ""
      },
      "DriverTable": {
        "type": "String",
        "defaultValue": "TMP_IDS_CLAIM"
      },
      "AdjFromTable": {
        "type": "String",
        "defaultValue": ""
      },
      "GrouperTable": {
        "type": "String",
        "defaultValue": "TMP_GROUPER_VER"
      },
      "RecycleDay": {
        "type": "String",
        "defaultValue": "MONDAY"
      },
      "RecycleFreq": {
        "type": "String",
        "defaultValue": "W"
      },
      "CntlJobName": {
        "type": "String",
        "defaultValue": "FctsClmCntl"
      },
      "SrcSysCd": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCdSK": {
        "type": "String",
        "defaultValue": ""
      },
      "TableID": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrentDate": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "HitListLinkCount": {
        "type": "String",
        "defaultValue": ""
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "FctsClmDriverHitList",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path,'/claim/driver/FctsClmDriverHitList')",
            "type": "Expression"
          },
          "baseParameters": {
            "DriverTable": {
              "value": "@pipeline().parameters.DriverTable",
              "type": "Expression"
            },
            "MonthsInMart": "24",
            "FacetsOwner": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsOwner",
              "type": "Expression"
            },
            "facets_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsSecret",
              "type": "Expression"
            },
            "BCBSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_BCBSOwner",
              "type": "Expression"
            },
            "bcbs_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_BCBSSecret",
              "type": "Expression"
            },
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "HitListLinkCount_JobLinkCount",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "FctsClmDriverHitList",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/JobLinkCount')",
            "type": "Expression"
          },
          "baseParameters": {
            "JobLinkCount_a1": "FctsClmDriverHitList",
            "JobLinkCount_a2": "TrnsSK",
            "JobLinkCount_a3": "NoClaimHit",
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "schema": {
              "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
              "type": "Expression"
            },
            "secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
              "type": "Expression"
            },
            "BCBSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_BCBSOwner",
              "type": "Expression"
            },
            "bcbs_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_BCBSSecret",
              "type": "Expression"
            },
            "FacetsOwner": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsOwner",
              "type": "Expression"
            },
            "facets_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsSecret",
              "type": "Expression"
            },
            "file_path": {
              "value": "",
              "type": "Expression"
            },
            "EnvProjectPath": {
              "value": "",
              "type": "Expression"
            },
            "delimiter": {
              "value": "",
              "type": "Expression"
            },
            "quote": {
              "value": "",
              "type": "Expression"
            },
            "header": {
              "value": "",
              "type": "Expression"
            },
            "nullValue": {
              "value": "",
              "type": "Expression"
            },
            "table_nm": {
              "value": "",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "HitListLinkCount",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "HitListLinkCount_JobLinkCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "HitListLinkCount",
          "value": {
            "value": "@string(activity('HitListLinkCount_JobLinkCount').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "HitListCountChk",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "HitListLinkCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@greater(int(variables('HitListLinkCount')), 0)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Email_HitList_Cnt",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "Email_Notification",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "recipients": {
                    "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                    "type": "Expression"
                  },
                  "subject": "Hit List ClaimID's exist that are not found in facets_repl",
                  "body": "There are CLM_ID values in the FctsClmHitList.dat that are not in CMC_CLCL_CLAIM table.  Please check the attachment.",
                  "blobFilenames": {
                    "value": "@concat(pipeline().globalParameters.gbl_param_environment,'/landing/FctsClaimHitListNullLkp.dat')",
                    "type": "Expression"
                  },
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": {
                    "value": "@pipeline().globalParameters.gbl_param_container_raw",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}