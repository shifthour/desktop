{
  "name": "FctsCustSvcRecycleSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/CustServ/Seq"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "RecycleCnt": {
        "type": "String"
      },
      "LinkCount": {
        "type": "String"
      },
      "var_Check_Count_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "var_If_1A_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "var_If_1A_Continuation_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "GetRecyleCount_a1": {
        "type": "String",
        "defaultValue": "FACETS"
      },
      "GetRecyleCount_a2": {
        "type": "String",
        "defaultValue": "hf_custsvc_recycle_keys"
      },
      "JobLinkCount_a1": {
        "type": "String",
        "defaultValue": "FctsCustScvRecycleExtr"
      },
      "JobLinkCount_a2": {
        "type": "String",
        "defaultValue": "Trans2"
      },
      "JobLinkCount_a3": {
        "type": "String",
        "defaultValue": "Output"
      }
    },
    "activities": [
      {
        "name": "GetRecyleCount",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/GetRecyleCount')",
            "type": "Expression"
          },
          "baseParameters": {
            "FACETSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_FACETSOwner",
              "type": "Expression"
            },
            "facets_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_FACETSSecret",
              "type": "Expression"
            },
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "SRC_SYSTEM": {
              "value": "@variables('GetRecyleCount_a1')",
              "type": "Expression"
            },
            "HASH_FILEExclusionListExtr": {
              "value": "@variables('GetRecyleCount_a2')",
              "type": "Expression"
            },
            "EnvProjectPath": {
              "value": "",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "Set_RecycleCnt",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "GetRecyleCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "RecycleCnt",
          "value": {
            "value": "@string(activity('GetRecyleCount').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "Check_Count",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "Set_RecycleCnt",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "on": {
            "value": "@if(greater(int(variables('RecycleCnt')),0),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_Check_Count_True",
                  "type": "SetVariable",
                  "dependsOn": [],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_Check_Count_branch",
                    "value": "1"
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_Check_Count_False",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_Check_Count_branch",
                "value": "0"
              }
            },
            {
              "name": "Rm_Hit_List",
              "type": "DatabricksNotebook",
              "dependsOn": [
                {
                  "activity": "Set_var_Check_Count_False",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/update/FctsCustSvcHitList.dat",
                    "type": "Expression"
                  },
                  "command": "delete",
                  "project": "integrate"
                }
              }
            }
          ]
        }
      },
      {
        "name": "If_1A",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "Check_Count",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "on": {
            "value": "@if(and(equals(variables('var_Check_Count_branch'),'1'), equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'FctsCustScvRecycleExtr'), false)),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_If_1A_True",
                  "type": "SetVariable",
                  "dependsOn": [],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_If_1A_branch",
                    "value": "1"
                  }
                },
                {
                  "name": "FctsCustScvRecycleExtr",
                  "type": "DatabricksNotebook",
                  "dependsOn": [
                    {
                      "activity": "Set_var_If_1A_True",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "timeout": "12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "linkedServiceName": {
                    "referenceName": "shareddatabricks",
                    "type": "LinkedServiceReference"
                  },
                  "typeProperties": {
                    "notebookPath": {
                      "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/CustServ/Driver/FctsCustScvRecycleExtr')",
                      "type": "Expression"
                    },
                    "baseParameters": {
                      "GlobalEnvironment": {
                        "value": "@pipeline().globalParameters.gbl_param_environment",
                        "type": "Expression"
                      }
                    }
                  }
                },
                {
                  "name": "chmod",
                  "type": "DatabricksNotebook",
                  "dependsOn": [
                    {
                      "activity": "FctsCustScvRecycleExtr",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "timeout": "12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "linkedServiceName": {
                    "referenceName": "shareddatabricks",
                    "type": "LinkedServiceReference"
                  },
                  "typeProperties": {
                    "notebookPath": {
                      "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                      "type": "Expression"
                    },
                    "baseParameters": {
                      "src_file_with_path": {
                        "value": "/update/FctsCustSvcHitList.dat",
                        "type": "Expression"
                      },
                      "command": "chmod",
                      "project": "integrate"
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_If_1A_False",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_If_1A_branch",
                "value": "0"
              }
            }
          ]
        }
      },
      {
        "name": "If_1A_Continuation",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "If_1A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "on": {
            "value": "@if(equals(variables('var_Check_Count_branch'),'1'),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_If_1A_Continuation_True",
                  "type": "SetVariable",
                  "dependsOn": [],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_If_1A_Continuation_branch",
                    "value": "1"
                  }
                },
                {
                  "name": "JobLinkCount",
                  "type": "DatabricksNotebook",
                  "dependsOn": [
                    {
                      "activity": "Set_var_If_1A_Continuation_True",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "timeout": "12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "linkedServiceName": {
                    "referenceName": "shareddatabricks",
                    "type": "LinkedServiceReference"
                  },
                  "typeProperties": {
                    "notebookPath": {
                      "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/JobLinkCount')",
                      "type": "Expression"
                    },
                    "baseParameters": {
                      "schema": {
                        "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                        "type": "Expression"
                      },
                      "secret_name": {
                        "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                        "type": "Expression"
                      },
                      "GlobalEnvironment": {
                        "value": "@pipeline().globalParameters.gbl_param_environment",
                        "type": "Expression"
                      },
                      "JobLinkCount_a1": {
                        "value": "@variables('JobLinkCount_a1')",
                        "type": "Expression"
                      },
                      "JobLinkCount_a2": {
                        "value": "@variables('JobLinkCount_a2')",
                        "type": "Expression"
                      },
                      "JobLinkCount_a3": {
                        "value": "@variables('JobLinkCount_a3')",
                        "type": "Expression"
                      },
                      "file_path": {
                        "value": "",
                        "type": "Expression"
                      },
                      "EnvProjectPath": {
                        "value": "",
                        "type": "Expression"
                      },
                      "delimiter": {
                        "value": "",
                        "type": "Expression"
                      },
                      "quote": {
                        "value": "",
                        "type": "Expression"
                      },
                      "header": {
                        "value": "",
                        "type": "Expression"
                      },
                      "nullValue": {
                        "value": "",
                        "type": "Expression"
                      },
                      "table_nm": {
                        "value": "",
                        "type": "Expression"
                      }
                    }
                  }
                },
                {
                  "name": "Set_LinkCount",
                  "type": "SetVariable",
                  "dependsOn": [
                    {
                      "activity": "JobLinkCount",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "LinkCount",
                    "value": {
                      "value": "@string(activity('JobLinkCount').output.runOutput)",
                      "type": "Expression"
                    }
                  }
                },
                {
                  "name": "Email_DAT",
                  "type": "ExecutePipeline",
                  "dependsOn": [
                    {
                      "activity": "Set_LinkCount",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "pipeline": {
                      "referenceName": "Email_Notification",
                      "type": "PipelineReference"
                    },
                    "waitOnCompletion": true,
                    "parameters": {
                      "recipients": {
                        "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                        "type": "Expression"
                      },
                      "subject": {
                        "value": "@concat(pipeline().globalParameters.gbl_param_IDSDB, ' ', variables('LinkCount'), ' Facets Customer Service Recycle Errors ')",
                        "type": "Expression"
                      },
                      "body": "The IDS Facets Customer Service processing had foreign key errors.  The reference IDs have been written to the Customer Service Hit List file for reprocessing.  The error count is in the subject line of this email.",
                      "blobFilenames": "",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": ""
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_If_1A_Continuation_False",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_If_1A_Continuation_branch",
                "value": "0"
              }
            }
          ]
        }
      }
    ]
  }
}