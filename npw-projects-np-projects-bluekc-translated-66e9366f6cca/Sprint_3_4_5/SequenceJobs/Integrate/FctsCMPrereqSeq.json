{
  "name": "FctsCMPrereqSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/MedMgt/MedMgt/Seq"
    },
    "parameters": {
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCdSK": {
        "type": "String",
        "defaultValue": ""
      },
      "TableID": {
        "type": "String",
        "defaultValue": ""
      },
      "LookbackDate": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1A",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'DropCreateTempTbl'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "DropCreateTempTbl",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "SQLQueryCmd",
                  "type": "PipelineReference"
                },
                "parameters": {
                  "FacetsOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_FacetsOwner",
                    "type": "Expression"
                  },
                  "facets_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_FacetsSecret",
                    "type": "Expression"
                  },
                  "Command1": "DROP TABLE IF EXISTS tempdb..TMP_IDS_CM",
                  "Command2": "CREATE TABLE tempdb..TMP_IDS_CM (CMCM_ID CHAR(9) NOT NULL, CONSTRAINT IDSUM02 PRIMARY KEY NONCLUSTERED (CMCM_ID))"
                },
                "waitOnCompletion": true
              },
              "policy": {
                "secureInput": false
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_1B",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_1A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'FctsCMDriverHitList'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "FctsCMDriverHitList",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "FctsCMDriverHitList",
                  "type": "PipelineReference"
                },
                "parameters": {
                  "DriverTable": {
                    "value": "@pipeline().parameters.TableID",
                    "type": "Expression"
                  }
                },
                "waitOnCompletion": true
              },
              "policy": {
                "secureInput": false
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_1C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_1B",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'MvMedMgtCmHitList'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "MvMedMgtCmHitList",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/update/FctsMedMgtCMHitList.dat",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/landing/processed/FctsMedMgtCMHitList.dat:",
                    "type": "Expression"
                  },
                  "command": "move",
                  "project": "integrate"
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}