                  "subject": "IDS MBR_ENR_QHP Abort",
                  "body": "The IDS Facets MBR_ENR_QHP Cntl cannot run while there is another process listed on the P_RUN_CYC as running.   This job is being halted.\n\nSOURCE:           FACETS\nSUBJECT:          MBRENRQHP\nTARGET:           IDS\nFREQUENCY:    DAILY",
                  "blobFilenames": " ",
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": " "
                }
              }
