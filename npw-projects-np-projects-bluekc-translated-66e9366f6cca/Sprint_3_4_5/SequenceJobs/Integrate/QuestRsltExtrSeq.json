{
  "name": "QuestRsltExtrSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/Lab/Seq/Quest"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": "\\\"\\\""
      },
      "RowPassThru": {
        "type": "String",
        "defaultValue": "Y"
      },
      "CurrRunDt": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "RunId": {
        "type": "String",
        "defaultValue": ""
      },
      "EmailAddr": {
        "type": "String",
        "defaultValue": ""
      },
      "EmailNotification": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCd": {
        "type": "String",
        "defaultValue": ""
      },
      "CntlFileIn": {
        "type": "String",
        "defaultValue": ""
      },
      "RsltFileIn": {
        "type": "String",
        "defaultValue": ""
      },
      "FacetsSrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      },
      "BCASrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1B",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'QuestLabRsltExtr'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "QuestLabRsltExtr",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/Lab/LabRslt/Quest/QuestLabRsltExtr')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "CurrRunCycle": {
                    "value": "@pipeline().parameters.CurrRunCycle",
                    "type": "Expression"
                  },
                  "RowPassThru": {
                    "value": "@pipeline().parameters.RowPassThru",
                    "type": "Expression"
                  },
                  "CurrRunDt": {
                    "value": "@pipeline().parameters.CurrRunDt",
                    "type": "Expression"
                  },
                  "RunID": {
                    "value": "@pipeline().parameters.RunId",
                    "type": "Expression"
                  },
                  "SrcSysCdSk": {
                    "value": "@pipeline().parameters.SrcSysCdSk",
                    "type": "Expression"
                  },
                  "SrcSysCd": {
                    "value": "@pipeline().parameters.SrcSysCd",
                    "type": "Expression"
                  },
                  "CntlFileIn": {
                    "value": "@pipeline().parameters.CntlFileIn",
                    "type": "Expression"
                  },
                  "RsltFileIn": {
                    "value": "@pipeline().parameters.RsltFileIn",
                    "type": "Expression"
                  },
                  "BCBSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_BCBSOwner",
                    "type": "Expression"
                  },
                  "bcbs_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_BCBSSecret",
                    "type": "Expression"
                  },
                  "FacetsSrcSysCdSk": {
                    "value": "@pipeline().parameters.FacetsSrcSysCdSk",
                    "type": "Expression"
                  },
                  "BCASrcSysCdSk": {
                    "value": "@pipeline().parameters.BCASrcSysCdSk",
                    "type": "Expression"
                  }
                }
              }
            }
          ]
        }
      },
      {
        "name": "TouchErrorFile",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "If_1B",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/QUEST_LAB_RSLT_ERRORS.txt",
              "type": "Expression"
            },
            "command": "touch",
            "project": "integrate"
          }
        }
      },
      {
        "name": "Email",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "TouchErrorFile",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "Email_Notification",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "recipients": {
              "value": "@pipeline().parameters.EmailNotification",
              "type": "Expression"
            },
            "subject": "Quest Lab Result Status",
            "body": "The Quest Lab Result data has been loaded. Attached is a file containing the results of the load.  If there were errors, they will be in error file that is also attached\n\n",
            "blobFilenames": {
              "value": "@concat(pipeline().globalParameters.gbl_param_environment,'/external/QUEST_LAB_RSLT_STATUS.txt,/external/QUEST_LAB_RSLT_ERRORS.txt')",
              "type": "Expression"
            },
            "fromemail": {
              "value": "@pipeline().globalParameters.gbl_param_fromemail",
              "type": "Expression"
            },
            "containerName": {
              "value": "@pipeline().globalParameters.gbl_param_container_published",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "FTPSourceFileToLan",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Email",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
            "type": "Expression"
          },
          "baseParameters": {
            "MACHINE": "o_lib",
            "FTPCMD": "put",
            "LOCALPATH": {
              "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/landing')",
              "type": "Expression"
            },
            "LOCALFILENAME": {
              "value": "@pipeline().parameters.RsltFileIn",
              "type": "Expression"
            },
            "REMOTEPATH": "/library/library/IAD/PHI11/Shared/Input_IDS/Quest",
            "REMOTEFILENAME": {
              "value": "@concat('QUEST_LabResults_', pipeline().parameters.RunId, '.txt')",
              "type": "Expression"
            },
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "Archive_input_file",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "FTPSourceFileToLan",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/landing",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.",
              "type": "Expression"
            },
            "command": "move",
            "project": "integrate"
          }
        }
      },
      {
        "name": "Archive_control_file",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Archive_input_file",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/landing",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.",
              "type": "Expression"
            },
            "command": "move",
            "project": "integrate"
          }
        }
      },
      {
        "name": "Archive_result_file",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Archive_control_file",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/QUEST_LAB_RSLT_STATUS.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/processed/QUEST_LAB_RSLT_STATUS.txt.",
              "type": "Expression"
            },
            "command": "move",
            "project": "integrate"
          }
        }
      },
      {
        "name": "Archive_error_file",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Archive_result_file",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/QUEST_LAB_RSLT_ERRORS.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/processed/QUEST_LAB_RSLT_ERRORS.txt.",
              "type": "Expression"
            },
            "command": "move",
            "project": "integrate"
          }
        }
      }
    ]
  }
}