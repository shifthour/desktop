        ],
        "typeProperties": {
          "notebookPath": "/Shared/Utilities/FIND_DATE",
          "baseParameters": {
            "inputDate": "@pipeline().globalParameters.RunCycleDate",
            "increment": "@string(mul(-1, pipeline().globalParameters.NbrMonthsToProcess))",
