{
  "name": "OptumMedDBalancingClmCobLoadSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/claim/SeqOptum"
    },
    "parameters": {
      "RunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "Source": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_11A",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'ConcatBClmCob'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "ConcatBClmCob",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/prepare_files')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "FILEPATH": {
                    "value": "'load'",
                    "type": "Expression"
                  },
                  "PATTERN": {
                    "value": "@concat('B_CLM_COB.', pipeline().parameters.Source, '.*')",
                    "type": "Expression"
                  },
                  "tableName": "B_CLM_COB",
                  "primarySort": "-k9,9 -k5,5r",
                  "secondarySort": "-k1,3",
                  "EnvProjectPath": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_11B",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_11A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'CopyBClmCob'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "CopyBClmCob",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/load/B_CLM_COB.uniq",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/.dat.",
                    "type": "Expression"
                  },
                  "command": "copy",
                  "project": "integrate"
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_11C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_11B",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'LoadBCLMCOB'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "LoadBCLMCOB",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/DB.LOAD')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "table": "B_CLM_COB",
                  "action": "REPLACE",
                  "file_name": "B_CLM_COB.uniq",
                  "run_stat": "Y",
                  "owner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  },
                  "EnvProjectPath": {
                    "value": "",
                    "type": "Expression"
                  },
                  "file_path": {
                    "value": "",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}