{
  "name": "AhyEligBalancingLoadSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/member/Seq/Balancing"
    },
    "parameters": {
      "RunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "Source": {
        "type": "String",
        "defaultValue": "ECOM"
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1A",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'ConcatBAhyElig'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "ConcatBAhyElig",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'prepare_files')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "FILEPATH": {
                    "value": "'load'",
                    "type": "Expression"
                  },
                  "PATTERN": {
                    "value": "@concat('B_AHY_ELIG.', pipeline().parameters.Source, '*')",
                    "type": "Expression"
                  },
                  "datasetName": "B_AHY_ELIG",
                  "SORTKEY_PK": "9,9 -k5,5",
                  "SORTKEY_TS": "1,2",
                  "EnvProjectPath": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_1B",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_1A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'CopyBAhyElig'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "CopyBAhyElig",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/load/B_AHY_ELIG.uniq",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/balancing/snapshot/IDS_AHY_ELIG.dat.",
                    "type": "Expression"
                  },
                  "command": "copy",
                  "project": "integrate"
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_1C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_1B",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'LoadBAhyElig'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "LoadBAhyElig",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/DB.LOAD')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "table": "B_AHY_ELIG",
                  "action": "REPLACE",
                  "file_name": "B_AHY_ELIG.uniq",
                  "run_stat": "Y",
                  "owner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  },
                  "EnvProjectPath": {
                    "value": "",
                    "type": "Expression"
                  },
                  "file_path": {
                    "value": "",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}