        ],
        "userProperties": [],
        "typeProperties": {
          "on": {
            "value": "@if(and(equals(variables('var_CountChk_branch'),'0'),not(contains(variables('ExclusionList'),'IdeaMbrRiskMesrExtrSeq'))),'1','0')",
            "type": "Expression"
          },
