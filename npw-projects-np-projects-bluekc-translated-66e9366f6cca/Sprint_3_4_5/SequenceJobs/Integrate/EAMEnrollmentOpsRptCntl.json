            "ids_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
              "type": "Expression"
            },
            "TCSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_TCSOwner",
              "type": "Expression"
            },
            "tcs_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_TCSSecret",
              "type": "Expression"
            },
            "MTMOwner": {
              "value": "@pipeline().globalParameters.gbl_param_MTMOwner",
              "type": "Expression"
            },
            "mtm_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_MTMSecret",
              "type": "Expression"
            },
            "LEP_FileName": {
              "value": "@pipeline().parameters.LEP_FileName",
              "type": "Expression"
            },
            "Environment": {
              "value": "@pipeline().parameters.Environment",
              "type": "Expression"
            },
            "LEPLTRDT": {
              "value": "@pipeline().parameters.LEPLTRDT",
              "type": "Expression"
            },
            "Initial_JobName": {
              "value": "@variables('JobName')",
              "type": "Expression"
            },
