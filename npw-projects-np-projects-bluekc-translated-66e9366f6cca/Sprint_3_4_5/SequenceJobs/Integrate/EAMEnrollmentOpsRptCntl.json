              "type": "Expression"
            },
            "eamrpt_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_EAMRPTSecret",
              "type": "Expression"
            },
            "IDSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
              "type": "Expression"
