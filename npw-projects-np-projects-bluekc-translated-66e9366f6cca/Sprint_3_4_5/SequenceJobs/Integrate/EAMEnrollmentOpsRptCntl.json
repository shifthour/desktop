        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/WriteRunID')",
            "type": "Expression"
          },
          "baseParameters": {
            "entry_name": {
              "value": "@concat(variables('JobName'), 'RunID')",
              "type": "Expression"
            },
            "IDSOwner": {
              "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
              "type": "Expression"
            },
            "secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
              "type": "Expression"
            },
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Execute_EAMEnrollmentOpsRptCntl1",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "WriteRunID_NB",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "EAMEnrollmentOpsRptCntl1",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "EmailSupport": {
              "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
              "type": "Expression"
            },
            "FacetsOwner": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsOwner",
              "type": "Expression"
            },
            "facets_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_FacetsSecret",
              "type": "Expression"
            },
            "EAMOwner": {
              "value": "@pipeline().globalParameters.gbl_param_EAMOwner",
              "type": "Expression"
            },
            "eam_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_EAMSecret",
              "type": "Expression"
            },
            "EAMRPTOwner": {
