                    "pipeline": {
                      "referenceName": "Email_Notification",
                      "type": "PipelineReference"
                    },
                    "waitOnCompletion": true,
                    "parameters": {
                      "recipients": {
                        "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                        "type": "Expression"
                      },
                      "subject": "MADOR 1099 Process Abort",
                      "body": "The MADOR 1099 process can not run while another instance of the job in the P_RUN_CYCLE is open as running.\n\nEdwMassKc1099ExtrCntl used the following values when doing the ProcessCheckExtr:\n\nSubject: MADOR_1099\nSource: EDW\nTarget: EDW",
                      "blobFilenames": " ",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": " "
                    }
                  }
                }
              ]
            }
