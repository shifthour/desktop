          "on": {
            "value": "@if(and(equals(variables('CountChk_branch'),'1'),not(contains(variables('ExclusionList'),'EdwACAActivityFeeExtr'))),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_If_1A_True",
                  "type": "SetVariable",
                  "dependsOn": [],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
