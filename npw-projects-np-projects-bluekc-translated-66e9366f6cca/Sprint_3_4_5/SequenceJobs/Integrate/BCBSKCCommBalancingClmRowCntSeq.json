                  "TrgtTable": "DRUG_CLM",
                  "SrcTable": "B_DRUG_CLM",
                  "NotifyMessage": {
                    "value": "@concat('ROW COUNT BALANCING ', string(pipeline().parameters.SrcSysCd), ' - IDS DRUG_CLAIM OUT OF TOLERANCE')",
                    "type": "Expression"
                  },
                  "UWSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_UWSOwner",
                    "type": "Expression"
                  },
                  "uws_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_UWSSecret",
                    "type": "Expression"
                  },
                  "SubjectArea": "Claims",
                  "CurrentDate": {
                    "value": "@pipeline().parameters.CurrentDate",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
