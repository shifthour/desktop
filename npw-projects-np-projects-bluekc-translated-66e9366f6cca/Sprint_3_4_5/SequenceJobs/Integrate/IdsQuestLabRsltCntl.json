                    "type": "Expression"
                  },
                  "Source": "@variables('Source')",
                  "Target": "@variables('Target')",
                  "Subject": "@variables('Subject')",
                  "Frequency": "@variables('Frequency')"
                }
              }
            },
            {
              "name": "SetVariable_RunCyc",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "Time",
                  "dependencyConditions": [
