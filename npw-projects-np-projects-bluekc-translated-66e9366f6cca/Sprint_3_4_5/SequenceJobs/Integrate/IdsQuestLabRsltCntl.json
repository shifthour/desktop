      },
      "Target": {
        "defaultValue": "IDS"
      },
      "Subject": {
        "defaultValue": "LABRSLT"
      },
      "Frequency": {
        "defaultValue": "MONTHLY"
      },
      "BeginDt": {
        "defaultValue": ""
      },
      "LinkCount": {
        "defaultValue": ""
      },
      "CntlFileIn": {
        "defaultValue": ""
      },
      "RsltFileIn": {
        "defaultValue": ""
      },
      "RunCyc": {
        "defaultValue": ""
      },
      "EndDt": {
        "defaultValue": ""
      },
      "Message": {
        "defaultValue": ""
      },
      "ExclusionList": {
        "defaultValue": ""
      },
      "BeginYrMo": {
        "defaultValue": ""
      },
      "CurrentDate": {
        "defaultValue": ""
      },
      "RunCycle": {
        "defaultValue": ""
      },
      "SrcSysCdSk": {
        "defaultValue": ""
      },
      "ErrorFile": {
        "defaultValue": ""
      },
      "FacetsSrcSysCdSk": {
        "defaultValue": ""
      },
      "BCASrcSysCdSk": {
        "defaultValue": ""
      },
      "var_CountChk_branch": {
        "defaultValue": ""
      },
      "var_If_CntlFile_branch": {
        "defaultValue": ""
      },
      "var_If_RsltFile_branch": {
        "defaultValue": ""
