{
  "name": "WdmTableClearSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/WebDataMart/Util"
    },
    "parameters": {
      "TableList": {
        "type": "String",
        "defaultValue": ""
      },
      "CallerID": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      },
      "Counter": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "StartLoop",
        "type": "ForEach",
        "dependsOn": [],
        "typeProperties": {
          "items": {
            "value": "@split(pipeline().parameters.TableList, ',')",
            "type": "Expression"
          },
          "activities": [
            {
              "name": "WdmTableDel",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/WebDataMart/Util/WdmTableDel')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "TableName": {
                    "value": "@variables('Counter')",
                    "type": "Expression"
                  },
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "ClmMartOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_ClmMartOwner",
                    "type": "Expression"
                  },
                  "clmmart_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_ClmMartSecret",
                    "type": "Expression"
                  }
                }
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              }
            }
          ]
        }
      }
    ]
  }
}