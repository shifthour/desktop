{
  "name": "LabCorpRsltExtrSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/Lab/Seq/LabCorp"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "RowPassThru": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrRunDt": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "RunId": {
        "type": "String",
        "defaultValue": ""
      },
      "InputFile": {
        "type": "String",
        "defaultValue": ""
      },
      "EmailAddr": {
        "type": "String",
        "defaultValue": ""
      },
      "EmailNotification": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      },
      "SrcSysCd": {
        "type": "String",
        "defaultValue": ""
      },
      "FacetsSrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      },
      "BCASrcSysCdSk": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LabRsltCntErrors": {
        "type": "String",
        "defaultValue": ""
      },
      "ErrorFile": {
        "type": "String",
        "defaultValue": ""
      },
      "JobLinkCount_a1": {
        "type": "String",
        "defaultValue": "LabCorpLabRsltExtr"
      },
      "JobLinkCount_a2": {
        "type": "String",
        "defaultValue": "BUSINESS_RULES"
      },
      "JobLinkCount_a3": {
        "type": "String",
        "defaultValue": "Bad_Records"
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1B",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'LabCorpLabRsltExtr'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "LabCorpLabRsltExtr",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/Lab/LabRslt/LabCorp/LabCorpLabRsltExtr')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "BCBSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_BCBSOwner",
                    "type": "Expression"
                  },
                  "bcbs_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_BCBSSecret",
                    "type": "Expression"
                  },
                  "CurrRunCycle": {
                    "value": "@pipeline().parameters.CurrRunCycle",
                    "type": "Expression"
                  },
                  "RowPassThru": {
                    "value": "@pipeline().parameters.RowPassThru",
                    "type": "Expression"
                  },
                  "CurrRunDt": {
                    "value": "@pipeline().parameters.CurrRunDt",
                    "type": "Expression"
                  },
                  "RunId": {
                    "value": "@pipeline().parameters.RunId",
                    "type": "Expression"
                  },
                  "SrcSysCdSk": {
                    "value": "@pipeline().parameters.SrcSysCdSk",
                    "type": "Expression"
                  },
                  "SrcSysCd": {
                    "value": "@pipeline().parameters.SrcSysCd",
                    "type": "Expression"
                  },
                  "InputFile": {
                    "value": "@pipeline().parameters.InputFile",
                    "type": "Expression"
                  },
                  "FacetsSrcSysCdSk": {
                    "value": "@pipeline().parameters.FacetsSrcSysCdSk",
                    "type": "Expression"
                  },
                  "BCASrcSysCdSk": {
                    "value": "@pipeline().parameters.BCASrcSysCdSk",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "JobLinkCount",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "If_1B",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/JobLinkCount')",
            "type": "Expression"
          },
          "baseParameters": {
            "JobLinkCount_a1": "LabCorpLabRsltExtr",
            "JobLinkCount_a2": "BUSINESS_RULES",
            "JobLinkCount_a3": "Bad_Records",
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "file_path": {
              "value": "",
              "type": "Expression"
            },
            "EnvProjectPath": {
              "value": "",
              "type": "Expression"
            },
            "delimiter": {
              "value": "",
              "type": "Expression"
            },
            "quote": {
              "value": "",
              "type": "Expression"
            },
            "header": {
              "value": "",
              "type": "Expression"
            },
            "nullValue": {
              "value": "",
              "type": "Expression"
            },
            "table_nm": {
              "value": "",
              "type": "Expression"
            },
            "schema": {
              "value": "",
              "type": "Expression"
            },
            "secret_name": {
              "value": "",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Set_LabRsltCntErrors",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "JobLinkCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "LabRsltCntErrors",
          "value": {
            "value": "@string(activity('JobLinkCount').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "Set_ErrorFile",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "Set_LabRsltCntErrors",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "ErrorFile",
          "value": {
            "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/external/LABCORP_LAB_RSLT_ERRORS.txt')",
            "type": "Expression"
          }
        }
      },
      {
        "name": "If_1C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "Set_ErrorFile",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@not(equals(variables('LabRsltCntErrors'), 0))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Email",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "Email_Notification",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "recipients": {
                    "value": "@pipeline().parameters.EmailNotification",
                    "type": "Expression"
                  },
                  "subject": "ENC: New Error File created for LabCorp Lab Result",
                  "body": "Attached is the new error file created for LabCorp Lab Result.  \n\nA backup copy has been made and compressed in the processed directory.",
                  "blobFilenames": {
                    "value": "@variables('ErrorFile')",
                    "type": "Expression"
                  },
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": {
                    "value": "@pipeline().globalParameters.gbl_param_container_published",
                    "type": "Expression"
                  }
                }
              }
            },
            {
              "name": "CpFile",
              "type": "DatabricksNotebook",
              "dependsOn": [
                {
                  "activity": "Email",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/external/LABCORP_LAB_RSLT_ERRORS.txt",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/external/processed/LABCORP_LAB_RSLT_ERRORS.txt.",
                    "type": "Expression"
                  },
                  "command": "move",
                  "project": "integrate"
                }
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "FTPSourceFileToLan",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "If_1C",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
            "type": "Expression"
          },
          "baseParameters": {
            "MACHINE": "o_lib",
            "FTPCMD": "put",
            "LOCALPATH": {
              "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/landing')",
              "type": "Expression"
            },
            "LOCALFILENAME": {
              "value": "@pipeline().parameters.InputFile",
              "type": "Expression"
            },
            "REMOTEPATH": "/library/library/IAD/PHI11/Shared/Input_IDS/LabCorp",
            "REMOTEFILENAME": {
              "value": "@concat('LABCORP_LabResults_', pipeline().parameters.RunId, '.txt')",
              "type": "Expression"
            },
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Archive_input_file",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "FTPSourceFileToLan",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/landing",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.",
              "type": "Expression"
            },
            "command": "move",
            "project": "integrate"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ]
  }
}