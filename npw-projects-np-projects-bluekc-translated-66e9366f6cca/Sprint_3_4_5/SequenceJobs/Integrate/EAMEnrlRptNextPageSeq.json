                        "type": "DatabricksNotebook",
                        "dependsOn": [
                          {
                            "activity": "var_If_1H_Continuation_branch_True",
                            "dependencyConditions": [
                              "Succeeded"
                            ]
                          }
                        ],
                        "policy": {
                          "timeout": "12:00:00",
                          "retry": 0,
                          "retryIntervalInSeconds": 30,
                          "secureOutput": false,
                          "secureInput": false
                        },
                        "linkedServiceName": {
                          "referenceName": "shareddatabricks",
                          "type": "LinkedServiceReference"
                        },
                        "typeProperties": {
                          "notebookPath": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
                          "baseParameters": {
                            "MACHINE": "o_lib",
                            "FTPCMD": "put",
                            "LOCALPATH": {
                              "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/landing')",
                              "type": "Expression"
