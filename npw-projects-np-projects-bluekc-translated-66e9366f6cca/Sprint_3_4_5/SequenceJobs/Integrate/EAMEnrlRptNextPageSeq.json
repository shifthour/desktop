{
  "name": "EAMEnrlRptNextPageSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/TraceabilityReporting/EnrollmetOperations"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrDate": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "Environment": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "FileList": {
        "type": "String",
        "defaultValue": ""
      },
      "var_If_0A_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "var_If_1G_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "var_If_1H_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "var_If_1H_Continuation_branch": {
        "type": "String",
        "defaultValue": "0"
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "Variables_LISTFILES",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/LIST.FILES')",
          "baseParameters": {
            "file_path": "($FilePath:'/landing','*_NXTPG_FCT_BKC_':@pipeline().parameters.Environment:'_RETURN_ANOC_WELCOME.txt')",
            "gbl_param_environment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "file_pattern": {
              "value": "",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "var_FileList_Variables",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "Variables_LISTFILES",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "FileList",
          "value": {
            "value": "@string(activity('Variables_LISTFILES').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "ListFiles_LISTFILES",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "var_FileList_Variables",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/LIST.FILES')",
          "baseParameters": {
            "file_path": "($FilePath:'/landing','*_NXTPG_FCT_BKC_':@pipeline().parameters.Environment:'_RETURN_ANOC_WELCOME*.txt')",
            "gbl_param_environment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            },
            "file_pattern": {
              "value": "",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "var_FileList_ListFiles",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "ListFiles_LISTFILES",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "FileList",
          "value": {
            "value": "@string(activity('ListFiles_LISTFILES').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "If_0A",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "var_FileList_ListFiles",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "on": {
            "value": "@if(equals(length(trim(variables('FileList'))), 0),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "var_If_0A_branch_True",
                  "type": "SetVariable",
                  "dependsOn": [],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_If_0A_branch",
                    "value": {
                      "value": "1",
                      "type": "Expression"
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "var_If_0A_branch_False",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_If_0A_branch",
                "value": {
                  "value": "0",
                  "type": "Expression"
                }
              }
            }
          ]
        }
      },
      {
        "name": "StartLoop",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "If_0A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "items": {
            "value": "@split(variables('FileList'), ',')",
            "type": "Expression"
          },
          "activities": [
            {
              "name": "If_1G",
              "type": "Switch",
              "dependsOn": [],
              "typeProperties": {
                "on": {
                  "value": "@if(and(equals(variables('var_If_0A_branch'),'0'), equals(indexOf(concat(';', pipeline().parameters.ExclusionList, ';'), ';EAMEnrlRptNxtPgWLCMKitExtr;'), -1)),'1','0')",
                  "type": "Expression"
                },
                "cases": [
                  {
                    "value": "1",
                    "activities": [
                      {
                        "name": "var_If_1G_branch_True",
                        "type": "SetVariable",
                        "dependsOn": [],
                        "policy": {
                          "secureOutput": false,
                          "secureInput": false
                        },
                        "userProperties": [],
                        "typeProperties": {
                          "variableName": "var_If_1G_branch",
                          "value": {
                            "value": "1",
                            "type": "Expression"
                          }
                        }
                      },
                      {
                        "name": "EAMEnrlRptNxtPgWLCMKitExtr",
                        "type": "ExecutePipeline",
                        "dependsOn": [
                          {
                            "activity": "var_If_1G_branch_True",
                            "dependencyConditions": [
                              "Succeeded"
                            ]
                          }
                        ],
                        "policy": {
                          "secureInput": false
                        },
                        "typeProperties": {
                          "waitOnCompletion": true,
                          "pipeline": "EAMEnrlRptNxtPgWLCMKitExtr",
                          "parameters": {
                            "RUNID": {
                              "value": "@pipeline().parameters.RunID",
                              "type": "Expression"
                            },
                            "CurrDt": {
                              "value": "@pipeline().parameters.CurrDate",
                              "type": "Expression"
                            },
                            "InputFile": {
                              "value": "@item()",
                              "type": "Expression"
                            },
                            "InputFilePrefix": {
                              "value": "@substring(item(),0,7)",
                              "type": "Expression"
                            }
                          }
                        }
                      }
                    ]
                  }
                ],
                "defaultActivities": [
                  {
                    "name": "var_If_1G_branch_False",
                    "type": "SetVariable",
                    "dependsOn": [],
                    "policy": {
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "userProperties": [],
                    "typeProperties": {
                      "variableName": "var_If_1G_branch",
                      "value": {
                        "value": "0",
                        "type": "Expression"
                      }
                    }
                  }
                ]
              }
            },
            {
              "name": "If_1H",
              "type": "Switch",
              "dependsOn": [
                {
                  "activity": "If_1G",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "typeProperties": {
                "on": {
                  "value": "@if(and(equals(variables('var_If_0A_branch'),'0'), equals(indexOf(concat(';', pipeline().parameters.ExclusionList, ';'), ';EAMEnrlRptNxtPgWLCMKitLoad;'), -1)),'1','0')",
                  "type": "Expression"
                },
                "cases": [
                  {
                    "value": "1",
                    "activities": [
                      {
                        "name": "var_If_1H_branch_True",
                        "type": "SetVariable",
                        "dependsOn": [],
                        "policy": {
                          "secureOutput": false,
                          "secureInput": false
                        },
                        "userProperties": [],
                        "typeProperties": {
                          "variableName": "var_If_1H_branch",
                          "value": {
                            "value": "1",
                            "type": "Expression"
                          }
                        }
                      },
                      {
                        "name": "EAMEnrlRptNxtPgWLCMKitLoad",
                        "type": "ExecutePipeline",
                        "dependsOn": [
                          {
                            "activity": "var_If_1H_branch_True",
                            "dependencyConditions": [
                              "Succeeded"
                            ]
                          }
                        ],
                        "policy": {
                          "secureInput": false
                        },
                        "typeProperties": {
                          "waitOnCompletion": true,
                          "pipeline": "EAMEnrlRptNxtPgWLCMKitLoad",
                          "parameters": {
                            "EAMRPTOwner": {
                              "value": "@pipeline().globalParameters.gbl_param_EAMRPTOwner",
                              "type": "Expression"
                            },
                            "eamrpt_secret_name": {
                              "value": "@pipeline().globalParameters.gbl_param_EAMRPTSecret",
                              "type": "Expression"
                            },
                            "RUNID": {
                              "value": "@pipeline().parameters.RunID",
                              "type": "Expression"
                            },
                            "InputFilePrefix": {
                              "value": "@substring(item(),0,7)",
                              "type": "Expression"
                            }
                          }
                        }
                      }
                    ]
                  }
                ],
                "defaultActivities": [
                  {
                    "name": "var_If_1H_branch_False",
                    "type": "SetVariable",
                    "dependsOn": [],
                    "policy": {
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "userProperties": [],
                    "typeProperties": {
                      "variableName": "var_If_1H_branch",
                      "value": {
                        "value": "0",
                        "type": "Expression"
                      }
                    }
                  }
                ]
              }
            },
            {
              "name": "If_1H_Continuation",
