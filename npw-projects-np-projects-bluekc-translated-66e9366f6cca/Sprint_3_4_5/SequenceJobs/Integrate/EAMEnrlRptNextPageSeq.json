                            "LOCALFILENAME": {
                              "value": "@item()",
                              "type": "Expression"
                            },
                            "REMOTEPATH": "/library/library/Medicare_Advantage/PHI11/Shared/MA_Compliance",
                            "REMOTEFILENAME": {
                              "value": "@concat(item(), pipeline().parameters.RunID)",
                              "type": "Expression"
                            }
                          }
                        }
                      },
                      {
                        "name": "cp_NxtPg_SrcFile",
                        "type": "DatabricksNotebook",
                        "dependsOn": [
                          {
                            "activity": "FtpFiletoLAN",
                            "dependencyConditions": [
                              "Succeeded"
                            ]
                          }
                        ],
                        "policy": {
                          "timeout": "12:00:00",
                          "retry": 0,
                          "retryIntervalInSeconds": 30,
                          "secureOutput": false,
                          "secureInput": false
                        },
                        "linkedServiceName": {
                          "referenceName": "shareddatabricks",
                          "type": "LinkedServiceReference"
                        },
                        "typeProperties": {
                          "notebookPath": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                          "baseParameters": {
                            "src_file_with_path": {
                              "value": "/landing",
                              "type": "Expression"
                            },
                            "trgt_file_with_path": {
                              "value": "/.",
                              "type": "Expression"
                            },
                            "command": "copy",
                            "project": "integrate"
                          }
                        }
                      }
                    ]
                  }
                ],
                "defaultActivities": [
                  {
                    "name": "var_If_1H_Continuation_branch_False",
                    "type": "SetVariable",
                    "dependsOn": [],
                    "policy": {
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "userProperties": [],
                    "typeProperties": {
                      "variableName": "var_If_1H_Continuation_branch",
                      "value": {
                        "value": "0",
                        "type": "Expression"
                      }
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}