                {
                  "activity": "If_1H",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "typeProperties": {
                "on": {
                  "value": "@if(equals(variables('var_If_0A_branch'),'0'),'1','0')",
                  "type": "Expression"
                },
                "cases": [
                  {
                    "value": "1",
                    "activities": [
                      {
                        "name": "var_If_1H_Continuation_branch_True",
                        "type": "SetVariable",
                        "dependsOn": [],
                        "policy": {
                          "secureOutput": false,
                          "secureInput": false
                        },
                        "userProperties": [],
                        "typeProperties": {
                          "variableName": "var_If_1H_Continuation_branch",
                          "value": {
                            "value": "1",
