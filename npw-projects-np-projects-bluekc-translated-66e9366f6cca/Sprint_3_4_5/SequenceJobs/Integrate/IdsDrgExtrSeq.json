{
  "name": "IdsDrgExtrSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/codes/Seq"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrentDate": {
        "type": "String",
        "defaultValue": "2007-10-21"
      },
      "RunCycle": {
        "type": "String",
        "defaultValue": "100"
      },
      "DrgMethodCode": {
        "type": "String",
        "defaultValue": "CMS"
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1A",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'FTPDrgWgt'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "FTPDrgWgt",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "MACHINE": "o_lib",
                  "FTPCMD": "get",
                  "LOCALPATH": "/library/library/IAD/PHI11/Shared/Input_IDS/DRG",
                  "LOCALFILENAME": {
                    "value": "@concat('DRGWgt_', pipeline().parameters.DrgMethodCode, '.csv')",
                    "type": "Expression"
                  },
                  "REMOTEPATH": {
                    "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/landing')",
                    "type": "Expression"
                  },
                  "REMOTEFILENAME": "DRGWgt.dat"
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "If_1B",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_1A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IdsDrgExtr'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "IdsDrgExtr",
              "type": "DatabricksNotebook",
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/codes/drg/IdsDrgExtr')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "DrgMethodCode": {
                    "value": "@pipeline().parameters.DrgMethodCode",
                    "type": "Expression"
                  },
                  "CurrRunCycle": {
                    "value": "@pipeline().parameters.RunCycle",
                    "type": "Expression"
                  },
                  "CurrentDate": {
                    "value": "@pipeline().parameters.CurrentDate",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}