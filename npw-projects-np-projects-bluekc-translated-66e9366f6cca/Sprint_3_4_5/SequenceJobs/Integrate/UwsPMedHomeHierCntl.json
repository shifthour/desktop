                  ],
                  "policy": {
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "pipeline": {
                      "referenceName": "Email_Notification",
                      "type": "PipelineReference"
                    },
                    "waitOnCompletion": true,
                    "parameters": {
                      "recipients": {
                        "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                        "type": "Expression"
                      },
                      "subject": "P_MED_HOME_HIER Aborted due to another MED_HOME_HIER processing",
                      "body": "P_MED_HOME_HIER  processing can not run while MED_HOME_HIER is being updated or extracted from.\n\nSource = 'UWS'\nTarget = 'IDS'\nSubject = 'MED_HOME_HIER'",
                      "blobFilenames": "",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": ""
                    }
                  }
                }
              ]
            }
