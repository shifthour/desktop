                      "subject": "Optum RX Admin Fee Process  Abort",
                      "body": "The Optum RX  Admin Fee  processing cannot run while IDS claim is being updated or extracted from.\n\nSource:  OPTUMRX.PBM.AdminClaimFee\nTarget:    IDS\nSubject:  Claim",
                      "blobFilenames": null,
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": " "
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "var_CountChk_branch_False",
