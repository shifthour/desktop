                      "subject": "Optum Accum Recon Process Abort",
                      "body": "The Optum Accum Recon processing cannot run while another instance of the job is being updated or extracted from.\n\nSource:  OptumRX Accum Recon\nTarget:   AccumsRecon_Product\nSubject: OptumRX Accum Recon",
                      "blobFilenames": " ",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": {
                        "value": " ",
                        "type": "Expression"
                      }
