{
  "name": "IDSPurgeClaimSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/claim/SeqPurge"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "ClaimTable": {
        "type": "String",
        "defaultValue": ""
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "StartLoop",
        "type": "ForEach",
        "typeProperties": {
          "items": [
            "CLM",
            "CLM_ALT_PAYE",
            "CLM_ATCHMT",
            "CLM_CHK",
            "CLM_COB",
            "CLM_DIAG",
            "CLM_EXTRNL_MBRSH",
            "CLM_EXTRNL_PROV",
            "CLM_EXTRNL_REF_DATA",
            "CLM_LN",
            "CLM_LN_CLNCL_EDIT",
            "CLM_LN_COB",
            "CLM_LN_DIAG",
            "CLM_LN_DSALW",
            "CLM_LN_OVRD",
            "CLM_LN_PCA"
          ],
          "activities": [
            {
              "name": "Set_ClaimTable",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "ClaimTable",
                "value": {
                  "value": "@string(item())",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "If_1A",
              "type": "IfCondition",
              "dependsOn": [
                {
                  "activity": "Set_ClaimTable",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "userProperties": [],
              "typeProperties": {
                "expression": {
                  "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IDSPurgeClaimIDDel'), false)",
                  "type": "Expression"
                },
                "ifTrueActivities": [
                  {
                    "name": "IDSPurgeClaimIDDel",
                    "type": "DatabricksNotebook",
                    "dependsOn": [],
                    "policy": {
                      "timeout": "12:00:00",
                      "retry": 0,
                      "retryIntervalInSeconds": 30,
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "userProperties": [],
                    "typeProperties": {
                      "notebookPath": {
                        "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/claim/Purge/IDSPurgeClaimIDDel')",
                        "type": "Expression"
                      },
                      "baseParameters": {
                        "ClaimTable": {
                          "value": "@variables('ClaimTable')",
                          "type": "Expression"
                        },
                        "IDSOwner": {
                          "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                          "type": "Expression"
                        },
                        "ids_secret_name": {
                          "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                          "type": "Expression"
                        }
                      }
                    },
                    "linkedServiceName": {
                      "referenceName": "shareddatabricks",
                      "type": "LinkedServiceReference"
                    }
                  }
                ],
                "ifFalseActivities": []
              }
            }
          ]
        }
      },
      {
        "name": "StartLoop2",
        "type": "ForEach",
        "typeProperties": {
          "items": [
            "CLM_LN_PROC_CD_MOD",
            "CLM_LN_SAV",
            "CLM_LTR",
            "CLM_NOTE",
            "CLM_OVER_PAYMT",
            "CLM_OVRD",
            "CLM_PCA",
            "CLM_PROV",
            "CLM_STTUS_AUDIT",
            "DNTL_CLM_LN",
            "DRUG_CLM",
            "FCLTY_CLM",
            "FCLTY_CLM_COND",
            "FCLTY_CLM_OCCUR",
            "FCLTY_CLM_PROC",
            "FCLTY_CLM_VAL",
            "ITS_CLM",
            "ITS_CLM_MSG"
          ],
          "activities": [
            {
              "name": "Set_ClaimTable2",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "ClaimTable",
                "value": {
                  "value": "@string(item())",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "If_2A",
              "type": "IfCondition",
              "dependsOn": [
                {
                  "activity": "Set_ClaimTable2",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "userProperties": [],
              "typeProperties": {
                "expression": {
                  "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IDSPurgeClaimIDDel2'), false)",
                  "type": "Expression"
                },
                "ifTrueActivities": [
                  {
                    "name": "IDSPurgeClaimIDDel2",
                    "type": "DatabricksNotebook",
                    "dependsOn": [],
                    "policy": {
                      "timeout": "12:00:00",
                      "retry": 0,
                      "retryIntervalInSeconds": 30,
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "userProperties": [],
                    "typeProperties": {
                      "notebookPath": {
                        "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/claim/Purge/IDSPurgeClaimIDDel')",
                        "type": "Expression"
                      },
                      "baseParameters": {
                        "ClaimTable": {
                          "value": "@variables('ClaimTable')",
                          "type": "Expression"
                        },
                        "IDSOwner": {
                          "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                          "type": "Expression"
                        },
                        "ids_secret_name": {
                          "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                          "type": "Expression"
                        }
                      }
                    },
                    "linkedServiceName": {
                      "referenceName": "shareddatabricks",
                      "type": "LinkedServiceReference"
                    }
                  }
                ],
                "ifFalseActivities": []
              }
            }
          ]
        }
      }
    ]
  }
}