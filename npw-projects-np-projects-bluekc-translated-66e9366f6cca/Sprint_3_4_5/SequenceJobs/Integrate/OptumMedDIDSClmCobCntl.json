                      "body": "The IDS OPTUMRX file could not be found on unix. The job will not go further and end as semi-success.\n",
                      "blobFilenames": "",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": " "
                    }
                  }
