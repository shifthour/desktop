{
  "name": "OptumMedDIDSClmCobCntl",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Integrate/Jobs/claim/COB"
    },
    "parameters": {
      "Environment": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "JobName": {
        "defaultValue": ""
      },
      "GroupName": {
        "defaultValue": "IDS_CLM_COB"
      },
      "Source": {
        "defaultValue": "OPTUMRX"
      },
      "Target": {
        "defaultValue": "IDS"
      },
      "Subject": {
        "defaultValue": "CLAIM"
      },
      "Frequency": {
        "defaultValue": "DAILY"
      },
      "LinkCount": {
        "defaultValue": ""
      },
      "FileList": {
        "defaultValue": ""
      },
      "ExclusionList": {
        "defaultValue": ""
      },
      "Logging": {
        "defaultValue": "Y"
      },
      "SrcSysCdSk": {
        "defaultValue": ""
      },
      "RunCycle": {
        "defaultValue": ""
      },
      "RunID": {
        "defaultValue": ""
      },
      "CurrDateTimestamp": {
        "defaultValue": ""
      },
      "CurrDate": {
        "defaultValue": ""
      },
