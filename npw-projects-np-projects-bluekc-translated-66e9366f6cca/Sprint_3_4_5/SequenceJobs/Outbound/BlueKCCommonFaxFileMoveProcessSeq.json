{
  "name": "BlueKCCommonFaxFileMoveProcessSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Outbound/Jobs/GuidingCare/Fullfilment"
    },
    "parameters": {
      "Environment": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "Vendor": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "ListFile": {
        "type": "String",
        "defaultValue": ""
      },
      "count": {
        "type": "String",
        "defaultValue": ""
      },
      "FileCount": {
        "type": "String",
        "defaultValue": ""
      },
      "COMM_SK": {
        "type": "String",
        "defaultValue": ""
      },
      "ATTACHMENTS": {
        "type": "String",
        "defaultValue": ""
      },
      "var_Nested_Condition_180_branch": {
        "type": "String",
        "defaultValue": ""
      },
      "var_Nested_Condition_122_branch": {
        "type": "String",
        "defaultValue": ""
      },
      "var_MV_File_branch": {
        "type": "String",
        "defaultValue": ""
      },
      "LIST.FILES_a1": {
        "type": "String",
        "defaultValue": ""
      },
      "LIST.FILES_a2": {
        "type": "String",
        "defaultValue": ""
      },
      "Row.Count_a1": {
        "type": "String",
        "defaultValue": ""
      },
      "Row.Count_a2": {
        "type": "String",
        "defaultValue": ""
      },
      "FIELD_a1": {
        "type": "String",
        "defaultValue": ""
      },
      "FIELD_a2": {
        "type": "String",
        "defaultValue": ""
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "LIST_FILES",
        "type": "DatabricksNotebook",
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/LIST.FILES')",
            "type": "Expression"
          },
          "baseParameters": {
            "file_path": {
              "value": "@variables('LIST.FILES_a1')",
              "type": "Expression"
            },
            "file_pattern": {
              "value": "@variables('LIST.FILES_a2')",
              "type": "Expression"
            },
            "gbl_param_environment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "Set_ListFile",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "LIST_FILES",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "ListFile",
          "value": {
            "value": "@string(activity('LIST_FILES').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "Nested_Condition_180",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "Set_ListFile",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "on": {
            "value": "@if(greater(length(trim(variables('ListFile'))),0),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_Nested_Condition_180_branch",
                  "type": "SetVariable",
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_Nested_Condition_180_branch",
                    "value": "1"
                  }
                },
                {
                  "name": "ROW_COUNT",
                  "type": "DatabricksNotebook",
                  "dependsOn": [
                    {
                      "activity": "Set_var_Nested_Condition_180_branch",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "timeout": "12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "linkedServiceName": {
                    "referenceName": "shareddatabricks",
                    "type": "LinkedServiceReference"
                  },
                  "typeProperties": {
                    "notebookPath": {
                      "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/Row.Count')",
                      "type": "Expression"
                    },
                    "baseParameters": {
                      "Row.Count_a1": {
                        "value": "@variables('Row.Count_a1')",
                        "type": "Expression"
                      },
                      "Row.Count_a2": {
                        "value": "@variables('Row.Count_a2')",
                        "type": "Expression"
                      },
                      "GlobalEnvironment": {
                        "value": "@pipeline().globalParameters.gbl_param_environment",
                        "type": "Expression"
                      }
                    }
                  }
                },
                {
                  "name": "Set_count",
                  "type": "SetVariable",
                  "dependsOn": [
                    {
                      "activity": "ROW_COUNT",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "count",
                    "value": {
                      "value": "@string(activity('ROW_COUNT').output.runOutput)",
                      "type": "Expression"
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_Nested_Condition_180_branch_false",
              "type": "SetVariable",
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_Nested_Condition_180_branch",
                "value": "0"
              }
            }
          ]
        }
      },
      {
        "name": "Nested_Condition_122",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "Nested_Condition_180",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "on": {
            "value": "@if(and(equals(variables('var_Nested_Condition_180_branch'),'1'),greater(length(trim(variables('count'))),0)),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_Nested_Condition_122_branch",
                  "type": "SetVariable",
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_Nested_Condition_122_branch",
                    "value": "1"
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_Nested_Condition_122_branch_false",
              "type": "SetVariable",
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_Nested_Condition_122_branch",
                "value": "0"
              }
            }
          ]
        }
      },
      {
        "name": "StartLoop_Recipients",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "Nested_Condition_122",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "items": {
            "value": "@range(1, int(variables('count')))",
            "type": "Expression"
          },
          "activities": [
            {
              "name": "Reading_Fax_File",
              "type": "DatabricksNotebook",
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "command": "cat",
                  "project": {
                    "value": "@toLower('Outbound')",
                    "type": "Expression"
                  }
                }
              }
            },
            {
              "name": "Set_COMM_SK",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "Reading_Fax_File",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "COMM_SK",
                "value": {
                  "value": "@string(activity('Reading_Fax_File').output.runOutput)",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "Set_ATTACHMENTS",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "Set_COMM_SK",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "ATTACHMENTS",
                "value": {
                  "value": "@string(activity('Reading_Fax_File').output.runOutput)",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "Cmd_ChkPDFFile",
              "type": "DatabricksNotebook",
              "dependsOn": [
                {
                  "activity": "Set_ATTACHMENTS",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/ATTACHMENTS",
                    "type": "Expression"
                  },
                  "command": "cat",
                  "project": {
                    "value": "@toLower('Outbound')",
                    "type": "Expression"
                  }
                }
              }
            },
            {
              "name": "FIELD_CMD_ChkPDFFile",
              "type": "DatabricksNotebook",
              "dependsOn": [
                {
                  "activity": "Cmd_ChkPDFFile",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FIELD')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "FIELD_a1": {
                    "value": "@variables('FIELD_a1')",
                    "type": "Expression"
                  },
                  "FIELD_a2": {
                    "value": "@variables('FIELD_a2')",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              }
            },
            {
              "name": "Set_FileCount",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "FIELD_CMD_ChkPDFFile",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "FileCount",
                "value": {
                  "value": "@string(activity('FIELD_CMD_ChkPDFFile').output.runOutput)",
                  "type": "Expression"
                }
              }
            }
          ]
        }
      },
      {
        "name": "MV_File",
        "type": "Switch",
        "dependsOn": [
          {
            "activity": "StartLoop_Recipients",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "on": {
            "value": "@if(and(and(equals(variables('var_Nested_Condition_180_branch'),'1'),equals(variables('var_Nested_Condition_122_branch'),'1')),equals(variables('FileCount'),'1')),'1','0')",
            "type": "Expression"
          },
          "cases": [
            {
              "value": "1",
              "activities": [
                {
                  "name": "Set_var_MV_File_branch",
                  "type": "SetVariable",
                  "policy": {
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "variableName": "var_MV_File_branch",
                    "value": "1"
                  }
                },
                {
                  "name": "MovePDFFileToProcessed",
                  "type": "DatabricksNotebook",
                  "dependsOn": [
                    {
                      "activity": "Set_var_MV_File_branch",
                      "dependencyConditions": [
                        "Succeeded"
                      ]
                    }
                  ],
                  "policy": {
                    "timeout": "12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                  },
                  "linkedServiceName": {
                    "referenceName": "shareddatabricks",
                    "type": "LinkedServiceReference"
                  },
                  "typeProperties": {
                    "notebookPath": {
                      "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                      "type": "Expression"
                    },
                    "baseParameters": {
                      "src_file_with_path": {
                        "value": "/ATTACHMENTS",
                        "type": "Expression"
                      },
                      "trgt_file_with_path": {
                        "value": "/ATTACHMENTS",
                        "type": "Expression"
                      },
                      "command": "move",
                      "project": {
                        "value": "@toLower('Outbound')",
                        "type": "Expression"
                      }
                    }
                  }
                }
              ]
            }
          ],
          "defaultActivities": [
            {
              "name": "Set_var_MV_File_branch_false",
              "type": "SetVariable",
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "variableName": "var_MV_File_branch",
                "value": "0"
              }
            }
          ]
        }
      },
      {
        "name": "Mov_MovFile",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "StartLoop_Recipients",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/PercepMoveFilesData.txt",
              "type": "Expression"
            },
            "command": "move",
            "project": {
              "value": "@toLower('Outbound')",
              "type": "Expression"
            }
          }
        }
      }
    ]
  }
}