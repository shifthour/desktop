{
  "name": "BlueKCCommonFulFmntMetadataFileAndPDFFilesComparision",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Outbound/Jobs/GuidingCare/Fullfilment"
    },
    "parameters": {
      "Environment": {
        "type": "String",
        "defaultValue": ""
      },
      "MetadataFile": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "SourceCode": {
        "type": "String",
        "defaultValue": ""
      },
      "TempPDFFileList": {
        "type": "String",
        "defaultValue": ""
      },
      "MetadataPDFFileList": {
        "type": "String",
        "defaultValue": ""
      },
      "LandingDirPDFFileList": {
        "type": "String",
        "defaultValue": ""
      },
      "MissingPDFFiles": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "FileCount": {
        "type": "String",
        "defaultValue": ""
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "Cmd_MetadataPDFs",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/*.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Cmd_RemoveHeaderNames",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_MetadataPDFs",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Cmd_LandingDirPDFs",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_RemoveHeaderNames",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/_BKC_*.pdf",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Cmd_CmpFiles",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_LandingDirPDFs",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Cmd_Chk_MissingPDFFile",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_CmpFiles",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Set_FileCount",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "Cmd_Chk_MissingPDFFile",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "FileCount",
          "value": {
            "value": "@string(activity('Cmd_Chk_MissingPDFFile').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "If_1C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "Set_FileCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@greater(int(variables('FileCount')),0)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Missing_PDF_File_Email_Alert",
              "type": "ExecutePipeline",
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "Email_Notification",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "recipients": {
                    "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                    "type": "Expression"
                  },
                  "subject": {
                    "value": "@concat('Fullfilment ', pipeline().parameters.SourceCode, ' Missing PDF List')",
                    "type": "Expression"
                  },
                  "body": "Fullfilment missing PDF file list in attached file, Please check and transfer the missing files.\n\nCOMM TRNSMSN Database ( Fullfilment Broker)\n\nFrequency = Every 1 Hour",
                  "blobFilenames": {
                    "value": "@concat('/external/', pipeline().parameters.SourceCode, '_', pipeline().parameters.Environment, '_', pipeline().parameters.MissingPDFFiles, '_', pipeline().parameters.RunID, '.txt')",
                    "type": "Expression"
                  },
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": {
                    "value": "@pipeline().globalParameters.gbl_param_container_published",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "Mv_Compress_Files",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "If_1C",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "project": "outbound"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ]
  }
}