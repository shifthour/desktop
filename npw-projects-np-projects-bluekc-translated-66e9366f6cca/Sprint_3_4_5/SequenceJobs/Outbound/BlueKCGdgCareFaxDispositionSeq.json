          "waitOnCompletion": true
        }
      },
      {
        "name": "BlueKCGdgCareFaxDispostionStsUpdate",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "BlueKCGdgCareFaxDispostionFileExtr",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "BlueKCGdgCareFaxDispostionStsUpdate",
            "type": "PipelineReference"
          },
          "parameters": {
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            }
          },
          "waitOnCompletion": true
        }
      },
      {
        "name": "BlueKCCommonRightFaxAPIStsHistLoad",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "BlueKCGdgCareFaxDispostionStsUpdate",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "BlueKCCommonRightFaxAPIStsHistLoad",
            "type": "PipelineReference"
          },
          "parameters": {
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            }
          },
          "waitOnCompletion": true
        }
      },
      {
        "name": "Cmd_ExtrFileCount",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "BlueKCCommonRightFaxAPIStsHistLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "command": "wc",
            "project": "outbound"
          }
        }
      },
      {
        "name": "SetVariable_FileCount",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "Cmd_ExtrFileCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "FileCount",
          "value": {
            "value": "@string(activity('Cmd_ExtrFileCount').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "FTP_Files",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "SetVariable_FileCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@and(equals(trim(string(pipeline().parameters.FTPFiles)),'Y'), greater(int(variables('FileCount')), 1))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "FTP_AHDspstn_File",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "MACHINE": {
                    "value": "@pipeline().parameters.SiFTPServer",
                    "type": "Expression"
                  },
                  "ACCT": {
                    "value": "@pipeline().parameters.SiFTPAcct",
                    "type": "Expression"
                  },
                  "PW": {
                    "value": "@pipeline().parameters.SiFTPPW",
                    "type": "Expression"
                  },
                  "FTPCMD": "put",
                  "LOCALPATH": "/external",
                  "LOCALFILENAME": {
                    "value": "@concat(pipeline().parameters.AHOutboundFile, '_', pipeline().parameters.RunID, '.txt')",
                    "type": "Expression"
                  },
                  "REMOTEPATH": "/",
                  "REMOTEFILENAME": {
                    "value": "@concat(pipeline().parameters.Environment, '1.', pipeline().parameters.VendorEnv, '.BLUEKC_', pipeline().parameters.AHOutboundFile, '_', pipeline().parameters.RunID, '.txt')",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
    ]
  }
}