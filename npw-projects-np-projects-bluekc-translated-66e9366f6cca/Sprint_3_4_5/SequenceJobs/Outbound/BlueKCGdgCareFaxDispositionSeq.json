          {
            "activity": "BlueKCCommonRightFaxAPIPendingJobIDStsSeq",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "BlueKCGdgCareFaxDispostionFileExtr",
            "type": "PipelineReference"
          },
          "parameters": {
            "PerceptiveURL": {
              "value": "@pipeline().parameters.PerceptiveURL",
              "type": "Expression"
            },
            "RunID": {
              "value": "@pipeline().parameters.RunID",
              "type": "Expression"
            },
            "AHOutboundFile": {
              "value": "@pipeline().parameters.AHOutboundFile",
              "type": "Expression"
            },
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            }
