              "value": "@pipeline().parameters.ParamFilePath",
              "type": "Expression"
            },
            "FullfilmentMetadata": "FullfilmentMetadata.txt",
            "DynamicAccessToken": "DynamicAccessToken.txt",
            "RightFaxAPIURL": {
              "value": "@pipeline().parameters.RightFaxAPIURL",
              "type": "Expression"
            }
          },
          "waitOnCompletion": true
        }
      },
      {
        "name": "BlueKCGdgCareFaxDispostionFileExtr",
