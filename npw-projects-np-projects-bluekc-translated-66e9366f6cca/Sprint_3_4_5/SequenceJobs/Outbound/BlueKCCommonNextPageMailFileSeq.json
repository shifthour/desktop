{
  "name": "BlueKCCommonNextPageMailFileSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Outbound/Jobs/GuidingCare/Fullfilment"
    },
    "parameters": {
      "ParamFilePath": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "NXTPGOutboundFile": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrDateTm": {
        "type": "String",
        "defaultValue": ""
      },
      "ProvType": {
        "type": "String",
        "defaultValue": ""
      },
      "EmailNotice": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrentDateM1": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "FileCount": {
        "type": "String"
      },
      "Field_a1": {
        "type": "String"
      },
      "Field_a2": {
        "type": "String"
      },
      "Field_a3": {
        "type": "String"
      },
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "Cmd_LandingDirPDFs",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/landing",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/NextPagePDFCheckList.txt",
              "type": "Expression"
            },
            "command": "ls",
            "project": "outbound"
          }
        }
      },
      {
        "name": "BlueKCCommonNextPageMailFileExtr",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_LandingDirPDFs",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/GuidingCare/Fullfilment/BlueKCCommonNextPageMailFileExtr')",
            "type": "Expression"
          },
          "baseParameters": {
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            },
            "commtrnsmsn_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnSecret",
              "type": "Expression"
            },
            "ParamFilePath": {
              "value": "@pipeline().parameters.ParamFilePath",
              "type": "Expression"
            },
            "RunID": {
              "value": "@pipeline().parameters.RunID",
              "type": "Expression"
            },
            "NXTPGOutboundFile": {
              "value": "@pipeline().parameters.NXTPGOutboundFile",
              "type": "Expression"
            },
            "CurrDateTm": {
              "value": "@pipeline().parameters.CurrDateTm",
              "type": "Expression"
            },
            "ProvType": {
              "value": "@pipeline().parameters.ProvType",
              "type": "Expression"
            },
            "CurrentDateM1": {
              "value": "@pipeline().parameters.CurrentDateM1",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "BlueKCCommonNextPageMailInitiateStatusUpdate",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "BlueKCCommonNextPageMailFileExtr",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "BlueKCCommonNextPageMailInitiateStatusUpdate",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            },
            "commtrnsmsn_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnSecret",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "BlueKCCommonNextPageStatusOutboundHistLoad",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "BlueKCCommonNextPageMailInitiateStatusUpdate",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "BlueKCCommonNextPageStatusOutboundHistLoad",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "CommTrnsmsnOwner": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnOwner",
              "type": "Expression"
            },
            "commtrnsmsn_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_CommTrnsmsnSecret",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "Cmd_Chk_MissingPDFFile",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "BlueKCCommonNextPageStatusOutboundHistLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/NextPageMissingPDFLetters.txt",
              "type": "Expression"
            },
            "command": "wc -l",
            "project": "outbound"
          }
        }
      },
      {
        "name": "Field_FileCount",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Cmd_Chk_MissingPDFFile",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/Field')",
            "type": "Expression"
          },
          "baseParameters": {
            "Field_a1": {
              "value": "@string(activity('Cmd_Chk_MissingPDFFile').output.runOutput)",
              "type": "Expression"
            },
            "Field_a2": " ",
            "Field_a3": " ",
            "GlobalEnvironment": {
              "value": "@pipeline().globalParameters.gbl_param_environment",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "Set_FileCount",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "Field_FileCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "variableName": "FileCount",
          "value": {
            "value": "@string(activity('Field_FileCount').output.runOutput)",
            "type": "Expression"
          }
        }
      },
      {
        "name": "If_1C",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "Set_FileCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@greater(int(variables('FileCount')),0)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Missing_PDF_File_Email_Alert",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "Email_Notification",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "recipients": {
                    "value": "@pipeline().parameters.EmailNotice",
                    "type": "Expression"
                  },
                  "subject": "Fullfilment Altruista Missing PDF List",
                  "body": "Fullfilment missing PDF file list in attached file, Please check and transfer the missing files.\n\nCOMM TRNSMSN Database ( Fullfilment Broker)\n\nFrequency = Every 1 Hour",
                  "blobFilenames": {
                    "value": "@concat(pipeline().globalParameters.gbl_param_environment,'/external/NextPageMissingPDFLetters.txt')",
                    "type": "Expression"
                  },
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": {
                    "value": "@pipeline().globalParameters.gbl_param_container_published",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "Mv_Compress_Files",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "If_1C",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/NextPageMissingPDFLetters.txt",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/.txt",
              "type": "Expression"
            },
            "command": "move",
            "project": "outbound"
          }
        }
      }
    ]
  }
}