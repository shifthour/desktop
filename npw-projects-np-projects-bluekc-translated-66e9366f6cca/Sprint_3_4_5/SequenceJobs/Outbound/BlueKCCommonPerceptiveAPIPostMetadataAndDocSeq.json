              "value": "@pipeline().parameters.Vendor",
              "type": "Expression"
            },
            "COMM_SK": {
              "value": "@pipeline().parameters.COMM_SK",
              "type": "Expression"
            },
            "ATTACHMENTS": {
              "value": "@pipeline().parameters.ATTACHMENTS",
              "type": "Expression"
            }
