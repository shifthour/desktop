                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/external/GetFaxJobIDResponse.json",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/.txt",
                    "type": "Expression"
                  },
                  "command": "cat <src_file_with_path> > <trgt_file_with_path>; mv <trgt_file_with_path> <trgt_file_with_path>../../processed/; compress -f <trgt_file_with_path>../../processed/*.txt",
                  "project": "outbound"
                }
              }
            }
          ],
          "ifFalseActivities": [
            {
              "name": "ApigeeStatusLog",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/external/GetApigeeJobIdResponse.json",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/.txt",
                    "type": "Expression"
                  },
                  "command": "cat <src_file_with_path> > <trgt_file_with_path>; mv <trgt_file_with_path> <trgt_file_with_path>../../processed/; compress -f <trgt_file_with_path>../../processed/*.txt",
                  "project": "outbound"
                }
