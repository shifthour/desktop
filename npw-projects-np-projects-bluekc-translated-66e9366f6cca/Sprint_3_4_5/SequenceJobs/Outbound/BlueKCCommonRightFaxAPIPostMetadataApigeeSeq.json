        "type": "String",
        "defaultValue": ""
      },
      "COMM_SK": {
        "type": "String",
        "defaultValue": ""
      },
      "FIRSTNAME": {
        "type": "String",
        "defaultValue": ""
      },
      "LASTNAME": {
        "type": "String",
        "defaultValue": ""
      },
      "MIDDLENAME": {
        "type": "String",
        "defaultValue": ""
