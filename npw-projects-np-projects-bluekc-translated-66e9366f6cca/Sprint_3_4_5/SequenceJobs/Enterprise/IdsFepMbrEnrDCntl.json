                      "body": "The IdsFepMbrEnrDCntl  cannot run while Member is being updated or extracted from.\n\nSOURCE=IDS\nTarget = EDW\nSUBJECT CD = FEP_MBR_ENR",
                      "blobFilenames": "",
                      "fromemail": {
                        "value": "@pipeline().globalParameters.gbl_param_fromemail",
                        "type": "Expression"
                      },
                      "containerName": " "
                    }
                  }
