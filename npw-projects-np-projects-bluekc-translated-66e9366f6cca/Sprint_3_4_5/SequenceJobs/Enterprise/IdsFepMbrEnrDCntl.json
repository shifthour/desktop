                  "policy": {
                    "secureInput": false
                  },
                  "userProperties": [],
                  "typeProperties": {
                    "pipeline": {
                      "referenceName": "Execute_ShellCommand",
                      "type": "PipelineReference"
                    },
                    "waitOnCompletion": true,
                    "parameters": {
