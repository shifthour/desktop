  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/MedMgt/Solucia/Seq"
    },
    "parameters": {
      "CurrRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
