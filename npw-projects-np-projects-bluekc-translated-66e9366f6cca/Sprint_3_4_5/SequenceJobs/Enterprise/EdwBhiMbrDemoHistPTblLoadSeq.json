{
  "name": "EdwBhiMbrDemoHistPTblLoadSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/BHI/Seq"
    },
    "parameters": {
      "CurrDate": {
        "type": "String",
        "defaultValue": ""
      },
      "FTP_NDW25IND": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "BHIMbrDemoPTblLoad",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/BHI/MbrDemogrphc/BHIMbrDemoPTblLoad')",
            "type": "Expression"
          },
          "baseParameters": {
            "CurrDate": {
              "value": "@pipeline().parameters.CurrDate",
              "type": "Expression"
            },
            "DemoMbrFile": {
              "value": "@if(equals(pipeline().parameters.FTP_NDW25IND, 'Y'), 'std_member_demographic_ndw_25.5', 'std_member_demographic')",
              "type": "Expression"
            },
            "EDWOwner": {
              "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
              "type": "Expression"
            },
            "edw_secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
              "type": "Expression"
            }
          }
        }
      },
      {
        "name": "LoadP_BCBSA_MBR_DTL",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "BHIMbrDemoPTblLoad",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/DB.LOAD')",
            "type": "Expression"
          },
          "baseParameters": {
            "table": "P_BCBSA_MBR_DTL",
            "action": "REPLACE",
            "file_name": "P_BCBSA_MBR_DTL.dat",
            "run_stat": "N",
            "owner": {
              "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
              "type": "Expression"
            },
            "secret_name": {
              "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
              "type": "Expression"
            },
            "EnvProjectPath": {
              "value": "",
              "type": "Expression"
            },
            "file_path": {
              "value": "",
              "type": "Expression"
            }
          }
        }
      }
    ]
  }
}