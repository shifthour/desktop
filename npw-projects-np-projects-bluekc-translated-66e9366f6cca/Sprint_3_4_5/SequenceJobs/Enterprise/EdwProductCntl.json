                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "EdwProductCntl1",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "IDSFilePath": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSFilePath",
                    "type": "Expression"
                  },
                  "EmailSupport": {
                    "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                    "type": "Expression"
                  },
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "EDWOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
                    "type": "Expression"
                  },
                  "edw_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
                    "type": "Expression"
                  },
                  "VrblCmpntFullDrvr": {
                    "value": "@pipeline().parameters.VrblCmpntFullDrvr",
                    "type": "Expression"
                  },
                  "BillCmpntFullDrvr": {
                    "value": "@pipeline().parameters.BillCmpntFullDrvr",
                    "type": "Expression"
                  },
                  "PdCmpntFullDrvr": {
                    "value": "@pipeline().parameters.PdCmpntFullDrvr",
                    "type": "Expression"
                  },
                  "BnfSumTxFullDrvr": {
                    "value": "@pipeline().parameters.BnfSumTxFullDrvr",
                    "type": "Expression"
                  },
                  "LmtCmpntFullDrvr": {
                    "value": "@pipeline().parameters.LmtCmpntFullDrvr",
                    "type": "Expression"
                  },
                  "TargetIds": {
                    "value": "@pipeline().parameters.TargetIds",
                    "type": "Expression"
                  },
                  "Initial_JobName": {
                    "value": "@variables('JobName')",
                    "type": "Expression"
                  },
                  "Initial_Source": {
                    "value": "@variables('Source')",
                    "type": "Expression"
                  },
                  "Initial_Target": {
                    "value": "@variables('Target')",
                    "type": "Expression"
                  },
                  "Initial_Subject": {
                    "value": "@variables('Subject')",
                    "type": "Expression"
                  },
