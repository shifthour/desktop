                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/WriteRunInfo')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "arg1": {
                    "value": "@concat(variables('JobName'), ':', 'RunDate')",
                    "type": "Expression"
                  },
                  "arg2": {
                    "value": "@variables('CurrentDate')",
                    "type": "Expression"
                  },
                  "arg3": {
                    "value": "@variables('CurrentDate')",
                    "type": "Expression"
                  },
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  },
                  "secret_name": {
                    "value": "",
                    "type": "Expression"
                  },
                  "IDSOwner": {
                    "value": "",
                    "type": "Expression"
                  }
                }
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              }
            },
            {
              "name": "EdwProductCntl1",
              "type": "ExecutePipeline",
              "dependsOn": [
                {
