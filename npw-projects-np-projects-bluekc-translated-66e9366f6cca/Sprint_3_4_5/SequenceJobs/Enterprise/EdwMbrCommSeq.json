{
  "name": "EdwMbrCommSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Membership/EdwLoads/Seq"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "EDWRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrentDate": {
        "type": "String",
        "defaultValue": ""
      },
      "CrmMbrCommRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "IdsMbrCommRunCycle": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_MbrCommD",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IdsEdwMbrCommDExtr'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "IdsEdwMbrCommDExtr",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/DataWarehouse/Membership/EdwLoads/MbrCommD/IdsEdwMbrCommDExtr')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "EDWRunCycle": {
                    "value": "@pipeline().parameters.EDWRunCycle",
                    "type": "Expression"
                  },
                  "EDWRunCycleDate": {
                    "value": "@pipeline().parameters.CurrentDate",
                    "type": "Expression"
                  },
                  "CrmMbrCommRunCycle": {
                    "value": "@pipeline().parameters.CrmMbrCommRunCycle",
                    "type": "Expression"
                  },
                  "IdsMbrCommRunCycle": {
                    "value": "@pipeline().parameters.IdsMbrCommRunCycle",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "LoadMbrComm",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "If_MbrCommD",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IdsEdwMbrCommDLoad'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "IdsEdwMbrCommDLoad",
              "type": "ExecutePipeline",
              "userProperties": [],
              "policy": {
                "secureInput": false
              },
              "typeProperties": {
                "pipeline": {
                  "referenceName": "IdsEdwMbrCommDLoad",
                  "type": "PipelineReference"
                },
                "parameters": {
                  "EDWOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
                    "type": "Expression"
                  },
                  "edw_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
                    "type": "Expression"
                  }
                },
                "waitOnCompletion": true
              }
            }
          ],
          "ifFalseActivities": []
        }
      }
