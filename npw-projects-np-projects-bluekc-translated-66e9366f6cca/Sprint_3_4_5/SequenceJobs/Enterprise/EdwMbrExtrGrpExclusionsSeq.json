{
  "name": "EdwMbrExtrGrpExclusionsSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Membership/EdwLoads/Seq"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "EDWRunCycle": {
        "type": "String",
        "defaultValue": ""
      },
      "EDWRunCycleDate": {
        "type": "String",
        "defaultValue": ""
      },
      "CurrentDate": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "If_1A",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'FTPOTAT'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "FTPOTAT",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/FTP')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "MACHINE": "o_lib",
                  "FTPCMD": "get",
                  "LOCALPATH": "/library/library/IAD/PHI09/Shared/Input_EDW/MailExclusions",
                  "LOCALFILENAME": "grp_mail_excl.csv",
                  "REMOTEPATH": {
                    "value": "@concat(pipeline().globalParameters.gbl_param_FilePath, '/landing')",
                    "type": "Expression"
                  },
                  "REMOTEFILENAME": "grp_mail_excl.dat",
                  "GlobalEnvironment": {
                    "value": "@pipeline().globalParameters.gbl_param_environment",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        },
        "dependsOn": []
      },
      {
        "name": "If_GrpMail",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IdsEdwGrpMailExclDExtr'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "IdsEdwGrpMailExclDExtr",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/DataWarehouse/Membership/EdwLoads/GrpMailExclD/IdsEdwGrpMailExclDExtr')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "IDSOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "ids_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "EDWRunCycle": {
                    "value": "@pipeline().parameters.EDWRunCycle",
                    "type": "Expression"
                  },
                  "EDWRunCycleDate": {
                    "value": "@pipeline().parameters.EDWRunCycleDate",
                    "type": "Expression"
                  }
                }
              }
            },
            {
              "name": "IdsEdwGrpMailExclDPkey",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/DataWarehouse/Membership/EdwLoads/GrpMailExclD/IdsEdwGrpMailExclDPkey')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "EDWOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
                    "type": "Expression"
                  },
                  "edw_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
                    "type": "Expression"
                  },
                  "EDWRunCycleDate": {
                    "value": "@pipeline().parameters.EDWRunCycleDate",
                    "type": "Expression"
                  },
                  "EDWRunCycle": {
                    "value": "@pipeline().parameters.EDWRunCycle",
                    "type": "Expression"
                  }
                }
              },
              "dependsOn": [
                {
                  "activity": "IdsEdwGrpMailExclDExtr",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ]
            },
            {
              "name": "CheckCount",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/load/GRP_MAIL_EXCL_D_Lkp_Rej.dat",
                    "type": "Expression"
                  },
                  "command": "cat",
                  "cut_column_index": "1",
                  "project": "enterprise"
                }
              },
              "dependsOn": [
                {
                  "activity": "IdsEdwGrpMailExclDExtr",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ]
            }
          ],
          "ifFalseActivities": []
        },
        "dependsOn": [
          {
            "activity": "If_1A",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ]
      },
      {
        "name": "If_CheckCount_Reject",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@greaterOrEquals(int(activity('CheckCount').output.runOutput),1)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Email_DAT",
              "type": "ExecutePipeline",
              "userProperties": [],
              "policy": {
                "secureInput": false
              },
              "typeProperties": {
                "pipeline": {
                  "referenceName": "Email_Notification",
                  "type": "PipelineReference"
                },
                "waitOnCompletion": true,
                "parameters": {
                  "recipients": {
                    "value": "@pipeline().globalParameters.gbl_param_EmailSupport",
                    "type": "Expression"
                  },
                  "subject": "EDW GRP_MAIL_EXC_ID table has reject records",
                  "body": "Job IdsEdwGrpMailExclDExtr got records in the reject file. ",
                  "blobFilenames": {
                    "value": "@concat(pipeline().globalParameters.gbl_param_environment, '/load/GRP_MAIL_EXCL_D_Lkp_Rej.dat')",
                    "type": "Expression"
                  },
                  "fromemail": {
                    "value": "@pipeline().globalParameters.gbl_param_fromemail",
                    "type": "Expression"
                  },
                  "containerName": {
                    "value": "@pipeline().globalParameters.gbl_param_container_integrate",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        },
        "dependsOn": [
          {
            "activity": "If_GrpMail",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ]
      },
      {
        "name": "If_LoadGrpMail",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'IdsEdwGrpMailExclDLoad'), false)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "IdsEdwGrpMailExclDLoad",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/DataWarehouse/Membership/EdwLoads/GrpMailExclD/IdsEdwGrpMailExclDLoad')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "EDWOwner": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
                    "type": "Expression"
                  },
                  "edw_secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
                    "type": "Expression"
                  }
                }
              }
            }
          ],
          "ifFalseActivities": []
        },
        "dependsOn": [
          {
            "activity": "If_GrpMail",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ]
      }
    ]
  }
}