                  },
                  "arg2": {
                    "value": "@string('FORMAT.DATE(@DATE, \"DATE\", \"CURRENT\", \"CCYY-MM-DD\")')",
                    "type": "Expression"
                  },
                  "arg3": {
                    "value": "@string('FORMAT.DATE(@DATE, \"DATE\", \"CURRENT\", \"CCYY-MM-DD\")')",
