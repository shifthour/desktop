{
  "name": "EdwClaimCleanUpSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/DataWarehouse/Claims/EdwLoads/Seq"
    },
    "parameters": {
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "StartEdwTruncate",
        "type": "ForEach",
        "dependsOn": [],
        "typeProperties": {
          "items": [
            "W_CLM_DEL"
          ],
          "activities": [
            {
              "name": "Truncate_EDW",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/DB.TRUNCATE')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "owner_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWOwner",
                    "type": "Expression"
                  },
                  "secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_EDWSecret",
                    "type": "Expression"
                  },
                  "DBTable": {
                    "value": "@item()",
                    "type": "Expression"
                  }
                }
              }
            }
          ]
        }
      },
      {
        "name": "StartIdsTruncate",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "StartEdwTruncate",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "items": [
            "W_RVNU_HIER",
            "W_DNTL_CAT_HIER"
          ],
          "activities": [
            {
              "name": "Truncate_IDS",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/DB.TRUNCATE')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "owner_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSOwner",
                    "type": "Expression"
                  },
                  "secret_name": {
                    "value": "@pipeline().globalParameters.gbl_param_IDSSecret",
                    "type": "Expression"
                  },
                  "DBTable": {
                    "value": "@item()",
                    "type": "Expression"
                  }
                }
              }
            }
          ]
        }
      }
    ]
  }
}