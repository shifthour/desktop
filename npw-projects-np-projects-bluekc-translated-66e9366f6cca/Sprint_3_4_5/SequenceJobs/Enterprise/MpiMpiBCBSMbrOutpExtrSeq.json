{
  "name": "MpiMpiBCBSMbrOutpExtrSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/MPI/MPI_BCBS/Seq"
    },
    "parameters": {
      "CurrDtmSybaseTS": {
        "type": "String",
        "defaultValue": "2012-10-11 14:22:23.000"
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": "''"
      },
      "ListFiles": {
        "type": "String",
        "defaultValue": ""
      },
      "MpiNtfctnIn": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String"
      },
      "JobLinkCount_a1": {
        "type": "String",
        "defaultValue": "MpiMpiBCBSMbrOutPExtr"
      },
      "JobLinkCount_a2": {
        "type": "String",
        "defaultValue": "Trans"
      },
      "JobLinkCount_a3": {
        "type": "String",
        "defaultValue": "MbrOutp"
      }
    },
    "activities": [
      {
        "name": "StartLoop",
        "type": "ForEach",
        "typeProperties": {
          "items": {
            "value": "@split(pipeline().parameters.ListFiles, ',')",
            "type": "Expression"
          },
          "activities": [
            {
              "name": "If_1A",
              "type": "IfCondition",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "expression": {
                  "value": "@equals(contains(split(string(pipeline().parameters.ExclusionList), ';'), 'MpiMpiBCBSMbrOutPExtr'), false)",
                  "type": "Expression"
                },
                "ifTrueActivities": [
                  {
                    "name": "MpiMpiBCBSMbrOutPExtr_Notebook",
                    "type": "DatabricksNotebook",
                    "userProperties": [],
                    "dependsOn": [],
                    "policy": {
                      "timeout": "12:00:00",
                      "retry": 0,
                      "retryIntervalInSeconds": 30,
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "linkedServiceName": {
                      "referenceName": "shareddatabricks",
                      "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                      "notebookPath": {
                        "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path, '/MPI/MPI_BCBS/MBR_OUTP/MpiMpiBCBSMbrOutPExtr')",
                        "type": "Expression"
                      },
                      "baseParameters": {
                        "FileName": {
                          "value": "@item()",
                          "type": "Expression"
                        },
                        "CurrDtmSybaseTS": {
                          "value": "@pipeline().parameters.CurrDtmSybaseTS",
                          "type": "Expression"
                        },
                        "MpiNtfctnIn": {
                          "value": "@pipeline().parameters.MpiNtfctnIn",
                          "type": "Expression"
                        },
                        "MPI_BCBSOwner": {
                          "value": "@pipeline().globalParameters.gbl_param_MPI_BCBSOwner",
                          "type": "Expression"
                        },
                        "mpi_bcbs_secret_name": {
                          "value": "@pipeline().globalParameters.gbl_param_MPI_BCBSSecret",
                          "type": "Expression"
                        },
                        "GlobalEnvironment": {
                          "value": "@pipeline().globalParameters.gbl_param_environment",
                          "type": "Expression"
                        }
                      }
                    }
                  },
                  {
                    "name": "JobLinkCount_Notebook",
                    "type": "DatabricksNotebook",
                    "userProperties": [],
                    "dependsOn": [
                      {
                        "activity": "MpiMpiBCBSMbrOutPExtr_Notebook",
                        "dependencyConditions": [
                          "Succeeded"
                        ]
                      }
                    ],
                    "policy": {
                      "timeout": "12:00:00",
                      "retry": 0,
                      "retryIntervalInSeconds": 30,
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "linkedServiceName": {
                      "referenceName": "shareddatabricks",
                      "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                      "notebookPath": "@concat(pipeline().globalParameters.gbl_param_routine_notebook_path, '/sequencer_routines/JobLinkCount')",
                      "baseParameters": {
                        "JobLinkCount_a1": {
                          "value": "@variables('JobLinkCount_a1')",
                          "type": "Expression"
                        },
                        "JobLinkCount_a2": {
                          "value": "@variables('JobLinkCount_a2')",
                          "type": "Expression"
                        },
                        "JobLinkCount_a3": {
                          "value": "@variables('JobLinkCount_a3')",
                          "type": "Expression"
                        },
                        "GlobalEnvironment": {
                          "value": "@pipeline().globalParameters.gbl_param_environment",
                          "type": "Expression"
                        },
                        "file_path": {
                          "value": "",
                          "type": "Expression"
                        },
                        "EnvProjectPath": {
                          "value": "",
                          "type": "Expression"
                        },
                        "delimiter": {
                          "value": "",
                          "type": "Expression"
                        },
                        "quote": {
                          "value": "",
                          "type": "Expression"
                        },
                        "header": {
                          "value": "",
                          "type": "Expression"
                        },
                        "nullValue": {
                          "value": "",
                          "type": "Expression"
                        },
                        "table_nm": {
                          "value": "",
                          "type": "Expression"
                        },
                        "schema": {
                          "value": "",
                          "type": "Expression"
                        },
                        "secret_name": {
                          "value": "",
                          "type": "Expression"
                        }
                      }
                    }
                  },
                  {
                    "name": "Set_LinkCount",
                    "type": "SetVariable",
                    "userProperties": [],
                    "dependsOn": [
                      {
                        "activity": "JobLinkCount_Notebook",
                        "dependencyConditions": [
                          "Succeeded"
                        ]
                      }
                    ],
                    "policy": {
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "typeProperties": {
                      "variableName": "LinkCount",
                      "value": {
                        "value": "@string(activity('JobLinkCount_Notebook').output.runOutput)",
                        "type": "Expression"
                      }
                    }
                  }
                ],
                "ifFalseActivities": []
              }
            },
            {
              "name": "MvMbrOutpFile_Notebook",
              "type": "DatabricksNotebook",
              "userProperties": [],
              "dependsOn": [
                {
                  "activity": "If_1A",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_scripts, '/Generic_ADLS_File_Operations')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "src_file_with_path": {
                    "value": "/landing",
                    "type": "Expression"
                  },
                  "trgt_file_with_path": {
                    "value": "/landing/processed",
                    "type": "Expression"
                  },
                  "command": "move",
                  "project": "enterprise"
                }
              }
            }
          ]
        }
      }
    ]
  }
}