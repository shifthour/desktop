{
  "name": "EdwBhiMbrDemoHistFTPSeq",
  "type": "Microsoft.DataFactory/factories/pipelines",
  "properties": {
    "folder": {
      "name": "Enterprise/Jobs/BHI/Seq"
    },
    "parameters": {
      "ProdIn": {
        "type": "String",
        "defaultValue": ""
      },
      "RunID": {
        "type": "String",
        "defaultValue": ""
      },
      "FTPFiles": {
        "type": "String",
        "defaultValue": ""
      },
      "ExclusionList": {
        "type": "String",
        "defaultValue": ""
      },
      "FTP_NDW25IND": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "variables": {
      "LinkCount": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "Check_FTP_N",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@and(equals(pipeline().parameters.FTPFiles,'Y'),and(not(contains(pipeline().parameters.ExclusionList,'EdwBHIMbrDemoExtrFTP')),equals(pipeline().parameters.FTP_NDW25IND,'N')))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "EdwBHIMbrDemoExtrFTP",
              "type": "DatabricksNotebook",
              "dependsOn": [],
              "policy": {
                "timeout": "12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "notebookPath": {
                  "value": "@concat(pipeline().globalParameters.gbl_param_notebook_path,'/BHI/MbrDemogrphc/EdwBHIMbrDemoExtrFTP')",
                  "type": "Expression"
                },
                "baseParameters": {
                  "ProdIn": {
                    "value": "@pipeline().parameters.ProdIn",
                    "type": "Expression"
                  }
                }
              },
              "linkedServiceName": {
                "referenceName": "shareddatabricks",
                "type": "LinkedServiceReference"
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "Check_FTP_Y",
        "type": "IfCondition",
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "value": "@and(equals(pipeline().parameters.FTPFiles,'Y'),and(not(contains(pipeline().parameters.ExclusionList,'EdwBHIMbrDemoExtrFTP_NDW')),equals(pipeline().parameters.FTP_NDW25IND,'Y')))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "EdwBHIMbrDemoExtrFTP_NDW",
              "type": "ExecutePipeline",
              "dependsOn": [],
              "policy": {
                "secureInput": false
              },
              "userProperties": [],
              "typeProperties": {
                "pipeline": {
                  "referenceName": "EdwBHIMbrDemoExtrFTP_NDW",
                  "type": "PipelineReference"
                },
                "parameters": {
                  "ProdIn": {
                    "value": "@pipeline().parameters.ProdIn",
                    "type": "Expression"
                  }
                },
                "waitOnCompletion": true
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "mv_compress",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Check_FTP_N",
            "dependencyConditions": [
              "Succeeded"
            ]
          },
          {
            "activity": "Check_FTP_Y",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/std_member_demographic",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/processed/std_member_demographic.",
              "type": "Expression"
            },
            "command": "move",
            "project": "enterprise"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "mv_compress1",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "mv_compress",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/std_member_demographic_dupes",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/processed/std_member_demographic_dupes.",
              "type": "Expression"
            },
            "command": "move",
            "project": "enterprise"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Compress",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "mv_compress1",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "notebookPath": {
            "value": "@concat(pipeline().globalParameters.gbl_param_scripts,'/Generic_ADLS_File_Operations')",
            "type": "Expression"
          },
          "baseParameters": {
            "src_file_with_path": {
              "value": "/external/processed/P_BCBSA_MBR_DTL_HIST_REJECTS.dat",
              "type": "Expression"
            },
            "trgt_file_with_path": {
              "value": "/external/processed/P_BCBSA_MBR_DTL_HIST_REJECTS.dat.",
              "type": "Expression"
            },
            "command": "move",
            "project": "enterprise"
          }
        },
        "linkedServiceName": {
          "referenceName": "shareddatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ]
  }
}