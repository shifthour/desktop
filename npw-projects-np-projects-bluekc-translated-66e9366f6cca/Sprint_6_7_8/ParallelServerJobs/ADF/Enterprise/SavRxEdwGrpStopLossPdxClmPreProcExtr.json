        "userProperties": [],
        "typeProperties": {
          "scripts": [
            {
              "type": "Query",
              "text": {
                "value": "DROP TABLE IF EXISTS @{pipeline().globalParameters.gbl_param_edw_staging}.Tmp2_SavRxEdwGrpStopLossPdxClmPreProcExtr SELECT 'SAVRX' AS SRC_SYS_CD, CASE WHEN GRP_NO IS NULL OR LEN(dbo.trim_default(GRP_NO))=0 THEN '' ELSE dbo.trim_default(GRP_NO) END AS GRP_BASE, CASE WHEN PD_DT IS NULL OR LEN(dbo.trim_default(PD_DT))=0 THEN '1753-01' ELSE SUBSTRING(CONVERT(VARCHAR(10), CONVERT(DATE, PD_DT, 112), 23), 1, 7) END AS PRCS_DT INTO @{pipeline().globalParameters.gbl_param_edw_staging}.Tmp2_SavRxEdwGrpStopLossPdxClmPreProcExtr FROM @{pipeline().globalParameters.gbl_param_edw_staging}.Tmp_SavRxEdwGrpStopLossPdxClmPreProcExtr",
                "type": "Expression"
